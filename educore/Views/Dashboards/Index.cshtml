@{
    ViewData["Title"] = "Dashboard";
}

@section VendorStyles {
    <link rel="stylesheet" href="~/vendor/libs/apex-charts/apex-charts.css" />
}

@section VendorScripts {
    <script src="~/vendor/libs/apex-charts/apexcharts.js"></script>
}

@section PageStyles {
    <style>
        .erp-dashboard {
            --erp-radius: 1rem;
            --erp-border: var(--ec-border, #ececf5);
            --erp-muted:  var(--ec-text-muted, #8b8175);
        }

            .erp-dashboard .card {
                border:        1px solid var(--ec-border, #ececf5);
                border-radius: var(--erp-radius);
                box-shadow:    0 .125rem .75rem rgba(67,89,113,.06);
            }

            .erp-dashboard .card-header {
                border-bottom: 1px solid var(--ec-border, #ececf5);
                padding:       1.25rem 1.25rem .5rem;
            }

            .erp-dashboard .card-body {
                padding: 1.25rem;
            }

        .erp-alert {
            border-radius: var(--erp-radius);
            background: #fff;
            border-left: .35rem solid #ea5455;
            box-shadow: 0 .125rem .75rem rgba(67,89,113,.08);
        }

        .erp-alert-icon, .erp-stat-icon {
            width: 2.75rem;
            height: 2.75rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: .85rem;
            flex: 0 0 auto;
        }

        .erp-stat-card {
            min-height: 8.4rem;
            transition: transform .2s ease, box-shadow .2s ease;
        }

            .erp-stat-card:hover {
                transform: translateY(-2px);
                box-shadow: 0 .5rem 1.25rem rgba(67,89,113,.09);
            }

        .erp-label {
            color: var(--erp-muted);
            font-size: .78rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: .03em;
        }

        .erp-value {
            color:       var(--ec-text-dark, #2b1b12);
            font-size:   1.45rem;
            font-weight: 800;
            line-height: 1.2;
        }

        .erp-subtext {
            color: var(--erp-muted);
            font-size: .85rem;
        }

        .erp-progress {
            height: .45rem;
            border-radius: 999px;
            background: #f0f2f4;
            overflow: hidden;
        }

            .erp-progress span {
                display: block;
                height: 100%;
                border-radius: inherit;
            }

        .erp-dark-card {
            color: #fff;
            background: linear-gradient(135deg,#1f2937,#111827);
        }

            .erp-dark-card .erp-label, .erp-dark-card .erp-subtext {
                color: rgba(255,255,255,.68);
            }

        .erp-chart {
            min-height: 315px;
        }

        .erp-mini-chart {
            min-height: 230px;
        }

        .erp-table thead th {
            color:          var(--erp-muted);
            font-size:      .76rem;
            font-weight:    700;
            text-transform: uppercase;
            letter-spacing: .035em;
            background:     #faf9f7;
            border-bottom:  1px solid var(--ec-border-warm, #f0eee9);
            white-space:    nowrap;
        }

        .erp-table tbody td {
            padding:        1rem .9rem;
            vertical-align: middle;
            border-bottom:  1px solid var(--ec-border, #ececf5);
        }

        .erp-table tbody tr:hover {
            background: #fffaf5;
        }

        .erp-avatar {
            width: 2.25rem;
            height: 2.25rem;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: .8rem;
            font-weight: 700;
        }

        .erp-status {
            display: inline-flex;
            align-items: center;
            padding: .35rem .75rem;
            border-radius: 999px;
            font-size: .74rem;
            font-weight: 700;
            text-transform: uppercase;
        }

        .erp-search {
            max-width: 18rem;
        }
        @@media (max-width: 991.98px) {
            .erp-search

        {
            max-width: 100%;
        }

        .erp-chart {
            min-height: 280px;
        }

        }
        @@media (max-width: 575.98px) {
            .erp-dashboard .card-body

        {
            padding: 1rem;
        }

        .erp-value {
            font-size: 1.25rem;
        }

        .erp-stat-card {
            min-height: auto;
        }

        }</style>
}

@* ************** School ERP Dashboard ************** *@
