@section PageScripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
          const primary = '#696cff', success = '#28c76f', warning = '#ff9f43', danger = '#ea5455';

          if (document.querySelector('#collectionTrendChart')) {
            new ApexCharts(document.querySelector('#collectionTrendChart'), {
              chart: { type: 'area', height: 315, toolbar: { show: false }, parentHeightOffset: 0 },
              series: [{ name: 'Collection', data: [2000, 5600, 10000, 7200, 13201] }],
              xaxis: { categories: ['1 May', '2 May', '3 May', '4 May', '6 May'], labels: { style: { colors: '#a1acb8' } } },
              yaxis: { labels: { formatter: value => '₹' + Math.round(value / 1000) + 'k', style: { colors: '#a1acb8' } } },
              stroke: { curve: 'smooth', width: 3 },
              colors: [primary],
              dataLabels: { enabled: false },
              grid: { borderColor: '#eceef1' },
              fill: { type: 'gradient', gradient: { opacityFrom: .32, opacityTo: .04 } },
              tooltip: { y: { formatter: value => '₹ ' + value.toLocaleString('en-IN') } }
            }).render();
          }

          if (document.querySelector('#paymentModesChart')) {
            new ApexCharts(document.querySelector('#paymentModesChart'), {
              chart: { type: 'donut', height: 230 },
              series: [100], labels: ['Cash'], colors: [success],
              dataLabels: { enabled: false }, legend: { show: false },
              stroke: { width: 0 }, plotOptions: { pie: { donut: { size: '68%' } } }
            }).render();
          }

          if (document.querySelector('#feeStatusChart')) {
            new ApexCharts(document.querySelector('#feeStatusChart'), {
              chart: { type: 'bar', height: 210, toolbar: { show: false } },
              series: [{ name: 'Students', data: [3, 10] }],
              xaxis: { categories: ['Fully Paid', 'Due / Partial'] },
              colors: [success, danger], dataLabels: { enabled: false },
              plotOptions: { bar: { borderRadius: 6, distributed: true, columnWidth: '48%' } },
              grid: { borderColor: '#eceef1' }, legend: { show: false }
            }).render();
          }
        });
    </script>
}
