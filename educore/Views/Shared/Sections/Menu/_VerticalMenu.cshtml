<aside id="layout-menu" class="layout-menu menu-vertical menu bg-menu-theme">

    <div class='app-brand demo @((ViewData["navbarFull"] != null && Convert.ToBoolean(ViewData["navbarFull"])) ? "d-xl-none" : "")'>

        @* <a asp-area=""
           asp-controller="Dashboards"
           asp-action="Index"
           class="app-brand-link"> *@
           <a asp-area="@(role == "SUPER_ADMIN" ? "SuperAdmin" : "Admin")"
   asp-controller="Dashboard"
   asp-action="Index"
   class="app-brand-link">
            <span class="app-brand-logo demo">
                @await Html.PartialAsync("../_Partials/_Macros")
            </span>

            <span class="app-brand-text demo menu-text fw-bold ms-2">
                @appName
            </span>
        </a>

        <a href="javascript:void(0);"
           class="layout-menu-toggle menu-link text-large ms-auto">
            <i class="icon-base bx bx-chevron-left d-block d-xl-none align-middle"></i>
        </a>
    </div>

    <div class="sidebar-search">
        <input type="text" placeholder="Filter menu..." />
    </div>
    <div class="menu-inner-shadow"></div>

    <ul class="menu-inner py-1">

        <li class="menu-header small text-uppercase">
            <span class="menu-header-text">
                @(string.IsNullOrWhiteSpace(roleName) ? role : roleName) Menu
            </span>
        </li>

        @if (!string.IsNullOrWhiteSpace(role) && menus.ContainsKey(role))
        {
            foreach (var item in menus[role])
            {
                var controller = GetController(item);
                var isActive = IsActive(controller);

                if (item == "Sign out")
                {
                    <li class="menu-item">
                        <a asp-area=""
                           asp-controller="Account"
                           asp-action="Logout"
                           class="menu-link">
                            <i class="menu-icon icon-base bx @GetIcon(item)"></i>
                            <div class="text-truncate">@item</div>
                        </a>
                    </li>
                }
                else if (item == "Support")
                {
                    <li class="menu-item">
                        <a href="@supportUrl"
                           target="_blank"
                           class="menu-link">
                            <i class="menu-icon icon-base bx @GetIcon(item)"></i>
                            <div class="text-truncate">@item</div>
                        </a>
                    </li>
                }
                else if (item == "Install App")
                {
                    <li class="menu-item">
                        <a href="javascript:void(0);"
                           class="menu-link">
                            <i class="menu-icon icon-base bx @GetIcon(item)"></i>
                            <div class="text-truncate">@item</div>
                        </a>
                    </li>
                }
                else if (item == "School Settings")
                {
                    var schoolSettingsOpen = IsActive("SchoolSettings");

                    <li class='menu-item @(schoolSettingsOpen ? "active open" : "")'>

                        <a href="javascript:void(0);"
                           class="menu-link menu-toggle">
                            <i class="menu-icon icon-base bx bx-cog"></i>
                            <div class="text-truncate">School Settings</div>
                        </a>

                        <ul class="menu-sub">

                            <li class='menu-item @(IsActive("BasicProfile") ? "active" : "")'>
                                <a asp-area="Admin"
                                   asp-controller="SchoolSettings"
                                   asp-action="BasicProfile"
                                   class="menu-link">

                                    <i class="bx bx-user submenu-icon submenu-profile"></i>

                                    <div class="text-truncate">
                                        Basic Profile
                                    </div>

                                </a>
                            </li>

                            <li class='menu-item @(IsActive("AcademicSetup") ? "active" : "")'>
                                <a asp-area="Admin"
                                   asp-controller="SchoolSettings"
                                   asp-action="AcademicSetup"
                                   class="menu-link">

                                    <i class="bx bx-book-open submenu-icon submenu-academic"></i>

                                    <div class="text-truncate">
                                        Academic Setup
                                    </div>

                                </a>
                            </li>

                            <li class='menu-item @(IsActive("FeeHead") ? "active" : "")'>
                                <a asp-area="Admin"
                                   asp-controller="SchoolSettings"
                                   asp-action="FeeHead"
                                   class="menu-link">

                                    <i class="bx bx-wallet submenu-icon submenu-feehead"></i>

                                    <div class="text-truncate">
                                        Fee Head
                                    </div>

                                </a>
                            </li>
                            <li class='menu-item @(IsActive("FeeStructure") ? "active" : "")'>
                                <a asp-area="Admin"
                                   asp-controller="SchoolSettings"
                                   asp-action="FeeStructure"
                                   class="menu-link">

                                    <i class="bx bx-credit-card submenu-icon submenu-feestructure"></i>

                                    <div class="text-truncate">
                                        Fee Structure
                                    </div>

                                </a>
                            </li>

                            <li class='menu-item @(IsActive("EnquiryCRM") ? "active" : "")'>
                                <a asp-area="Admin"
                                   asp-controller="Enquiry"
                                   asp-action="EnquiryCRM"
                                   class="menu-link">

                                    <i class="bx bx-message-square-detail submenu-icon submenu-crm"></i>

                                    <div class="text-truncate">
                                        Enquiry CRM
                                    </div>

                                </a>
                            </li>

                        </ul>
                    </li>
                }
                else
                {
                    <li class='menu-item @(isActive ? "active" : "")'>
                        <a asp-area="@GetArea(item)"
                           asp-controller="@controller"
                           asp-action="Index"
                           class="menu-link">

                            <i class="menu-icon icon-base bx @GetIcon(item)"></i>
                            <div class="text-truncate">@item</div>
                        </a>
                    </li>
                }
            }
        }
        else
        {
            <li class="menu-item">
                <a asp-area=""
                   asp-controller="Account"
                   asp-action="Login"
                   class="menu-link">
                    <i class="menu-icon icon-base bx bx-log-in"></i>
                    <div class="text-truncate">Login</div>
                </a>
            </li>
        }

    </ul>
</aside>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const searchInput = document.querySelector(".sidebar-search input");
        const rootMenuItems = document.querySelectorAll("#layout-menu > ul.menu-inner > li.menu-item");

        if (!searchInput) return;

        searchInput.addEventListener("input", function () {
            const value = this.value.toLowerCase().trim();

            rootMenuItems.forEach(item => {
                const text = item.innerText.toLowerCase();
                const subMenu = item.querySelector(".menu-sub");

                if (!value) {
                    item.style.display = "";
                    item.classList.remove("open");
                    return;
                }

                if (text.includes(value)) {
                    item.style.display = "";

                    if (subMenu) {
                        item.classList.add("open");
                        subMenu.style.display = "block";
                    }
                } else {
                    item.style.display = "none";
                }
            });
        });
    });
</script>