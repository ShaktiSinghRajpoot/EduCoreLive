        @if (secFinance)
        {
        <li class="menu-header"><span class="menu-header-text">Finance</span></li>
        }

        @* ---- Fees ---- *@
        @if (gFees)
        {
        <li class='menu-item @Open("FeeStructure","FeeHead","ManageFee","PaymentVerification","FeeDueReminders")'>
            <a href="javascript:void(0);" class="menu-link menu-toggle">
