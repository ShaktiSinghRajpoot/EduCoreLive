            <span class="app-brand-logo demo">@await Html.PartialAsync("../_Partials/_Macros")</span>
            <span class="app-brand-text demo menu-text fw-bold ms-2">@appName</span>
        </a>
        <a href="javascript:void(0);" class="layout-menu-toggle menu-link text-large ms-auto">
            <i class="icon-base bx bx-chevron-left d-block d-xl-none align-middle"></i>
        </a>
    </div>

    <div class="sidebar-search"><input type="text" placeholder="Search menu..." /></div>
    <div class="menu-inner-shadow"></div>

    <ul class="menu-inner py-1">

