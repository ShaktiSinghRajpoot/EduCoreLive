@using EduCoreDataAccessLayer.Helpers
@using System.Security.Claims

@{
    var currentPage = Context.Request.Path.Value ?? "";

    var role = User.FindFirst("role_code")?.Value
               ?? User.FindFirst(ClaimTypes.Role)?.Value
               ?? Context.Session.GetString("RoleCode")
               ?? "";

    var roleName = User.FindFirst("role_name")?.Value
                   ?? Context.Session.GetString("RoleName")
                   ?? "";

    var userName = User.FindFirst(Common.SK_UserName)?.Value
                   ?? Context.Session.GetString("UserName")
                   ?? "";

    var appName = "EduCore";
    var supportUrl = "#";

    var menus = new Dictionary<string, string[]>
    {
        ["SUPER_ADMIN"] = new[] {
            "Dashboard", "Schools", "Sign out"
        },

        ["SCHOOL_ADMIN"] = new[] {
            "Dashboard",
            "Admission & Students",
            "Enquiry CRM",
            "Student Attendance",
            "Exams & Results",
            "Fees Management",
            "Payment Verification",
            "Fee Due Reminders",
            "Staff Management",
            "Leave Management",
            "Payroll Management",
            "Staff Attendance",
            "Inventory Management",
            "Accounts & Expenses",
            "Timetable Management",
            "Notice Board",
            "Smart Bell",
            "Advanced Bus Tracking",
            "ID Cards",
            "Transfer Certificates",
            "Certifications",
            "Reports",
            "Billing & Subscription",
            "School Settings",
            "Support",
            "Install App",
            "Sign out",
            ////
           "Fee",
           "Admission"

        },

        ["TEACHER"] = new[] {
            "Dashboard",
            "Enquiry CRM",
            "Student Attendance",
            "Exams & Results",
            "Leave Management",
            "Payroll Management",
            "Staff Attendance",
            "Timetable Management",
            "ID Cards",
            "Support",
            "Install App",
            "Sign out"
        },

        ["ACCOUNTANT"] = new[] {
            "Dashboard",
            "Enquiry CRM",
            "Fees Management",
            "Payment Verification",
            "Fee Due Reminders",
            "Leave Management",
            "Payroll Management",
            "Staff Attendance",
            "Inventory Management",
            "Accounts & Expenses",
            "Reports",
            "Support",
            "Install App",
            "Sign out",
            ////
           "Fee"
        },

        ["RECEPTIONIST"] = new[] {
            "Dashboard",
            "Admission & Students",
            "Enquiry CRM",
            "Leave Management",
            "Payroll Management",
            "Staff Attendance",
            "Inventory Management",
            "ID Cards",
            "Transfer Certificates",
            "Support",
            "Install App",
            "Sign out"
        }
    };

    string GetIcon(string name) => name switch
    {
        "Dashboard" => "bx-home-smile",
        "Schools" => "bx-buildings",
        "Admission & Students" => "bx-user-plus",
        "Enquiry CRM" => "bx-message-square-detail",
        "Student Attendance" => "bx-user-check",
        "Exams & Results" => "bx-file",
        "Fees Management" => "bx-wallet",
        "Payment Verification" => "bx-check-shield",
        "Fee Due Reminders" => "bx-bell",
        "Staff Management" => "bx-group",
        "Leave Management" => "bx-calendar-minus",
        "Payroll Management" => "bx-money",
        "Staff Attendance" => "bx-user-voice",
        "Inventory Management" => "bx-package",
        "Accounts & Expenses" => "bx-receipt",
        "Timetable Management" => "bx-time-five",
        "Notice Board" => "bx-news",
        "Smart Bell" => "bx-bell-ring",
        "Advanced Bus Tracking" => "bx-bus",
        "ID Cards" => "bx-id-card",
        "Transfer Certificates" => "bx-transfer",
        "Certifications" => "bx-certification",
        "Reports" => "bx-bar-chart-alt-2",
        "Billing & Subscription" => "bx-credit-card",
        "School Settings" => "bx-cog",
        "Support" => "bx-support",
        "Install App" => "bx-download",
        "Sign out" => "bx-log-out",
        //
        "Fees" => "bx-wallet",
        "Admission" => "bx-user-plus",
        _ => "bx-circle"
    };

    string GetController(string name)
    {
        return name.Replace("&", "And")
                   .Replace(" ", "")
                   .Replace("-", "");
    }

    string GetArea(string item)
    {
        if (item == "Dashboard")
            return role == "SUPER_ADMIN" ? "SuperAdmin" : "Admin";

        if (role == "SUPER_ADMIN")
            return "SuperAdmin";

        return "Admin";
    }

    bool IsActive(string value)
    {
        return currentPage.Contains(value, StringComparison.OrdinalIgnoreCase);
    }
}
