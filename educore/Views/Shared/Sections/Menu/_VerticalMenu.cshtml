            </a>
            <ul class="menu-sub">
                <li class='menu-item @On("StudentAttendance")'><a asp-area="ERP" asp-controller="Attendance" asp-action="StudentAttendance" class="menu-link"><i class="bx bx-user-check submenu-icon c-green"></i><div class="text-truncate">Student Attendance</div></a></li>
