<script>
    document.addEventListener("DOMContentLoaded", function () {
        const layoutMenu = document.getElementById("layout-menu");

        // --- Desktop submenu click-to-toggle ---------------------------------
        // Sneat's menu.js binds the submenu click-toggle for TOUCH devices only
        // (`if (window.Helpers.isMobileDevice) ...`). On desktop the submenu was
        // only opening on hover and collapsing when the pointer left. Bind an
        // explicit click-to-toggle (with accordion) for non-touch devices. The
        // submenu is pure CSS (.menu-item.open > .menu-sub { display:flex }), so
        // toggling the `open` class is all that's needed.
        const isTouch = window.Helpers && Helpers.isMobileDevice && Helpers.isMobileDevice();
        if (layoutMenu && !isTouch) {
            layoutMenu.addEventListener("click", function (e) {
                const toggle = e.target.closest(".menu-toggle");
                if (!toggle || !layoutMenu.contains(toggle)) return;
                e.preventDefault();
                const item = toggle.parentElement;                  // li.menu-item
                const opening = !item.classList.contains("open");
                Array.from(item.parentElement.children).forEach(sib => {
                    if (sib !== item) sib.classList.remove("open");  // accordion
                });
                item.classList.toggle("open", opening);
            });
        }

        // --- Active-state resolver (robust, URL-based) ------------------------
        // Source of truth for "where am I": match the current URL to a menu link,
        // mark it active, and OPEN every parent above it. This replaces the old
        // server-side substring matching, which had incomplete keyword lists
        // (some pages never highlighted) and collisions (wrong item highlighted).
        // Runs on every page load, so the active branch is always expanded.
        if (layoutMenu) {
            (function resolveActive() {
                function norm(p) {
                    p = (p || "").toLowerCase();
                    if (p.length > 1 && p.endsWith("/")) p = p.slice(0, -1);
                    return p;
                }
                function pathOf(a) {
                    try { return norm(new URL(a.href, location.origin).pathname); }
                    catch (e) { return ""; }
                }
                var here  = norm(location.pathname);
                var links = Array.prototype.slice.call(
                    layoutMenu.querySelectorAll('a.menu-link[href]'));
                links = links.filter(function (a) {
                    var h = a.getAttribute('href') || '';
                    return h && h.indexOf('javascript:') !== 0 && h !== '#';
                });

                // 1) Best match: exact URL, or the current page sits *under* a link's
                //    URL (covers detail/edit pages). Longest match wins.
                var best = null, bestLen = -1;
                links.forEach(function (a) {
                    var ap = pathOf(a);
                    if (!ap || ap === '/') return;
                    if (here === ap || here.indexOf(ap + '/') === 0) {
                        if (ap.length > bestLen) { best = a; bestLen = ap.length; }
                    }
                });

                // 2) Fallback for pages with no menu entry of their own (e.g. an
                //    Edit screen): match by area/controller (first two path
                //    segments) — but only if every candidate is in the SAME top
                //    group, so we never highlight the wrong one.
                if (!best) {
                    var seg = here.split('/').filter(Boolean);
                    if (seg.length >= 2) {
                        var prefix = '/' + seg[0] + '/' + seg[1];
                        var cands = links.filter(function (a) {
                            var ap = pathOf(a);
                            return ap === prefix || ap.indexOf(prefix + '/') === 0;
                        });
                        var groups = [];
                        cands.forEach(function (a) {
                            var g = a.closest('ul.menu-inner > li.menu-item');
                            if (g && groups.indexOf(g) === -1) groups.push(g);
                        });
                        if (cands.length && groups.length === 1) best = cands[0];
                    }
                }

                if (!best) return;

                // Clear anything the server may have marked, then apply exactly one branch.
                layoutMenu.querySelectorAll('.menu-item.active, .menu-item.open')
                    .forEach(function (li) { li.classList.remove('active', 'open'); });

                var p = best.parentElement;   // the <a>'s <li>
                while (p && p !== layoutMenu) {
                    if (p.tagName === 'LI' && p.classList.contains('menu-item')) {
                        p.classList.add('active');
                        if (p.querySelector(':scope > ul.menu-sub')) p.classList.add('open');
                    }
                    p = p.parentElement;
                }

                if (best.scrollIntoView) {
                    try { best.scrollIntoView({ block: 'center' }); } catch (e) {}
                }
            })();
        }

        // --- Menu filter ------------------------------------------------------
        const searchInput = document.querySelector(".sidebar-search input");
        if (!searchInput) return;

        const rootItems = document.querySelectorAll("#layout-menu > ul.menu-inner > li.menu-item");
        const headers   = document.querySelectorAll("#layout-menu > ul.menu-inner > li.menu-header");

        searchInput.addEventListener("input", function () {
            const value = this.value.toLowerCase().trim();
            headers.forEach(h => h.style.display = value ? "none" : "");

            rootItems.forEach(item => {
                const text = item.innerText.toLowerCase();
                const sub  = item.querySelector(".menu-sub");
                if (!value) { item.style.display = ""; item.classList.remove("open"); return; }
                if (text.includes(value)) {
                    item.style.display = "";
                    if (sub) item.classList.add("open");   // CSS reveals the sub
                } else {
                    item.style.display = "none";
                }
            });
        });
    });
</script>
