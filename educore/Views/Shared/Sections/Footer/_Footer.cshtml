@{
  TempData.Keep();
  ViewData["containerNav"] = (ViewData["containerNav"] ??= "container-fluid");
  var appName = TempData.Peek("appName") as string ?? "EduCore";
}

<!-- Footer -->
<footer class="content-footer footer bg-footer-theme">
  <div class="@ViewData["containerNav"]">
    <div class="footer-container d-flex align-items-center justify-content-between py-3 flex-md-row flex-column gap-2">

      @* Left — product copyright *@
      <div class="text-muted small text-center text-md-start">
        &#169;
        <script>document.write(new Date().getFullYear());</script>
        <span class="fw-semibold">@appName</span> · School ERP. All rights reserved.
      </div>

      @* Right — version + live status pill (SaaS touch) *@
      <div class="d-flex align-items-center gap-3 small">
        <span class="text-muted">v1.0.0</span>
        <span class="d-inline-flex align-items-center gap-1 text-muted">
          <span class="d-inline-block rounded-circle bg-success"
                style="width:7px;height:7px;" aria-hidden="true"></span>
          All systems operational
        </span>
      </div>

    </div>
  </div>
</footer>
<!-- / Footer -->
