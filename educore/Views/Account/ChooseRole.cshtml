@model List<educore.Models.UserViewModel>

@{
    Layout = "_BlankLayout";
    ViewData["Title"] = "Choose Role";

    var currentUser = Model?.FirstOrDefault();
}

@if (Model == null || !Model.Any())
{
    <main class="page-shell">
        <div class="brand">eduCore</div>

        <section class="role-card-wrapper">
            <h1 class="title">No roles assigned</h1>
            <p class="subtitle">Please contact your administrator.</p>
        </section>
    </main>

    return;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>eduCore | Choose Role</title>

    <style>
        :root {
            --primary: #ff8a00;
            --primary-dark: #eb7d00;
            --primary-soft: #fff4e6;
            --tag-bg: #fff4e6;
            --bg-start: #fff7ed;
            --bg-end: #f8f7f5;
            --card: #ffffff;
            --text: #2b1b12;
            --muted: #8b8175;
            --border: #f0eee9;
            --shadow: 0 20px 45px rgba(67, 89, 113, 0.10);
            --radius-lg: 22px;
            --radius-md: 16px;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: Inter, Roboto, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        }

        body {
            min-height: 100vh;
            background: linear-gradient(135deg, var(--bg-start), var(--bg-end));
            color: var(--text);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 18px;
        }

        .page-shell {
            width: 100%;
            max-width: 430px;
        }

        .brand {
            text-align: center;
            margin-bottom: 18px;
            font-size: 24px;
            font-weight: 800;
            color: var(--primary);
            letter-spacing: -0.04em;
        }

        .role-card-wrapper {
            background: rgba(255, 255, 255, 0.86);
            backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.75);
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow);
            padding: 24px;
        }

        .user-block {
            text-align: center;
            margin-bottom: 22px;
        }

        .avatar-text {
            width: 64px;
            height: 64px;
            border-radius: 50%;
            border: 4px solid #ffffff;
            box-shadow: 0 8px 20px rgba(255, 138, 0, 0.18);
            margin: 0 auto 10px;
            background: var(--primary-soft);
            color: var(--primary-dark);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 26px;
            font-weight: 800;
        }

        .user-name {
            font-size: 18px;
            font-weight: 700;
            letter-spacing: -0.02em;
        }

        .user-meta {
            margin-top: 3px;
            font-size: 13px;
            color: var(--muted);
        }

        .title {
            font-size: 22px;
            font-weight: 750;
            line-height: 1.25;
            text-align: center;
            letter-spacing: -0.04em;
            margin-bottom: 6px;
        }

        .subtitle {
            font-size: 14px;
            line-height: 1.5;
            text-align: center;
            color: var(--muted);
            margin-bottom: 22px;
        }

        .roles-list {
            display: grid;
            gap: 12px;
        }

        .role-form {
            display: block;
        }

        .role-option {
            width: 100%;
            border: 1px solid var(--border);
            background: var(--card);
            border-radius: var(--radius-md);
            padding: 15px;
            display: flex;
            align-items: center;
            gap: 14px;
            cursor: pointer;
            text-align: left;
            transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease, background 0.18s ease;
            min-height: 82px;
        }

            .role-option:hover,
            .role-option:focus-visible {
                outline: none;
                transform: translateY(-2px);
                border-color: rgba(255, 138, 0, 0.35);
                box-shadow: 0 12px 28px rgba(15, 23, 42, 0.09);
            }

            .role-option:active {
                transform: scale(0.985);
            }

            .role-option.last-used {
                background: var(--primary-soft);
                border-color: rgba(255, 138, 0, 0.28);
            }

        .role-icon {
            width: 44px;
            height: 44px;
            border-radius: 14px;
            background: #ffffff;
            display: grid;
            place-items: center;
            font-size: 22px;
            flex: 0 0 auto;
            box-shadow: inset 0 0 0 1px rgba(229, 231, 235, 0.8);
        }

        .role-content {
            flex: 1;
            min-width: 0;
        }

        .role-header {
            display: flex;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
            margin-bottom: 4px;
        }

        .role-title {
            font-size: 15.5px;
            font-weight: 750;
            color: var(--text);
        }

        .tag {
            font-size: 11px;
            font-weight: 700;
            color: var(--primary-dark);
            background: var(--tag-bg);
            padding: 4px 8px;
            border-radius: 999px;
        }

        .role-desc {
            font-size: 13px;
            color: var(--muted);
            line-height: 1.4;
        }

        .chevron {
            color: #9ca3af;
            font-size: 22px;
            flex: 0 0 auto;
        }

        .helper-text {
            margin-top: 18px;
            text-align: center;
            color: var(--muted);
            font-size: 12.5px;
            line-height: 1.5;
        }

        @@media (min-width: 720px) {
            .page-shell {
                max-width: 460px;
            }

            .role-card-wrapper {
                padding: 30px;
            }
        }
    </style>
</head>

<body>
    <main class="page-shell">
        <div class="brand">eduCore</div>

        <section class="role-card-wrapper" aria-labelledby="page-title">
            <div class="user-block">
                <div class="avatar-text">
                    @((currentUser?.FullName ?? "U").Substring(0, 1).ToUpper())
                </div>

                <div class="user-name">@currentUser?.FullName</div>
                <div class="user-meta">@currentUser?.Email</div>
            </div>

            <h1 class="title" id="page-title">Choose how you want to continue</h1>
            <p class="subtitle">Select the role you want to use for this session.</p>

            <div class="roles-list" role="list" aria-label="Available roles">
                @foreach (var role in Model)
                {
                    var icon = role.RoleCode switch
                    {
                        "SUPER_ADMIN" => "🛡️",
                        "SCHOOL_ADMIN" => "🏫",
                        "TEACHER" => "🎓",
                        "ACCOUNTANT" => "🧾",
                        "RECEPTIONIST" => "☎️",
                        _ => "👤"
                    };

                    var desc = role.RoleCode switch
                    {
                        "SUPER_ADMIN" => "Manage schools and global system settings.",
                        "SCHOOL_ADMIN" => "Manage school users, settings and reports.",
                        "TEACHER" => "Manage classes, attendance and students.",
                        "ACCOUNTANT" => "Handle fees, billing and payment records.",
                        "RECEPTIONIST" => "Manage front desk, visitors and enquiries.",
                        _ => "Continue with this role."
                    };

                    <form asp-area="" asp-controller="Account" asp-action="ContinueAs" method="post" class="role-form">
                        @Html.AntiForgeryToken()

                        <input type="hidden" name="roleCode" value="@role.RoleCode" />

                        <button class="role-option"
                                type="submit"
                                data-role-code="@role.RoleCode"
                                onclick="setLastUsedRole(this.dataset.roleCode)">
                            <span class="role-icon" aria-hidden="true">@icon</span>

                            <span class="role-content">
                                <span class="role-header">
                                    <span class="role-title">Continue as @role.RoleName</span>
                                </span>

                                <span class="role-desc">@desc</span>
                            </span>

                            <span class="chevron" aria-hidden="true">›</span>
                        </button>
                    </form>
                }
            </div>

            <p class="helper-text">You can switch roles later from your profile menu inside eduCore.</p>
        </section>
    </main>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const lastRole = localStorage.getItem("eduCoreLastRole");

            if (!lastRole) return;

            document.querySelectorAll(".role-option").forEach(function (button) {
                const roleCode = button.getAttribute("data-role-code");

                if (roleCode === lastRole) {
                    button.classList.add("last-used");

                    const header = button.querySelector(".role-header");

                    if (header && !header.querySelector(".tag")) {
                        const tag = document.createElement("span");
                        tag.className = "tag";
                        tag.innerText = "Last used";
                        header.appendChild(tag);
                    }
                }
            });
        });

        function setLastUsedRole(roleCode) {
            if (!roleCode) return;
            localStorage.setItem("eduCoreLastRole", roleCode);
        }
    </script>
</body>
</html>