@model ForgotPasswordViewModel
@{
    Layout = "_BlankLayout";
    ViewData["Title"] = "Forgot Password";
}

@section PageStyles {
    <style>
        .login-page { min-height:100vh; display:flex; align-items:center; justify-content:center;
            background:linear-gradient(135deg,#fff7ed 0%,#f8f7f5 50%,#fff4e6 100%); padding:1.5rem; }
        .login-card { width:100%; max-width:420px; background:#fff; border:1px solid #f0eee9;
            border-radius:22px; padding:2.5rem 2rem; box-shadow:0 8px 24px rgba(67,89,113,.14); }
        .brand-name { text-align:center; font-size:1.5rem; font-weight:800; color:#ff8a00; letter-spacing:-.03em; margin-bottom:1rem; }
        .login-title { text-align:center; font-size:1.6rem; font-weight:800; color:#2b1b12; margin-bottom:.25rem; }
        .login-subtitle { text-align:center; color:#8b8175; font-size:.9rem; margin-bottom:1.75rem; }
        .login-input-wrap { position:relative; margin-bottom:1.25rem; }
        .login-input-wrap .field-icon { position:absolute; left:.9rem; top:50%; transform:translateY(-50%); color:#8b8175; font-size:1.1rem; pointer-events:none; z-index:4; }
        .login-input-wrap .form-control { padding-left:2.6rem; }
        .login-btn { font-weight:700; min-height:48px; border-radius:12px; margin-bottom:1rem; }
        .login-links { text-align:center; font-size:.8rem; color:#8b8175; }
        .login-links a { color:#ff8a00; text-decoration:none; }
    </style>
}

<div class="login-page">
    <div class="login-card">

        <div class="brand-name">@TempData.Peek("appName")</div>
        <h1 class="login-title">Forgot Password</h1>
        <p class="login-subtitle">Enter your registered email or mobile number and we'll send you a 6-digit code.</p>

        <form asp-controller="Account" asp-action="ForgotPassword" method="post" autocomplete="off">
            @Html.AntiForgeryToken()

            <div>
                <label asp-for="Identifier" class="form-label">Email or mobile number</label>
                <div class="login-input-wrap">
                    <i class="icon-base bx bx-user field-icon"></i>
                    <input asp-for="Identifier" type="text" class="form-control" placeholder="name@example.com or 98XXXXXXXX" autofocus />
                </div>
                <span asp-validation-for="Identifier" class="text-danger small d-block mb-2"></span>
            </div>

            <button class="btn btn-primary d-grid w-100 login-btn" type="submit">
                Send Code <span class="ms-1">→</span>
            </button>
        </form>

        <div class="login-links">
            <a asp-controller="Account" asp-action="Login">← Back to login</a>
        </div>
    </div>
</div>

@section PageScripts {
    <partial name="_ValidationScriptsPartial" />
}
