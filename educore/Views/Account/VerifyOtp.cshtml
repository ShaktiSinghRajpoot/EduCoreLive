@model VerifyOtpViewModel
@{
    Layout = "_BlankLayout";
    ViewData["Title"] = "Verify Code";
}

@section PageStyles {
    <style>
        .login-page { min-height:100vh; display:flex; align-items:center; justify-content:center;
            background:linear-gradient(135deg,#fff7ed 0%,#f8f7f5 50%,#fff4e6 100%); padding:1.5rem; }
        .login-card { width:100%; max-width:420px; background:#fff; border:1px solid #f0eee9;
            border-radius:22px; padding:2.5rem 2rem; box-shadow:0 8px 24px rgba(67,89,113,.14); }
        .brand-name { text-align:center; font-size:1.5rem; font-weight:800; color:#ff8a00; letter-spacing:-.03em; margin-bottom:1rem; }
        .login-title { text-align:center; font-size:1.6rem; font-weight:800; color:#2b1b12; margin-bottom:.25rem; }
        .login-subtitle { text-align:center; color:#8b8175; font-size:.9rem; margin-bottom:1.75rem; }
        .login-input-wrap { position:relative; margin-bottom:1.25rem; }
        .login-input-wrap .field-icon { position:absolute; left:.9rem; top:50%; transform:translateY(-50%); color:#8b8175; font-size:1.1rem; pointer-events:none; z-index:4; }
        .login-input-wrap .form-control { padding-left:2.6rem; }
        .otp-input { letter-spacing:8px; font-weight:700; text-align:center; font-size:1.3rem; }
        .login-btn { font-weight:700; min-height:48px; border-radius:12px; margin-bottom:1rem; }
        .login-links { text-align:center; font-size:.8rem; color:#8b8175; }
        .login-links a { color:#ff8a00; text-decoration:none; }
    </style>
}

<div class="login-page">
    <div class="login-card">

        <div class="brand-name">@TempData.Peek("appName")</div>
        <h1 class="login-title">Enter Verification Code</h1>
        <p class="login-subtitle">We've sent a 6-digit code to your registered email and mobile. Enter it below and choose a new password.</p>

        <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>

        <form asp-controller="Account" asp-action="VerifyOtp" method="post" autocomplete="off">
            @Html.AntiForgeryToken()

            <div>
                <label asp-for="Otp" class="form-label">Verification code</label>
                <input asp-for="Otp" class="form-control otp-input" maxlength="6" inputmode="numeric"
                       placeholder="••••••" autofocus />
                <span asp-validation-for="Otp" class="text-danger small d-block mb-2"></span>
            </div>

            <div class="mt-2">
                <label asp-for="NewPassword" class="form-label">New Password</label>
                <div class="login-input-wrap">
                    <i class="icon-base bx bx-key field-icon"></i>
                    <input asp-for="NewPassword" type="password" class="form-control" placeholder="At least 8 characters" />
                </div>
                <span asp-validation-for="NewPassword" class="text-danger small d-block mb-2"></span>
            </div>

            <div>
                <label asp-for="ConfirmPassword" class="form-label">Confirm New Password</label>
                <div class="login-input-wrap">
                    <i class="icon-base bx bx-key field-icon"></i>
                    <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Re-enter new password" />
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-danger small d-block mb-2"></span>
            </div>

            <button class="btn btn-primary d-grid w-100 login-btn" type="submit">
                Reset Password <span class="ms-1">→</span>
            </button>
        </form>

        <div class="login-links">
            <a asp-controller="Account" asp-action="ForgotPassword">Didn't get a code? Request again</a>
            <span class="mx-1">•</span>
            <a asp-controller="Account" asp-action="Login">Back to login</a>
        </div>
    </div>
</div>

@section PageScripts {
    <partial name="_ValidationScriptsPartial" />
}
