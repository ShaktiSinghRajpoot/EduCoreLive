@model ChangePasswordViewModel
@{
    Layout = "_BlankLayout";
    ViewData["Title"] = "Change Password";
}

@section PageStyles {
    <style>
        .login-page {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #fff7ed 0%, #f8f7f5 50%, #fff4e6 100%);
            padding: 1.5rem;
        }

        .login-card {
            width: 100%;
            max-width: 420px;
            background: #ffffff;
            border: 1px solid #f0eee9;
            border-radius: 22px;
            padding: 2.5rem 2rem;
            box-shadow: 0 8px 24px rgba(67, 89, 113, .14);
        }

        .brand-name {
            text-align: center;
            font-size: 1.5rem;
            font-weight: 800;
            color: #ff8a00;
            letter-spacing: -.03em;
            margin-bottom: 1rem;
        }

        .login-title {
            text-align: center;
            font-size: 1.6rem;
            font-weight: 800;
            color: #2b1b12;
            margin-bottom: .25rem;
        }

        .login-subtitle {
            text-align: center;
            color: #8b8175;
            font-size: .9rem;
            margin-bottom: 1.75rem;
        }

        .login-input-wrap {
            position: relative;
            margin-bottom: 1.25rem;
        }

        .login-input-wrap .field-icon {
            position: absolute;
            left: .9rem;
            top: 50%;
            transform: translateY(-50%);
            color: #8b8175;
            font-size: 1.1rem;
            pointer-events: none;
            z-index: 4;
        }

        .login-input-wrap .form-control {
            padding-left: 2.6rem;
            padding-right: 2.6rem;
        }

        .password-eye {
            position: absolute;
            right: .9rem;
            top: 50%;
            transform: translateY(-50%);
            color: #8b8175;
            cursor: pointer;
            z-index: 4;
        }

        .login-btn {
            font-weight: 700;
            min-height: 48px;
            border-radius: 12px;
            margin-bottom: 1rem;
        }

        .login-links { text-align: center; font-size: .8rem; color: #8b8175; }
        .login-links a { color: #ff8a00; text-decoration: none; }

        @@media (max-width: 480px) {
            .login-card { padding: 2rem 1.25rem; border-radius: 18px; }
        }
    </style>
}

<div class="login-page">
    <div class="login-card">

        <div class="brand-name">@TempData.Peek("appName")</div>

        <h1 class="login-title">@(Model.IsForced ? "Set a New Password" : "Change Password")</h1>
        <p class="login-subtitle">
            @(Model.IsForced
                ? "For your security, please change your temporary password before continuing."
                : "Enter your current password and choose a new one.")
        </p>

        <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>

        <form asp-controller="Account" asp-action="ChangePassword" method="post" autocomplete="off">
            @Html.AntiForgeryToken()

            @* Current password is only asked on a normal change — not on the forced
               first-login reset, where the user just signed in with the temp password. *@
            @if (!Model.IsForced)
            {
                <div>
                    <label asp-for="CurrentPassword" class="form-label">Current Password</label>
                    <div class="login-input-wrap">
                        <i class="icon-base bx bx-lock-alt field-icon"></i>
                        <input asp-for="CurrentPassword" type="password" class="form-control" placeholder="••••••••••" autofocus />
                        <span class="password-eye"><i class="icon-base bx bx-hide"></i></span>
                    </div>
                    <span asp-validation-for="CurrentPassword" class="text-danger small d-block mb-2"></span>
                </div>
            }

            <div>
                <label asp-for="NewPassword" class="form-label">New Password</label>
                <div class="login-input-wrap">
                    <i class="icon-base bx bx-key field-icon"></i>
                    <input asp-for="NewPassword" type="password" class="form-control" placeholder="At least 8 characters" autofocus="@Model.IsForced" />
                    <span class="password-eye"><i class="icon-base bx bx-hide"></i></span>
                </div>
                <span asp-validation-for="NewPassword" class="text-danger small d-block mb-2"></span>
            </div>

            <div>
                <label asp-for="ConfirmPassword" class="form-label">Confirm New Password</label>
                <div class="login-input-wrap">
                    <i class="icon-base bx bx-key field-icon"></i>
                    <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Re-enter new password" />
                    <span class="password-eye"><i class="icon-base bx bx-hide"></i></span>
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-danger small d-block mb-2"></span>
            </div>

            <button class="btn btn-primary d-grid w-100 login-btn" type="submit">
                Update Password <span class="ms-1">→</span>
            </button>
        </form>

        @if (!Model.IsForced)
        {
            <div class="login-links">
                <a asp-controller="Account" asp-action="Logout" asp-route-dummy="" onclick="event.preventDefault(); document.getElementById('cp-logout').submit();">Sign Out</a>
                <form id="cp-logout" asp-controller="Account" asp-action="Logout" method="post" class="d-none">@Html.AntiForgeryToken()</form>
            </div>
        }
        else
        {
            <div class="login-links">
                <form asp-controller="Account" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-link p-0 login-links" style="text-decoration:none;">Sign out instead</button>
                </form>
            </div>
        }
    </div>
</div>

@section PageScripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Show/hide password — works for every .password-eye on the page.
        document.querySelectorAll('.password-eye').forEach(function (eye) {
            eye.addEventListener('click', function () {
                var input = this.parentElement.querySelector('input');
                var icon = this.querySelector('i');
                if (!input) return;
                if (input.type === 'password') {
                    input.type = 'text';
                    icon.classList.remove('bx-hide'); icon.classList.add('bx-show');
                } else {
                    input.type = 'password';
                    icon.classList.remove('bx-show'); icon.classList.add('bx-hide');
                }
            });
        });
    </script>
}
