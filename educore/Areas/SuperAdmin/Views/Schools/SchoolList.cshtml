@using educore.Models
 @model IEnumerable<SchoolListModel>

@{
    ViewData["Title"] = "School List";
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
}

<div class="container-fluid flex-grow-1 px-0">

    <div class="ec-page-shell mt-2">
        <div class="ec-page-header-compact">
            <div class="row align-items-center">
                <div class="col-md-6 d-flex align-items-center gap-3">
                    <div class="ec-page-icon-sm">
                        <i class="bx bx-building-house"></i>
                    </div>
                    <div>
                        <h5 class="mb-0 fw-bold">Schools</h5>
                        <p class="text-muted small mb-0">Total: @ViewBag.TotalRecords entries</p>
                    </div>
                </div>
                <div class="col-md-6 text-md-end mt-2 mt-md-0">
                    <button class="btn ec-btn-soft btn-sm me-2" data-bs-toggle="offcanvas" data-bs-target="#schoolFilterCanvas">
                        <i class="bx bx-filter-alt me-1"></i> Filter
                    </button>
                    <a href="/SuperAdmin/Schools/Create" class="btn ec-btn-cta btn-sm">
                        <i class="bx bx-plus me-1"></i> New School
                    </a>
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table ec-table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-5">Tenant</th>
                        <th class="ps-4">School</th>
                        <th>School Code</th>
                        <th>Board / Type</th>
                        <th>Location</th>
                        <th>Primary Contact</th>
                        <th>Status</th>
                        <th>CreatedAt</th>
                        <th class="text-center">Manage</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            var Tenantinitials = !string.IsNullOrWhiteSpace(item.TenantName)
                            ? item.TenantName.Substring(0, Math.Min(2, item.TenantName.Length)).ToUpper()
                            : "SC";

                            var initials = !string.IsNullOrWhiteSpace(item.SchoolName)
                            ? item.SchoolName.Substring(0, Math.Min(2, item.SchoolName.Length)).ToUpper()
                            : "SC";

                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar avatar-sm me-3">
                                            <span class="avatar-initial rounded bg-label-success" style="font-size: 0.7rem;">@Tenantinitials</span>
                                        </div>
                                        <div>
                                            <a href="/SuperAdmin/School/View/@item.TenantId" class="fw-semibold text-dark d-block mb-0">
                                                @item.TenantName
                                            </a>
                                            <span class="text-muted" style="font-size: 0.75rem;">
                                                @item.TenantCode
                                            </span>
                                        </div>
                                    </div>
                                </td>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar avatar-sm me-3">
                                            <span class="avatar-initial rounded bg-label-warning" style="font-size: 0.7rem;">@initials</span>
                                        </div>
                                        <div>
                                            <a href="/SuperAdmin/School/View/@item.SchoolId" class="fw-semibold text-dark d-block mb-0">
                                                @item.SchoolName
                                            </a>
                                            <span class="text-muted" style="font-size: 0.75rem;">
                                                @item.DisplayName
                                            </span>
                                        </div>
                                    </div>
                                </td>

                                

                                <td>
                                    <span class="badge bg-label-secondary text-uppercase" style="font-size: 0.65rem;">
                                        @item.SchoolCode
                                    </span>
                                </td>

                                <td>
                                    <div class="fw-medium small">@item.BoardName</div>
                                    <div class="text-muted" style="font-size: 0.7rem;">@item.SchoolTypeName</div>
                                </td>

                                <td>
                                    <div class="small">@item.City</div>
                                    <div class="text-muted" style="font-size: 0.7rem;">@item.State</div>
                                </td>

                                <td>
                                    <div class="small fw-medium">@item.ContactName</div>
                                    <div class="text-muted" style="font-size: 0.7rem;">
                                        <i class="bx bx-phone-call"></i> @item.Phone
                                    </div>
                                </td>

                                <td>
                                    @if (item.StatusName == "Active")
                                    {
                                        <span class="ec-badge ec-badge-active">Active</span>
                                    }
                                    else if (item.StatusName == "Inactive")
                                    {
                                        <span class="ec-badge ec-badge-inactive">Inactive</span>
                                    }
                                    else
                                    {
                                        <span class="ec-badge ec-badge-default">@item.StatusName</span>
                                    }
                                </td>

                                <td>
                                    <div class="fw-medium small">@item.CreatedAt</div>
                                </td>

                                <td class="text-end pe-4">
                                    <div class="action-btn-group">
                                        <a asp-area="SuperAdmin"
                                           asp-controller="School"
                                           asp-action="Edit"
                                           asp-route-id="@item.SchoolId"
                                           class="btn btn-icon btn-sm btn-label-warning"
                                           title="Edit">
                                            <i class="bx bx-edit-alt"></i>
                                        </a>

                                        <div class="d-inline-block">
                                            <button type="button"
                                                    class="btn btn-icon btn-sm btn-label-secondary hide-arrow"
                                                    data-bs-toggle="dropdown">
                                                <i class="bx bx-dots-vertical-rounded"></i>
                                            </button>

                                            <div class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                                                <a class="dropdown-item"
                                                   asp-area="SuperAdmin"
                                                   asp-controller="School"
                                                   asp-action="Admins"
                                                   asp-route-id="@item.SchoolId">
                                                    <i class="bx bx-user me-2"></i> Admins
                                                </a>

                                                <a class="dropdown-item"
                                                   asp-area="SuperAdmin"
                                                   asp-controller="School"
                                                   asp-action="Documents"
                                                   asp-route-id="@item.SchoolId">
                                                    <i class="bx bx-file me-2"></i> Documents
                                                </a>

                                                <div class="dropdown-divider"></div>

                                                <form asp-action="Delete"
                                                      asp-route-id="@item.SchoolId"
                                                      method="post"
                                                      onsubmit="return confirm('Disable this school?');">
                                                    @Html.AntiForgeryToken()

                                                    <button type="submit" class="dropdown-item text-danger">
                                                        <i class="bx bx-trash me-2"></i> Disable
                                                    </button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                         <tr>
                            <td colspan="8" class="text-center py-5">
                                <i class="bx bx-building-house fs-1 text-muted"></i>
                                <div class="fw-bold mt-2">No schools found</div>
                                <small class="text-muted">Create your first school to get started.</small>
                            </td>
                        </tr> 
                    }
                </tbody>
            </table>
        </div>

        <div class="d-flex justify-content-between align-items-center p-3 border-top bg-light-subtle">
            <small class="text-muted fw-medium">
                Showing @ViewBag.FromRecord-@ViewBag.ToRecord of @ViewBag.TotalRecords
            </small>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(ViewBag.PageNo <= 1 ? "disabled" : "")">
                        <a class="page-link shadow-none" href="?page=@(ViewBag.PageNo - 1)"><i class="bx bx-chevron-left"></i></a>
                    </li>
                    <li class="page-item active"><a class="page-link" href="#">@ViewBag.PageNo</a></li>
                    <li class="page-item"><a class="page-link shadow-none" href="?page=@(ViewBag.PageNo + 1)"><i class="bx bx-chevron-right"></i></a></li>
                </ul>
            </nav>
        </div>
    </div>
</div>
<div class="offcanvas offcanvas-end border-0 shadow" tabindex="-1" id="schoolFilterCanvas" style="width: 380px;">
    <div class="offcanvas-header border-bottom p-4">
        <div class="d-flex align-items-center gap-3">
            <div class="page-icon-small" style="width: 40px; height: 40px; font-size: 20px;">
                <i class="bx bx-filter-alt"></i>
            </div>
            <div>
                <h5 class="offcanvas-title fw-bold">Filter Schools</h5>
                <p class="text-muted small mb-0">Narrow down your results</p>
            </div>
        </div>
        <button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas"></button>
    </div>

    <form method="get" asp-action="SchoolList" class="h-100 d-flex flex-column">
        <div class="offcanvas-body p-4">
            <div class="mb-4">
                <label class="form-label fw-semibold text-uppercase" style="font-size: 0.7rem; color: #8b8175;">Location Details</label>
                <div class="row g-2">
                    <div class="col-6">
                        <input type="text" name="City" class="form-control form-control-sm border-light-subtle shadow-none" placeholder="City" value="@ViewBag.City" />
                    </div>
                    <div class="col-6">
                        <input type="text" name="State" class="form-control form-control-sm border-light-subtle shadow-none" placeholder="State" value="@ViewBag.State" />
                    </div>
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label fw-semibold text-uppercase" style="font-size: 0.7rem; color: #8b8175;">Classifications</label>
                <div class="d-flex flex-column gap-3">
                    <select name="StatusId" class="form-select border-light-subtle shadow-none" asp-items="ViewBag.Statuses">
                        <option value="">All Statuses</option>
                    </select>

                    <select name="BoardId" class="form-select border-light-subtle shadow-none" asp-items="ViewBag.Boards">
                        <option value="">All Boards</option>
                    </select>

                    <select name="SchoolTypeId" class="form-select border-light-subtle shadow-none" asp-items="ViewBag.SchoolTypes">
                        <option value="">All Types</option>
                    </select>
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label fw-semibold text-uppercase" style="font-size: 0.7rem; color: #8b8175;">Registration Date</label>
                <div class="input-group input-group-merge">
                    <input type="date" name="FromDate" class="form-control border-light-subtle shadow-none" value="@ViewBag.FromDate" />
                    <span class="input-group-text border-light-subtle bg-light text-muted small">to</span>
                    <input type="date" name="ToDate" class="form-control border-light-subtle shadow-none" value="@ViewBag.ToDate" />
                </div>
            </div>
        </div>

        <div class="p-4 border-top bg-light-subtle mt-auto">
            <div class="d-flex gap-2">
                <a href="/SuperAdmin/Schools/SchoolList" class="btn btn-label-secondary w-100 fw-bold">
                    Reset
                </a>
                <button type="submit" class="btn btn-primary w-100 fw-bold shadow-sm">
                    Apply Filters
                </button>
            </div>
        </div>
    </form>
</div>

<div class="d-md-none p-3">
    @if (Model != null && Model.Any())
    {
        foreach (var item in Model)
        {
            <div class="card border shadow-none mb-3" style="border-radius: 12px;">
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="badge bg-label-secondary" style="font-size: 0.6rem;">@item.SchoolCode</span>
                        @if (item.StatusName == "Active")
                        {
                            <span class="text-success fw-bold small">● Active</span>
                        }
                        else
                        {
                            <span class="text-warning fw-bold small">● @item.StatusName</span>
                        }
                    </div>
                    <h6 class="fw-bold mb-1">@item.SchoolName</h6>
                    <p class="text-muted small mb-3">@item.City, @item.State</p>

                    <div class="d-flex justify-content-between align-items-center">
                        <div class="text-muted small">
                            <strong>Board:</strong> @item.BoardName
                        </div>
                        <div class="d-flex gap-2">
                            <a href="/SuperAdmin/Schools/View/@item.SchoolId" class="btn btn-sm btn-label-info p-1 px-2"><i class="bx bx-show"></i></a>
                            <a href="/SuperAdmin/Schools/Edit/@item.SchoolId" class="btn btn-sm btn-label-warning p-1 px-2"><i class="bx bx-edit"></i></a>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>