@using Microsoft.AspNetCore.Mvc.Rendering
@using educore.Models
@model IEnumerable<SchoolListModel>

@{
    ViewData["Title"] = "Schools";
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";

    int page = ViewBag.Page ?? 1;
    int pageSize = ViewBag.PageSize ?? 10;
    int totalPages = ViewBag.TotalPages ?? 1;
    int total = ViewBag.TotalRecords ?? 0;

    // Build a page URL that preserves the current filters.
    Func<int, string> PageUrl = p => Url.Action("SchoolList", new
    {
        search = (string?)ViewBag.Search,
        city = (string?)ViewBag.City,
        state = (string?)ViewBag.State,
        statusId = (int?)ViewBag.StatusId,
        boardId = (int?)ViewBag.BoardId,
        schoolTypeId = (int?)ViewBag.SchoolTypeId,
        fromDate = (string?)ViewBag.FromDate,
        toDate = (string?)ViewBag.ToDate,
        page = p,
        pageSize = pageSize
    })!;

    bool hasFilters = !string.IsNullOrWhiteSpace((string?)ViewBag.Search)
        || !string.IsNullOrWhiteSpace((string?)ViewBag.City)
        || !string.IsNullOrWhiteSpace((string?)ViewBag.State)
        || ViewBag.StatusId != null || ViewBag.BoardId != null || ViewBag.SchoolTypeId != null
        || !string.IsNullOrWhiteSpace((string?)ViewBag.FromDate)
        || !string.IsNullOrWhiteSpace((string?)ViewBag.ToDate);
}

@section PageStyles {
<link href="~/css/educore-theme.css" rel="stylesheet" />
<style>
    .scl-card{ border:1px solid var(--ec-border); border-radius:var(--ec-radius); background:#fff; padding:1.1rem 1.2rem; display:flex; align-items:center; gap:.9rem; height:100%; transition:var(--ec-transition); }
    .scl-card:hover{ transform:translateY(-2px); box-shadow:var(--ec-shadow); border-color:rgba(255,138,0,.22); }
    .scl-card-ic{ width:46px; height:46px; flex:0 0 46px; border-radius:13px; display:flex; align-items:center; justify-content:center; font-size:1.3rem; }
    .scl-card-val{ font-size:1.5rem; font-weight:800; color:var(--ec-text-dark); line-height:1.1; }
    .scl-card-lbl{ font-size:.71rem; font-weight:800; color:var(--ec-text-muted); text-transform:uppercase; letter-spacing:.05em; }

    .scl-srch-wrap{ position:relative; flex:1 1 220px; max-width:340px; }
    .scl-srch-ic{ position:absolute; left:.65rem; top:50%; transform:translateY(-50%); color:var(--ec-text-muted); font-size:1rem; pointer-events:none; }
    .scl-srch-inp{ width:100%; height:36px; padding:0 .75rem 0 2rem; border-radius:8px; border:1px solid var(--ec-border); background:#fafaf8; font-size:.84rem; font-weight:600; color:var(--ec-text); outline:none; transition:var(--ec-transition); }
    .scl-srch-inp:focus{ border-color:rgba(255,138,0,.55); background:#fff; box-shadow:0 0 0 3px rgba(255,138,0,.1); }
    .scl-chip{ height:36px; padding:0 .65rem; border-radius:8px; border:1px solid var(--ec-border); background:#fafaf8; font-size:.8rem; font-weight:700; color:var(--ec-text-muted); cursor:pointer; outline:none; }

    .scl-tbl-wrap{ overflow-x:auto; -webkit-overflow-scrolling:touch; }
    .scl-tbl{ min-width:1000px; width:100%; }
    .scl-tbl thead th{ background:linear-gradient(180deg,#fffaf3,#fff6ea); color:var(--ec-text-light); font-size:.7rem; text-transform:uppercase; letter-spacing:.06em; font-weight:800; padding:.8rem .9rem; border-bottom:1px solid var(--ec-border); white-space:nowrap; }
    .scl-tbl tbody td{ padding:.78rem .9rem; vertical-align:middle; border-bottom:1px solid #f4f0eb; font-size:.84rem; font-weight:600; color:var(--ec-text); }
    .scl-tbl tbody tr:hover td{ background:#fffaf3; }
    .scl-av{ width:38px; height:38px; flex:0 0 38px; border-radius:10px; display:inline-flex; align-items:center; justify-content:center; font-size:.72rem; font-weight:800; }
    .scl-nm{ font-weight:800; color:var(--ec-text-dark); font-size:.87rem; line-height:1.2; }
    .scl-sub{ font-size:.72rem; color:var(--ec-text-muted); }

    .scl-bdg{ display:inline-flex; align-items:center; gap:.28rem; padding:.26rem .65rem; border-radius:999px; font-size:.69rem; font-weight:800; white-space:nowrap; }
    .scl-bdg::before{ content:''; width:5px; height:5px; border-radius:50%; flex-shrink:0; }
    .b-active{ background:#d4edda; color:#155724; } .b-active::before{ background:#28a745; }
    .b-inactive{ background:#e2e3e5; color:#495057; } .b-inactive::before{ background:#6c757d; }

    .scl-act{ width:32px; height:32px; border-radius:7px; border:1px solid var(--ec-border); background:#fff; display:inline-flex; align-items:center; justify-content:center; font-size:1rem; cursor:pointer; transition:var(--ec-transition); text-decoration:none; padding:0; }
    .scl-act.edit{ color:#ff8a00; } .scl-act.edit:hover{ background:var(--ec-primary-light); border-color:rgba(255,138,0,.4); }
    .scl-act.del{ color:#dc3545; } .scl-act.del:hover{ background:#fde8e8; border-color:#dc3545; }

    .scl-pg-wrap{ display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:.65rem; padding-top:1rem; border-top:1px solid var(--ec-border); }
    .scl-pg-info{ font-size:.81rem; color:var(--ec-text-muted); font-weight:650; }
    .scl-pg-btn{ min-width:32px; height:32px; padding:0 .4rem; border-radius:7px; border:1px solid var(--ec-border); background:#fff; color:var(--ec-text); font-size:.8rem; font-weight:700; display:inline-flex; align-items:center; justify-content:center; cursor:pointer; transition:var(--ec-transition); text-decoration:none; }
    .scl-pg-btn:hover{ background:var(--ec-primary-light); border-color:var(--ec-primary); color:var(--ec-primary); }
    .scl-pg-btn.active{ background:var(--ec-primary); border-color:var(--ec-primary); color:#fff; }
    .scl-pg-btn.disabled{ opacity:.35; pointer-events:none; }

    .scl-empty{ padding:3rem 1rem; text-align:center; }
    .scl-empty-ic{ width:64px; height:64px; border-radius:18px; background:var(--ec-primary-light); color:var(--ec-primary); display:inline-flex; align-items:center; justify-content:center; font-size:1.8rem; margin-bottom:.9rem; }
</style>
}

<div class="ec-page-shell">
  <div class="ec-page-content">

    <div class="ec-page-header">
      <div class="ec-page-header-inner">
        <div class="ec-page-title-wrap">
          <div class="ec-page-icon rounded-4 d-flex align-items-center justify-content-center">
            <i class="bx bx-building-house fs-4"></i>
          </div>
          <div>
            <h4 class="ec-page-title mb-1">Schools</h4>
            <div class="ec-page-subtitle">Manage every school across all tenants</div>
          </div>
        </div>
        <a asp-area="SuperAdmin" asp-controller="Schools" asp-action="Create"
           class="btn btn-primary d-flex align-items-center gap-1">
          <i class="bx bx-plus"></i><span>New School</span>
        </a>
      </div>
    </div>

    <div class="row g-3 mb-4">
      <div class="col-6 col-lg-4">
        <div class="scl-card">
          <div class="scl-card-ic bg-label-primary text-primary"><i class="bx bx-buildings"></i></div>
          <div><div class="scl-card-val">@total</div><div class="scl-card-lbl">@(hasFilters ? "Matching Schools" : "Total Schools")</div></div>
        </div>
      </div>
      <div class="col-6 col-lg-4">
        <div class="scl-card">
          <div class="scl-card-ic bg-label-success text-success"><i class="bx bx-check-circle"></i></div>
          <div><div class="scl-card-val">@(ViewBag.ActiveRecords ?? 0)</div><div class="scl-card-lbl">Active</div></div>
        </div>
      </div>
      <div class="col-6 col-lg-4">
        <div class="scl-card">
          <div class="scl-card-ic bg-label-secondary text-secondary"><i class="bx bx-pause-circle"></i></div>
          <div><div class="scl-card-val">@(ViewBag.InactiveRecords ?? 0)</div><div class="scl-card-lbl">Inactive</div></div>
        </div>
      </div>
    </div>

    <div class="ec-card mb-0">
      <div class="ec-card-header">
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-2 mb-3">
          <div class="ec-section-title-wrap">
            <span class="ec-section-icon"><i class="bx bx-list-ul"></i></span>
            <div>
              <div class="ec-section-title">School Directory</div>
              <div class="ec-section-subtitle">
                  @(total == 0 ? "No schools found" : $"Showing {ViewBag.FromRecord}–{ViewBag.ToRecord} of {total} schools")
              </div>
            </div>
          </div>
        </div>

        @* Search + filters all submit as one GET form. *@
        <form method="get" asp-action="SchoolList" class="d-flex align-items-center gap-2 flex-wrap">
          <input type="hidden" name="pageSize" value="@pageSize" />
          @* Preserve active offcanvas filters when searching from the toolbar. *@
          <input type="hidden" name="city" value="@ViewBag.City" />
          <input type="hidden" name="state" value="@ViewBag.State" />
          <input type="hidden" name="statusId" value="@ViewBag.StatusId" />
          <input type="hidden" name="boardId" value="@ViewBag.BoardId" />
          <input type="hidden" name="schoolTypeId" value="@ViewBag.SchoolTypeId" />
          <input type="hidden" name="fromDate" value="@ViewBag.FromDate" />
          <input type="hidden" name="toDate" value="@ViewBag.ToDate" />
          <div class="scl-srch-wrap">
            <i class="bx bx-search scl-srch-ic"></i>
            <input type="search" name="search" value="@ViewBag.Search" class="scl-srch-inp" placeholder="Search school, code, tenant, city…">
          </div>
          <button type="submit" class="btn btn-sm btn-primary"><i class="bx bx-search me-1"></i>Search</button>
          <button type="button" class="btn btn-sm btn-label-secondary position-relative" data-bs-toggle="offcanvas" data-bs-target="#schoolFilterCanvas">
            <i class="bx bx-filter-alt me-1"></i>Filters
            @if (hasFilters)
            {
                <span class="badge rounded-pill bg-primary position-absolute top-0 start-100 translate-middle" style="font-size:.6rem;">●</span>
            }
          </button>
          @if (hasFilters)
          {
              <a asp-action="SchoolList" class="btn btn-sm btn-label-danger"><i class="bx bx-x me-1"></i>Clear</a>
          }
        </form>
      </div>

      <div class="ec-card-body pt-2">
        <div class="scl-tbl-wrap">
          <table class="table scl-tbl align-middle mb-0">
            <thead>
              <tr>
                <th>Tenant</th>
                <th>School</th>
                <th>Code</th>
                <th>Board / Type</th>
                <th>Location</th>
                <th>Primary Contact</th>
                <th>Status</th>
                <th>Created</th>
                <th class="text-end">Actions</th>
              </tr>
            </thead>
            <tbody>
              @if (Model != null && Model.Any())
              {
                  var colors = new[] { "primary", "info", "success", "warning", "danger", "secondary" };
                  foreach (var item in Model)
                  {
                      var c = colors[Math.Abs(item.SchoolId) % colors.Length];
                      var nm = string.IsNullOrWhiteSpace(item.SchoolName) ? "SC" : item.SchoolName.Trim();
                      var initials = (nm.Length >= 2 ? nm.Substring(0, 2) : nm).ToUpper();
                      <tr>
                        <td><div class="scl-nm">@item.TenantName</div></td>
                        <td>
                          <div class="d-flex align-items-center gap-2">
                            <span class="scl-av bg-label-@c text-@c">@initials</span>
                            <div><div class="scl-nm">@item.SchoolName</div><div class="scl-sub">@item.DisplayName</div></div>
                          </div>
                        </td>
                        <td><span class="badge bg-label-secondary text-uppercase">@item.SchoolCode</span></td>
                        <td><div class="fw-semibold small">@item.BoardName</div><div class="scl-sub">@item.SchoolTypeName</div></td>
                        <td><div class="small">@item.City</div><div class="scl-sub">@item.State</div></td>
                        <td><div class="small fw-semibold">@item.ContactName</div><div class="scl-sub"><i class="bx bx-phone-call"></i> @item.Phone</div></td>
                        <td>
                          @if (item.StatusName == "Active")
                          {
                              <span class="scl-bdg b-active">Active</span>
                          }
                          else
                          {
                              <span class="scl-bdg b-inactive">@(item.StatusName ?? "Inactive")</span>
                          }
                        </td>
                        <td><div class="small">@(item.CreatedAt == DateTime.MinValue ? "" : item.CreatedAt.ToString("dd MMM yyyy"))</div></td>
                        <td>
                          <div class="d-flex gap-1 justify-content-end">
                            <a asp-action="Edit" asp-route-id="@item.SchoolId" class="scl-act edit" title="Edit"><i class="bx bx-edit-alt"></i></a>
                            <form asp-action="Delete" asp-route-id="@item.SchoolId" method="post" class="d-inline"
                                  onsubmit="return confirm('Disable this school?');">
                              @Html.AntiForgeryToken()
                              <button type="submit" class="scl-act del" title="Disable"><i class="bx bx-trash"></i></button>
                            </form>
                          </div>
                        </td>
                      </tr>
                  }
              }
            </tbody>
          </table>

          @if (Model == null || !Model.Any())
          {
              <div class="scl-empty">
                <div class="scl-empty-ic"><i class="bx bx-building-house"></i></div>
                <h6 class="fw-bold mb-1" style="color:var(--ec-text-dark);">No schools found</h6>
                <p class="text-muted small mb-0">@(hasFilters ? "Try adjusting or clearing your filters." : "Create your first school to get started.")</p>
              </div>
          }
        </div>

        @if (total > 0)
        {
            <div class="scl-pg-wrap">
              <div class="scl-pg-info">Showing @ViewBag.FromRecord–@ViewBag.ToRecord of @total</div>
              <div class="d-flex gap-1 flex-wrap justify-content-end">
                <a class="scl-pg-btn @(page <= 1 ? "disabled" : "")" href="@PageUrl(page - 1)"><i class="bx bx-chevron-left"></i></a>
                @{
                    int from = Math.Max(1, page - 2);
                    int to = Math.Min(totalPages, from + 4);
                    from = Math.Max(1, to - 4);
                }
                @if (from > 1)
                {
                    <a class="scl-pg-btn" href="@PageUrl(1)">1</a>
                    @if (from > 2) { <span class="scl-pg-info px-1">…</span> }
                }
                @for (int i = from; i <= to; i++)
                {
                    <a class="scl-pg-btn @(i == page ? "active" : "")" href="@PageUrl(i)">@i</a>
                }
                @if (to < totalPages)
                {
                    @if (to < totalPages - 1) { <span class="scl-pg-info px-1">…</span> }
                    <a class="scl-pg-btn" href="@PageUrl(totalPages)">@totalPages</a>
                }
                <a class="scl-pg-btn @(page >= totalPages ? "disabled" : "")" href="@PageUrl(page + 1)"><i class="bx bx-chevron-right"></i></a>
              </div>
            </div>
        }
      </div>
    </div>

  </div>
</div>

@* ── Filter offcanvas (GET form) ───────────────────────────── *@
<div class="offcanvas offcanvas-end border-0 shadow" tabindex="-1" id="schoolFilterCanvas" style="width: 380px;">
  <div class="offcanvas-header border-bottom p-4">
    <div class="d-flex align-items-center gap-3">
      <span class="ec-section-icon"><i class="bx bx-filter-alt"></i></span>
      <div>
        <h5 class="offcanvas-title fw-bold mb-0">Filter Schools</h5>
        <p class="text-muted small mb-0">Narrow down the directory</p>
      </div>
    </div>
    <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
  </div>

  <form method="get" asp-action="SchoolList" class="h-100 d-flex flex-column">
    <input type="hidden" name="search" value="@ViewBag.Search" />
    <input type="hidden" name="pageSize" value="@pageSize" />
    <div class="offcanvas-body p-4">

      <label class="form-label fw-semibold small text-uppercase text-muted">Location</label>
      <div class="row g-2 mb-4">
        <div class="col-6"><input type="text" name="city" class="form-control form-control-sm" placeholder="City" value="@ViewBag.City" /></div>
        <div class="col-6"><input type="text" name="state" class="form-control form-control-sm" placeholder="State" value="@ViewBag.State" /></div>
      </div>

      <label class="form-label fw-semibold small text-uppercase text-muted">Classification</label>
      <div class="d-flex flex-column gap-3 mb-4">
        <select name="statusId" class="form-select form-select-sm" asp-items="ViewBag.Statuses">
          <option value="">All Statuses</option>
        </select>
        <select name="boardId" class="form-select form-select-sm" asp-items="ViewBag.Boards">
          <option value="">All Boards</option>
        </select>
        <select name="schoolTypeId" class="form-select form-select-sm" asp-items="ViewBag.SchoolTypes">
          <option value="">All Types</option>
        </select>
      </div>

      <label class="form-label fw-semibold small text-uppercase text-muted">Created Between</label>
      <div class="input-group input-group-sm">
        <input type="date" name="fromDate" class="form-control" value="@ViewBag.FromDate" />
        <span class="input-group-text">to</span>
        <input type="date" name="toDate" class="form-control" value="@ViewBag.ToDate" />
      </div>
    </div>

    <div class="p-4 border-top mt-auto">
      <div class="d-flex gap-2">
        <a asp-action="SchoolList" class="btn btn-label-secondary w-100 fw-bold">Reset</a>
        <button type="submit" class="btn btn-primary w-100 fw-bold">Apply Filters</button>
      </div>
    </div>
  </form>
</div>
