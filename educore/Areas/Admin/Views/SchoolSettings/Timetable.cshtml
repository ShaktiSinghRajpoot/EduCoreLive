@{
    ViewData["Title"] = "Timetable";
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
}

@section PageStyles {
<link href="~/css/educore-theme.css" rel="stylesheet" />
<style>
/* ===== Timetable (tt-*) ===== */

/* compact inline stats */
.tt-stats{ display:flex; gap:.4rem; flex-wrap:wrap; }
.tt-stat{ display:inline-flex; align-items:center; gap:.3rem; padding:.3rem .65rem; border-radius:999px; background:#faf9f7; border:1px solid var(--ec-border); font-size:.74rem; font-weight:700; color:var(--ec-text-muted); white-space:nowrap; }
.tt-stat b{ color:var(--ec-text-dark); font-weight:800; }
.tt-stat i{ font-style:normal; }
.tt-stat.clash{ background:#fff0f0; border-color:#f5c2c7; color:#b02a37; }
.tt-stat.clash.zero{ background:#faf9f7; border-color:var(--ec-border); color:var(--ec-text-muted); }

/* toolbar */
.tt-fbar{ display:flex; align-items:center; gap:.55rem; flex-wrap:wrap; }
.tt-seg{ display:inline-flex; border:1px solid var(--ec-border); border-radius:9px; overflow:hidden; background:#fafaf8; }
.tt-seg button{ border:0; background:transparent; padding:0 .85rem; height:36px; font-size:.79rem; font-weight:700; color:var(--ec-text-muted); cursor:pointer; transition:var(--ec-transition); display:inline-flex; align-items:center; gap:.35rem; }
.tt-seg button.on{ background:var(--ec-primary); color:#fff; }
.tt-select{ height:36px; min-width:150px; padding:0 .6rem; border-radius:8px; border:1px solid var(--ec-border); background:#fff; font-size:.82rem; font-weight:700; color:var(--ec-text,#2b2c40); outline:none; transition:var(--ec-transition); }
.tt-select:focus{ border-color:rgba(255,138,0,.55); box-shadow:0 0 0 3px rgba(255,138,0,.1); }
.tt-btn{ height:36px; padding:0 .8rem; border-radius:8px; border:1px solid var(--ec-border); background:#fafaf8; font-size:.78rem; font-weight:700; color:var(--ec-text-muted); cursor:pointer; outline:none; display:inline-flex; align-items:center; gap:.35rem; transition:var(--ec-transition); white-space:nowrap; }
.tt-btn:hover{ background:#fff; border-color:rgba(255,138,0,.4); color:var(--ec-text,#2b2c40); }
.tt-hint{ font-size:.73rem; color:var(--ec-text-muted); font-weight:650; }

/* ---- desktop grid ---- */
.tt-wrap{ overflow-x:auto; -webkit-overflow-scrolling:touch; }
.tt-grid{ border-collapse:separate; border-spacing:5px; width:100%; min-width:820px; }
.tt-grid th{ background:linear-gradient(180deg,#fffaf3,#fff6ea); color:var(--ec-text-light,#9a938b); font-size:.69rem; text-transform:uppercase; letter-spacing:.05em; font-weight:800; padding:.45rem .4rem; border-radius:8px; text-align:center; white-space:nowrap; }
.tt-grid th.tt-pcol{ width:90px; text-align:left; padding-left:.6rem; }
.tt-pcell{ background:#faf9f7; border:1px solid var(--ec-border); border-radius:9px; padding:.4rem .55rem; white-space:nowrap; }
.tt-pname{ font-weight:800; color:var(--ec-text-dark); font-size:.8rem; }
.tt-ptime{ font-size:.63rem; color:var(--ec-text-muted); font-weight:650; }

.tt-cell{ border:1px solid var(--ec-border); border-radius:9px; background:#fff; min-height:54px; width:100%; padding:.4rem .45rem; text-align:left; cursor:pointer; transition:var(--ec-transition); display:flex; flex-direction:column; gap:.1rem; justify-content:center; }
.tt-cell:hover{ border-color:rgba(255,138,0,.45); background:#fffaf3; }
.tt-cell.empty{ align-items:center; justify-content:center; color:var(--ec-text-muted); }
.tt-cell.empty i{ font-size:1.05rem; opacity:.55; }
.tt-cell.ro{ cursor:default; }
.tt-cell.ro:hover{ border-color:var(--ec-border); background:#fff; }
.tt-cell.clash{ border-color:#ea5455; background:#fff0f0; box-shadow:0 0 0 1px rgba(234,84,85,.25) inset; }
.tt-subj{ font-weight:800; color:var(--ec-text-dark); font-size:.78rem; line-height:1.15; display:flex; align-items:center; gap:.25rem; }
.tt-subj .dot{ width:7px; height:7px; border-radius:50%; flex:0 0 7px; }
.tt-teacher{ font-size:.69rem; color:var(--ec-text-muted); font-weight:650; line-height:1.1; }
.tt-room{ font-size:.63rem; color:var(--ec-text-light,#9a938b); font-weight:700; }
.tt-clash-ic{ color:#ea5455; font-size:.82rem; }

.tt-break td{ background:repeating-linear-gradient(45deg,#faf7f2,#faf7f2 8px,#f4efe7 8px,#f4efe7 16px); border-radius:8px; text-align:center; font-size:.7rem; font-weight:800; color:var(--ec-text-muted); text-transform:uppercase; letter-spacing:.07em; padding:.32rem; }

/* subject color dots */
.s1{background:#7367f0} .s2{background:#ff8a00} .s3{background:#28c76f} .s4{background:#00cfe8}
.s5{background:#ea5455} .s6{background:#9c27b0} .s7{background:#ff9f43} .s8{background:#1e88e5}

/* ---- mobile day view ---- */
.tt-mob{ display:none; }
.tt-days{ display:flex; gap:.35rem; overflow-x:auto; padding-bottom:.35rem; margin-bottom:.8rem; -webkit-overflow-scrolling:touch; }
.tt-day{ flex:0 0 auto; padding:.4rem .85rem; border-radius:9px; border:1px solid var(--ec-border); background:#fafaf8; font-size:.8rem; font-weight:800; color:var(--ec-text-muted); cursor:pointer; transition:var(--ec-transition); }
.tt-day.on{ background:var(--ec-primary); color:#fff; border-color:var(--ec-primary); }
.tt-mrow{ display:grid; grid-template-columns:72px 1fr; gap:.6rem; align-items:stretch; margin-bottom:.5rem; }
.tt-mp{ background:#faf9f7; border:1px solid var(--ec-border); border-radius:10px; padding:.45rem .55rem; display:flex; flex-direction:column; justify-content:center; }
.tt-mp-name{ font-weight:800; color:var(--ec-text-dark); font-size:.82rem; }
.tt-mp-time{ font-size:.64rem; color:var(--ec-text-muted); font-weight:650; }
.tt-mbreak{ background:repeating-linear-gradient(45deg,#faf7f2,#faf7f2 8px,#f4efe7 8px,#f4efe7 16px); border-radius:9px; text-align:center; font-size:.7rem; font-weight:800; color:var(--ec-text-muted); text-transform:uppercase; letter-spacing:.07em; padding:.5rem; margin-bottom:.5rem; }
.tt-mcell{ border:1px solid var(--ec-border); border-radius:10px; background:#fff; padding:.5rem .6rem; display:flex; flex-direction:column; gap:.12rem; justify-content:center; cursor:pointer; transition:var(--ec-transition); }
.tt-mcell.empty{ align-items:center; justify-content:center; color:var(--ec-text-muted); flex-direction:row; gap:.3rem; font-size:.78rem; font-weight:700; }
.tt-mcell.clash{ border-color:#ea5455; background:#fff0f0; }
.tt-mcell.ro{ cursor:default; }

/* modal */
.tt-mwarn{ display:none; border-radius:10px; padding:.6rem .75rem; background:#fff0f0; border:1px solid #f5c2c7; color:#842029; font-size:.8rem; font-weight:700; align-items:flex-start; gap:.4rem; }
.tt-mwarn.show{ display:flex; }
.tt-modal-lbl{ font-size:.72rem; font-weight:800; text-transform:uppercase; color:var(--ec-text-muted); }

@@media (max-width:767.98px){
    .tt-wrap{ display:none; }
    .tt-mob{ display:block; }
}
</style>
}

<div class="ec-page-shell">
  <div class="ec-page-content">

    <!-- Header -->
    <div class="ec-page-header">
      <div class="ec-page-header-inner">
        <div class="ec-page-title-wrap">
          <div class="ec-page-icon rounded-4 d-flex align-items-center justify-content-center">
            <i class="bx bx-time-five fs-4"></i>
          </div>
          <div>
            <h4 class="ec-page-title mb-1">Timetable</h4>
            <div class="ec-page-subtitle">Build weekly schedules — clashes flagged the moment they happen</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Main -->
    <div class="ec-card mb-0">
      <div class="ec-card-header">
        <!-- title + inline stats on one row -->
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-2 mb-3">
          <div class="ec-section-title-wrap">
            <span class="ec-section-icon"><i class="bx bx-grid-alt"></i></span>
            <div>
              <div class="ec-section-title" id="gridTitle">Weekly Timetable</div>
              <div class="ec-section-subtitle">Periods read from the selected shift’s bell schedule</div>
            </div>
          </div>
          <div class="tt-stats" id="statBar"></div>
        </div>

        <!-- toolbar -->
        <div class="tt-fbar">
          <div class="tt-seg" id="viewSeg">
            <button data-v="class" class="on"><i class="bx bx-group"></i>Class</button>
            <button data-v="teacher"><i class="bx bx-user-voice"></i>Teacher</button>
          </div>
          <select class="tt-select" id="shiftSel" title="Bell schedule from Period Structure"></select>
          <select class="tt-select" id="pickClass"></select>
          <select class="tt-select d-none" id="pickTeacher"></select>
          <button class="tt-btn" id="btnCopy"><i class="bx bx-copy-alt"></i>Copy Mon → Week</button>
          <span class="tt-hint ms-auto" id="modeHint"><i class="bx bx-info-circle"></i> Click a cell to assign</span>
        </div>
      </div>

      <div class="ec-card-body pt-2">
        <!-- desktop -->
        <div class="tt-wrap">
          <table class="tt-grid" id="ttGrid"></table>
        </div>
        <!-- mobile -->
        <div class="tt-mob">
          <div class="tt-days" id="dayTabs"></div>
          <div id="mobList"></div>
        </div>
      </div>
    </div>

  </div>
</div>

<!-- Cell editor modal (class view only) -->
<div class="modal fade" id="cellModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content" style="border:0;border-radius:20px;overflow:hidden;">
      <div class="ec-card-header d-flex align-items-center justify-content-between p-3 p-lg-4">
        <div class="ec-section-title-wrap">
          <span class="ec-section-icon"><i class="bx bx-edit"></i></span>
          <div>
            <div class="ec-section-title">Assign Period</div>
            <div class="ec-section-subtitle" id="cellSlot">—</div>
          </div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="ec-card-body p-3 p-lg-4">
        <div class="row g-3">
          <div class="col-12 col-sm-6">
            <label class="form-label tt-modal-lbl">Subject</label>
            <select class="form-select" id="mSubject"></select>
          </div>
          <div class="col-12 col-sm-6">
            <label class="form-label tt-modal-lbl">Teacher</label>
            <select class="form-select" id="mTeacher"></select>
          </div>
          <div class="col-12">
            <label class="form-label tt-modal-lbl">Room</label>
            <input type="text" class="form-control" id="mRoom" placeholder="e.g. 204">
          </div>
        </div>
        <div class="tt-mwarn mt-3" id="cellWarn"><i class="bx bx-error fs-5"></i><span id="cellWarnTxt"></span></div>
      </div>
      <div class="ec-card-body pt-0 p-3 p-lg-4 d-flex flex-column flex-sm-row justify-content-between gap-2">
        <button type="button" class="btn btn-outline-danger px-3" id="cellClear"><i class="bx bx-trash me-1"></i>Clear</button>
        <div class="d-flex gap-2">
          <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Cancel</button>
          <button type="button" class="btn btn-primary px-4" id="cellSave"><i class="bx bx-check me-1"></i>Save</button>
        </div>
      </div>
    </div>
  </div>
</div>

@section PageScripts {
<script>
(function(){
'use strict';

/* ---- Bell schedules per shift (would come from Period Structure SP) ---- */
var SCHEDULES={
  senior:[
    {id:'p1',name:'P1',time:'08:00–08:40',type:'class'},
    {id:'p2',name:'P2',time:'08:40–09:20',type:'class'},
    {id:'p3',name:'P3',time:'09:20–10:00',type:'class'},
    {id:'b1',name:'Break',time:'10:00–10:15',type:'break'},
    {id:'p4',name:'P4',time:'10:15–10:55',type:'class'},
    {id:'p5',name:'P5',time:'10:55–11:35',type:'class'},
    {id:'l1',name:'Lunch',time:'11:35–12:10',type:'break'},
    {id:'p6',name:'P6',time:'12:10–12:50',type:'class'},
    {id:'p7',name:'P7',time:'12:50–13:30',type:'class'},
    {id:'p8',name:'P8',time:'13:30–14:10',type:'class'}
  ],
  primary:[
    {id:'p1',name:'P1',time:'08:30–09:05',type:'class'},
    {id:'p2',name:'P2',time:'09:05–09:40',type:'class'},
    {id:'b1',name:'Break',time:'09:40–09:55',type:'break'},
    {id:'p3',name:'P3',time:'09:55–10:30',type:'class'},
    {id:'p4',name:'P4',time:'10:30–11:05',type:'class'},
    {id:'l1',name:'Lunch',time:'11:05–11:40',type:'break'},
    {id:'p5',name:'P5',time:'11:40–12:15',type:'class'},
    {id:'p6',name:'P6',time:'12:15–12:50',type:'class'}
  ]
};
var SHIFTS=[{id:'senior',label:'Senior Wing'},{id:'primary',label:'Primary Wing'}];
var DAYS=['Mon','Tue','Wed','Thu','Fri','Sat'];

var SUBJECTS=[
  {id:1,name:'English'},{id:2,name:'Maths'},{id:3,name:'Science'},{id:4,name:'Social Studies'},
  {id:5,name:'Hindi'},{id:6,name:'Computer'},{id:7,name:'Phys. Edu'},{id:8,name:'Art'}
];
var TEACHERS=[
  {id:1,name:'Mrs. Rao'},{id:2,name:'Ms. Dsouza'},{id:3,name:'Mr. Khanna'},{id:4,name:'Mrs. Iyer'},
  {id:5,name:'Mrs. Sharma'},{id:6,name:'Mr. Banerjee'},{id:7,name:'Ms. Fernandes'},{id:8,name:'Mr. Mehta'},
  {id:9,name:'Mrs. Pillai'},{id:10,name:'Dr. Nair'},{id:11,name:'Mr. Gupta'},{id:12,name:'Ms. Verma'}
];
var SECTIONS=[
  {id:'5A',label:'Class 5 – A',room:'201',wing:'senior'},
  {id:'5B',label:'Class 5 – B',room:'202',wing:'senior'},
  {id:'10A',label:'Class 10 – A',room:'301',wing:'senior'},
  {id:'10B',label:'Class 10 – B',room:'302',wing:'senior'},
  {id:'12A',label:'Class 12 – A',room:'402',wing:'senior'}
];

/* TT[sectionId][dayIdx+'_'+periodId] = {subjectId, teacherId, room} */
var TT={};
SECTIONS.forEach(function(s){ TT[s.id]={}; });
TT['10A']['0_p1']={subjectId:2,teacherId:3,room:'301'};
TT['10A']['0_p2']={subjectId:1,teacherId:1,room:'301'};
TT['10A']['1_p1']={subjectId:3,teacherId:10,room:'Lab-1'};
TT['10B']['0_p1']={subjectId:4,teacherId:3,room:'302'};  // clash w/ 10A (Mr. Khanna)
TT['10B']['0_p3']={subjectId:5,teacherId:12,room:'302'};
TT['5A']['0_p1']={subjectId:1,teacherId:5,room:'201'};

var view='class', shift='senior', curSection='10A', curTeacher=1, curDay=0, ctx=null;
function PERIODS(){ return SCHEDULES[shift]; }

function esc(s){ return String(s).replace(/[&<>"]/g,function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c];}); }
function toast(t,m){ if(typeof toastr!=='undefined') toastr[t](m); }
function subj(id){ return SUBJECTS.find(function(x){return x.id===id;}); }
function teacherName(id){ var t=TEACHERS.find(function(x){return x.id===id;}); return t?t.name:''; }
function sectionLabel(id){ var s=SECTIONS.find(function(x){return x.id===id;}); return s?s.label:''; }

function clashSection(sectionId,dayIdx,periodId,teacherId){
  if(!teacherId) return null;
  for(var i=0;i<SECTIONS.length;i++){
    var sid=SECTIONS[i].id; if(sid===sectionId) continue;
    var e=TT[sid][dayIdx+'_'+periodId];
    if(e && e.teacherId===teacherId) return SECTIONS[i];
  }
  return null;
}

/* selectors */
(function(){
  var sh=document.getElementById('shiftSel');
  SHIFTS.forEach(function(s){ var o=document.createElement('option'); o.value=s.id; o.textContent=s.label; sh.appendChild(o); });
  var pc=document.getElementById('pickClass');
  SECTIONS.forEach(function(s){ var o=document.createElement('option'); o.value=s.id; o.textContent=s.label; pc.appendChild(o); });
  pc.value=curSection;
  var pt=document.getElementById('pickTeacher');
  TEACHERS.forEach(function(t){ var o=document.createElement('option'); o.value=t.id; o.textContent=t.name; pt.appendChild(o); });
  pt.value=curTeacher;
  var ms=document.getElementById('mSubject'); ms.innerHTML='<option value="0">— Select —</option>';
  SUBJECTS.forEach(function(s){ var o=document.createElement('option'); o.value=s.id; o.textContent=s.name; ms.appendChild(o); });
  var mt=document.getElementById('mTeacher'); mt.innerHTML='<option value="0">— Select —</option>';
  TEACHERS.forEach(function(t){ var o=document.createElement('option'); o.value=t.id; o.textContent=t.name; mt.appendChild(o); });
  var dt=document.getElementById('dayTabs');
  DAYS.forEach(function(d,i){ var b=document.createElement('button'); b.className='tt-day'+(i===0?' on':''); b.textContent=d; b.dataset.d=i; dt.appendChild(b); });
})();

/* stats */
function renderStats(){
  var classPeriods=PERIODS().filter(function(p){return p.type==='class';}).length * DAYS.length;
  var bar=document.getElementById('statBar');
  if(view==='class'){
    var filled=0, clashes=0;
    PERIODS().filter(function(p){return p.type==='class';}).forEach(function(p){
      DAYS.forEach(function(d,di){ var e=TT[curSection][di+'_'+p.id]; if(e){ filled++; if(clashSection(curSection,di,p.id,e.teacherId)) clashes++; } });
    });
    bar.innerHTML='<span class="tt-stat"><b>'+filled+'</b><i>/ '+classPeriods+' set</i></span>'
      +'<span class="tt-stat"><b>'+(classPeriods-filled)+'</b><i>free</i></span>'
      +'<span class="tt-stat clash'+(clashes?'':' zero')+'"><i class="bx bx-error-circle"></i><b>'+clashes+'</b><i>clash'+(clashes===1?'':'es')+'</i></span>';
  } else {
    var taught=0, secSet={};
    PERIODS().filter(function(p){return p.type==='class';}).forEach(function(p){
      DAYS.forEach(function(d,di){ SECTIONS.forEach(function(sec){ var e=TT[sec.id][di+'_'+p.id]; if(e && e.teacherId===curTeacher){ taught++; secSet[sec.id]=1; } }); });
    });
    bar.innerHTML='<span class="tt-stat"><b>'+taught+'</b><i>periods/wk</i></span>'
      +'<span class="tt-stat"><b>'+(classPeriods-taught)+'</b><i>free</i></span>'
      +'<span class="tt-stat"><b>'+Object.keys(secSet).length+'</b><i>classes</i></span>';
  }
}

/* desktop grid */
function renderGrid(){
  var g=document.getElementById('ttGrid');
  var head='<thead><tr><th class="tt-pcol">Period</th>'+DAYS.map(function(d){return '<th>'+d+'</th>';}).join('')+'</tr></thead>';
  var body='<tbody>';
  PERIODS().forEach(function(p){
    if(p.type==='break'){
      body+='<tr class="tt-break"><td class="tt-pcell"><div class="tt-pname">'+p.name+'</div><div class="tt-ptime">'+p.time+'</div></td><td colspan="'+DAYS.length+'">'+p.name+' · '+p.time+'</td></tr>';
      return;
    }
    body+='<tr><td><div class="tt-pcell"><div class="tt-pname">'+p.name+'</div><div class="tt-ptime">'+p.time+'</div></div></td>';
    DAYS.forEach(function(d,di){ body+='<td>'+cellHtml(di,p.id,false)+'</td>'; });
    body+='</tr>';
  });
  g.innerHTML=head+body+'</tbody>';
}

/* mobile day list */
function renderMob(){
  var box=document.getElementById('mobList');
  document.querySelectorAll('.tt-day').forEach(function(b){ b.classList.toggle('on', parseInt(b.dataset.d,10)===curDay); });
  box.innerHTML=PERIODS().map(function(p){
    if(p.type==='break') return '<div class="tt-mbreak">'+p.name+' · '+p.time+'</div>';
    return '<div class="tt-mrow"><div class="tt-mp"><div class="tt-mp-name">'+p.name+'</div><div class="tt-mp-time">'+p.time+'</div></div>'+cellHtml(curDay,p.id,true)+'</div>';
  }).join('');
}

function cellHtml(dayIdx,periodId,mob){
  var base=mob?'tt-mcell':'tt-cell';
  if(view==='class'){
    var e=TT[curSection][dayIdx+'_'+periodId];
    if(!e){ return '<'+(mob?'div':'button')+' class="'+base+' empty js-cell" data-d="'+dayIdx+'" data-p="'+periodId+'"><i class="bx bx-plus"></i>'+(mob?'Add':'')+'</'+(mob?'div':'button')+'>'; }
    var c=clashSection(curSection,dayIdx,periodId,e.teacherId), s=subj(e.subjectId);
    return '<'+(mob?'div':'button')+' class="'+base+' js-cell'+(c?' clash':'')+'" data-d="'+dayIdx+'" data-p="'+periodId+'">'
      +'<div class="tt-subj"><span class="dot s'+e.subjectId+'"></span>'+esc(s?s.name:'')+(c?' <i class="bx bx-error tt-clash-ic" title="Clash with '+esc(c.label)+'"></i>':'')+'</div>'
      +'<div class="tt-teacher">'+esc(teacherName(e.teacherId))+'</div>'
      +'<div class="tt-room">Room '+esc(e.room||'—')+'</div></'+(mob?'div':'button')+'>';
  } else {
    for(var i=0;i<SECTIONS.length;i++){
      var sid=SECTIONS[i].id, e2=TT[sid][dayIdx+'_'+periodId];
      if(e2 && e2.teacherId===curTeacher){
        var s2=subj(e2.subjectId);
        return '<div class="'+base+' ro"><div class="tt-subj"><span class="dot s'+e2.subjectId+'"></span>'+esc(s2?s2.name:'')+'</div>'
          +'<div class="tt-teacher">'+esc(SECTIONS[i].label)+'</div><div class="tt-room">Room '+esc(e2.room||'—')+'</div></div>';
      }
    }
    return '<div class="'+base+' ro empty"><span style="font-size:.7rem;font-weight:700;">Free</span></div>';
  }
}

function render(){
  renderGrid(); renderMob(); renderStats(); bindCells();
  document.getElementById('gridTitle').textContent = view==='class' ? sectionLabel(curSection)+' — Timetable' : teacherName(curTeacher)+' — Schedule';
  document.getElementById('btnCopy').style.display = view==='class' ? '' : 'none';
}

function bindCells(){
  if(view!=='class') return;
  document.querySelectorAll('.js-cell').forEach(function(b){
    b.addEventListener('click',function(){ openCell(parseInt(this.dataset.d,10), this.dataset.p); });
  });
}

/* cell editor */
function openCell(dayIdx,periodId){
  ctx={dayIdx:dayIdx,periodId:periodId};
  var e=TT[curSection][dayIdx+'_'+periodId]||{subjectId:0,teacherId:0,room:''};
  var pname=PERIODS().find(function(p){return p.id===periodId;}).name;
  document.getElementById('cellSlot').textContent=sectionLabel(curSection)+' · '+DAYS[dayIdx]+' · '+pname;
  document.getElementById('mSubject').value=e.subjectId||0;
  document.getElementById('mTeacher').value=e.teacherId||0;
  document.getElementById('mRoom').value=e.room || (SECTIONS.find(function(s){return s.id===curSection;}).room) || '';
  checkModalClash();
  new bootstrap.Modal(document.getElementById('cellModal')).show();
}
function checkModalClash(){
  if(!ctx) return;
  var tid=parseInt(document.getElementById('mTeacher').value,10);
  var c=clashSection(curSection,ctx.dayIdx,ctx.periodId,tid), w=document.getElementById('cellWarn');
  if(c){ document.getElementById('cellWarnTxt').textContent=teacherName(tid)+' is already teaching '+c.label+' at this slot.'; w.classList.add('show'); }
  else w.classList.remove('show');
}
document.getElementById('mTeacher').addEventListener('change',checkModalClash);
document.getElementById('cellSave').addEventListener('click',function(){
  var sid=parseInt(document.getElementById('mSubject').value,10), tid=parseInt(document.getElementById('mTeacher').value,10);
  if(!sid){ toast('error','Pick a subject.'); return; }
  TT[curSection][ctx.dayIdx+'_'+ctx.periodId]={subjectId:sid,teacherId:tid,room:document.getElementById('mRoom').value.trim()};
  // Wire to SP: save timetable cell (sectionId, day, periodId, subjectId, teacherId, room)
  bootstrap.Modal.getInstance(document.getElementById('cellModal')).hide();
  render(); toast('success','Period updated.');
});
document.getElementById('cellClear').addEventListener('click',function(){
  delete TT[curSection][ctx.dayIdx+'_'+ctx.periodId];
  bootstrap.Modal.getInstance(document.getElementById('cellModal')).hide();
  render(); toast('info','Period cleared.');
});

/* copy Monday → whole week */
document.getElementById('btnCopy').addEventListener('click',function(){
  var classP=PERIODS().filter(function(p){return p.type==='class';});
  var monCount=classP.filter(function(p){return TT[curSection]['0_'+p.id];}).length;
  if(!monCount){ toast('error','Monday is empty — fill it first, then copy.'); return; }
  if(!confirm('Copy Monday’s '+monCount+' period(s) to Tue–Sat for '+sectionLabel(curSection)+'? This overwrites those days.')) return;
  for(var di=1; di<DAYS.length; di++){
    classP.forEach(function(p){
      var src=TT[curSection]['0_'+p.id];
      if(src) TT[curSection][di+'_'+p.id]={subjectId:src.subjectId,teacherId:src.teacherId,room:src.room};
      else delete TT[curSection][di+'_'+p.id];
    });
  }
  // Wire to SP: bulk-save copied week
  render(); toast('success','Monday copied across the week. Review flagged clashes & tweak.');
});

/* toolbar */
document.querySelectorAll('#viewSeg button').forEach(function(b){
  b.addEventListener('click',function(){
    view=this.dataset.v;
    document.querySelectorAll('#viewSeg button').forEach(function(x){ x.classList.toggle('on',x===b); });
    document.getElementById('pickClass').classList.toggle('d-none',view!=='class');
    document.getElementById('pickTeacher').classList.toggle('d-none',view!=='teacher');
    document.getElementById('modeHint').innerHTML = view==='class'
      ? '<i class="bx bx-info-circle"></i> Click a cell to assign'
      : '<i class="bx bx-lock-alt"></i> Read-only — from class timetables';
    render();
  });
});
document.getElementById('shiftSel').addEventListener('change',function(){ shift=this.value; render(); });
document.getElementById('pickClass').addEventListener('change',function(){ curSection=this.value; render(); });
document.getElementById('pickTeacher').addEventListener('change',function(){ curTeacher=parseInt(this.value,10); render(); });
document.getElementById('dayTabs').addEventListener('click',function(e){ var b=e.target.closest('.tt-day'); if(!b) return; curDay=parseInt(b.dataset.d,10); renderMob(); });

render();

})();
</script>
}
