@{
    ViewData["Title"] = "Subject Management";
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
    var classes = ViewBag.Classes as List<string> ?? new List<string>();
}

@section PageStyles {
<link href="~/css/educore-theme.css" rel="stylesheet" />
<style>
.sm-page{
    font-family:'Public Sans',system-ui,-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;
    color:var(--ec-text);
}

/* ── Left class panel ───────────────────────── */
.sm-class-panel{
    border:1px solid var(--ec-border);
    border-radius:var(--ec-radius);
    background:#fff;
    overflow:hidden;
    position:sticky; top:80px; 
}
.sm-panel-hdr{
    padding:.85rem 1.1rem;
    border-bottom:1px solid var(--ec-border);
    background:linear-gradient(135deg,var(--ec-primary-soft) 0%,#fff 70%);
    display:flex; align-items:center; justify-content:space-between; gap:.5rem;
}
.sm-panel-title{
    font-size:.82rem; font-weight:900; color:var(--ec-text-dark);
    text-transform:uppercase; letter-spacing:.04em;
}
.sm-panel-count{
    font-size:.72rem; font-weight:800; color:var(--ec-text-muted);
    background:#f5f4f2; border:1px solid var(--ec-border);
    border-radius:999px; padding:.18rem .55rem;
}
.sm-class-list{ max-height:calc(100vh - 220px); overflow-y:auto; }
.sm-class-list::-webkit-scrollbar{ width:4px; }
.sm-class-list::-webkit-scrollbar-thumb{ background:rgba(255,138,0,.2); border-radius:999px; }

.sm-class-item{
    display:flex; align-items:center; gap:.75rem;
    padding:.78rem 1.1rem; cursor:pointer;
    border-bottom:1px solid #f5f0ea;
    transition:var(--ec-transition);
}
.sm-class-item:last-child{ border-bottom:0; }
.sm-class-item:hover{ background:var(--ec-primary-light); }
.sm-class-item.active{
    background:var(--ec-primary-light);
    border-left:3px solid var(--ec-primary);
}
.sm-class-ic{
    width:36px; height:36px; flex:0 0 36px;
    border-radius:10px;
    background:var(--ec-primary-light); color:var(--ec-primary);
    display:flex; align-items:center; justify-content:center;
    font-size:1rem; transition:var(--ec-transition);
}
.sm-class-item.active .sm-class-ic{
    background:var(--ec-primary); color:#fff;
}
.sm-class-name{
    font-size:.86rem; font-weight:800; color:var(--ec-text-dark);
    flex:1 1 auto; min-width:0;
}
.sm-class-meta{
    font-size:.72rem; font-weight:650; color:var(--ec-text-muted); margin-top:.08rem;
}
.sm-count-badge{
    flex:0 0 auto;
    display:inline-flex; align-items:center; justify-content:center;
    min-width:24px; height:24px; border-radius:999px;
    font-size:.7rem; font-weight:900; padding:0 .4rem;
}
.sm-badge-ok   { background:#d1f0e0; color:#0a5a35; }
.sm-badge-warn { background:#fff3cd; color:#856404; }
.sm-badge-zero { background:#fde8e8; color:#842029; }

/* ── Right subject area ─────────────────────── */
.sm-right{ height:100%; }

.sm-empty-state{
    border:1px dashed var(--ec-border);
    border-radius:var(--ec-radius);
    background:linear-gradient(135deg,#fff,var(--ec-primary-soft));
    padding:4rem 2rem; text-align:center;
    display:flex; flex-direction:column; align-items:center;
}
.sm-empty-ic{
    width:72px; height:72px; border-radius:20px;
    background:var(--ec-primary-light); color:var(--ec-primary);
    display:flex; align-items:center; justify-content:center;
    font-size:2rem; margin-bottom:1rem;
}
.sm-empty-title{ font-size:1.05rem; font-weight:900; color:var(--ec-text-dark); margin-bottom:.4rem; }
.sm-empty-sub{ font-size:.84rem; font-weight:650; color:var(--ec-text-muted); max-width:320px; }

.sm-subj-area{
    border:1px solid var(--ec-border);
    border-radius:var(--ec-radius);
    background:#fff; overflow:hidden;
}

/* Area header */
.sm-area-hdr{
    padding:1.1rem 1.25rem;
    border-bottom:1px solid var(--ec-border);
    background:linear-gradient(135deg,var(--ec-primary-soft) 0%,#fff 65%);
    display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:.5rem;
}
.sm-area-title{ font-size:1.05rem; font-weight:900; color:var(--ec-text-dark); }
.sm-area-meta{
    font-size:.78rem; font-weight:700; color:var(--ec-text-muted);
    display:flex; align-items:center; gap:.4rem;
}
.sm-subj-counter{
    display:inline-flex; align-items:center; justify-content:center;
    min-width:26px; height:26px; border-radius:999px; padding:0 .45rem;
    background:var(--ec-primary-light); color:var(--ec-primary);
    font-size:.75rem; font-weight:900;
}

.sm-area-body{ padding:1.25rem; }

/* Suggestions */
.sm-suggest-section{ margin-bottom:1.25rem; }
.sm-suggest-lbl{
    font-size:.68rem; font-weight:900; text-transform:uppercase; letter-spacing:.05em;
    color:var(--ec-text-muted); display:flex; align-items:center; gap:.3rem;
    margin-bottom:.55rem;
}
.sm-suggest-chips{ display:flex; flex-wrap:wrap; gap:.4rem; }
.sm-suggest-chip{
    height:30px; padding:0 .8rem; border-radius:999px;
    border:1.5px dashed rgba(255,138,0,.35); background:#fff;
    color:var(--ec-primary); font-size:.77rem; font-weight:800;
    cursor:pointer; transition:var(--ec-transition);
    display:inline-flex; align-items:center; gap:.3rem;
}
.sm-suggest-chip:hover{
    background:var(--ec-primary-light);
    border-color:var(--ec-primary); border-style:solid;
}
.sm-suggest-chip.chip-added{
    background:#f5f5f5; border-color:#ddd; border-style:solid;
    color:#aaa; cursor:not-allowed; pointer-events:none;
}
.sm-suggest-chip.chip-added i{ color:#28a745; }

/* Add input row */
.sm-add-row{
    display:grid; grid-template-columns:1fr auto; gap:.55rem;
    margin-bottom:1.25rem;
}
.sm-add-input{
    border:1.5px solid var(--ec-border); border-radius:12px;
    min-height:44px; padding:0 1rem;
    font-size:.88rem; font-weight:700; color:var(--ec-text);
    outline:none; transition:border-color .2s, box-shadow .2s;
}
.sm-add-input:focus{
    border-color:var(--ec-primary);
    box-shadow:0 0 0 3px rgba(255,138,0,.12);
}
.sm-add-input::placeholder{ color:var(--ec-text-muted); }
.sm-add-btn{
    height:44px; padding:0 1.25rem; border-radius:12px; border:0;
    background:linear-gradient(135deg,#ff8a00,#ff9f2f);
    color:#fff; font-size:.86rem; font-weight:800;
    cursor:pointer; display:inline-flex; align-items:center; gap:.4rem;
    transition:var(--ec-transition); white-space:nowrap;
    box-shadow:0 4px 14px rgba(255,138,0,.22);
}
.sm-add-btn:hover{ transform:translateY(-1px); box-shadow:0 8px 20px rgba(255,138,0,.3); }

/* Subject pills grid */
.sm-pill-section{ margin-bottom:1.25rem; }
.sm-pill-lbl{
    font-size:.68rem; font-weight:900; text-transform:uppercase; letter-spacing:.05em;
    color:var(--ec-text-muted); margin-bottom:.6rem; display:flex; align-items:center; gap:.3rem;
}
.sm-pill-wrap{ display:flex; flex-wrap:wrap; gap:.55rem; min-height:40px; }
.sm-pill{
    display:inline-flex; align-items:center; gap:.45rem;
    padding:.4rem .55rem .4rem .85rem; border-radius:999px;
    background:#e8f4fd; border:1px solid rgba(13,110,253,.18);
    color:#084298; font-weight:800; font-size:.84rem;
    transition:var(--ec-transition);
}
.sm-pill:hover{ border-color:rgba(13,110,253,.4); box-shadow:0 2px 8px rgba(13,110,253,.1); }
.sm-pill-remove{
    width:1.4rem; height:1.4rem; border-radius:50%; padding:0;
    background:rgba(13,110,253,.12); color:#0d6efd; border:0;
    display:inline-flex; align-items:center; justify-content:center;
    cursor:pointer; transition:var(--ec-transition); font-size:.85rem;
}
.sm-pill-remove:hover{ background:#0d6efd; color:#fff; }

/* No subjects note */
.sm-no-subj{
    border:1px dashed var(--ec-border); border-radius:12px;
    padding:1.25rem; text-align:center;
    color:var(--ec-text-muted); font-size:.84rem; font-weight:700;
    background:#fafaf8;
    display:flex; align-items:center; justify-content:center; gap:.5rem;
}

/* Save bar */
.sm-save-bar{
    border-top:1px solid var(--ec-border);
    padding:1rem 1.25rem;
    background:#fafaf8;
    display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:.75rem;
}
.sm-save-hint{
    font-size:.78rem; font-weight:650; color:var(--ec-text-muted);
    display:flex; align-items:center; gap:.35rem;
}
.sm-save-btn{
    height:42px; padding:0 1.5rem; border-radius:999px; border:0;
    background:linear-gradient(135deg,#ff8a00,#ff9f2f); color:#fff;
    font-size:.86rem; font-weight:800; cursor:pointer;
    display:inline-flex; align-items:center; gap:.4rem;
    box-shadow:0 4px 14px rgba(255,138,0,.22);
    transition:var(--ec-transition);
}
.sm-save-btn:hover{ transform:translateY(-1px); box-shadow:0 8px 22px rgba(255,138,0,.3); }
.sm-cancel-btn{
    height:42px; padding:0 1.25rem; border-radius:999px;
    border:1px solid var(--ec-border); background:#fff;
    color:var(--ec-text); font-size:.86rem; font-weight:800;
    cursor:pointer; transition:var(--ec-transition);
}
.sm-cancel-btn:hover{ background:var(--ec-primary-light); border-color:rgba(255,138,0,.3); }

/* Toast */
.sm-toast{
    position:fixed; top:1.25rem; right:1.25rem; z-index:9999;
    background:#fff; border:1px solid #d1e7dd; border-left:4px solid #28a745;
    border-radius:14px; padding:.85rem 1.2rem;
    box-shadow:0 8px 28px rgba(0,0,0,.1);
    display:flex; align-items:center; gap:.75rem;
    font-size:.86rem; font-weight:700; color:#0a5a35;
    transform:translateX(110%);
    transition:transform .35s cubic-bezier(.34,1.56,.64,1);
    max-width:320px;
}
.sm-toast.show{ transform:translateX(0); }

@@media (max-width:991.98px){
    .sm-class-panel{ position:static; margin-bottom:1.25rem; }
    .sm-class-list{ max-height:220px; }
}
@@media (max-width:575.98px){
    .sm-add-row{ grid-template-columns:1fr; }
    .sm-save-bar{ flex-direction:column; align-items:stretch; }
    .sm-save-btn, .sm-cancel-btn{ width:100%; justify-content:center; }
}
</style>
}

<div class="ec-page-shell sm-page">
  <div class="ec-page-content">

    <!-- ── Page header ───────────────────────── -->
    <div class="ec-page-header">
        <div class="ec-page-header-inner">
            <div class="ec-page-title-wrap">
                <div class="ec-page-icon rounded-4 d-flex align-items-center justify-content-center">
                    <i class="bx bx-book-alt fs-4"></i>
                </div>
                <div>
                    <h4 class="ec-page-title mb-1">Subject Management</h4>
                    <div class="ec-page-subtitle">Configure subjects for each class — used in exams, timetable and mark entry</div>
                </div>
            </div>
            <a asp-area="Admin" asp-controller="SchoolSettings" asp-action="ClassSection"
               class="btn btn-outline-secondary d-flex align-items-center gap-1">
                <i class="bx bx-cog"></i><span class="d-none d-sm-inline">Classes &amp; Sections</span>
            </a>
        </div>
    </div>

    <div class="row g-4">

        <!-- ── Left: Class list ──────────────── -->
        <div class="col-12 col-lg-4 col-xl-3">
            <div class="sm-class-panel">
                <div class="sm-panel-hdr">
                    <span class="sm-panel-title"><i class="bx bx-layer me-1"></i>Classes</span>
                    <span class="sm-panel-count">@classes.Count classes</span>
                </div>
                <div class="sm-class-list" id="classList">
                    @foreach (var cls in classes)
                    {
                        <div class="sm-class-item" data-class="@cls">
                            <div class="sm-class-ic"><i class="bx bx-book-open"></i></div>
                            <div class="flex-grow-1 min-width-0">
                                <div class="sm-class-name">@cls</div>
                                <div class="sm-class-meta"><span class="cls-subj-count">0</span> subjects</div>
                            </div>
                            <span class="sm-count-badge sm-badge-zero cls-badge">0</span>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- ── Right: Subject area ───────────── -->
        <div class="col-12 col-lg-8 col-xl-9 sm-right">

            <!-- Empty state -->
            <div class="sm-empty-state" id="smEmptyState">
                <div class="sm-empty-ic"><i class="bx bx-book-alt"></i></div>
                <div class="sm-empty-title">Select a class to manage subjects</div>
                <div class="sm-empty-sub">Click any class on the left to view and configure its subjects.</div>
            </div>

            <!-- Subject work area (hidden until class selected) -->
            <div class="sm-subj-area" id="smSubjArea" style="display:none;">

                <!-- Header -->
                <div class="sm-area-hdr">
                    <div>
                        <div class="sm-area-title" id="smAreaTitle">—</div>
                        <div class="sm-area-meta">
                            <i class="bx bx-book-content" style="color:var(--ec-primary);"></i>
                            <span id="smSubjCountLabel">0 subjects configured</span>
                        </div>
                    </div>
                    <span class="sm-subj-counter" id="smSubjCounter">0</span>
                </div>

                <div class="sm-area-body">

                    <!-- Smart suggestions -->
                    <div class="sm-suggest-section">
                        <div class="sm-suggest-lbl">
                            <i class="bx bx-bulb" style="color:#f59e0b;"></i> Quick add suggestions
                        </div>
                        <div class="sm-suggest-chips" id="smSuggestChips"></div>
                    </div>

                    <!-- Add input -->
                    <div class="sm-add-row">
                        <input type="text" class="sm-add-input" id="smSubjInput"
                               placeholder="Type a custom subject name and press Enter…" maxlength="80">
                        <button class="sm-add-btn" id="smAddBtn">
                            <i class="bx bx-plus"></i> Add Subject
                        </button>
                    </div>

                    <!-- Subjects list -->
                    <div class="sm-pill-section">
                        <div class="sm-pill-lbl">
                            <i class="bx bx-check-circle" style="color:#16a34a;"></i>
                            Configured Subjects
                        </div>
                        <div class="sm-pill-wrap" id="smPillWrap"></div>
                        <div class="sm-no-subj" id="smNoSubj">
                            <i class="bx bx-info-circle"></i>
                            No subjects added yet — use suggestions above or type a custom name.
                        </div>
                    </div>

                </div>

                <!-- Save bar -->
                <div class="sm-save-bar">
                    <div class="sm-save-hint">
                        <i class="bx bx-info-circle" style="color:var(--ec-primary);"></i>
                        Changes apply to exam creation, mark entry and timetable for this class.
                    </div>
                    <div class="d-flex gap-2">
                        <button class="sm-cancel-btn" id="smCancelBtn">Discard</button>
                        <button class="sm-save-btn" id="smSaveBtn">
                            <i class="bx bx-save"></i> Save Subjects
                        </button>
                    </div>
                </div>

            </div>
        </div>

    </div>


  </div>
</div>

<!-- Toast -->
<div class="sm-toast" id="smToast">
    <i class="bx bx-check-circle" style="font-size:1.3rem;color:#28a745;flex-shrink:0;"></i>
    <span id="smToastMsg">Subjects saved.</span>
</div>

@section PageScripts {
<script>
$(document).ready(function () {

    // ── Smart suggestions by class name ──────────────────────────────────────
    function getSuggestions(className) {
        const n = className.toLowerCase();
        if (/nur|kg|lkg|ukg|nursery|kindergarten|play/i.test(n))
            return ['English','Hindi','Maths','Drawing','Rhymes','EVS','General Knowledge'];
        if (/^(class\s*)?(1st?|2nd?|1|2)$/i.test(n))
            return ['English','Hindi','Mathematics','EVS','General Knowledge','Drawing','Computer'];
        if (/^(class\s*)?(3rd?|4th?|5th?|3|4|5)$/i.test(n))
            return ['English','Hindi','Mathematics','Science','Social Science','General Knowledge','Computer'];
        if (/^(class\s*)?(6th?|7th?|8th?|6|7|8)$/i.test(n))
            return ['English','Hindi','Mathematics','Science','Social Science','Sanskrit','Computer'];
        if (/^(class\s*)?(9th?|10th?|9|10)$/i.test(n))
            return ['English','Hindi','Mathematics','Science','Social Science','Sanskrit','IT \/ Computer'];
        if (/science/i.test(n))
            return ['English','Physics','Chemistry','Biology','Mathematics','Computer Science','Physical Education'];
        if (/commerce/i.test(n))
            return ['English','Accountancy','Business Studies','Economics','Mathematics','Informatics Practices'];
        if (/arts?|humanities/i.test(n))
            return ['English','History','Geography','Political Science','Economics','Psychology','Physical Education'];
        return ['English','Hindi','Mathematics','Science','Social Science','Sanskrit','Computer','Physical Education'];
    }

    // ── State ─────────────────────────────────────────────────────────────────
    // subjectData: { 'Class 9': ['Mathematics','English', ...], ... }
    // Pre-populate from localStorage so data survives page navigation
    const LS_KEY     = 'educore_subjects';
    const subjectData = JSON.parse(localStorage.getItem(LS_KEY) || '{}');
    let activeClass   = null;
    let originalSnap  = [];   // snapshot of subjects when class was loaded

    // ── Helpers ──────────────────────────────────────────────────────────────
    function showToast(msg, type) {
        const t     = document.getElementById('smToast');
        const color = type === 'error' ? '#dc3545' : '#28a745';
        t.style.borderLeftColor = color;
        t.querySelector('i').style.color = color;
        $('#smToastMsg').text(msg);
        $(t).addClass('show');
        setTimeout(() => $(t).removeClass('show'), 3200);
    }

    function getSubjects(cls) {
        return subjectData[cls] || [];
    }

    function setSubjects(cls, arr) {
        subjectData[cls] = arr;
        updateClassBadge(cls);
    }

    // ── Update left panel badge ───────────────────────────────────────────────
    function updateClassBadge(cls) {
        const count = getSubjects(cls).length;
        const $item = $('#classList .sm-class-item[data-class="' + CSS.escape(cls) + '"]');
        const $badge = $item.find('.cls-badge');
        const $meta  = $item.find('.cls-subj-count');

        $meta.text(count);
        $badge.text(count);
        $badge.removeClass('sm-badge-ok sm-badge-warn sm-badge-zero');
        if (count >= 4)     $badge.addClass('sm-badge-ok');
        else if (count > 0) $badge.addClass('sm-badge-warn');
        else                $badge.addClass('sm-badge-zero');
    }

    // ── Render subject pills ──────────────────────────────────────────────────
    function renderPills() {
        if (!activeClass) return;
        const subjects = getSubjects(activeClass);
        const $wrap    = $('#smPillWrap');
        $wrap.empty();

        subjects.forEach(function(s) {
            $wrap.append(buildPill(s));
        });

        const count = subjects.length;
        $('#smNoSubj').toggleClass('d-none', count > 0);
        $('#smSubjCounter').text(count);
        $('#smSubjCountLabel').text(count + ' subject' + (count !== 1 ? 's' : '') + ' configured');
        updateSuggestionState();
    }

    function buildPill(subject) {
        const safe = $('<div>').text(subject).html();
        return $(`
            <span class="sm-pill" data-subject="${safe}">
                <span>${safe}</span>
                <button type="button" class="sm-pill-remove" title="Remove">
                    <i class="bx bx-x"></i>
                </button>
            </span>
        `);
    }

    // ── Render suggestions ────────────────────────────────────────────────────
    function renderSuggestions(cls) {
        const suggestions = getSuggestions(cls);
        const $wrap = $('#smSuggestChips');
        $wrap.empty();
        suggestions.forEach(function(s) {
            const $chip = $(`<button type="button" class="sm-suggest-chip" data-subj="${s}">
                <i class="bx bx-plus" style="font-size:.8rem;"></i>${s}
            </button>`);
            $wrap.append($chip);
        });
        updateSuggestionState();
    }

    function updateSuggestionState() {
        if (!activeClass) return;
        const added = getSubjects(activeClass).map(s => s.toLowerCase());
        $('#smSuggestChips .sm-suggest-chip').each(function() {
            const s = $(this).data('subj').toLowerCase();
            if (added.includes(s)) {
                $(this).addClass('chip-added');
                $(this).html(`<i class="bx bx-check" style="font-size:.8rem;color:#28a745;"></i>${$(this).data('subj')}`);
            } else {
                $(this).removeClass('chip-added');
                $(this).html(`<i class="bx bx-plus" style="font-size:.8rem;"></i>${$(this).data('subj')}`);
            }
        });
    }

    // ── Load a class into the work area ──────────────────────────────────────
    function loadClass(cls) {
        activeClass  = cls;
        originalSnap = [...getSubjects(cls)];

        // Highlight left panel
        $('#classList .sm-class-item').removeClass('active');
        $(`#classList .sm-class-item[data-class="${CSS.escape(cls)}"]`).addClass('active');

        // Show work area
        $('#smEmptyState').hide();
        $('#smSubjArea').show();

        // Set title
        $('#smAreaTitle').text(cls);

        // Render
        renderSuggestions(cls);
        renderPills();

        // Focus input
        $('#smSubjInput').val('').focus();
    }

    // ── Class item click ──────────────────────────────────────────────────────
    $(document).on('click', '.sm-class-item', function() {
        const cls = $(this).data('class');
        if (cls === activeClass) return;
        loadClass(cls);
    });

    // ── Add via suggestion chip ───────────────────────────────────────────────
    $(document).on('click', '.sm-suggest-chip:not(.chip-added)', function() {
        const s = $(this).data('subj');
        addSubject(s);
    });

    // ── Add via button ────────────────────────────────────────────────────────
    $('#smAddBtn').on('click', function() {
        const val = $.trim($('#smSubjInput').val());
        if (!val) { showToast('Please enter a subject name.', 'error'); return; }
        addSubject(val);
        $('#smSubjInput').val('').focus();
    });

    // ── Add via Enter key ─────────────────────────────────────────────────────
    $('#smSubjInput').on('keypress', function(e) {
        if (e.which === 13) { e.preventDefault(); $('#smAddBtn').click(); }
    });

    function addSubject(s) {
        if (!activeClass) return;
        const subjects = getSubjects(activeClass);
        if (subjects.map(x => x.toLowerCase()).includes(s.toLowerCase())) {
            showToast(s + ' is already added.', 'error');
            return;
        }
        subjects.push(s);
        setSubjects(activeClass, subjects);
        renderPills();
    }

    // ── Remove pill ───────────────────────────────────────────────────────────
    $(document).on('click', '.sm-pill-remove', function() {
        const s = $(this).closest('.sm-pill').data('subject');
        if (!activeClass) return;
        const subjects = getSubjects(activeClass).filter(x => x !== s);
        setSubjects(activeClass, subjects);
        renderPills();
    });

    // ── Discard changes ───────────────────────────────────────────────────────
    $('#smCancelBtn').on('click', function() {
        if (!activeClass) return;
        setSubjects(activeClass, [...originalSnap]);
        renderPills();
        showToast('Changes discarded.', 'error');
    });

    // ── Save — persists to localStorage so CreateExam can read it ────────────
    $('#smSaveBtn').on('click', function() {
        if (!activeClass) return;
        originalSnap = [...getSubjects(activeClass)];
        localStorage.setItem(LS_KEY, JSON.stringify(subjectData));
        showToast('Subjects saved · CreateExam will use these subjects.', 'success');
        updateAllBadges();
    });

    function updateAllBadges() {
        $('#classList .sm-class-item').each(function() {
            updateClassBadge($(this).data('class'));
        });
    }

    // ── Init — restore badges from localStorage ───────────────────────────────
    $('#classList .sm-class-item').each(function() {
        updateClassBadge($(this).data('class'));
    });

    // Show a connected indicator if data already exists in localStorage
    const stored = JSON.parse(localStorage.getItem(LS_KEY) || '{}');
    const configuredCount = Object.keys(stored).filter(k => stored[k].length > 0).length;
    if (configuredCount > 0) {
        showToast(configuredCount + ' classes already configured · connected to Create Exam.', 'success');
    }

});
</script>
}
