@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model EduCoreDataAccessLayer.Models.Admin.EnquiryCrmPageModel
@{
    ViewData["Title"] = "Enquiry CRM";
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
    var stats        = Model.Stats;
    var sessions     = Model.AvailableSessions;
    var classes      = Model.AvailableClasses;
    var counsellors  = Model.AvailableCounsellors;
    var showRegistration = Model.Workflow.EnableRegistration;
}

@section PageStyles {
<style>
    /* ── Top progress loader ── */
    #crmTopLoader {
        position: fixed; top: 0; left: 0; width: 0%; height: 3px;
        background: var(--ec-primary); z-index: 99999;
        opacity: 1; pointer-events: none; border-radius: 0 2px 2px 0;
    }

    /* ── KPI Cards ── */
    .crm-kpi-card {
        background: var(--ec-white); border: 1px solid var(--ec-border);
        border-radius: 12px; padding: .9rem 1.1rem;
        transition: box-shadow .18s; height: 100%;
    }
    .crm-kpi-card:hover { box-shadow: 0 4px 18px rgba(0,0,0,.07); }
    .crm-kpi-card .kpi-icon {
        width: 42px; height: 42px; border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.2rem; flex-shrink: 0;
    }
    .crm-kpi-card .kpi-value  { font-size: 1.5rem; font-weight: 700; line-height: 1; }
    .crm-kpi-card .kpi-label  { font-size: .7rem; font-weight: 600; text-transform: uppercase; letter-spacing: .05em; color: var(--ec-text-muted); }
    .crm-kpi-card .kpi-sub    { font-size: .72rem; color: var(--ec-text-muted); margin-top: .15rem; }

    /* ── Pipeline Tabs ── */
    .crm-pipeline { display: flex; gap: .4rem; overflow-x: auto; padding-bottom: .2rem; }
    .crm-pipeline::-webkit-scrollbar { height: 3px; }
    .crm-pipeline::-webkit-scrollbar-thumb { background: var(--ec-border); border-radius: 3px; }
    .pipeline-tab {
        display: inline-flex; flex-direction: column; align-items: center;
        padding: .38rem .8rem; border-radius: 9px;
        border: 1.5px solid var(--ec-border); background: var(--ec-white);
        cursor: pointer; white-space: nowrap; transition: all .14s;
        text-decoration: none; min-width: 74px; user-select: none;
    }
    .pipeline-tab:hover, .pipeline-tab.active {
        border-color: var(--ec-primary); background: var(--ec-primary-light);
    }
    .pipeline-tab .ptab-count { font-size: 1rem; font-weight: 700; color: var(--ec-text-dark); line-height: 1.15; }
    .pipeline-tab .ptab-label { font-size: .65rem; font-weight: 600; letter-spacing: .04em; text-transform: uppercase; color: var(--ec-text-muted); margin-top: .1rem; }
    .pipeline-tab.active .ptab-count, .pipeline-tab.active .ptab-label { color: var(--ec-primary); }

    /* ── Table helpers ── */
    .lead-name { font-weight: 700; color: var(--ec-text-dark); font-size: .87rem; }
    .lead-meta { font-size: .76rem; color: var(--ec-text-muted); }
    .student-avatar {
        width: 34px; height: 34px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-weight: 700; font-size: .74rem; flex-shrink: 0;
    }
    .fee-pill {
        display: inline-flex; align-items: center;
        border: 1.5px solid var(--ec-border); border-radius: 999px;
        padding: .22rem .6rem; font-weight: 700; font-size: .76rem;
        background: var(--ec-primary-light); color: var(--ec-primary);
    }
    .source-pill {
        display: inline-flex; align-items: center; gap: .2rem;
        font-size: .71rem; font-weight: 600; padding: .16rem .44rem;
        border-radius: 6px; background: rgba(0,0,0,.04); color: var(--ec-text-muted);
    }
    .crm-action-btn { width: 31px; height: 31px; padding: 0; border-radius: 7px; }
    .lead-row { cursor: pointer; }
    .lead-row:hover { background-color: #fafbff !important; }
    .overdue-row td:first-child { border-left: 3px solid #ef4444; }
    .followup-overdue  { color: #ef4444; font-weight: 700; font-size: .78rem; }
    .followup-today    { color: #f59e0b; font-weight: 700; font-size: .78rem; }
    .followup-upcoming { color: var(--ec-text-dark); font-size: .8rem; font-weight: 600; }
    .followup-done     { color: #22c55e; font-size: .8rem; font-weight: 600; }
    .followup-count-badge {
        display: inline-flex; align-items: center; gap: .2rem;
        font-size: .7rem; color: var(--ec-text-muted);
        background: rgba(0,0,0,.04); border-radius: 4px; padding: .1rem .35rem;
    }

    /* ── Status dropdown ── */
    .status-badge-toggle { cursor: pointer; user-select: none; }
    .status-badge-toggle:hover { opacity: .85; }
    .dropdown-item.status-opt { display: flex; align-items: center; gap: .4rem; }
    .dropdown-item.status-opt.active { background: var(--ec-primary-light) !important; color: var(--ec-primary) !important; }
    .dropdown-item.status-opt.disabled-opt { opacity: .45; pointer-events: none; }
    .status-opt .check-icon { margin-left: auto; color: var(--ec-primary); font-size: .85rem; }

    /* ── Quick filter pills ── */
    .qf-btn {
        display: inline-flex; align-items: center; gap: .28rem;
        padding: .28rem .7rem; border-radius: 999px;
        border: 1.5px solid var(--ec-border); background: var(--ec-white);
        font-size: .77rem; font-weight: 600; color: var(--ec-text-muted);
        cursor: pointer; transition: all .14s; white-space: nowrap;
    }
    .qf-btn:hover { border-color: var(--ec-primary); color: var(--ec-primary); background: var(--ec-primary-light); }
    .qf-btn.active-warning { border-color: #f59e0b; color: #92400e; background: #fffbeb; }
    .qf-btn.active-danger  { border-color: #ef4444; color: #991b1b; background: #fef2f2; }

    /* ── Pagination ── */
    .crm-pg-bar {
        display: flex; align-items: center; justify-content: space-between;
        flex-wrap: wrap; gap: .5rem; padding: .6rem 1rem;
        border-top: 1px solid var(--ec-border);
    }
    .crm-pg-bar .pagination { margin-bottom: 0; }

    /* ── Mobile card view ── */
    .crm-card { background: var(--ec-white); border: 1px solid var(--ec-border); border-radius: 11px; padding: .9rem; margin-bottom: .6rem; }
    .crm-card.overdue-card { border-left: 3px solid #ef4444; }

    /* ── Follow-up timeline ── */
    .followup-timeline { list-style: none; padding: 0; margin: 0; }
    .followup-timeline li {
        position: relative; padding: 0 0 1.2rem 2rem;
        border-left: 2px solid var(--ec-border);
    }
    .followup-timeline li:last-child { border-left: 2px solid transparent; padding-bottom: 0; }
    .followup-timeline li::before {
        content: ''; position: absolute; left: -6px; top: 4px;
        width: 10px; height: 10px; border-radius: 50%;
        background: var(--ec-primary); border: 2px solid var(--ec-white);
        box-shadow: 0 0 0 2px var(--ec-primary);
    }
    .tl-time  { font-size: .72rem; color: var(--ec-text-muted); margin-bottom: .25rem; }
    .tl-title { font-weight: 700; font-size: .84rem; color: var(--ec-text-dark); }
    .tl-note  { font-size: .79rem; color: var(--ec-text-muted); margin-top: .15rem; }

    /* ── Modal scroll fix (form breaks flex chain) ── */
    #addEnquiryModal .modal-content,
    #addEnquiryModal .modal-content > form,
    #logFollowupModal .modal-content {
        max-height: calc(100dvh - 3.5rem);
        display: flex; flex-direction: column;
        overflow: hidden; flex: 1 1 auto; min-height: 0;
    }
    #addEnquiryModal .modal-header,  #addEnquiryModal .modal-footer,
    #logFollowupModal .modal-header, #logFollowupModal .modal-footer { flex-shrink: 0; }
    #addEnquiryModal .modal-body,
    #logFollowupModal .modal-body {
        flex: 1 1 auto; min-height: 0;
        overflow-y: auto; overflow-x: hidden;
        overscroll-behavior-y: contain;
        -webkit-overflow-scrolling: touch;
    }
    @@media (max-width: 575.98px) {
        #addEnquiryModal .modal-content,
        #addEnquiryModal .modal-content > form,
        #logFollowupModal .modal-content { max-height: calc(100dvh - 1rem); }
        #addEnquiryModal .modal-dialog,
        #logFollowupModal .modal-dialog  { margin: .5rem; }
    }

    /* ── Responsive ── */
    @@media (max-width: 767.98px) {
        .crm-table-wrap { display: none !important; }
        .crm-card-list  { display: block; }
        .crm-pg-bar     { justify-content: center; }
    }
    @@media (min-width: 768px) {
        .crm-card-list  { display: none !important; }
        .crm-table-wrap { display: block; }
    }
</style>
}

<div id="crmTopLoader"></div>
@* Standalone CSRF token for all AJAX POST calls on this page *@
@Html.AntiForgeryToken()

<div class="ec-page-shell enquiry-crm-page">
    <div class="ec-page-content">

    <!-- ── Page Header ─── -->
    <div class="ec-page-header">
        <div class="ec-page-header-inner d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
            <div class="ec-page-title-wrap d-flex align-items-start gap-3">
                <div class="ec-page-icon"><i class="bx bx-message-square-detail"></i></div>
                <div>
                    <h3 class="ec-page-title mb-1">Enquiry CRM</h3>
                    <p class="ec-page-subtitle mb-0">Track admission enquiries, follow-ups &amp; conversion pipeline.</p>
                </div>
            </div>
            <div class="d-flex gap-2 flex-shrink-0">
                <button type="button" class="btn btn-outline-secondary">
                    <i class="bx bx-export me-1"></i> Export
                </button>
                <button type="button" class="btn btn-primary" id="btnAddEnquiry"
                        data-bs-toggle="modal" data-bs-target="#addEnquiryModal">
                    <i class="bx bx-user-plus me-1"></i> Add Enquiry
                </button>
            </div>
        </div>
    </div>

    <!-- ── KPI Cards ─── -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-sm-4 col-xl-2">
            <div class="crm-kpi-card d-flex align-items-center gap-3">
                <div class="kpi-icon bg-label-primary"><i class="bx bx-group text-primary"></i></div>
                <div><div class="kpi-value text-primary">@stats.TotalLeads</div><div class="kpi-label">Total Leads</div><div class="kpi-sub">This session</div></div>
            </div>
        </div>
        <div class="col-6 col-sm-4 col-xl-2">
            <div class="crm-kpi-card d-flex align-items-center gap-3">
                <div class="kpi-icon bg-label-warning"><i class="bx bx-time text-warning"></i></div>
                <div><div class="kpi-value text-warning">@stats.DueToday</div><div class="kpi-label">Due Today</div><div class="kpi-sub">Follow-ups</div></div>
            </div>
        </div>
        <div class="col-6 col-sm-4 col-xl-2">
            <div class="crm-kpi-card d-flex align-items-center gap-3">
                <div class="kpi-icon bg-label-danger"><i class="bx bx-error-circle text-danger"></i></div>
                <div><div class="kpi-value text-danger">@stats.OverdueCount</div><div class="kpi-label">Overdue</div><div class="kpi-sub">Need attention</div></div>
            </div>
        </div>
        <div class="col-6 col-sm-4 col-xl-2">
            <div class="crm-kpi-card d-flex align-items-center gap-3">
                <div class="kpi-icon bg-label-info"><i class="bx bx-building text-info"></i></div>
                <div><div class="kpi-value text-info">@stats.CampusVisits</div><div class="kpi-label">Campus Visits</div><div class="kpi-sub">Scheduled</div></div>
            </div>
        </div>
        <div class="col-6 col-sm-4 col-xl-2">
            <div class="crm-kpi-card d-flex align-items-center gap-3">
                <div class="kpi-icon bg-label-success"><i class="bx bx-check-circle text-success"></i></div>
                <div><div class="kpi-value text-success">@stats.Admitted</div><div class="kpi-label">Admitted</div><div class="kpi-sub">This session</div></div>
            </div>
        </div>
        <div class="col-6 col-sm-4 col-xl-2">
            <div class="crm-kpi-card d-flex align-items-center gap-3">
                <div class="kpi-icon bg-label-secondary"><i class="bx bx-trending-up"></i></div>
                <div><div class="kpi-value">@stats.ConversionRate%</div><div class="kpi-label">Conversion</div><div class="kpi-sub">Rate</div></div>
            </div>
        </div>
    </div>

    <!-- ── Pipeline Tabs ─── -->
    <div class="ec-card mb-3">
        <div class="ec-card-header">
            <div class="d-flex justify-content-between align-items-center gap-3">
                <div class="ec-section-title-wrap">
                    <span class="ec-section-icon"><i class="bx bx-git-branch"></i></span>
                    <div><h5 class="ec-section-title mb-1">Admission Pipeline</h5><p class="ec-section-subtitle mb-0">Click a stage to filter.</p></div>
                </div>
            </div>
        </div>
        <div class="ec-card-body py-3">
            <div class="crm-pipeline" id="pipelineTabs">
                <a class="pipeline-tab active" data-pipeline=""              href="#"><span class="ptab-count">@stats.TotalLeads</span><span class="ptab-label">All</span></a>
                <a class="pipeline-tab"        data-pipeline="new"           href="#"><span class="ptab-count">@stats.CntNew</span><span class="ptab-label">New</span></a>
                <a class="pipeline-tab"        data-pipeline="followup"      href="#"><span class="ptab-count">@stats.CntFollowup</span><span class="ptab-label">Follow-up</span></a>
                <a class="pipeline-tab"        data-pipeline="interested"    href="#"><span class="ptab-count">@stats.CntInterested</span><span class="ptab-label">Interested</span></a>
                <a class="pipeline-tab"        data-pipeline="campusvisit"   href="#"><span class="ptab-count">@stats.CntCampusVisit</span><span class="ptab-label">Campus Visit</span></a>
                @if (showRegistration)
                {
                <a class="pipeline-tab"        data-pipeline="registered"    href="#"><span class="ptab-count">@stats.CntRegistered</span><span class="ptab-label">Registered</span></a>
                }
                <a class="pipeline-tab"        data-pipeline="admitted"      href="#"><span class="ptab-count">@stats.Admitted</span><span class="ptab-label">Admitted</span></a>
                <a class="pipeline-tab"        data-pipeline="notinterested" href="#"><span class="ptab-count text-danger">@stats.CntNotInterested</span><span class="ptab-label">Not Interested</span></a>
            </div>
        </div>
    </div>

    <!-- ── Filters ─── -->
    <div class="ec-card mb-3">
        <div class="ec-card-header">
            <div class="d-flex justify-content-between align-items-center gap-3">
                <div class="ec-section-title-wrap">
                    <span class="ec-section-icon"><i class="bx bx-filter-alt"></i></span>
                    <div><h5 class="ec-section-title mb-0">Search &amp; Filter</h5></div>
                </div>
            </div>
        </div>
        <div class="ec-card-body">
            <div class="row g-2 align-items-end">
                <div class="col-12 col-lg-4">
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-end-0 pe-1">
                            <i class="bx bx-search text-muted"></i>
                        </span>
                        <input type="search" class="form-control border-start-0 ps-0"
                               id="leadSearch" placeholder="Search student, parent or mobile..." />
                    </div>
                </div>
                <div class="col-6 col-sm-3 col-lg-2">
                    <select class="form-select" id="sessionFilter">
                        <option value="">All Sessions</option>
                        @foreach (var s in sessions){<option value="@s.Text">@s.Text</option>}
                    </select>
                </div>
                <div class="col-6 col-sm-3 col-lg-2">
                    <select class="form-select" id="classFilter">
                        <option value="">All Classes</option>
                        @foreach (var c in classes){<option value="@c.Text">@c.Text</option>}
                    </select>
                </div>
                <div class="col-6 col-sm-3 col-lg-2">
                    <select class="form-select" id="sourceFilter">
                        <option value="">All Sources</option>
                        <option value="Walk-in">Walk-in</option>
                        <option value="QR Code">QR Code</option>
                        <option value="Referral">Referral</option>
                        <option value="Website">Website</option>
                        <option value="Phone Call">Phone Call</option>
                        <option value="Social Media">Social Media</option>
                    </select>
                </div>
                @if (counsellors.Any())
                {
                    <div class="col-6 col-sm-3 col-lg-2">
                        <select class="form-select" id="counsellorFilter">
                            <option value="">All Counsellors</option>
                            @foreach (var c in counsellors){<option value="@c.Value">@c.Text</option>}
                        </select>
                    </div>
                }
            </div>
            <div class="d-flex flex-wrap align-items-center gap-2 mt-3 pt-3 border-top">
                <span class="text-muted" style="font-size:.76rem">Quick:</span>
                <button type="button" class="qf-btn" id="btnTodayFollowups">
                    <i class="bx bx-time"></i> Today's Follow-ups
                </button>
                <button type="button" class="qf-btn" id="btnOverdue">
                    <i class="bx bx-error-circle"></i> Overdue Only
                </button>
                <button type="button" class="qf-btn ms-auto" id="btnClear">
                    <i class="bx bx-x"></i> Clear All
                </button>
            </div>
        </div>
    </div>

    <!-- ── Desktop Table ─── -->
    <div class="ec-card crm-table-wrap">
        <div class="ec-card-header">
            <div class="d-flex justify-content-between align-items-center gap-3">
                <div class="ec-section-title-wrap">
                    <span class="ec-section-icon"><i class="bx bx-list-ul"></i></span>
                    <div>
                        <h5 class="ec-section-title mb-1">Enquiries</h5>
                        <p class="ec-section-subtitle mb-0" id="tableSubtitle">Loading...</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table ec-table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th style="min-width:185px">Student</th>
                        <th style="min-width:165px">Parent &amp; Contact</th>
                        <th style="min-width:110px">Class / Session</th>
                        <th style="min-width:100px">Source</th>
                        <th style="min-width:130px">Status</th>
                        <th style="min-width:130px">Next Follow-up</th>
                        <th style="min-width:80px">Age</th>
                        <th class="text-end" style="min-width:185px">Actions</th>
                    </tr>
                </thead>
                <tbody id="leadTableBody">
                    <tr id="loadingRow">
                        <td colspan="8" class="text-center py-5 text-muted">
                            <div class="spinner-border spinner-border-sm text-primary me-2" role="status"></div>
                            Loading enquiries...
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="text-center py-5 d-none" id="leadEmptyState">
            <div class="avatar avatar-lg mx-auto mb-3">
                <span class="avatar-initial rounded bg-label-secondary"><i class="bx bx-search"></i></span>
            </div>
            <h6 class="mb-1">No enquiries match your filters</h6>
            <p class="text-muted mb-0">Try adjusting search, filters, or pipeline stage.</p>
        </div>

        <div class="crm-pg-bar" id="pgBar">
            <div class="d-flex align-items-center gap-2 flex-wrap">
                <label class="text-muted" style="font-size:.77rem">Per page:</label>
                <select class="form-select form-select-sm" id="pageSizeSelect" style="width:auto">
                    <option value="10" selected>10</option>
                    <option value="25">25</option>
                    <option value="50">50</option>
                </select>
                <span class="text-muted" id="pgInfo" style="font-size:.77rem"></span>
            </div>
            <nav><ul class="pagination pagination-sm mb-0" id="pgControls"></ul></nav>
        </div>
    </div>

    <!-- ── Mobile Card List ─── -->
    <div class="crm-card-list" id="mobileCardList">
        <div class="text-center py-5 text-muted" id="mobileLoader">
            <div class="spinner-border spinner-border-sm text-primary me-2" role="status"></div>
            Loading...
        </div>
    </div>
    <div class="ec-card d-md-none mt-2" id="mobilePgCard" style="display:none!important">
        <div class="crm-pg-bar">
            <div class="d-flex align-items-center gap-2">
                <label class="text-muted" style="font-size:.77rem">Per page:</label>
                <select class="form-select form-select-sm" id="mobilePgSize" style="width:auto">
                    <option value="10" selected>10</option>
                    <option value="25">25</option>
                    <option value="50">50</option>
                </select>
            </div>
            <nav><ul class="pagination pagination-sm mb-0" id="mobilePgControls"></ul></nav>
        </div>
    </div>

    </div><!-- ec-page-content -->
</div><!-- ec-page-shell -->

<!-- ════════════════════════════════════════════════════════
     ADD ENQUIRY MODAL
═════════════════════════════════════════════════════════ -->
<div class="modal fade" id="addEnquiryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <form asp-action="SaveEnquiry" asp-controller="Enquiry" asp-area="Admin" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="EnquiryId" id="enquiryFormId" value="0" />

                <div class="modal-header">
                    <div class="d-flex justify-content-between align-items-center w-100 me-3">
                        <div class="ec-section-title-wrap">
                            <div class="ec-section-icon"><i class="bx bx-user-plus"></i></div>
                            <div><h5 class="modal-title mb-0" id="enquiryModalTitle">Add Enquiry</h5><small class="text-muted" id="enquiryModalSubtitle">Capture student &amp; parent details.</small></div>
                        </div>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">

                    <!-- Student -->
                    <div class="ec-section-title-wrap mb-3">
                        <div class="ec-section-icon"><i class="bx bx-child"></i></div>
                        <div><h6 class="mb-0">Student Information</h6></div>
                    </div>
                    <div class="row g-3 mb-4">
                        <div class="col-12 col-md-6">
                            <label class="form-label">Student Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" name="StudentName" placeholder="e.g. Anmol Kumar" required />
                        </div>
                        <div class="col-6 col-md-3">
                            <label class="form-label">Gender</label>
                            <select class="form-select" name="Gender">
                                <option value="" disabled selected>Select</option>
                                <option>Male</option><option>Female</option><option>Other</option>
                            </select>
                        </div>
                        <div class="col-6 col-md-3">
                            <label class="form-label">Date of Birth</label>
                            <input type="date" class="form-control" name="Dob" />
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">Class Interested In <span class="text-danger">*</span></label>
                            <select class="form-select" name="ClassName" id="addClassName" required>
                                <option value="" disabled selected>Select class</option>
                                @foreach (var c in classes){<option value="@c.Text">@c.Text</option>}
                            </select>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">Academic Session <span class="text-danger">*</span></label>
                            <select class="form-select" name="Session" required>
                                <option value="" disabled>Select session</option>
                                @foreach (var s in sessions){<option value="@s.Text" selected="@s.Selected">@s.Text</option>}
                            </select>
                        </div>
                        <!-- Current school + class -->
                        <div class="col-12 col-md-6">
                            <label class="form-label">Current School</label>
                            <input type="text" class="form-control" name="CurrentSchool"
                                   placeholder="e.g. Delhi Public School" />
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">Currently Studying in Class</label>
                            <select class="form-select" name="CurrentClass">
                                <option value="" selected>Select current class</option>
                                <option>Nursery</option><option>LKG</option><option>UKG</option>
                                <option>1st</option><option>2nd</option><option>3rd</option>
                                <option>4th</option><option>5th</option><option>6th</option>
                                <option>7th</option><option>8th</option><option>9th</option>
                                <option>10th</option><option>11th</option><option>12th</option>
                                <option>Not Currently Enrolled</option>
                            </select>
                        </div>
                        <!-- Interested Stream — shown only for classes 11 and 12 -->
                        <div class="col-12 col-md-6 d-none" id="streamRow">
                            <label class="form-label">Interested Stream</label>
                            <select class="form-select" name="InterestedStream">
                                <option value="" selected>Select stream</option>
                                <option>Science (PCM)</option>
                                <option>Science (PCB)</option>
                                <option>Commerce</option>
                                <option>Arts / Humanities</option>
                                <option>Vocational</option>
                            </select>
                        </div>
                    </div>

                    <hr class="mb-4">

                    <!-- Parent / Guardian -->
                    <div class="ec-section-title-wrap mb-3">
                        <div class="ec-section-icon"><i class="bx bx-user"></i></div>
                        <div><h6 class="mb-0">Parent / Guardian</h6></div>
                    </div>
                    <div class="row g-3 mb-4">
                        <div class="col-12 col-md-6">
                            <label class="form-label">Father's Name</label>
                            <input type="text" class="form-control" name="FatherName" placeholder="e.g. Rajaram Sharma" />
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">Father's Mobile <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text">+91</span>
                                <input type="tel" class="form-control" name="FatherMobile" id="addFatherMobile"
                                       placeholder="9876543210" />
                            </div>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">Mother's Name</label>
                            <input type="text" class="form-control" name="MotherName" placeholder="e.g. Sunita Sharma" />
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">Mother's Mobile</label>
                            <div class="input-group">
                                <span class="input-group-text">+91</span>
                                <input type="tel" class="form-control" name="MotherMobile" placeholder="Optional" />
                            </div>
                        </div>
                        <!-- Hidden primary mobile — auto-filled from father mobile -->
                        <input type="hidden" name="Mobile" id="addPrimaryMobile" value="" />
                        <div class="col-12 col-md-6">
                            <label class="form-label">Parent Email</label>
                            <input type="email" class="form-control" name="ParentEmail" id="addParentEmail"
                                   placeholder="e.g. rajaram@gmail.com" />
                            <small class="text-muted">For sending brochure &amp; fee structure.</small>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">WhatsApp Number</label>
                            <div class="input-group">
                                <span class="input-group-text">+91</span>
                                <input type="tel" class="form-control" name="WhatsAppNumber" id="addWhatsApp"
                                       placeholder="Same as father's mobile" />
                            </div>
                            <div class="form-check mt-1">
                                <input class="form-check-input" type="checkbox"
                                       id="whatsappSameAsMobile" checked />
                                <label class="form-check-label text-muted" for="whatsappSameAsMobile"
                                       style="font-size:.78rem">
                                    Same as father's mobile
                                </label>
                            </div>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">City</label>
                            <input type="text" class="form-control" name="City" placeholder="e.g. Jaipur" />
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">Area / Locality</label>
                            <input type="text" class="form-control" name="AreaLocality" placeholder="e.g. Malviya Nagar" />
                        </div>
                    </div>

                    <hr class="mb-4">

                    <!-- Enquiry Details -->
                    <div class="ec-section-title-wrap mb-3">
                        <div class="ec-section-icon"><i class="bx bx-detail"></i></div>
                        <div><h6 class="mb-0">Enquiry Details</h6></div>
                    </div>
                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <label class="form-label">Lead Source <span class="text-danger">*</span></label>
                            <select class="form-select" name="LeadSource" id="addLeadSource">
                                <option selected>Walk-in</option>
                                <option>QR Code</option>
                                <option>Referral</option>
                                <option>Website</option>
                                <option>Phone Call</option>
                                <option>Social Media</option>
                            </select>
                        </div>
                        <div class="col-12 col-md-6" id="initialStatusRow">
                            <label class="form-label">Initial Status</label>
                            <select class="form-select" name="Status" id="addInitialStatus">
                                <option selected>New</option>
                                <option>Follow-up Pending</option>
                                <option>Interested</option>
                            </select>
                        </div>
                        <!-- Referrer fields — shown only when Source = Referral -->
                        <div class="col-12 col-md-6 d-none" id="referrerNameRow">
                            <label class="form-label">Referred By (Name)</label>
                            <input type="text" class="form-control" name="ReferrerName" placeholder="Who referred this family?" />
                        </div>
                        <div class="col-12 col-md-6 d-none" id="referrerMobileRow">
                            <label class="form-label">Referrer Mobile</label>
                            <div class="input-group">
                                <span class="input-group-text">+91</span>
                                <input type="tel" class="form-control" name="ReferrerMobile" placeholder="Optional" />
                            </div>
                        </div>
                        @if (counsellors.Any())
                        {
                            <div class="col-12 col-md-6">
                                <label class="form-label">Assign Counsellor</label>
                                <select class="form-select" name="AssignedToId">
                                    <option value="">Unassigned</option>
                                    @foreach (var c in counsellors){<option value="@c.Value">@c.Text</option>}
                                </select>
                            </div>
                        }
                        <div class="col-12 col-md-6">
                            <label class="form-label">Next Follow-up Date</label>
                            <input type="date" class="form-control" name="NextFollowupDate" />
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label d-block">School Transport Required?</label>
                            <div class="d-flex gap-3 mt-1">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio"
                                           name="TransportRequired" id="transportNo" value="false" checked />
                                    <label class="form-check-label" for="transportNo">No</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio"
                                           name="TransportRequired" id="transportYes" value="true" />
                                    <label class="form-check-label" for="transportYes">Yes — needs school bus</label>
                                </div>
                            </div>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Initial Notes</label>
                            <textarea class="form-control" name="Notes" rows="3"
                                      placeholder="Discussion notes, parent concerns, requirements..."></textarea>
                        </div>
                    </div>

                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary" id="saveEnquiryBtn">
                        <i class="bx bx-save me-1"></i> Save Enquiry
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- ════════════════════════════════════════════════════════
     LOG FOLLOW-UP MODAL
═════════════════════════════════════════════════════════ -->
<div class="modal fade" id="logFollowupModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <div class="ec-section-title-wrap">
                    <div class="ec-section-icon"><i class="bx bx-phone-call"></i></div>
                    <div><h5 class="modal-title mb-0">Log Follow-up</h5><small class="text-muted" id="followupStudentName"></small></div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="followupEnquiryId" value="" />

                <div class="row g-3">
                    <div class="col-6">
                        <label class="form-label">Contact Type <span class="text-danger">*</span></label>
                        <select class="form-select" id="followupType">
                            <option value="Call" selected>📞 Phone Call</option>
                            <option value="WhatsApp">💬 WhatsApp</option>
                            <option value="In-Person">🤝 In-Person Visit</option>
                            <option value="Email">✉️ Email</option>
                            <option value="Visit">🏫 Campus Visit</option>
                        </select>
                    </div>
                    <div class="col-6">
                        <label class="form-label">Outcome <span class="text-danger">*</span></label>
                        <select class="form-select" id="followupOutcome">
                            <option value="" disabled selected>Select outcome</option>
                            <option value="Interested">✅ Interested</option>
                            <option value="Call Back Later">🔁 Call Back Later</option>
                            <option value="No Answer">📵 No Answer</option>
                            <option value="Busy">⏳ Busy / Will Call Back</option>
                            <option value="Left Message">💬 Left Message</option>
                            <option value="Not Interested">❌ Not Interested</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Notes / Discussion Points</label>
                        <textarea class="form-control" id="followupNotes" rows="3"
                                  placeholder="What was discussed? Any specific concerns or requirements?"></textarea>
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label">Next Follow-up Date</label>
                        <input type="date" class="form-control" id="followupNextDate" />
                    </div>

                    <!-- Update Status (optional) -->
                    <div class="col-12">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="updateStatusCheck" />
                            <label class="form-check-label" for="updateStatusCheck">
                                Also update enquiry status
                            </label>
                        </div>
                    </div>
                    <div class="col-12 d-none" id="newStatusRow">
                        <label class="form-label">New Status</label>
                        <select class="form-select" id="followupNewStatus">
                            <option value="">Keep current</option>
                            <option value="New">New</option>
                            <option value="Follow-up Pending">Follow-up Pending</option>
                            <option value="Interested">Interested</option>
                            <option value="Campus Visit Scheduled">Campus Visit Scheduled</option>
                            <option value="Not Interested">Not Interested</option>
                        </select>
                        @* Registration Done / Admission Confirmed are intentionally omitted —
                           they are set only by the Register action and admission save. *@
                    </div>

                    <!-- Lost reason — shown when status or outcome = Not Interested -->
                    <div class="col-12 d-none" id="lostReasonRow">
                        <label class="form-label">Reason for Not Interested <span class="text-danger">*</span></label>
                        <select class="form-select" id="followupLostReason">
                            <option value="" disabled selected>Select reason</option>
                            <option>Fees Too High</option>
                            <option>Admitted to Another School</option>
                            <option>Distance / Transport Issue</option>
                            <option>No Seats Available</option>
                            <option>Changed Mind</option>
                            <option>Not Responding</option>
                            <option>Other</option>
                        </select>
                    </div>

                    <!-- Follow-up history -->
                    <div class="col-12 mt-2" id="followupHistorySection">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <small class="fw-bold text-muted text-uppercase" style="letter-spacing:.05em">History</small>
                            <div class="spinner-border spinner-border-sm text-primary d-none" id="historyLoader" role="status"></div>
                        </div>
                        <ul class="followup-timeline" id="followupTimeline">
                            <li><div class="tl-time">Loading...</div></li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="saveFollowupBtn">
                    <i class="bx bx-save me-1"></i> Save Follow-up
                </button>
            </div>
        </div>
    </div>
</div>

