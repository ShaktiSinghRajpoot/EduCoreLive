                        <i class="bx bx-trash text-danger"></i>
                    </div>
                    <h6 class="modal-title mb-0">Delete Enquiry</h6>
                </div>
                <button type="button" class="btn-close flex-shrink-0" data-bs-dismiss="modal"></button>
