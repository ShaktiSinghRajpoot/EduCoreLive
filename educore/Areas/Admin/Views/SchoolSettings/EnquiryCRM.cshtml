<!-- ════════════════════════════════════════════════════════
     REGISTER ENQUIRY MODAL
═════════════════════════════════════════════════════════ -->
<div class="modal fade" id="registerEnquiryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <div class="ec-section-title-wrap">
                    <div class="ec-section-icon" style="background:rgba(255,138,0,.12)">
                        <i class="bx bx-clipboard text-primary"></i>
                    </div>
                    <div>
                        <h5 class="modal-title mb-0">Register Enquiry</h5>
                        <small class="text-muted">Issue a registration number for this lead.</small>
                    </div>
                </div>
                <button type="button" class="btn-close flex-shrink-0" data-bs-dismiss="modal"></button>
            </div>
