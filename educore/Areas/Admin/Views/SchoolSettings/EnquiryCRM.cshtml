                    <!-- Registration fee — shown only when fee is enabled -->
                    <div class="col-12 d-none" id="regFeeRow">
                        <div class="d-flex align-items-center justify-content-between p-2 rounded"
                             style="background:#fff8ef;border:1px solid #ffe2c2;">
                            <div>
                                <div class="fw-bold" style="font-size:.88rem">Registration Fee</div>
                                <small class="text-muted">Amount: <span class="fw-bold" id="regFeeAmountLabel">₹0</span></small>
                            </div>
                            <div class="form-check form-switch m-0">
                                <input class="form-check-input" type="checkbox" id="regFeePaid" />
                                <label class="form-check-label" for="regFeePaid" style="font-size:.82rem">Fee collected</label>
                            </div>
                        </div>
                        <!-- Payment details — shown only when fee is collected; issues a receipt -->
                        <div class="row g-2 mt-1 d-none" id="regPaymentRow">
                            <div class="col-12 col-md-6">
                                <label class="form-label">Payment Mode</label>
                                <select class="form-select" id="regPaymentMode">
