                                <small class="text-muted d-block" style="font-size:.7rem;text-transform:uppercase;letter-spacing:.05em">Student</small>
                                <div class="fw-bold" id="regStudentName">—</div>
                            </div>
                            <div class="col-6">
                                <small class="text-muted d-block" style="font-size:.7rem;text-transform:uppercase;letter-spacing:.05em">Parent</small>
                                <div class="fw-bold" id="regParentName">—</div>
                            </div>
                            <div class="col-6">
                                <small class="text-muted d-block" style="font-size:.7rem;text-transform:uppercase;letter-spacing:.05em">Class</small>
                                <div class="fw-bold" id="regClassName">—</div>
                            </div>
                            <div class="col-6">
                                <small class="text-muted d-block" style="font-size:.7rem;text-transform:uppercase;letter-spacing:.05em">Session</small>
                                <div class="fw-bold" id="regSession">—</div>
