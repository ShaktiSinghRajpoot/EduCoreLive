            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger btn-sm" id="confirmDeleteBtn">
                    <i class="bx bx-trash me-1"></i> Delete
                </button>
            </div>
        </div>
    </div>
</div>

@section PageScripts {
<script>
$(document).ready(function () {

    /* ── Toastr ─────────────────────────────────────────── */
    toastr.options = {
        closeButton: true, progressBar: true, newestOnTop: true,
        positionClass: 'toast-top-right', preventDuplicates: true, timeOut: 3500
    };
    @if (TempData["Message"] != null)
    {
        <text>
        (function(){
            var r = '@TempData["Result"]';
            var m = '@Html.Raw((TempData["Message"] ?? "").ToString().Replace("'", "\\'").Replace("\r","").Replace("\n",""))';
            if (r === '1') toastr.success(m); else toastr.error(m);
        })();
        </text>
    }

    /* ── CSRF token (uses standalone token outside any form) ── */
    var csrf = $('input[name="__RequestVerificationToken"]').first().val();
    if (!csrf) {
        // Fallback: try to retrieve from any rendered antiforgery input
        csrf = $('[name="__RequestVerificationToken"]').val() || '';
    }

    /* ── Loader ─────────────────────────────────────────── */
    var $loader = $('#crmTopLoader');
    function showLoader() { $loader.stop(true).css({ width:'0%', opacity:1 }).animate({ width:'72%' }, 300); }
    function hideLoader() {
        $loader.stop(true).animate({ width:'100%' }, 180, function() {
            $(this).delay(150).animate({ opacity:0 }, 180, function(){ $(this).css({ width:'0%', opacity:1 }); });
        });
    }

    /* ── Filter state ───────────────────────────────────── */
    var F = { page:1, pageSize:10, search:'', session:'', className:'', source:'', pipeline:'', assignedTo:'', overdue:false, today:false };

    /* ── HTML escape ────────────────────────────────────── */
    function esc(s) {
        return (s||'').toString()
            .replace(/&/g,'&amp;').replace(/</g,'&lt;')
            .replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
    }

    /* ── Fetch data ─────────────────────────────────────── */
    var fetchXhr;
    function fetchData(resetPage) {
        if (resetPage) F.page = 1;
        if (fetchXhr) fetchXhr.abort();
        showLoader();

        fetchXhr = $.get('/Admin/Enquiry/GetEnquiriesData', {
            page: F.page, pageSize: F.pageSize,
            search: F.search, session: F.session, className: F.className,
            source: F.source, pipeline: F.pipeline, assignedTo: F.assignedTo,
            overdue: F.overdue, today: F.today
        })
        .done(function(d) {
            if (!d.success) { hideLoader(); return; }
            renderTable(d.rows);
            renderMobileCards(d.rows);
            updatePagination(d);
            hideLoader();
        })
        .fail(function(x) {
            if (x.statusText !== 'abort') { toastr.error('Failed to load data.'); hideLoader(); }
        });
    }

    /* ── Status dropdown ────────────────────────────────── */
    // Registration stage shows only when the school enables it in Admission Workflow settings.
    var SHOW_REGISTRATION = @(showRegistration ? "true" : "false");
    // When true, an enquiry must be "Registration Done" before it can be converted to admission.
    var REGISTRATION_REQUIRED = @((showRegistration && Model.Workflow.RegistrationRequiredBeforeAdmission) ? "true" : "false");
    var REG_FEE_ENABLED = @((showRegistration && Model.Workflow.EnableRegistrationFee) ? "true" : "false");
    // The registration fee amount is master data — the sum of Registration-point Fee
    // Heads for the enquiry's class. It is fetched per-enquiry when the register modal
    // opens (see openRegisterModal), not stored on the workflow settings.
    var REG_FEE_AMOUNT  = 0;
    var REG_AUTO_NUMBER = @(Model.Workflow.AutoGenerateRegistrationNumber ? "true" : "false");
    // Only MANUAL statuses belong here. Registration Done and Admission Confirmed are
    // action-driven (set by the Register action / admission save) and must NOT be
    // directly selectable — picking them here would create records with no registration
    // number / no student. They are reached only through their proper actions.
    var STATUS_LIST = [
        { key:'New',                    label:'New',                    icon:'bx-user',         cls:'' },
        { key:'Follow-up Pending',      label:'Follow-up Pending',      icon:'bx-phone',        cls:'' },
        { key:'Interested',             label:'Interested',             icon:'bx-heart',        cls:'' },
        { key:'Campus Visit Scheduled', label:'Campus Visit Scheduled', icon:'bx-building',     cls:'' },
        { key:'Not Interested',         label:'Not Interested',         icon:'bx-x-circle',     cls:'text-danger' }
    ];

    function buildStatusDropdown(r) {
        if (r.isTerminal) {
            return '<span class="badge bg-label-success" title="Admission Confirmed — final status">'
                + '<i class="bx bx-check-circle me-1"></i>' + esc(r.status) + '</span>';
        }
        // Registration Done is action-driven (issued by the Register action). Lock it as a
        // badge — to revert, use Cancel Registration on the Registrations screen.
        if (r.status === 'Registration Done') {
            return '<span class="badge bg-label-secondary" title="Registered — use Cancel Registration to revert">'
                + '<i class="bx bx-clipboard me-1"></i>' + esc(r.status) + '</span>';
        }
        var items = STATUS_LIST.map(function (s) {
            var isActive  = (s.key === r.status);
            var needsLost = (s.key === 'Not Interested' || s.key === 'Dropped');
            return '<li><a class="dropdown-item status-opt' + (isActive ? ' active' : '') + ' ' + s.cls + '"'
                + ' href="#"'
                + ' data-id="'     + r.enquiryId + '"'
                + ' data-status="' + esc(s.key)  + '"'
                + (needsLost ? ' data-needs-lost="1"' : '') + '>'
                + '<i class="bx ' + s.icon + ' me-2"></i>' + esc(s.label)
                + (isActive ? '<i class="bx bx-check check-icon ms-auto"></i>' : '')
                + '</a></li>';
        }).join('');

        /* ── NO onclick="stopPropagation" here ───────────────────────
           Bootstrap dropdown data-API + jQuery delegation both listen
           on document. stopPropagation on a parent kills them both.
           The row-click handler's own guard (.closest button/a/.dropdown)
           already prevents row navigation when clicking inside a dropdown.
        ──────────────────────────────────────────────────────────── */
        return '<div class="dropdown">'
            + '<span class="badge ' + esc(r.statusBadgeClass) + ' status-badge-toggle"'
            + ' data-bs-toggle="dropdown" aria-expanded="false" style="cursor:pointer">'
            + esc(r.status)
            + ' <i class="bx bx-chevron-down" style="font-size:.65rem;opacity:.75;vertical-align:middle"></i>'
            + '</span>'
            + '<ul class="dropdown-menu dropdown-menu-end shadow py-1" style="min-width:215px;font-size:.82rem">'
            + '<li><div class="px-3 pt-2 pb-1" style="font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--ec-text-muted)">Change Status</div></li>'
            + '<li><hr class="dropdown-divider my-1"></li>'
            + items
            + '</ul></div>';
    }

    /* ── Render table ───────────────────────────────────── */
    function renderTable(rows) {
        if (!rows || rows.length === 0) {
            $('#leadTableBody').html('');
            $('#leadEmptyState').removeClass('d-none');
            return;
        }
        $('#leadEmptyState').addClass('d-none');
        $('#leadTableBody').html(rows.map(buildTableRow).join(''));
        // Re-initialise Bootstrap tooltips on dynamically injected rows
        $('#leadTableBody [data-bs-toggle="tooltip"]').tooltip({ trigger: 'hover' });
    }

    function buildTableRow(r) {
        var oClass = r.isOverdue ? 'overdue-row' : '';
        var fwIcon = r.followupIcon ? '<i class="bx ' + esc(r.followupIcon) + ' me-1"></i>' : '';
        var fwSub  = r.followupSubtext ? '<div class="lead-meta">' + esc(r.followupSubtext) + '</div>' : '';
        var fwCnt  = r.followupCount > 0
            ? ' <span class="followup-count-badge"><i class="bx bx-chat"></i>' + r.followupCount + '</span>' : '';

        return '<tr class="lead-row ' + oClass + '" data-id="' + r.enquiryId + '">'
            + '<td><div class="d-flex align-items-center gap-2">'
            +   '<div class="student-avatar ' + esc(r.avatarColorClass) + '">' + esc(r.studentInitials) + '</div>'
            +   '<div>'
            +     '<div class="lead-name">' + esc(r.studentName) + '</div>'
            +     '<div class="lead-meta">' + esc(r.className) + ' &middot; ' + esc(r.session) + '</div>'
            +   '</div>'
            + '</div></td>'
            + '<td>'
            +   '<div class="fw-semibold text-dark" style="font-size:.83rem">' + esc(r.parentName) + '</div>'
            +   '<a href="' + esc(r.callUrl) + '" class="lead-meta text-decoration-none" onclick="event.stopPropagation()">'
            +     '<i class="bx bx-phone me-1"></i>' + esc(r.mobile) + '</a>'
            + '</td>'
            + '<td>'
            +   '<span class="badge bg-label-primary">' + esc(r.className) + '</span>'
            +   '<div class="lead-meta mt-1">' + esc(r.session) + '</div>'
            + '</td>'
            + '<td><span class="source-pill"><i class="bx ' + esc(r.sourceIcon) + '"></i> ' + esc(r.leadSource) + '</span></td>'
            + '<td>' + buildStatusDropdown(r) + '</td>'
            + '<td>'
            +   '<div class="' + esc(r.followupCssClass) + '">' + fwIcon + esc(r.followupDisplay) + fwCnt + '</div>'
            +   fwSub
            + '</td>'
            + '<td><span class="lead-meta">' + esc(r.daysSinceLabel) + '</span></td>'
            + '<td class="text-end"><div class="d-inline-flex gap-1 align-items-center flex-nowrap">'
            /* ── Contact: Call · WhatsApp ── */
            +   '<a href="' + esc(r.callUrl) + '"'
            +     ' class="btn btn-sm btn-icon btn-outline-info crm-action-btn" title="Call">'
            +     '<i class="bx bx-phone-call"></i></a>'
            +   '<a href="' + esc(r.whatsAppUrl) + '" target="_blank"'
            +     ' class="btn btn-sm btn-icon btn-outline-success crm-action-btn" title="WhatsApp">'
            +     '<i class="bx bxl-whatsapp"></i></a>'
            +   '<div class="vr mx-1" style="opacity:.18"></div>'
            /* ── Nurture & progress: Follow-up · Register · Convert ── */
            +   '<button type="button" class="btn btn-sm btn-icon btn-outline-secondary crm-action-btn btn-log-followup"'
            +     ' title="Log Follow-up"'
            +     ' data-id="' + r.enquiryId + '" data-name="' + esc(r.studentName) + '">'
            +     '<i class="bx bx-calendar-plus"></i></button>'
            + ((SHOW_REGISTRATION && !r.isTerminal && r.status !== 'Registration Done')
                ? '<button type="button" class="btn btn-sm btn-icon btn-outline-primary crm-action-btn btn-register-enquiry"'
                +   ' title="Register"'
                +   ' data-id="'      + r.enquiryId       + '"'
                +   ' data-name="'    + esc(r.studentName) + '"'
                +   ' data-parent="'  + esc(r.parentName)  + '"'
                +   ' data-class="'   + esc(r.className)   + '"'
                +   ' data-session="' + esc(r.session)     + '">'
                +   '<i class="bx bx-clipboard"></i></button>'
                : '')
            + (!r.isTerminal
                ? '<button type="button" class="btn btn-sm btn-icon btn-success crm-action-btn btn-convert-admission"'
                +   ' title="Convert to Admission"'
                +   ' data-id="'      + r.enquiryId         + '"'
                +   ' data-name="'    + esc(r.studentName)   + '"'
                +   ' data-parent="'  + esc(r.parentName)    + '"'
                +   ' data-mobile="'  + esc(r.mobile)        + '"'
                +   ' data-class="'   + esc(r.className)     + '"'
                +   ' data-session="' + esc(r.session)       + '"'
                +   ' data-status="'  + esc(r.status)        + '">'
                +   '<i class="bx bx-user-check"></i></button>'
                : '')
            +   '<div class="vr mx-1" style="opacity:.18"></div>'
            /* ── Manage: Edit · Delete ── */
            + (r.status !== 'Admission Confirmed'
                ? '<button type="button" class="btn btn-sm btn-icon btn-outline-primary crm-action-btn btn-edit-enquiry"'
                +   ' title="Edit enquiry" data-id="' + r.enquiryId + '"><i class="bx bx-edit"></i></button>'
                : '')
            +   '<button type="button" class="btn btn-sm btn-icon btn-outline-danger crm-action-btn btn-delete-enquiry"'
            +     ' title="Delete"'
            +     ' data-id="'   + r.enquiryId       + '"'
            +     ' data-name="' + esc(r.studentName) + '">'
            +     '<i class="bx bx-trash"></i></button>'
            + '</div></td>'
            + '</tr>';
    }

    /* ── Render mobile cards ────────────────────────────── */
    function renderMobileCards(rows) {
        $('#mobileLoader').hide();
        if (!rows || rows.length === 0) {
            $('#mobileCardList').html('<div class="text-center py-5 text-muted"><i class="bx bx-search fs-1 d-block mb-2 opacity-25"></i>No results.</div>');
            return;
        }
        $('#mobileCardList').html(rows.map(buildMobileCard).join(''));
    }

    function buildMobileCard(r) {
        var fwIcon = r.followupIcon ? '<i class="bx ' + esc(r.followupIcon) + ' me-1"></i>' : '';
        return '<div class="crm-card lead-row ' + (r.isOverdue ? 'overdue-card' : '') + '" data-id="' + r.enquiryId + '">'
            + '<div class="d-flex justify-content-between align-items-start mb-2">'
            +   '<div class="d-flex align-items-center gap-2">'
            +     '<div class="student-avatar ' + esc(r.avatarColorClass) + '">' + esc(r.studentInitials) + '</div>'
            +     '<div><div class="lead-name">' + esc(r.studentName) + '</div><div class="lead-meta">' + esc(r.parentName) + '</div></div>'
            +   '</div>'
            +   buildStatusDropdown(r)
            + '</div>'
            + '<div class="d-flex flex-wrap gap-2 mb-2">'
            +   '<span class="badge bg-label-primary">' + esc(r.className) + '</span>'
            +   '<span class="source-pill"><i class="bx ' + esc(r.sourceIcon) + '"></i> ' + esc(r.leadSource) + '</span>'
            + '</div>'
            + '<div class="d-flex justify-content-between align-items-center">'
            +   '<div class="' + esc(r.followupCssClass) + '" style="font-size:.76rem">' + fwIcon + esc(r.followupDisplay) + '</div>'
            +   '<div class="d-flex gap-1 flex-wrap align-items-center">'
            /* ── Contact: Call · WhatsApp ── */
            +     '<a href="' + esc(r.callUrl) + '" class="btn btn-sm btn-icon btn-outline-info crm-action-btn"><i class="bx bx-phone-call"></i></a>'
            +     '<a href="' + esc(r.whatsAppUrl) + '" target="_blank" class="btn btn-sm btn-icon btn-outline-success crm-action-btn"><i class="bx bxl-whatsapp"></i></a>'
            +     '<div class="vr mx-1" style="opacity:.18"></div>'
            /* ── Nurture & progress: Follow-up · Register · Convert ── */
            +     '<button class="btn btn-sm btn-icon btn-outline-secondary crm-action-btn btn-log-followup"'
            +       ' data-id="' + r.enquiryId + '" data-name="' + esc(r.studentName) + '">'
            +       '<i class="bx bx-calendar-plus"></i></button>'
            + ((SHOW_REGISTRATION && !r.isTerminal && r.status !== 'Registration Done')
                ? '<button class="btn btn-sm btn-icon btn-outline-primary crm-action-btn btn-register-enquiry"'
                +   ' data-id="'      + r.enquiryId       + '"'
                +   ' data-name="'    + esc(r.studentName) + '"'
                +   ' data-parent="'  + esc(r.parentName)  + '"'
                +   ' data-class="'   + esc(r.className)   + '"'
                +   ' data-session="' + esc(r.session)     + '">'
                +   '<i class="bx bx-clipboard"></i></button>'
                : '')
            + (!r.isTerminal
                ? '<button class="btn btn-sm btn-icon btn-success crm-action-btn btn-convert-admission"'
                +   ' data-id="'      + r.enquiryId       + '"'
                +   ' data-name="'    + esc(r.studentName) + '"'
                +   ' data-parent="'  + esc(r.parentName)  + '"'
                +   ' data-mobile="'  + esc(r.mobile)      + '"'
                +   ' data-class="'   + esc(r.className)   + '"'
                +   ' data-session="' + esc(r.session)     + '"'
                +   ' data-status="'  + esc(r.status)      + '">'
                +   '<i class="bx bx-user-check"></i></button>'
                : '')
            +     '<div class="vr mx-1" style="opacity:.18"></div>'
            /* ── Manage: Edit · Delete ── */
            + (r.status !== 'Admission Confirmed'
                ? '<button class="btn btn-sm btn-icon btn-outline-primary crm-action-btn btn-edit-enquiry" data-id="' + r.enquiryId + '"><i class="bx bx-edit"></i></button>'
                : '')
            +     '<button class="btn btn-sm btn-icon btn-outline-danger crm-action-btn btn-delete-enquiry"'
            +       ' data-id="' + r.enquiryId + '" data-name="' + esc(r.studentName) + '">'
            +       '<i class="bx bx-trash"></i></button>'
            +   '</div>'
            + '</div></div>';
    }

    /* ── Pagination ─────────────────────────────────────── */
    function updatePagination(d) {
        var s = d.totalCount > 0 ? (d.page-1)*d.pageSize+1 : 0;
        var e = Math.min(d.page*d.pageSize, d.totalCount);
        $('#tableSubtitle').text(d.totalCount + ' record' + (d.totalCount!==1?'s':'') + ' · page ' + d.page + ' of ' + d.totalPages);
        $('#pgInfo').text(d.totalCount > 0 ? 'Showing ' + s + '–' + e + ' of ' + d.totalCount : '0 results');
        var html = buildPgHtml(d.page, d.totalPages);
        $('#pgControls').html(html);
        $('#mobilePgControls').html(html);
        if (d.totalCount > 0) { $('#pgBar').show(); $('#mobilePgCard').css('display',''); }
    }

    function buildPgHtml(cur, total) {
        if (total <= 1) return '';
        var h = '<li class="page-item' + (cur<=1?' disabled':'') + '">'
              + '<a class="page-link" href="#" data-pg="' + (cur-1) + '"><i class="bx bx-chevron-left"></i></a></li>';
        pageRange(cur,total).forEach(function(p) {
            if (p==='...') { h += '<li class="page-item disabled"><span class="page-link">…</span></li>'; }
            else { h += '<li class="page-item' + (p===cur?' active':'') + '"><a class="page-link" href="#" data-pg="' + p + '">' + p + '</a></li>'; }
        });
        h += '<li class="page-item' + (cur>=total?' disabled':'') + '">'
           + '<a class="page-link" href="#" data-pg="' + (cur+1) + '"><i class="bx bx-chevron-right"></i></a></li>';
        return h;
    }

    function pageRange(cur, total) {
        if (total<=7) return Array.from({length:total},function(_,i){return i+1;});
        var r=[1]; if(cur>3) r.push('...');
        for(var i=Math.max(2,cur-1);i<=Math.min(total-1,cur+1);i++) r.push(i);
        if(cur<total-2) r.push('...'); r.push(total); return r;
    }

    $(document).on('click','#pgControls .page-link, #mobilePgControls .page-link',function(e){
        e.preventDefault(); var p=parseInt($(this).data('pg'));
        if(!isNaN(p)&&p>=1&&p!==F.page){F.page=p;fetchData(false);}
    });
    $('#pageSizeSelect').on('change',function(){ F.pageSize=parseInt($(this).val()); $('#mobilePgSize').val($(this).val()); fetchData(true); });
    $('#mobilePgSize').on('change',function(){ F.pageSize=parseInt($(this).val()); $('#pageSizeSelect').val($(this).val()); fetchData(true); });

    /* ── Pipeline tabs ──────────────────────────────────── */
    $('#pipelineTabs .pipeline-tab').on('click',function(e){
        e.preventDefault();
        $('#pipelineTabs .pipeline-tab').removeClass('active');
        $(this).addClass('active');
        F.pipeline=$(this).data('pipeline')||''; F.overdue=false; F.today=false;
        clearQF(); fetchData(true);
    });

    /* ── Quick filters ──────────────────────────────────── */
    $('#btnTodayFollowups').on('click',function(){
        F.today=!F.today; F.overdue=false; resetPipelineToAll();
        $(this).toggleClass('active-warning',F.today); $('#btnOverdue').removeClass('active-danger'); fetchData(true);
    });
    $('#btnOverdue').on('click',function(){
        F.overdue=!F.overdue; F.today=false; resetPipelineToAll();
        $(this).toggleClass('active-danger',F.overdue); $('#btnTodayFollowups').removeClass('active-warning'); fetchData(true);
    });
    $('#btnClear').on('click',function(){
        $('#leadSearch').val('');
        $('#sessionFilter,#classFilter,#sourceFilter,#counsellorFilter').val('');
        F={page:1,pageSize:F.pageSize,search:'',session:'',className:'',source:'',pipeline:'',assignedTo:'',overdue:false,today:false};
        clearQF(); resetPipelineToAll(); fetchData(true);
    });

    function resetPipelineToAll(){
        $('#pipelineTabs .pipeline-tab').removeClass('active');
        $('#pipelineTabs .pipeline-tab[data-pipeline=""]').addClass('active');
        F.pipeline='';
    }
    function clearQF(){
        $('#btnTodayFollowups').removeClass('active-warning');
        $('#btnOverdue').removeClass('active-danger');
    }

    /* ── Debounced search ───────────────────────────────── */
    var searchTimer;
    $('#leadSearch').on('input',function(){
        clearTimeout(searchTimer); showLoader(); F.search=$(this).val().trim();
        searchTimer=setTimeout(function(){fetchData(true);},350);
    });
    $('#sessionFilter').on('change',function(){ F.session=$(this).val(); fetchData(true); });
    $('#classFilter').on('change',function(){ F.className=$(this).val(); fetchData(true); });
    $('#sourceFilter').on('change',function(){ F.source=$(this).val(); fetchData(true); });
    $('#counsellorFilter').on('change',function(){ F.assignedTo=$(this).val(); fetchData(true); });

    /* ── Row click ──────────────────────────────────────── */
    $(document).on('click','.lead-row',function(e){
        if($(e.target).closest('button,a,.dropdown').length) return;
        // TODO: open detail page when built
        // window.location.href='/Admin/Enquiry/Detail/'+$(this).data('id');
    });

    /* ── Status dropdown click ──────────────────────────── */
    $(document).on('click','.status-opt',function(e){
        e.preventDefault(); e.stopPropagation();
        var $item  = $(this);
        var id     = $item.data('id');
        var status = $item.data('status');
        if ($item.hasClass('active')) return;

        // Not Interested → requires lost reason
        if ($item.data('needs-lost') === 1) {
            $('#lostEnquiryId').val(id);
            $('#lostTargetStatus').val(status);
            $('#lostReasonSelect').val('');
            new bootstrap.Modal(document.getElementById('lostReasonModal')).show();
            return;
        }

        callUpdateStatus(id, status, null);
    });

    /* ── Lost reason confirm ────────────────────────────── */
    $('#confirmLostBtn').on('click',function(){
        var id     = $('#lostEnquiryId').val();
        var status = $('#lostTargetStatus').val();
        var reason = $('#lostReasonSelect').val();
        if (!reason) { toastr.error('Please select a reason.'); return; }
        bootstrap.Modal.getInstance(document.getElementById('lostReasonModal')).hide();
        callUpdateStatus(id, status, reason);
    });

    function callUpdateStatus(id, status, lostReason) {
        $.ajax({
            url:         '/Admin/Enquiry/UpdateStatus',
            type:        'POST',
            contentType: 'application/json',
            headers:     { 'RequestVerificationToken': csrf },
            data: JSON.stringify({
                enquiryId:  parseInt(id),
                status:     status,
                lostReason: lostReason || null
            }),
            success: function (res) {
                if (res.success) {
                    toastr.success('Status changed to "' + status + '".');
                    fetchData(false);
                } else {
                    // SP may return a specific message (e.g. "Cannot change after Admission Confirmed")
                    toastr.error(res.message || 'Unable to update status.');
                }
            },
            error: function (xhr) {
                var msg = (xhr.responseJSON && xhr.responseJSON.message)
                            ? xhr.responseJSON.message : 'Something went wrong.';
                toastr.error(msg);
            }
        });
    }

    /* ── Log Follow-up ──────────────────────────────────── */
    $(document).on('click','.btn-log-followup',function(e){
        e.stopPropagation();
        var id   = $(this).data('id');
        var name = $(this).data('name');

        $('#followupEnquiryId').val(id);
        $('#followupStudentName').text(name);
        $('#followupType').val('Call');
        $('#followupOutcome').val('');
        $('#followupNotes').val('');
        $('#followupNextDate').val('');
        $('#updateStatusCheck').prop('checked',false);
        $('#newStatusRow').addClass('d-none');
        $('#lostReasonRow').addClass('d-none');
        $('#followupLostReason').val('');
        $('#followupTimeline').html('<li><div class="tl-time"><i class="bx bx-loader-circle bx-spin me-1"></i>Loading history...</div></li>');

        new bootstrap.Modal(document.getElementById('logFollowupModal')).show();
        loadFollowupHistory(id);
    });

    function loadFollowupHistory(id) {
        $('#historyLoader').removeClass('d-none');
        $('#followupTimeline').html('<li><div class="tl-time"><i class="bx bx-loader-circle bx-spin me-1"></i>Loading...</div></li>');

        $.get('/Admin/Enquiry/GetFollowups', { enquiryId: id })
        .done(function (d) {
            $('#historyLoader').addClass('d-none');
            if (!d.success) {
                $('#followupTimeline').html('<li><div class="tl-time text-muted">No history yet.</div></li>');
                return;
            }

            // Merge status history + follow-up logs into one chronological list
            var entries = [];

            if (d.history && d.history.length) {
                d.history.forEach(function (h) {
                    entries.push({
                        type:       'status',
                        sortKey:    h.changedAt,
                        display:    h.changedAt,
                        statusFrom: h.statusFrom,
                        statusTo:   h.statusTo,
                        badgeClass: h.statusToBadgeClass,
                        note:       h.changeNote
                    });
                });
            }

            if (d.followups && d.followups.length) {
                d.followups.forEach(function (f) {
                    entries.push({
                        type:       'followup',
                        sortKey:    f.followupDate || f.timeAgo,
                        display:    f.timeAgo,
                        typeIcon:   f.typeIcon,
                        followupType: f.followupType,
                        outcome:    f.outcome,
                        badgeClass: f.outcomeBadgeClass,
                        note:       f.notes,
                        statusBefore: f.statusBefore,
                        statusAfter:  f.statusAfter
                    });
                });
            }

            // Sort newest first (both arrays come with string dates — sort descending)
            entries.sort(function (a, b) {
                return new Date(b.sortKey) - new Date(a.sortKey);
            });

            var html = '';
            entries.forEach(function (e) {
                if (e.type === 'status') {
                    html += '<li>'
                        + '<div class="tl-time"><i class="bx bx-transfer me-1 text-muted"></i>' + esc(e.display) + '</div>'
                        + '<div class="tl-title">'
                        + (e.statusFrom ? '<span class="text-muted">' + esc(e.statusFrom) + '</span> → ' : '<span class="text-muted">Created</span> → ')
                        + '<span class="badge ' + esc(e.badgeClass) + '">' + esc(e.statusTo) + '</span>'
                        + '</div>'
                        + (e.note ? '<div class="tl-note">' + esc(e.note) + '</div>' : '')
                        + '</li>';
                } else {
                    html += '<li>'
                        + '<div class="tl-time"><i class="bx ' + esc(e.typeIcon) + ' me-1 text-primary"></i>' + esc(e.display) + '</div>'
                        + '<div class="tl-title"><strong>' + esc(e.followupType) + '</strong>'
                        + (e.outcome ? ' — <span class="badge ' + esc(e.badgeClass) + '">' + esc(e.outcome) + '</span>' : '')
                        + (e.statusAfter && e.statusAfter !== e.statusBefore
                            ? ' <i class="bx bx-right-arrow-alt text-muted"></i> <span class="text-muted small">' + esc(e.statusAfter) + '</span>'
                            : '')
                        + '</div>'
                        + (e.note ? '<div class="tl-note">' + esc(e.note) + '</div>' : '')
                        + '</li>';
                }
            });

            $('#followupTimeline').html(html || '<li><div class="tl-time text-muted">No activity yet.</div></li>');
        })
        .fail(function () {
            $('#historyLoader').addClass('d-none');
            $('#followupTimeline').html('<li><div class="tl-time text-danger"><i class="bx bx-error me-1"></i>Failed to load history.</div></li>');
        });
    }

    /* Show/hide status row when checkbox toggled */
    $('#updateStatusCheck').on('change',function(){
        if($(this).is(':checked')) $('#newStatusRow').removeClass('d-none');
        else { $('#newStatusRow').addClass('d-none'); $('#followupNewStatus').val(''); $('#lostReasonRow').addClass('d-none'); }
    });

    /* Show/hide lost reason based on outcome or new status */
    function checkLostVisibility() {
        var outcome   = $('#followupOutcome').val();
        var newStatus = $('#followupNewStatus').val();
        var needsLost = (outcome==='Not Interested') || (newStatus==='Not Interested') || (newStatus==='Dropped');
        if (needsLost) $('#lostReasonRow').removeClass('d-none');
        else            $('#lostReasonRow').addClass('d-none');
    }
    $('#followupOutcome, #followupNewStatus').on('change', checkLostVisibility);

    /* Save follow-up */
    $('#saveFollowupBtn').on('click', function () {
        var id         = parseInt($('#followupEnquiryId').val());
        var type       = $('#followupType').val() || 'Call';
        var outcome    = $('#followupOutcome').val();
        var notes      = $.trim($('#followupNotes').val()) || null;
        var nextDate   = $('#followupNextDate').val() || null;
        var newStatus  = ($('#updateStatusCheck').is(':checked') && $('#followupNewStatus').val())
                            ? $('#followupNewStatus').val() : null;
        var lostReason = $.trim($('#followupLostReason').val()) || null;

        // Validations
        if (!outcome) { toastr.error('Please select an outcome.'); return; }
        if ((outcome === 'Not Interested' || newStatus === 'Not Interested') && !lostReason) {
            toastr.error('Please select a reason for Not Interested.'); return;
        }
        if (!id) { toastr.error('Invalid enquiry.'); return; }

        var $btn = $(this).prop('disabled', true)
                          .html('<i class="bx bx-loader-circle bx-spin me-1"></i> Saving...');

        $.ajax({
            url:         '/Admin/Enquiry/LogFollowup',
            type:        'POST',
            contentType: 'application/json',
            headers:     { 'RequestVerificationToken': csrf },
            data: JSON.stringify({
                enquiryId:       id,
                followupType:    type,
                outcome:         outcome,
                notes:           notes,
                nextFollowupDate: nextDate,
                newStatus:       newStatus,
                lostReason:      lostReason
            }),
            success: function (res) {
                $btn.prop('disabled', false).html('<i class="bx bx-save me-1"></i> Save Follow-up');
                if (res.success) {
                    toastr.success('Follow-up logged successfully.');
                    bootstrap.Modal.getInstance(document.getElementById('logFollowupModal')).hide();
                    fetchData(false);
                } else {
                    toastr.error(res.message || 'Unable to save follow-up.');
                }
            },
            error: function (xhr) {
                $btn.prop('disabled', false).html('<i class="bx bx-save me-1"></i> Save Follow-up');
                var msg = (xhr.responseJSON && xhr.responseJSON.message)
                            ? xhr.responseJSON.message : 'Something went wrong. Please try again.';
                toastr.error(msg);
            }
        });
    });

    /* ── Register Enquiry ───────────────────────────────── */
    $(document).on('click', '.btn-register-enquiry', function () {
        var $btn = $(this);
        $('#regEnquiryId').val($btn.data('id'));
        $('#regStudentName').text($btn.data('name'));
        $('#regParentName').text($btn.data('parent') || '—');
        $('#regClassName').text($btn.data('class')   || '—');
        $('#regSession').text($btn.data('session')   || '—');

        // Registration number: auto-generated on save, or manual entry.
        var $num = $('#regNumber');
        if (REG_AUTO_NUMBER) {
            $num.val('').prop('disabled', true);
            $('#regNumberHint').text('Auto-generated when you save.');
        } else {
            $num.val('').prop('disabled', false);
            $('#regNumberHint').text('Enter the registration number.');
        }

        // Default date = today (YYYY-MM-DD).
        $('#regDate').val(new Date().toISOString().slice(0, 10));

        // Fee row (only when enabled). The amount is the sum of Registration-point
        // Fee Heads for this enquiry's class — fetched fresh from the fee structure.
        if (REG_FEE_ENABLED) {
            $('#regFeeRow').removeClass('d-none');
            $('#regPaymentRow').addClass('d-none');
            $('#regFeePaid').prop('checked', false);
            $('#regPaymentReference').val('');
            $('#regPaymentMode').val('Cash');
            $('#regFeeAmountLabel').text('Loading…');
            REG_FEE_AMOUNT = 0;
            $.getJSON('/Admin/Enquiry/GetRegistrationFee',
                      { className: $btn.data('class') || '', academicYear: $btn.data('session') || '' })
                .done(function (res) {
                    REG_FEE_AMOUNT = (res && res.amount) ? Number(res.amount) : 0;
                    $('#regFeeAmountLabel').text('₹' + REG_FEE_AMOUNT.toLocaleString('en-IN') +
                        (REG_FEE_AMOUNT === 0 ? ' — configure a Registration-point Fee Head' : ''));
                })
                .fail(function () { $('#regFeeAmountLabel').text('₹0'); });
        } else {
            $('#regFeeRow').addClass('d-none');
        }

        new bootstrap.Modal(document.getElementById('registerEnquiryModal')).show();
    });

    // Payment details appear only when the registration fee is marked collected.
    $(document).on('change', '#regFeePaid', function () {
        $('#regPaymentRow').toggleClass('d-none', !$(this).is(':checked'));
    });

    $('#confirmRegisterBtn').on('click', function () {
        var id = parseInt($('#regEnquiryId').val());
        if (!id) { return; }

        var regNumber = REG_AUTO_NUMBER ? '' : $.trim($('#regNumber').val());
        if (!REG_AUTO_NUMBER && regNumber === '') {
            toastr.error('Please enter a registration number.');
            return;
        }

        var $btn = $(this).prop('disabled', true)
                          .html('<i class="bx bx-loader-circle bx-spin me-1"></i> Saving…');

        $.ajax({
            url:         '/Admin/Enquiry/RegisterEnquiry',
            type:        'POST',
            contentType: 'application/json',
            headers:     { 'RequestVerificationToken': csrf },
            data: JSON.stringify({
                enquiryId:           id,
                registrationNumber:  regNumber,
                registrationDate:    $('#regDate').val(),
                registrationFeePaid: REG_FEE_ENABLED && $('#regFeePaid').is(':checked'),
                paymentMode:         $('#regPaymentMode').val(),
                paymentReference:    $.trim($('#regPaymentReference').val())
            })
        })
        .done(function (res) {
            if (res && res.success) {
                bootstrap.Modal.getInstance(document.getElementById('registerEnquiryModal')).hide();
                toastr.success((res.message || 'Registration completed.') +
                               (res.registrationNumber ? ' (' + res.registrationNumber + ')' : '') +
                               (res.receiptNo ? ' · Receipt ' + res.receiptNo : ''));
                fetchData(false);
            } else {
                toastr.error((res && res.message) || 'Unable to complete registration.');
            }
        })
        .fail(function () { toastr.error('Something went wrong while registering.'); })
        .always(function () {
            $btn.prop('disabled', false).html('<i class="bx bx-check me-1"></i> Complete Registration');
        });
    });

    /* ── Convert to Admission ───────────────────────────── */
    $(document).on('click', '.btn-convert-admission', function () {
        var $btn    = $(this);
        var id      = $btn.data('id');
        var name    = $btn.data('name');
        var parent  = $btn.data('parent');
        var mobile  = $btn.data('mobile');
        var cls     = $btn.data('class');
        var session = $btn.data('session');
        var status  = $btn.data('status');

        // Gate: when the school requires registration before admission, block
        // conversion until the lead has reached "Registration Done".
        if (REGISTRATION_REQUIRED && status !== 'Registration Done') {
            toastr.warning('Complete registration for ' + name + ' before converting to admission.');
            return;
        }

        $('#convertEnquiryId').val(id);
        $('#cvStudentName').text(name);
        $('#cvParentName').text(parent  || '—');
        $('#cvMobile').text(mobile      || '—');
        $('#cvClassName').text(cls      || '—');
        $('#cvSession').text(session    || '—');

        new bootstrap.Modal(document.getElementById('convertAdmissionModal')).show();
    });

    $('#confirmConvertBtn').on('click', function () {
        var id = parseInt($('#convertEnquiryId').val());
        if (!id) { return; }

        $(this).prop('disabled', true)
               .html('<i class="bx bx-loader-circle bx-spin me-1"></i> Opening…');

        // Hand off to the Admission module. Saving the admission there links
        // this enquiry (sets admission_id) and moves it to "Admission Confirmed",
        // so we do not pre-flip the status here.
        window.location.href = '/ERP/Admission/Create?enquiryId=' + id;
    });

    /* ── Delete Enquiry ─────────────────────────────────── */
    $(document).on('click', '.btn-delete-enquiry', function (e) {
        e.stopPropagation();
        var id   = $(this).data('id');
        var name = $(this).data('name');
        $('#deleteEnquiryId').val(id);
        $('#deleteEnquiryName').text(name);
        new bootstrap.Modal(document.getElementById('deleteEnquiryModal')).show();
    });

    $('#confirmDeleteBtn').on('click', function () {
        var id  = $('#deleteEnquiryId').val();
        var btn = $(this).prop('disabled', true)
                         .html('<i class="bx bx-loader-circle bx-spin me-1"></i> Deleting...');

        $.ajax({
            url:         '/Admin/Enquiry/DeleteEnquiry',
            type:        'POST',
            contentType: 'application/json',
            headers:     { 'RequestVerificationToken': csrf },
            data:        JSON.stringify({ enquiryId: parseInt(id) }),
            success: function (res) {
                btn.prop('disabled', false).html('<i class="bx bx-trash me-1"></i> Delete');
                bootstrap.Modal.getInstance(document.getElementById('deleteEnquiryModal')).hide();
                if (res.success) {
                    toastr.success('Enquiry deleted.');
                    fetchData(false);
                } else {
                    toastr.error(res.message || 'Unable to delete enquiry.');
                }
            },
            error: function () {
                btn.prop('disabled', false).html('<i class="bx bx-trash me-1"></i> Delete');
                toastr.error('Something went wrong. Please try again.');
            }
        });
    });

    /* ── Add Enquiry form: conditional fields ───────────── */
    // Stream: show for 11th / 12th only
    $('#addClassName').on('change',function(){
        var cls = $(this).val() || '';
        if(cls==='11th'||cls==='12th'||cls==='11'||cls==='12'||cls.startsWith('11')||cls.startsWith('12'))
            $('#streamRow').removeClass('d-none');
        else $('#streamRow').addClass('d-none');
    });

    // Referrer: show when source = Referral
    $('#addLeadSource').on('change',function(){
        if($(this).val()==='Referral'){
            $('#referrerNameRow,#referrerMobileRow').removeClass('d-none');
        } else {
            $('#referrerNameRow,#referrerMobileRow').addClass('d-none');
        }
    });

    // Sync hidden Mobile field from Father Mobile
    $('#addFatherMobile').on('input', function () {
        var mob = $(this).val().trim();
        $('#addPrimaryMobile').val(mob);
        // Also sync WhatsApp if "same as mobile" is checked
        if ($('#whatsappSameAsMobile').is(':checked')) {
            $('#addWhatsApp').val(mob);
        }
    });

    // WhatsApp "Same as mobile" toggle
    $('#whatsappSameAsMobile').on('change', function () {
        if ($(this).is(':checked')) {
            $('#addWhatsApp').val($('#addFatherMobile').val().trim()).prop('readonly', true);
        } else {
            $('#addWhatsApp').val('').prop('readonly', false).focus();
        }
    });
    // Default state: WhatsApp field is readonly (syncs from father mobile)
    $('#addWhatsApp').prop('readonly', true);

    /* ── Edit Enquiry ───────────────────────────────────── */
    function setEnqVal(name, val) {
        $('[name="' + name + '"]', '#addEnquiryModal').val(val == null ? '' : val);
    }

    function enquiryFormReset() {
        $('#addEnquiryModal form')[0].reset();
        $('#enquiryFormId').val('0');
        $('#enquiryModalTitle').text('Add Enquiry');
        $('#enquiryModalSubtitle').text('Capture student & parent details.');
        $('#saveEnquiryBtn').html('<i class="bx bx-save me-1"></i> Save Enquiry');
        $('#streamRow,#referrerNameRow,#referrerMobileRow').addClass('d-none');
        $('#whatsappSameAsMobile').prop('checked', true);
        $('#addWhatsApp').prop('readonly', true);
        $('#initialStatusRow').removeClass('d-none');   // status applies on Add only
    }

    function enquiryFormFill(d) {
        enquiryFormReset();
        $('#enquiryFormId').val(d.enquiryId);
        $('#enquiryModalTitle').text('Edit Enquiry');
        $('#enquiryModalSubtitle').text('Update student & parent details.');
        $('#saveEnquiryBtn').html('<i class="bx bx-save me-1"></i> Update Enquiry');

        setEnqVal('StudentName', d.studentName);
        setEnqVal('Gender', d.gender);
        setEnqVal('Dob', d.dob);
        setEnqVal('ClassName', d.className);
        setEnqVal('Session', d.session);
        setEnqVal('CurrentSchool', d.currentSchool);
        setEnqVal('CurrentClass', d.currentClass);
        setEnqVal('InterestedStream', d.interestedStream);
        setEnqVal('FatherName', d.fatherName);
        $('#addFatherMobile').val(d.fatherMobile || '');
        setEnqVal('MotherName', d.motherName);
        setEnqVal('MotherMobile', d.motherMobile);
        setEnqVal('ParentEmail', d.parentEmail);
        setEnqVal('City', d.city);
        setEnqVal('AreaLocality', d.areaLocality);
        setEnqVal('LeadSource', d.leadSource);
        // Status is NOT editable here — it's managed by the status dropdown / actions.
        // Hide the Initial Status field and leave the existing status untouched server-side.
        $('#initialStatusRow').addClass('d-none');
        setEnqVal('ReferrerName', d.referrerName);
        setEnqVal('ReferrerMobile', d.referrerMobile);
        if (d.assignedToId) setEnqVal('AssignedToId', d.assignedToId);
        setEnqVal('NextFollowupDate', d.nextFollowupDate);
        setEnqVal('Notes', d.notes);
        $('#addPrimaryMobile').val(d.fatherMobile || '');

        $('input[name="TransportRequired"][value="' + (d.transportRequired ? 'true' : 'false') + '"]').prop('checked', true);

        // WhatsApp: distinct number → uncheck "same as mobile"
        if (d.whatsAppNumber && d.whatsAppNumber !== d.fatherMobile) {
            $('#whatsappSameAsMobile').prop('checked', false);
            $('#addWhatsApp').val(d.whatsAppNumber).prop('readonly', false);
        } else {
            $('#whatsappSameAsMobile').prop('checked', true);
            $('#addWhatsApp').val(d.fatherMobile || '').prop('readonly', true);
        }

        // Fire conditional toggles (stream for 11/12, referrer for Referral)
        $('#addClassName').trigger('change');
        $('#addLeadSource').trigger('change');
    }

    function openEditEnquiry(id) {
        $.get('/Admin/Enquiry/GetEnquiry', { id: id })
            .done(function (res) {
                if (res.success) {
                    enquiryFormFill(res.data);
                    new bootstrap.Modal(document.getElementById('addEnquiryModal')).show();
                } else {
                    toastr.error(res.message || 'Unable to load enquiry.');
                }
            })
            .fail(function () { toastr.error('Failed to load enquiry.'); });
    }

    $(document).on('click', '.btn-edit-enquiry', function (e) {
        e.stopPropagation();
        openEditEnquiry($(this).data('id'));
    });

    // Add button → always start fresh
    $('#btnAddEnquiry').on('click', enquiryFormReset);

    // Auto-open edit when arriving with ?editId= (e.g. from the Registrations screen)
    (function () {
        var editId = new URLSearchParams(window.location.search).get('editId');
        if (editId && parseInt(editId) > 0) openEditEnquiry(parseInt(editId));
    })();

    /* ── Add Enquiry form validation ────────────────────── */
    $('#addEnquiryModal form').on('submit',function(e){
        var ok = true;
        function req(id, label){
            var val = $.trim($(id,'#addEnquiryModal').val());
            if(!val){ toastr.error(label+' is required.'); ok=false; }
        }
        req('[name="StudentName"]','Student Name');
        req('[name="ClassName"]','Class');
        req('[name="Session"]','Academic Session');

        var fMob = $.trim($('#addFatherMobile').val());
        if (!fMob) {
            toastr.error("Father's mobile number is required."); ok = false;
        } else if (!/^[6-9][0-9]{9}$/.test(fMob)) {
            toastr.error('Enter a valid 10-digit mobile number.'); ok = false;
        } else {
            $('#addPrimaryMobile').val(fMob);
        }

        // Sync WhatsApp if same-as-mobile checkbox is checked
        if ($('#whatsappSameAsMobile').is(':checked')) {
            $('#addWhatsApp').val(fMob);
        }

        // Optional email format check
        var email = $.trim($('#addParentEmail').val());
        if (email && !/^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(email)) {
            toastr.error('Enter a valid email address.'); ok = false;
        }

        if (!ok) e.preventDefault();
    });

    /* ── Init ───────────────────────────────────────────── */
    fetchData(true);
});
</script>
}
