@{
    ViewData["Title"] = "Academic Years";
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
}

@section PageStyles {
<link href="~/css/educore-theme.css" rel="stylesheet" />
<style>
/* ===== Academic Years (ay-*) ===== */
.ay-card{
    border:1px solid var(--ec-border); border-radius:var(--ec-radius);
    background:#fff; padding:1rem 1.1rem; display:flex; align-items:center; gap:.85rem; height:100%;
    transition:var(--ec-transition);
}
.ay-card:hover{ transform:translateY(-2px); box-shadow:var(--ec-shadow); }
.ay-card-ic{ width:44px; height:44px; flex:0 0 44px; border-radius:13px; display:flex; align-items:center; justify-content:center; font-size:1.25rem; }
.ay-card-val{ font-size:1.45rem; font-weight:800; color:var(--ec-text-dark); line-height:1.1; }
.ay-card-lbl{ font-size:.7rem; font-weight:800; color:var(--ec-text-muted); text-transform:uppercase; letter-spacing:.05em; }

.ay-row{
    border:1px solid var(--ec-border); border-radius:var(--ec-radius);
    background:#fff; padding:1rem 1.1rem; margin-bottom:.75rem;
    display:flex; align-items:center; gap:1rem; flex-wrap:wrap; transition:var(--ec-transition);
}
.ay-row:hover{ box-shadow:var(--ec-shadow); border-color:rgba(255,138,0,.3); }
.ay-row.current{ border-color:rgba(40,199,111,.45); background:linear-gradient(180deg,#fff,#f6fff9); }
.ay-ic{
    width:46px; height:46px; flex:0 0 46px; border-radius:13px;
    background:var(--ec-primary-light); color:var(--ec-primary);
    display:flex; align-items:center; justify-content:center; font-size:1.3rem;
}
.ay-name{ font-weight:800; color:var(--ec-text-dark); font-size:1rem; line-height:1.2; }
.ay-dates{ font-size:.78rem; color:var(--ec-text-muted); font-weight:650; }
.ay-badge{ display:inline-flex; align-items:center; gap:.3rem; padding:.22rem .6rem; border-radius:999px; font-size:.68rem; font-weight:800; }
.ay-badge.cur{ background:#d4edda; color:#155724; }
.ay-badge.cur::before{ content:''; width:6px; height:6px; border-radius:50%; background:#28a745; }
.ay-pill{ display:inline-flex; align-items:center; gap:.3rem; font-size:.76rem; font-weight:700; color:var(--ec-text-muted); }
.ay-actions{ display:flex; gap:.4rem; margin-left:auto; }
.ay-btn{
    height:34px; padding:0 .7rem; border-radius:8px; border:1px solid var(--ec-border);
    background:#fff; color:var(--ec-text-muted); font-size:.78rem; font-weight:700; cursor:pointer; outline:none;
    display:inline-flex; align-items:center; gap:.3rem; transition:var(--ec-transition); white-space:nowrap;
}
.ay-btn:hover{ background:var(--ec-primary-light); border-color:var(--ec-primary); color:var(--ec-primary); }
.ay-btn.success:hover{ background:#eafaf1; border-color:#28c76f; color:#1f9d57; }
.ay-btn.danger:hover{ background:#fff0f0; border-color:#dc3545; color:#dc3545; }
.ay-btn:disabled{ opacity:.45; cursor:not-allowed; }
.ay-empty{ padding:3rem 1rem; text-align:center; }
.ay-empty-ic{ width:64px; height:64px; border-radius:18px; background:var(--ec-primary-light); color:var(--ec-primary); display:inline-flex; align-items:center; justify-content:center; font-size:1.8rem; margin-bottom:.9rem; }
.ay-modal-lbl{ font-size:.72rem; font-weight:800; text-transform:uppercase; color:var(--ec-text-muted); }

@@media (max-width:575.98px){
    .ay-actions{ width:100%; margin-left:0; }
    .ay-btn{ flex:1 1 auto; justify-content:center; }
}
</style>
}

<div class="ec-page-shell">
  <div class="ec-page-content">

    <!-- Header -->
    <div class="ec-page-header">
      <div class="ec-page-header-inner">
        <div class="ec-page-title-wrap">
          <div class="ec-page-icon rounded-4 d-flex align-items-center justify-content-center">
            <i class="bx bx-calendar fs-4"></i>
          </div>
          <div>
            <h4 class="ec-page-title mb-1">Academic Years</h4>
            <div class="ec-page-subtitle">Create sessions, set the current year, and define start &amp; end dates</div>
          </div>
        </div>
        <button class="btn btn-primary d-flex align-items-center gap-1" id="btnAddYear">
          <i class="bx bx-plus"></i><span>New Academic Year</span>
        </button>
      </div>
    </div>

    <!-- Summary cards -->
    <div class="row g-3 mb-4">
      <div class="col-6 col-lg-3">
        <div class="ay-card">
          <div class="ay-card-ic bg-label-primary" style="color:var(--ec-primary);"><i class="bx bx-calendar"></i></div>
          <div><div class="ay-card-val" id="cTotal">—</div><div class="ay-card-lbl">Total Years</div></div>
        </div>
      </div>
      <div class="col-6 col-lg-3">
        <div class="ay-card">
          <div class="ay-card-ic bg-label-success text-success"><i class="bx bx-check-circle"></i></div>
          <div><div class="ay-card-val" id="cCurrent">—</div><div class="ay-card-lbl">Current Session</div></div>
        </div>
      </div>
    </div>

    <!-- List -->
    <div class="ec-card mb-0">
      <div class="ec-card-header">
        <div class="ec-section-title-wrap">
          <span class="ec-section-icon"><i class="bx bx-list-ul"></i></span>
          <div>
            <div class="ec-section-title">Sessions</div>
            <div class="ec-section-subtitle" id="resultText">Loading…</div>
          </div>
        </div>
      </div>
      <div class="ec-card-body pt-2">
        <div id="yearList"></div>
        <div class="ay-empty d-none" id="emptyState">
          <div class="ay-empty-ic"><i class="bx bx-calendar-plus"></i></div>
          <h6 class="fw-bold mb-1" style="color:var(--ec-text-dark);">No academic years yet</h6>
          <p class="text-muted small mb-0">Add your first session to get started.</p>
        </div>
      </div>
    </div>

  </div>
</div>

<!-- Year modal -->
<div class="modal fade" id="yearModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content" style="border:0;border-radius:20px;overflow:hidden;">
      <div class="ec-card-header d-flex align-items-center justify-content-between p-3 p-lg-4">
        <div class="ec-section-title-wrap">
          <span class="ec-section-icon"><i class="bx bx-calendar"></i></span>
          <div>
            <div class="ec-section-title" id="yearModalTitle">New Academic Year</div>
            <div class="ec-section-subtitle">Session definition</div>
          </div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="ec-card-body p-3 p-lg-4">
        <div class="row g-3">
          <div class="col-12">
            <label class="form-label ay-modal-lbl">Academic Year Name</label>
            <input type="text" class="form-control" id="mYearName" placeholder="e.g. 2027-2028">
          </div>
          <div class="col-12 col-sm-6">
            <label class="form-label ay-modal-lbl">Start Date</label>
            <input type="date" class="form-control" id="mStart">
          </div>
          <div class="col-12 col-sm-6">
            <label class="form-label ay-modal-lbl">End Date</label>
            <input type="date" class="form-control" id="mEnd">
          </div>
          <div class="col-12">
            <div class="form-check form-switch">
              <input class="form-check-input" type="checkbox" id="mCurrent">
              <label class="form-check-label" for="mCurrent" style="font-weight:700;font-size:.85rem;">Set as current session</label>
            </div>
          </div>
        </div>
      </div>
      <div class="ec-card-body pt-0 p-3 p-lg-4 d-flex flex-column flex-sm-row justify-content-end gap-2">
        <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary px-4" id="yearSave"><i class="bx bx-check me-1"></i>Save</button>
      </div>
    </div>
  </div>
</div>

@section PageScripts {
<script>
(function(){
'use strict';

var URL_SAVE    = '@Url.Action("SaveAcademicYear", "SchoolSettings", new { area = "Admin" })';
var URL_CURRENT = '@Url.Action("SetCurrentAcademicYear", "SchoolSettings", new { area = "Admin" })';
var URL_DELETE  = '@Url.Action("DeleteAcademicYear", "SchoolSettings", new { area = "Admin" })';

var DATA = @Html.Raw(ViewBag.YearsJson ?? "[]");
var editId = null;

function esc(s){ return String(s==null?'':s).replace(/[&<>"]/g,function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c];}); }
function toast(t,m){ if(typeof toastr!=='undefined') toastr[t](m); }
var MONTHS=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
function fmtDate(d){ if(!d) return '—'; var x=new Date(d); if(isNaN(x.getTime())) return '—'; return String(x.getDate()).padStart(2,'0')+' '+MONTHS[x.getMonth()]+' '+x.getFullYear(); }

function post(url, body){
  return fetch(url,{
    method:'POST',
    headers:{'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'},
    body:JSON.stringify(body)
  }).then(function(r){return r.json();});
}

function updateCards(){
  document.getElementById('cTotal').textContent = DATA.length;
  var cur = DATA.filter(function(y){return y.isCurrent;})[0];
  document.getElementById('cCurrent').textContent = cur ? cur.name : '—';
}

function render(){
  var box=document.getElementById('yearList'), empty=document.getElementById('emptyState');
  if(!DATA.length){ box.innerHTML=''; empty.classList.remove('d-none');
    document.getElementById('resultText').textContent='0 sessions'; return; }
  empty.classList.add('d-none');

  box.innerHTML = DATA.map(function(y){
    var curBadge = y.isCurrent ? '<span class="ay-badge cur">Current</span>' : '';
    var setCurBtn = y.isCurrent ? '' :
      '<button class="ay-btn success js-current" data-id="'+y.id+'" title="Set as current"><i class="bx bx-check-circle"></i>Set current</button>';
    return '<div class="ay-row'+(y.isCurrent?' current':'')+'">'
      + '<div class="ay-ic"><i class="bx bx-calendar"></i></div>'
      + '<div>'
      +   '<div class="d-flex align-items-center gap-2 flex-wrap"><span class="ay-name">'+esc(y.name)+'</span>'+curBadge+'</div>'
      +   '<div class="ay-dates">'+fmtDate(y.startDate)+' &ndash; '+fmtDate(y.endDate)+'</div>'
      + '</div>'
      + '<div class="d-flex align-items-center gap-3 ms-3">'
      +   '<span class="ay-pill"><i class="bx bx-been-here"></i>'+y.classCount+' class'+(y.classCount===1?'':'es')+'</span>'
      +   '<span class="ay-pill"><i class="bx bx-group"></i>'+y.studentCount+' student'+(y.studentCount===1?'':'s')+'</span>'
      + '</div>'
      + '<div class="ay-actions">'
      +   setCurBtn
      +   '<button class="ay-btn js-edit" data-id="'+y.id+'" title="Edit"><i class="bx bx-edit-alt"></i>Edit</button>'
      +   '<button class="ay-btn danger js-del" data-id="'+y.id+'" title="Delete"><i class="bx bx-trash"></i></button>'
      + '</div>'
      + '</div>';
  }).join('');

  document.getElementById('resultText').textContent = DATA.length+' session'+(DATA.length===1?'':'s')+' defined';
  bindEvents();
}

function bindEvents(){
  document.querySelectorAll('.js-edit').forEach(function(b){ b.addEventListener('click',function(){ openModal(parseInt(this.dataset.id,10)); }); });
  document.querySelectorAll('.js-current').forEach(function(b){ b.addEventListener('click',function(){ setCurrent(parseInt(this.dataset.id,10)); }); });
  document.querySelectorAll('.js-del').forEach(function(b){ b.addEventListener('click',function(){ del(parseInt(this.dataset.id,10)); }); });
}

function openModal(id){
  editId = id || null;
  var y = id ? DATA.filter(function(x){return x.id===id;})[0] : null;
  document.getElementById('yearModalTitle').textContent = y ? 'Edit Academic Year' : 'New Academic Year';
  document.getElementById('mYearName').value = y ? y.name : '';
  document.getElementById('mStart').value = y && y.startDate ? y.startDate : '';
  document.getElementById('mEnd').value = y && y.endDate ? y.endDate : '';
  document.getElementById('mCurrent').checked = y ? !!y.isCurrent : (DATA.length===0);
  new bootstrap.Modal(document.getElementById('yearModal')).show();
}
document.getElementById('btnAddYear').addEventListener('click',function(){ openModal(null); });

document.getElementById('yearSave').addEventListener('click',function(){
  var name=document.getElementById('mYearName').value.trim();
  if(!name){ toast('error','Academic year name is required.'); return; }
  var start=document.getElementById('mStart').value;
  var end=document.getElementById('mEnd').value;
  if(start && end && end < start){ toast('error','End date cannot be before start date.'); return; }

  post(URL_SAVE, { id: editId||0, name:name, startDate:start||null, endDate:end||null, isCurrent:document.getElementById('mCurrent').checked })
    .then(function(res){
      if(res && res.success){
        bootstrap.Modal.getInstance(document.getElementById('yearModal')).hide();
        toast('success','Academic year saved.');
        setTimeout(function(){ window.location.reload(); }, 600);
      } else { toast('error',(res&&res.message)||'Save failed.'); }
    })
    .catch(function(){ toast('error','Save failed. Check your connection.'); });
});

function setCurrent(id){
  post(URL_CURRENT, { id:id })
    .then(function(res){
      if(res && res.success){ toast('success','Current academic year updated.'); setTimeout(function(){ window.location.reload(); }, 500); }
      else { toast('error',(res&&res.message)||'Failed.'); }
    })
    .catch(function(){ toast('error','Failed. Check your connection.'); });
}

function del(id){
  var y = DATA.filter(function(x){return x.id===id;})[0];
  if(!y) return;
  if(!confirm('Delete academic year "'+y.name+'"?')) return;
  post(URL_DELETE, { id:id })
    .then(function(res){
      if(res && res.success){ toast('success','Academic year deleted.'); setTimeout(function(){ window.location.reload(); }, 500); }
      else { toast('error',(res&&res.message)||'Cannot delete this year.'); }
    })
    .catch(function(){ toast('error','Failed. Check your connection.'); });
}

/* Init */
updateCards();
render();

})();
</script>
}
