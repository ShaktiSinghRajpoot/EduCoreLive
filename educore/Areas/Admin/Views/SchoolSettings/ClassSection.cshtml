--@{
    ViewData["Title"] = "Classes & Sections";
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
}

@section PageStyles {
<link href="~/css/educore-theme.css" rel="stylesheet" />
<style>
/* ===== Classes & Sections (cs-*) ===== */

/* summary cards */
.cs-card{
    border:1px solid var(--ec-border); border-radius:var(--ec-radius);
    background:#fff; padding:1rem 1.1rem; 
    display:flex; align-items:center; gap:.85rem; height:100%;
    transition:var(--ec-transition);
}
.cs-card:hover{ transform:translateY(-2px); box-shadow:var(--ec-shadow); }
.cs-card-ic{ width:44px; height:44px; flex:0 0 44px; border-radius:13px; display:flex; align-items:center; justify-content:center; font-size:1.25rem; }
.cs-card-val{ font-size:1.45rem; font-weight:800; color:var(--ec-text-dark); line-height:1.1; }
.cs-card-lbl{ font-size:.7rem; font-weight:800; color:var(--ec-text-muted); text-transform:uppercase; letter-spacing:.05em; }

/* toolbar */
.cs-fbar{ display:flex; align-items:center; gap:.5rem; flex-wrap:wrap; }
.cs-srch-wrap{ position:relative; flex:1 1 200px; max-width:300px; }
.cs-srch-ic{ position:absolute; left:.65rem; top:50%; transform:translateY(-50%); color:var(--ec-text-muted); font-size:1rem; pointer-events:none; }
.cs-srch-inp{
    width:100%; height:36px; padding:0 .75rem 0 2rem;
    border-radius:8px; border:1px solid var(--ec-border);
    background:#fafaf8; font-size:.82rem; font-weight:600; color:var(--ec-text,#2b2c40); outline:none;
    transition:var(--ec-transition);
}
.cs-srch-inp:focus{ border-color:rgba(255,138,0,.55); background:#fff; box-shadow:0 0 0 3px rgba(255,138,0,.1); }
.cs-btn{
    height:36px; padding:0 .9rem; border-radius:8px; border:1px solid var(--ec-border);
    background:#fafaf8; color:var(--ec-text-muted); font-size:.8rem; font-weight:700; cursor:pointer; outline:none;
    display:inline-flex; align-items:center; gap:.35rem; transition:var(--ec-transition); white-space:nowrap;
}
.cs-btn:hover{ background:#fff; border-color:rgba(255,138,0,.4); color:var(--ec-text,#2b2c40); }
.cs-btn.primary{ border:0; background:var(--ec-primary); color:#fff; }
.cs-btn.primary:hover{ background:#e67c00; color:#fff; }

/* class accordion row */
.cs-class{
    border:1px solid var(--ec-border); border-radius:var(--ec-radius);
    background:#fff; margin-bottom:.75rem; overflow:hidden; transition:var(--ec-transition);
}
.cs-class.open{ box-shadow:var(--ec-shadow); border-color:rgba(255,138,0,.35); }
.cs-class-head{
    display:flex; align-items:center; gap:.9rem; padding:.9rem 1.1rem; cursor:pointer;
    user-select:none; transition:var(--ec-transition);
}
.cs-class-head:hover{ background:#fffaf3; }
.cs-rank{
    width:42px; height:42px; flex:0 0 42px; border-radius:12px;
    background:var(--ec-primary-light); color:var(--ec-primary);
    display:flex; align-items:center; justify-content:center; font-weight:800; font-size:.95rem;
}
.cs-class-name{ font-weight:800; color:var(--ec-text-dark); font-size:.98rem; line-height:1.2; }
.cs-class-meta{ font-size:.74rem; color:var(--ec-text-muted); font-weight:650; }
.cs-stream{ display:inline-flex; align-items:center; padding:.18rem .55rem; border-radius:999px; font-size:.66rem; font-weight:800; text-transform:uppercase; letter-spacing:.03em; }
.cs-stream.sci{ background:#cfe2ff; color:#084298; }
.cs-stream.com{ background:#d4edda; color:#155724; }
.cs-stream.art{ background:#fff3cd; color:#664d03; }
.cs-stream.gen{ background:#eceff5; color:#5a6072; }

.cs-pill{ display:inline-flex; align-items:center; gap:.3rem; font-size:.76rem; font-weight:700; color:var(--ec-text-muted); }
.cs-chev{ transition:transform .25s ease; font-size:1.4rem; color:var(--ec-text-muted); }
.cs-class.open .cs-chev{ transform:rotate(90deg); color:var(--ec-primary); }

.cs-icon-btn{
    width:30px; height:30px; border-radius:7px; border:1px solid var(--ec-border);
    background:#fff; color:var(--ec-text-muted); font-size:.95rem; cursor:pointer;
    display:inline-flex; align-items:center; justify-content:center; transition:var(--ec-transition); padding:0;
}
.cs-icon-btn:hover{ background:var(--ec-primary-light); border-color:var(--ec-primary); color:var(--ec-primary); }
.cs-icon-btn.danger:hover{ background:#fff0f0; border-color:#dc3545; color:#dc3545; }

/* sections body */
.cs-sec-body{ padding:0 1.1rem; max-height:0; overflow:hidden; transition:max-height .3s ease; }
.cs-class.open .cs-sec-body{ max-height:1600px; padding-bottom:1rem; }
.cs-sec-grid{ display:grid; grid-template-columns:repeat(auto-fill,minmax(230px,1fr)); gap:.7rem; padding-top:.25rem; border-top:1px dashed var(--ec-border); margin-top:.1rem; }

.cs-sec{ border:1px solid var(--ec-border); border-radius:14px; background:#fcfbf9; padding:.85rem .9rem; transition:var(--ec-transition); }
.cs-sec:hover{ background:#fff; border-color:rgba(255,138,0,.35); }
.cs-sec-top{ display:flex; align-items:center; justify-content:space-between; gap:.5rem; margin-bottom:.55rem; }
.cs-sec-name{ display:flex; align-items:center; gap:.5rem; }
.cs-sec-badge{ width:30px; height:30px; border-radius:9px; background:var(--ec-primary-light); color:var(--ec-primary); display:flex; align-items:center; justify-content:center; font-weight:800; font-size:.85rem; }
.cs-sec-title{ font-weight:800; color:var(--ec-text-dark); font-size:.88rem; }
.cs-sec-meta{ font-size:.72rem; color:var(--ec-text-muted); font-weight:650; display:flex; align-items:center; gap:.3rem; margin-bottom:.5rem; }
.cs-sec-meta i{ font-size:.9rem; }

/* capacity bar */
.cs-occ-row{ display:flex; align-items:center; justify-content:space-between; font-size:.72rem; font-weight:800; margin-bottom:.3rem; }
.cs-occ-num{ color:var(--ec-text-dark); }
.cs-occ-pct{ color:var(--ec-text-muted); }
.cs-bar{ height:7px; border-radius:99px; background:#eceff5; overflow:hidden; }
.cs-bar-fill{ height:100%; border-radius:99px; transition:width .4s ease; }
.cs-bar-fill.ok{ background:linear-gradient(90deg,#28c76f,#48da89); }
.cs-bar-fill.warn{ background:linear-gradient(90deg,#ff9f43,#ffbe76); }
.cs-bar-fill.full{ background:linear-gradient(90deg,#ea5455,#ff7674); }

.cs-add-sec{
    border:1.5px dashed var(--ec-border); border-radius:14px; background:transparent;
    display:flex; flex-direction:column; align-items:center; justify-content:center; gap:.3rem;
    min-height:118px; color:var(--ec-text-muted); font-size:.8rem; font-weight:700; cursor:pointer; transition:var(--ec-transition);
}
.cs-add-sec:hover{ border-color:var(--ec-primary); color:var(--ec-primary); background:var(--ec-primary-soft); }
.cs-add-sec i{ font-size:1.4rem; }

/* empty */
.cs-empty{ padding:3rem 1rem; text-align:center; }
.cs-empty-ic{ width:64px; height:64px; border-radius:18px; background:var(--ec-primary-light); color:var(--ec-primary); display:inline-flex; align-items:center; justify-content:center; font-size:1.8rem; margin-bottom:.9rem; }

.cs-modal-lbl{ font-size:.72rem; font-weight:800; text-transform:uppercase; color:var(--ec-text-muted); }

@@media (max-width:575.98px){
    .cs-card{ padding:.8rem .9rem; }
    .cs-card-val{ font-size:1.25rem; }
    .cs-srch-wrap{ flex:1 1 100%; max-width:100%; }
    .cs-class-meta-wrap{ display:none; }
    .cs-sec-grid{ grid-template-columns:1fr; }
}
</style>
}

<div class="ec-page-shell">
  <div class="ec-page-content">

    <!-- Header -->
    <div class="ec-page-header">
      <div class="ec-page-header-inner">
        <div class="ec-page-title-wrap">
          <div class="ec-page-icon rounded-4 d-flex align-items-center justify-content-center">
            <i class="bx bx-grid-alt fs-4"></i>
          </div>
          <div>
            <h4 class="ec-page-title mb-1">Classes &amp; Sections</h4>
            <div class="ec-page-subtitle">Define academic grades, divisions, capacity and class teachers</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Summary cards -->
    <div class="row g-3 mb-4">
      <div class="col-6 col-lg-3">
        <div class="cs-card">
          <div class="cs-card-ic bg-label-primary" style="color:var(--ec-primary);"><i class="bx bx-been-here"></i></div>
          <div><div class="cs-card-val" id="cClasses">—</div><div class="cs-card-lbl">Classes</div></div>
        </div>
      </div>
      <div class="col-6 col-lg-3">
        <div class="cs-card">
          <div class="cs-card-ic bg-label-info text-info"><i class="bx bx-grid"></i></div>
          <div><div class="cs-card-val" id="cSections">—</div><div class="cs-card-lbl">Sections</div></div>
        </div>
      </div>
      <div class="col-6 col-lg-3">
        <div class="cs-card">
          <div class="cs-card-ic bg-label-success text-success"><i class="bx bx-group"></i></div>
          <div><div class="cs-card-val" id="cStudents">—</div><div class="cs-card-lbl">Students</div></div>
        </div>
      </div>
      <div class="col-6 col-lg-3">
        <div class="cs-card">
          <div class="cs-card-ic bg-label-warning text-warning"><i class="bx bx-pie-chart-alt-2"></i></div>
          <div><div class="cs-card-val" id="cOcc">—</div><div class="cs-card-lbl">Avg Occupancy</div></div>
        </div>
      </div>
    </div>

    <!-- Main -->
    <div class="ec-card mb-0">
      <div class="ec-card-header">
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-2 mb-3">
          <div class="ec-section-title-wrap">
            <span class="ec-section-icon"><i class="bx bx-buildings"></i></span>
            <div>
              <div class="ec-section-title">Academic Structure</div>
              <div class="ec-section-subtitle" id="resultText">Loading…</div>
            </div>
          </div>
        </div>

        <div class="cs-fbar">
          <div class="cs-srch-wrap">
            <i class="bx bx-search cs-srch-ic"></i>
            <input type="search" class="cs-srch-inp" id="csSearch" placeholder="Search class or section…">
          </div>
          <button class="cs-btn" id="btnExpand"><i class="bx bx-expand-vertical"></i>Expand all</button>
          <button class="cs-btn" id="btnClone"><i class="bx bx-copy-alt"></i>Clone last year</button>
          <button class="cs-btn primary ms-auto" id="btnAddClass"><i class="bx bx-plus"></i>Add Class</button>
        </div>
      </div>

      <div class="ec-card-body pt-2">
        <div id="classList"></div>

        <div class="cs-empty d-none" id="emptyState">
          <div class="cs-empty-ic"><i class="bx bx-search-alt"></i></div>
          <h6 class="fw-bold mb-1" style="color:var(--ec-text-dark);">No classes found</h6>
          <p class="text-muted small mb-0">Try a different search, or add a class.</p>
        </div>
      </div>
    </div>

  </div>
</div>

<!-- Class modal -->
<div class="modal fade" id="classModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content" style="border:0;border-radius:20px;overflow:hidden;">
      <div class="ec-card-header d-flex align-items-center justify-content-between p-3 p-lg-4">
        <div class="ec-section-title-wrap">
          <span class="ec-section-icon"><i class="bx bx-been-here"></i></span>
          <div>
            <div class="ec-section-title" id="classModalTitle">Add Class</div>
            <div class="ec-section-subtitle">Academic grade definition</div>
          </div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="ec-card-body p-3 p-lg-4">
        <div class="row g-3">
          <div class="col-12 col-sm-8">
            <label class="form-label cs-modal-lbl">Class Name</label>
            <input type="text" class="form-control" id="mClassName" placeholder="e.g. Class 6">
          </div>
          <div class="col-12 col-sm-4">
            <label class="form-label cs-modal-lbl">Order / Rank</label>
            <input type="number" class="form-control" id="mClassRank" min="1" placeholder="6">
          </div>
          <div class="col-12 col-sm-6">
            <label class="form-label cs-modal-lbl">Stream</label>
            <select class="form-select" id="mClassStream">
              <option value="gen">General</option>
              <option value="sci">Science</option>
              <option value="com">Commerce</option>
              <option value="art">Arts</option>
            </select>
          </div>
          <div class="col-12 col-sm-6">
            <label class="form-label cs-modal-lbl">Coordinator</label>
            <input type="text" class="form-control" id="mClassCoord" placeholder="Optional">
          </div>
        </div>
        <div class="alert alert-info d-flex align-items-start gap-2 mt-3 mb-0" style="border-radius:12px;font-size:.82rem;">
          <i class="bx bx-info-circle fs-5"></i>
          <span><strong>Rank</strong> drives promotion order (Class 5 → Class 6) and report-card sequencing.</span>
        </div>
      </div>
      <div class="ec-card-body pt-0 p-3 p-lg-4 d-flex flex-column flex-sm-row justify-content-end gap-2">
        <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary px-4" id="classSave"><i class="bx bx-check me-1"></i>Save Class</button>
      </div>
    </div>
  </div>
</div>

<!-- Section modal -->
<div class="modal fade" id="secModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content" style="border:0;border-radius:20px;overflow:hidden;">
      <div class="ec-card-header d-flex align-items-center justify-content-between p-3 p-lg-4">
        <div class="ec-section-title-wrap">
          <span class="ec-section-icon"><i class="bx bx-grid"></i></span>
          <div>
            <div class="ec-section-title" id="secModalTitle">Add Section</div>
            <div class="ec-section-subtitle" id="secModalSub">—</div>
          </div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="ec-card-body p-3 p-lg-4">
        <div class="row g-3">
          <div class="col-12 col-sm-6">
            <label class="form-label cs-modal-lbl">Section Name</label>
            <input type="text" class="form-control" id="mSecName" placeholder="e.g. A">
          </div>
          <div class="col-12 col-sm-6">
            <label class="form-label cs-modal-lbl">Capacity</label>
            <input type="number" class="form-control" id="mSecCap" min="1" placeholder="40">
          </div>
          <div class="col-12 col-sm-6">
            <label class="form-label cs-modal-lbl">Room No.</label>
            <input type="text" class="form-control" id="mSecRoom" placeholder="e.g. 204">
          </div>
          <div class="col-12 col-sm-6">
            <label class="form-label cs-modal-lbl">Class Teacher</label>
            <div class="form-control d-flex align-items-center" id="mSecTeacherView" style="background:#f8f7f5;color:var(--ec-text-muted);font-weight:700;">—</div>
            <div class="form-text" style="font-size:.72rem;"><i class="bx bx-lock-alt"></i> Assigned on the <strong>Assign Class Teacher</strong> page.</div>
          </div>
        </div>
      </div>
      <div class="ec-card-body pt-0 p-3 p-lg-4 d-flex flex-column flex-sm-row justify-content-end gap-2">
        <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary px-4" id="secSave"><i class="bx bx-check me-1"></i>Save Section</button>
      </div>
    </div>
  </div>
</div>

@section PageScripts {
<script>
(function(){
'use strict';

var nextClassId=100, nextSecId=900;
var editClassId=null, secCtx={classId:null, secId:null};

/* Mock structure (would come from SP). cap = capacity, str = current strength */
var DATA=[
  {id:1, name:'Class 1',  rank:1,  stream:'gen', coord:'Mrs. Rao',
    sections:[
      {id:11,name:'A',cap:40,str:38,teacher:'Mrs. Rao',room:'101'},
      {id:12,name:'B',cap:40,str:35,teacher:'Ms. Dsouza',room:'102'}
    ]},
  {id:2, name:'Class 2',  rank:2,  stream:'gen', coord:'Mr. Khanna',
    sections:[
      {id:21,name:'A',cap:40,str:40,teacher:'Mr. Khanna',room:'103'},
      {id:22,name:'B',cap:40,str:33,teacher:'Mrs. Iyer',room:'104'}
    ]},
  {id:3, name:'Class 5',  rank:5,  stream:'gen', coord:'Mrs. Sharma',
    sections:[
      {id:31,name:'A',cap:42,str:39,teacher:'Mrs. Sharma',room:'201'},
      {id:32,name:'B',cap:42,str:41,teacher:'Mr. Banerjee',room:'202'},
      {id:33,name:'C',cap:42,str:28,teacher:'Ms. Fernandes',room:'203'}
    ]},
  {id:4, name:'Class 10', rank:10, stream:'gen', coord:'Mr. Mehta',
    sections:[
      {id:41,name:'A',cap:45,str:44,teacher:'Mr. Mehta',room:'301'},
      {id:42,name:'B',cap:45,str:45,teacher:'Mrs. Pillai',room:'302'}
    ]},
  {id:5, name:'Class 11', rank:11, stream:'sci', coord:'Dr. Nair',
    sections:[
      {id:51,name:'A',cap:50,str:31,teacher:'Dr. Nair',room:'401'}
    ]},
  {id:6, name:'Class 12', rank:12, stream:'com', coord:'Mr. Gupta',
    sections:[
      {id:61,name:'A',cap:50,str:22,teacher:'Mr. Gupta',room:'402'}
    ]}
];

var openSet={};   // classId -> bool

function esc(s){ return String(s).replace(/[&<>"]/g,function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c];}); }
function toast(t,m){ if(typeof toastr!=='undefined') toastr[t](m); }
function classStr(c){ return c.sections.reduce(function(a,s){return a+s.str;},0); }
function classCap(c){ return c.sections.reduce(function(a,s){return a+s.cap;},0); }
function streamLbl(s){ return {gen:'General',sci:'Science',com:'Commerce',art:'Arts'}[s]||'General'; }
function barCls(pct){ return pct>=100?'full':(pct>=85?'warn':'ok'); }

/* Summary */
function updateCards(){
  var sections=0, students=0, cap=0;
  DATA.forEach(function(c){ sections+=c.sections.length; students+=classStr(c); cap+=classCap(c); });
  document.getElementById('cClasses').textContent=DATA.length;
  document.getElementById('cSections').textContent=sections;
  document.getElementById('cStudents').textContent=students.toLocaleString('en-IN');
  document.getElementById('cOcc').textContent=(cap?Math.round(students/cap*100):0)+'%';
}

/* Render */
function render(){
  var q=document.getElementById('csSearch').value.toLowerCase().trim();
  var list=DATA.slice().sort(function(a,b){return a.rank-b.rank;});

  var box=document.getElementById('classList'), empty=document.getElementById('emptyState');
  var matched=0, html='';

  list.forEach(function(c){
    var hitClass=!q || c.name.toLowerCase().includes(q);
    var hitSec=c.sections.some(function(s){return ('section '+s.name).toLowerCase().includes(q) || s.name.toLowerCase()===q;});
    if(q && !hitClass && !hitSec) return;
    matched++;

    var str=classStr(c), cap=classCap(c), pct=cap?Math.round(str/cap*100):0;
    var isOpen=(q && hitSec) ? true : !!openSet[c.id];

    var secCards=c.sections.map(function(s){
      var p=s.cap?Math.round(s.str/s.cap*100):0;
      return '<div class="cs-sec">'
        +'<div class="cs-sec-top">'
        +  '<div class="cs-sec-name"><span class="cs-sec-badge">'+esc(s.name)+'</span><span class="cs-sec-title">Section '+esc(s.name)+'</span></div>'
        +  '<div class="d-flex gap-1">'
        +    '<button class="cs-icon-btn js-edit-sec" data-c="'+c.id+'" data-s="'+s.id+'" title="Edit"><i class="bx bx-edit-alt"></i></button>'
        +    '<button class="cs-icon-btn danger js-del-sec" data-c="'+c.id+'" data-s="'+s.id+'" title="Delete"><i class="bx bx-trash"></i></button>'
        +  '</div>'
        +'</div>'
        +'<div class="cs-sec-meta"><i class="bx bx-user-voice"></i>'+esc(s.teacher||'No teacher')+'</div>'
        +'<div class="cs-sec-meta"><i class="bx bx-door-open"></i>Room '+esc(s.room||'—')+'</div>'
        +'<div class="cs-occ-row"><span class="cs-occ-num">'+s.str+' / '+s.cap+'</span><span class="cs-occ-pct">'+p+'%</span></div>'
        +'<div class="cs-bar"><div class="cs-bar-fill '+barCls(p)+'" style="width:'+Math.min(p,100)+'%"></div></div>'
        +'</div>';
    }).join('');

    secCards+='<button class="cs-add-sec js-add-sec" data-c="'+c.id+'"><i class="bx bx-plus-circle"></i>Add Section</button>';

    var streamBadge=(c.stream && c.stream!=='gen')
      ? '<span class="cs-stream '+c.stream+'">'+streamLbl(c.stream)+'</span>' : '';

    html+='<div class="cs-class'+(isOpen?' open':'')+'" data-c="'+c.id+'">'
      +'<div class="cs-class-head js-toggle" data-c="'+c.id+'">'
      +  '<i class="bx bx-chevron-right cs-chev"></i>'
      +  '<div class="cs-rank">'+(c.rank||'–')+'</div>'
      +  '<div class="flex-grow-1">'
      +    '<div class="d-flex align-items-center gap-2 flex-wrap"><span class="cs-class-name">'+esc(c.name)+'</span>'+streamBadge+'</div>'
      +    '<div class="cs-class-meta">'+(c.coord?('Coordinator: '+esc(c.coord)):'No coordinator')+'</div>'
      +  '</div>'
      +  '<div class="d-flex align-items-center gap-3 cs-class-meta-wrap">'
      +    '<span class="cs-pill"><i class="bx bx-grid"></i>'+c.sections.length+' sec</span>'
      +    '<span class="cs-pill"><i class="bx bx-group"></i>'+str+'/'+cap+'</span>'
      +  '</div>'
      +  '<div class="d-flex gap-1">'
      +    '<button class="cs-icon-btn js-edit-class" data-c="'+c.id+'" title="Edit class"><i class="bx bx-edit-alt"></i></button>'
      +    '<button class="cs-icon-btn danger js-del-class" data-c="'+c.id+'" title="Delete class"><i class="bx bx-trash"></i></button>'
      +  '</div>'
      +'</div>'
      +'<div class="cs-sec-body"><div class="cs-sec-grid">'+secCards+'</div></div>'
      +'</div>';
  });

  if(!matched){ box.innerHTML=''; empty.classList.remove('d-none'); }
  else { box.innerHTML=html; empty.classList.add('d-none'); }

  document.getElementById('resultText').textContent=DATA.length+' classes · '+
    DATA.reduce(function(a,c){return a+c.sections.length;},0)+' sections defined';

  bindEvents();
}

function bindEvents(){
  document.querySelectorAll('.js-toggle').forEach(function(el){
    el.addEventListener('click',function(e){
      if(e.target.closest('button')) return;
      var id=parseInt(this.dataset.c,10);
      openSet[id]=!openSet[id]; render();
    });
  });
  document.querySelectorAll('.js-add-sec').forEach(function(b){ b.addEventListener('click',function(){ openSecModal(parseInt(this.dataset.c,10),null); }); });
  document.querySelectorAll('.js-edit-sec').forEach(function(b){ b.addEventListener('click',function(){ openSecModal(parseInt(this.dataset.c,10),parseInt(this.dataset.s,10)); }); });
  document.querySelectorAll('.js-del-sec').forEach(function(b){ b.addEventListener('click',function(){ delSection(parseInt(this.dataset.c,10),parseInt(this.dataset.s,10)); }); });
  document.querySelectorAll('.js-edit-class').forEach(function(b){ b.addEventListener('click',function(){ openClassModal(parseInt(this.dataset.c,10)); }); });
  document.querySelectorAll('.js-del-class').forEach(function(b){ b.addEventListener('click',function(){ delClass(parseInt(this.dataset.c,10)); }); });
}

/* ---- Class modal ---- */
function openClassModal(id){
  editClassId=id;
  var c=id?DATA.find(function(x){return x.id===id;}):null;
  document.getElementById('classModalTitle').textContent=c?'Edit Class':'Add Class';
  document.getElementById('mClassName').value=c?c.name:'';
  document.getElementById('mClassRank').value=c?c.rank:'';
  document.getElementById('mClassStream').value=c?c.stream:'gen';
  document.getElementById('mClassCoord').value=c?(c.coord||''):'';
  new bootstrap.Modal(document.getElementById('classModal')).show();
}
document.getElementById('btnAddClass').addEventListener('click',function(){ openClassModal(null); });
document.getElementById('classSave').addEventListener('click',function(){
  var name=document.getElementById('mClassName').value.trim();
  if(!name){ toast('error','Class name is required.'); return; }
  var rank=parseInt(document.getElementById('mClassRank').value,10)||0;
  var stream=document.getElementById('mClassStream').value;
  var coord=document.getElementById('mClassCoord').value.trim();
  if(editClassId){
    var c=DATA.find(function(x){return x.id===editClassId;});
    c.name=name; c.rank=rank; c.stream=stream; c.coord=coord;
    toast('success','Class updated.');
  } else {
    var nid=++nextClassId;
    DATA.push({id:nid,name:name,rank:rank,stream:stream,coord:coord,sections:[]});
    openSet[nid]=true;
    toast('success','Class added.');
  }
  // Wire to SP: save class (id,name,rank,stream,coord)
  bootstrap.Modal.getInstance(document.getElementById('classModal')).hide();
  updateCards(); render();
});
function delClass(id){
  var c=DATA.find(function(x){return x.id===id;});
  if(!c) return;
  if(classStr(c)>0){ toast('error','Cannot delete — '+classStr(c)+' students are enrolled. Move them first.'); return; }
  if(!confirm('Delete '+c.name+' and its '+c.sections.length+' section(s)?')) return;
  DATA=DATA.filter(function(x){return x.id!==id;});
  // Wire to SP: delete class
  updateCards(); render(); toast('success',c.name+' deleted.');
}

/* ---- Section modal ---- */
function openSecModal(classId,secId){
  secCtx={classId:classId,secId:secId};
  var c=DATA.find(function(x){return x.id===classId;});
  var s=secId?c.sections.find(function(x){return x.id===secId;}):null;
  document.getElementById('secModalTitle').textContent=s?'Edit Section':'Add Section';
  document.getElementById('secModalSub').textContent=c.name;
  document.getElementById('mSecName').value=s?s.name:'';
  document.getElementById('mSecCap').value=s?s.cap:40;
  document.getElementById('mSecRoom').value=s?(s.room||''):'';
  document.getElementById('mSecTeacherView').textContent=(s&&s.teacher)?s.teacher:'Not assigned';
  new bootstrap.Modal(document.getElementById('secModal')).show();
}
document.getElementById('secSave').addEventListener('click',function(){
  var c=DATA.find(function(x){return x.id===secCtx.classId;});
  if(!c) return;
  var name=document.getElementById('mSecName').value.trim();
  if(!name){ toast('error','Section name is required.'); return; }
  var cap=parseInt(document.getElementById('mSecCap').value,10)||0;
  var room=document.getElementById('mSecRoom').value.trim();
  if(secCtx.secId){
    var s=c.sections.find(function(x){return x.id===secCtx.secId;});
    if(cap<s.str){ toast('error','Capacity ('+cap+') is below current strength ('+s.str+').'); return; }
    s.name=name; s.cap=cap; s.room=room;   /* teacher is managed on the Assign Class Teacher page */
    toast('success','Section updated.');
  } else {
    c.sections.push({id:++nextSecId,name:name,cap:cap,str:0,teacher:'',room:room});
    toast('success','Section added to '+c.name+'.');
  }
  openSet[c.id]=true;
  // Wire to SP: save section (classId,secId,name,cap,teacher,room)
  bootstrap.Modal.getInstance(document.getElementById('secModal')).hide();
  updateCards(); render();
});
function delSection(classId,secId){
  var c=DATA.find(function(x){return x.id===classId;});
  var s=c.sections.find(function(x){return x.id===secId;});
  if(!s) return;
  if(s.str>0){ toast('error','Cannot delete — '+s.str+' students in Section '+s.name+'. Move them first.'); return; }
  if(!confirm('Delete Section '+s.name+' of '+c.name+'?')) return;
  c.sections=c.sections.filter(function(x){return x.id!==secId;});
  openSet[c.id]=true;
  // Wire to SP: delete section
  updateCards(); render(); toast('success','Section deleted.');
}

/* ---- Toolbar ---- */
var allOpen=false;
document.getElementById('btnExpand').addEventListener('click',function(){
  allOpen=!allOpen;
  DATA.forEach(function(c){ openSet[c.id]=allOpen; });
  this.innerHTML=allOpen?'<i class="bx bx-collapse-vertical"></i>Collapse all':'<i class="bx bx-expand-vertical"></i>Expand all';
  render();
});
document.getElementById('btnClone').addEventListener('click',function(){
  // Wire to SP: clone previous session structure into current year
  toast('info','Clone previous session: copies all classes & sections (without students) into the new academic year.');
});
document.getElementById('csSearch').addEventListener('input',render);

/* Init */
updateCards();
render();

})();
</script>
}
