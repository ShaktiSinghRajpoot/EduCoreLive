@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model EduCoreDataAccessLayer.Models.RolePermissionMatrix
@{
    ViewData["Title"] = "Role Permissions";
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
}

@section PageStyles {
<link href="~/css/educore-theme.css" rel="stylesheet" />
<style>
.pm-group{ border:1px solid var(--ec-border); border-radius:var(--ec-radius); background:#fff; margin-bottom:1.1rem; overflow:hidden; }
.pm-group-hdr{ display:flex; align-items:center; justify-content:space-between; gap:.5rem; padding:.7rem 1.1rem; background:var(--ec-primary-soft); border-bottom:1px solid var(--ec-border); }
.pm-group-title{ font-size:.82rem; font-weight:900; text-transform:uppercase; letter-spacing:.05em; color:var(--ec-text-dark); }
.pm-row{ display:grid; grid-template-columns:1fr 110px 110px; align-items:center; padding:.6rem 1.1rem; border-bottom:1px solid var(--ec-border); }
.pm-row:last-child{ border-bottom:none; }
.pm-feat{ font-size:.9rem; font-weight:700; color:var(--ec-text-dark); }
.pm-col-hdr{ font-size:.66rem; font-weight:800; text-transform:uppercase; letter-spacing:.04em; color:var(--ec-text-light); text-align:center; }
.pm-cell{ text-align:center; }
.pm-cell input{ width:1.25rem; height:1.25rem; cursor:pointer; }
.pm-cell .muted{ color:var(--ec-text-light); font-size:.8rem; }
.pm-sticky{ position:sticky; bottom:0; background:rgba(255,255,255,.96); backdrop-filter:blur(8px); border-top:1px solid var(--ec-border); padding:.9rem 1.1rem; display:flex; justify-content:space-between; align-items:center; gap:.75rem; border-radius:0 0 var(--ec-radius) var(--ec-radius); z-index:5; }
</style>
}

<div class="ec-page-shell">
  <div class="ec-page-content">

    <div class="ec-page-header">
      <div class="ec-page-header-inner">
        <div class="ec-page-title-wrap">
          <div class="ec-page-icon rounded-4 d-flex align-items-center justify-content-center">
            <i class="bx bx-slider-alt fs-4"></i>
          </div>
          <div>
            <h4 class="ec-page-title mb-1">Permissions — @Model.RoleName</h4>
            <div class="ec-page-subtitle">Tick what this role can do. <strong>Manage</strong> includes create, edit &amp; delete; it also grants <strong>View</strong>.</div>
          </div>
        </div>
        <a class="btn btn-outline-secondary d-flex align-items-center gap-1" asp-area="Admin" asp-controller="Roles" asp-action="Index">
          <i class="bx bx-arrow-back"></i><span>Back to Roles</span>
        </a>
      </div>
    </div>

    <form asp-area="Admin" asp-controller="Roles" asp-action="SavePermissions" method="post">
      @Html.AntiForgeryToken()
      <input type="hidden" name="roleId" value="@Model.RoleId" />

      @foreach (var g in Model.Groups)
      {
        <div class="pm-group">
          <div class="pm-group-hdr">
            <span class="pm-group-title">@g.GroupName</span>
            <div class="d-flex gap-2">
              <button type="button" class="btn btn-sm btn-outline-primary py-0" onclick="toggleGroup(this, true)">Select all</button>
              <button type="button" class="btn btn-sm btn-outline-secondary py-0" onclick="toggleGroup(this, false)">Clear</button>
            </div>
          </div>
          <div class="pm-row">
            <div></div>
            <div class="pm-col-hdr">View</div>
            <div class="pm-col-hdr">Manage</div>
          </div>
          @foreach (var row in g.Rows)
          {
            <div class="pm-row">
              <div class="pm-feat">@row.FeatureLabel</div>
              <div class="pm-cell">
                @if (row.ViewId is int vid)
                {
                  <input type="checkbox" name="permissionIds" value="@vid" class="cb-view" data-feat="@row.FeatureLabel" checked="@row.ViewGranted" />
                }
                else { <span class="muted">—</span> }
              </div>
              <div class="pm-cell">
                @if (row.ManageId is int mid)
                {
                  <input type="checkbox" name="permissionIds" value="@mid" class="cb-manage" data-feat="@row.FeatureLabel" checked="@row.ManageGranted" />
                }
                else { <span class="muted">—</span> }
              </div>
            </div>
          }
        </div>
      }

      <div class="pm-sticky">
        <span class="text-muted small"><i class="bx bx-info-circle me-1"></i>Changes apply to everyone with this role.</span>
        <button type="submit" class="btn btn-primary px-4"><i class="bx bx-check me-1"></i>Save Permissions</button>
      </div>
    </form>

  </div>
</div>

@section PageScripts {
<script>
  // Ticking "Manage" auto-ticks "View" for the same feature (manage implies view).
  document.querySelectorAll('.cb-manage').forEach(function(cb){
    cb.addEventListener('change', function(){
      if(!cb.checked) return;
      var feat = cb.getAttribute('data-feat');
      var view = document.querySelector('.cb-view[data-feat="'+CSS.escape(feat)+'"]');
      if(view) view.checked = true;
    });
  });
  function toggleGroup(btn, on){
    var group = btn.closest('.pm-group');
    group.querySelectorAll('input[type="checkbox"]').forEach(function(cb){ cb.checked = on; });
  }
</script>
}
