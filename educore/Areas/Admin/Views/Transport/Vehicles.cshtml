@{
    ViewData["Title"] = "Vehicles & Drivers";
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
    var vehicles = ViewBag.Vehicles as List<EduCoreDataAccessLayer.Models.Admin.TransportVehicle>
                   ?? new List<EduCoreDataAccessLayer.Models.Admin.TransportVehicle>();
    var routeOptions = ViewBag.RouteOptions as List<EduCoreDataAccessLayer.Models.Admin.TransportRoute>
                   ?? new List<EduCoreDataAccessLayer.Models.Admin.TransportRoute>();
}

@section PageStyles {
<style>
.tv-page{--p:#ff8a00;--soft:#fff4e6;--border:#ececf5;--heading:#2b1b12;--muted:#8b8175;}
.tv-page .btn-primary{background:linear-gradient(135deg,#ff8a00,#ff9f2f);border:0;border-radius:999px;font-weight:800;box-shadow:0 12px 24px rgba(255,138,0,.22);}
.tv-card{border:1px solid var(--border);border-radius:16px;background:#fff;}
.tv-page table{font-size:.9rem;} .tv-page th{color:var(--muted);font-size:.74rem;text-transform:uppercase;font-weight:800;}
.badge-off{background:#f1f0ee;color:#8b8175;border-radius:999px;padding:.15rem .6rem;font-size:.72rem;font-weight:800;}
</style>
}

<div class="ec-page-shell tv-page">
  <div class="ec-page-content">
    <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
      <div class="d-flex align-items-center gap-2">
        <div class="ec-page-icon rounded-4 d-flex align-items-center justify-content-center" style="background:var(--soft);color:var(--p);width:46px;height:46px"><i class="bx bx-car fs-4"></i></div>
        <div><h4 class="mb-0" style="color:var(--heading);font-weight:900">Vehicles &amp; Drivers</h4>
          <div class="text-muted" style="font-size:.8rem">Register buses and attach them to a route</div></div>
      </div>
      <button class="btn btn-primary px-3" id="addVehicleBtn"><i class="bx bx-plus me-1"></i>Add Vehicle</button>
    </div>

    <div class="tv-card p-2 p-lg-3">
      <table class="table align-middle mb-0">
        <thead><tr><th>Vehicle No</th><th>Capacity</th><th>Driver</th><th>Phone</th><th>Route</th><th></th></tr></thead>
        <tbody>
        @if(!vehicles.Any()){ <tr><td colspan="6" class="text-center text-muted py-4">No vehicles yet.</td></tr> }
        @foreach(var v in vehicles){
          <tr>
            <td class="fw-bold">@v.VehicleNo @(v.IsActive ? "" : Html.Raw("<span class='badge-off ms-1'>inactive</span>"))</td>
            <td>@(v.Capacity?.ToString() ?? "—")</td>
            <td>@(string.IsNullOrWhiteSpace(v.DriverName) ? "—" : v.DriverName)</td>
            <td>@(string.IsNullOrWhiteSpace(v.DriverPhone) ? "—" : v.DriverPhone)</td>
            <td>@(string.IsNullOrWhiteSpace(v.RouteName) ? "—" : v.RouteName)</td>
            <td class="text-end">
              <button class="btn btn-sm btn-outline-secondary rounded-circle editV"
                      data-id="@v.VehicleId" data-no="@v.VehicleNo" data-cap="@v.Capacity" data-dn="@v.DriverName" data-dp="@v.DriverPhone" data-rid="@v.RouteId"><i class="bx bx-edit"></i></button>
              <button class="btn btn-sm btn-outline-secondary rounded-circle toggleV" data-id="@v.VehicleId"><i class="bx bx-power-off"></i></button>
              <button class="btn btn-sm btn-outline-danger rounded-circle delV" data-id="@v.VehicleId" data-no="@v.VehicleNo"><i class="bx bx-trash"></i></button>
            </td>
          </tr>
        }
        </tbody>
      </table>
    </div>
  </div>
</div>

<div class="modal fade" id="vModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content" style="border-radius:18px">
      <div class="modal-header"><h5 class="modal-title" id="vTitle">Add Vehicle</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
      <div class="modal-body">
        <input type="hidden" id="vId" value="0">
        <div class="row g-3">
          <div class="col-md-6"><label class="form-label fw-bold">Vehicle Number</label><input id="vNo" class="form-control" placeholder="e.g. RJ14-AB-1234"></div>
          <div class="col-md-6"><label class="form-label fw-bold">Capacity</label><input id="vCap" type="number" min="0" class="form-control"></div>
          <div class="col-md-6"><label class="form-label fw-bold">Driver Name</label><input id="vDn" class="form-control"></div>
          <div class="col-md-6"><label class="form-label fw-bold">Driver Phone</label><input id="vDp" class="form-control"></div>
          <div class="col-12"><label class="form-label fw-bold">Route</label>
            <select id="vRid" class="form-select"><option value="">— Not assigned —</option>
              @foreach(var r in routeOptions){ <option value="@r.RouteId">@r.RouteName</option> }
            </select></div>
        </div>
      </div>
      <div class="modal-footer"><button class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button><button class="btn btn-primary" id="saveVBtn">Save</button></div>
    </div>
  </div>
</div>

@Html.AntiForgeryToken()

@section PageScripts {
<script>
$(function(){
  'use strict';
  var CSRF=$('input[name="__RequestVerificationToken"]').val();
  var URL={ save:'@Url.Action("SaveVehicle")', del:'@Url.Action("DeleteVehicle")', toggle:'@Url.Action("ToggleVehicleStatus")' };
  function notify(t,m){ if(typeof toastr!=='undefined') toastr[t](m); }
  function post(url,data){ return $.ajax({url:url,type:'POST',contentType:'application/json',headers:{'RequestVerificationToken':CSRF},data:JSON.stringify(data)}); }
  function postForm(url,data){ data.__RequestVerificationToken=CSRF; return $.post(url,data); }

  $('#addVehicleBtn').on('click',function(){ $('#vTitle').text('Add Vehicle'); $('#vId').val(0); $('#vNo,#vCap,#vDn,#vDp').val(''); $('#vRid').val(''); new bootstrap.Modal('#vModal').show(); });
  $('.editV').on('click',function(){ var d=$(this); $('#vTitle').text('Edit Vehicle'); $('#vId').val(d.data('id')); $('#vNo').val(d.data('no')); $('#vCap').val(d.data('cap')||''); $('#vDn').val(d.data('dn')||''); $('#vDp').val(d.data('dp')||''); $('#vRid').val(d.data('rid')||''); new bootstrap.Modal('#vModal').show(); });

  $('#saveVBtn').on('click',function(){
    var no=$('#vNo').val().trim(); if(!no){ notify('warning','Enter a vehicle number.'); return; }
    post(URL.save,{ vehicleId:Number($('#vId').val())||0, vehicleNo:no, capacity:Number($('#vCap').val())||null,
        driverName:$('#vDn').val().trim(), driverPhone:$('#vDp').val().trim(), routeId:Number($('#vRid').val())||null })
      .done(function(res){ if(res.success){ notify('success',res.message); setTimeout(function(){location.reload();},600);} else notify('error',res.message); });
  });
  $('.toggleV').on('click',function(){ postForm(URL.toggle,{id:$(this).data('id')}).done(function(res){ notify(res.success?'success':'error',res.message); if(res.success) setTimeout(function(){location.reload();},500); }); });
  $('.delV').on('click',function(){ if(!confirm('Delete vehicle "'+$(this).data('no')+'"?')) return; postForm(URL.del,{id:$(this).data('id')}).done(function(res){ notify(res.success?'success':'error',res.message); if(res.success) setTimeout(function(){location.reload();},500); }); });

  if(typeof toastr!=='undefined') toastr.options={closeButton:true,progressBar:true,positionClass:'toast-top-right',timeOut:3000};
});
</script>
}
