@{
    ViewData["Title"] = "Attendance Report";
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
}

@section PageStyles {
<link href="~/css/educore-theme.css" rel="stylesheet" />
<style>
/* ===== Attendance Register / Report (ar-*) ===== */

/* summary cards */
.ar-card{
    border:1px solid var(--ec-border); border-radius:var(--ec-radius);
    background:#fff; padding:1rem 1.1rem; display:flex; align-items:center; gap:.85rem; height:100%;
    transition:var(--ec-transition);
}
.ar-card:hover{ transform:translateY(-2px); box-shadow:var(--ec-shadow); }
.ar-card-ic{ width:44px; height:44px; flex:0 0 44px; border-radius:13px; display:flex; align-items:center; justify-content:center; font-size:1.25rem; }
.ar-card-val{ font-size:1.4rem; font-weight:800; color:var(--ec-text-dark); line-height:1.1; }
.ar-card-lbl{ font-size:.68rem; font-weight:800; color:var(--ec-text-muted); text-transform:uppercase; letter-spacing:.05em; }
.ar-card.alert-card{ border-color:rgba(234,84,85,.3); background:#fff6f6; }

/* toolbar */
.ar-fbar{ display:flex; align-items:center; gap:.55rem; flex-wrap:wrap; }
.ar-select{ height:38px; min-width:120px; padding:0 .65rem; border-radius:9px; border:1px solid var(--ec-border); background:#fff; font-size:.83rem; font-weight:700; color:var(--ec-text,#2b2c40); outline:none; transition:var(--ec-transition); }
.ar-select:focus{ border-color:rgba(255,138,0,.55); box-shadow:0 0 0 3px rgba(255,138,0,.1); }
.ar-btn{ height:38px; padding:0 .85rem; border-radius:9px; border:1px solid var(--ec-border); background:#fafaf8; font-size:.79rem; font-weight:700; color:var(--ec-text-muted); cursor:pointer; outline:none; display:inline-flex; align-items:center; gap:.35rem; transition:var(--ec-transition); white-space:nowrap; }
.ar-btn:hover{ background:#fff; border-color:rgba(255,138,0,.4); color:var(--ec-text,#2b2c40); }

/* segmented view toggle */
.ar-seg{ display:inline-flex; border:1px solid var(--ec-border); border-radius:9px; overflow:hidden; background:#fafaf8; }
.ar-seg button{ border:0; background:transparent; padding:0 .85rem; height:38px; font-size:.79rem; font-weight:700; color:var(--ec-text-muted); cursor:pointer; transition:var(--ec-transition); display:inline-flex; align-items:center; gap:.35rem; }
.ar-seg button.on{ background:var(--ec-primary); color:#fff; }

/* legend */
.ar-legend{ display:flex; gap:.9rem; flex-wrap:wrap; align-items:center; font-size:.73rem; font-weight:700; color:var(--ec-text-muted); }
.ar-legend span{ display:inline-flex; align-items:center; gap:.35rem; }
.ar-key{ width:16px; height:16px; border-radius:5px; display:inline-flex; align-items:center; justify-content:center; font-size:.6rem; font-weight:800; }

/* mark colors */
.m-P{ background:#d4edda; color:#155724; }
.m-A{ background:#fde8e8; color:#b02a37; }
.m-L{ background:#fff3cd; color:#856404; }
.m-H{ background:#eceff5; color:#9aa1b9; }
.m-x{ background:#fafafa; color:#cfcfcf; }

/* register grid */
.ar-wrap{ overflow-x:auto; -webkit-overflow-scrolling:touch; }
.ar-reg{ border-collapse:separate; border-spacing:0; width:100%; min-width:780px; font-size:.78rem; }
.ar-reg th, .ar-reg td{ padding:.3rem; text-align:center; white-space:nowrap; }
.ar-reg thead th{ background:linear-gradient(180deg,#fffaf3,#fff6ea); color:var(--ec-text-light,#9a938b); font-size:.66rem; font-weight:800; border-bottom:1px solid var(--ec-border); position:sticky; top:0; }
.ar-reg th.ar-stick, .ar-reg td.ar-stick{ position:sticky; left:0; z-index:2; background:#fff; text-align:left; min-width:160px; box-shadow:1px 0 0 var(--ec-border); }
.ar-reg thead th.ar-stick{ z-index:3; background:#fff6ea; }
.ar-reg th.wknd{ color:#c2410c; }
.ar-nm{ font-weight:800; color:var(--ec-text-dark); font-size:.8rem; line-height:1.15; }
.ar-rl{ font-size:.68rem; color:var(--ec-text-muted); font-weight:650; }
.ar-mark{ width:24px; height:24px; line-height:24px; border-radius:6px; display:inline-block; font-weight:800; font-size:.68rem; }
.ar-reg tbody tr:hover td:not(.ar-stick){ background:#fffaf3; }
.ar-totcol{ font-weight:800; }
.ar-pct{ font-weight:800; padding:.15rem .45rem; border-radius:7px; font-size:.74rem; display:inline-block; }
.ar-pct.good{ background:#d4edda; color:#155724; }
.ar-pct.warn{ background:#fff3cd; color:#856404; }
.ar-pct.bad{ background:#fde8e8; color:#b02a37; }

/* defaulter cards */
.ar-def{ border:1px solid var(--ec-border); border-radius:13px; background:#fff; padding:.75rem .85rem; display:flex; align-items:center; gap:.7rem; transition:var(--ec-transition); }
.ar-def:hover{ box-shadow:var(--ec-shadow); }
.ar-def-av{ width:38px; height:38px; flex:0 0 38px; border-radius:11px; background:#fde8e8; color:#b02a37; display:flex; align-items:center; justify-content:center; font-weight:800; font-size:.75rem; }
.ar-def-bar{ height:6px; border-radius:99px; background:#eceff5; overflow:hidden; margin-top:.3rem; }
.ar-def-fill{ height:100%; border-radius:99px; background:linear-gradient(90deg,#ea5455,#ff7674); }

/* student-history rows (mobile-friendly list view) */
.ar-hist{ display:flex; flex-direction:column; gap:.5rem; }
.ar-hrow{ display:flex; align-items:center; gap:.7rem; border:1px solid var(--ec-border); border-radius:13px; background:#fff; padding:.7rem .85rem; }
.ar-hrow-av{ width:38px; height:38px; flex:0 0 38px; border-radius:11px; background:var(--ec-primary-light); color:var(--ec-primary); display:flex; align-items:center; justify-content:center; font-weight:800; font-size:.75rem; }
.ar-hrow-mini{ display:flex; gap:.7rem; flex-wrap:wrap; font-size:.72rem; font-weight:700; color:var(--ec-text-muted); }
.ar-hrow-mini b{ color:var(--ec-text-dark); }

.ar-empty{ padding:2.5rem 1rem; text-align:center; }
.ar-empty-ic{ width:60px; height:60px; border-radius:17px; background:var(--ec-primary-light); color:var(--ec-primary); display:inline-flex; align-items:center; justify-content:center; font-size:1.7rem; margin-bottom:.8rem; }

@@media (max-width:575.98px){
    .ar-card{ padding:.8rem .9rem; }
    .ar-card-val{ font-size:1.2rem; }
    .ar-reg th.ar-stick, .ar-reg td.ar-stick{ min-width:130px; }
}
</style>
}

<div class="ec-page-shell">
  <div class="ec-page-content">

    <!-- Header -->
    <div class="ec-page-header">
      <div class="ec-page-header-inner">
        <div class="ec-page-title-wrap">
          <div class="ec-page-icon rounded-4 d-flex align-items-center justify-content-center">
            <i class="bx bx-bar-chart fs-4"></i>
          </div>
          <div>
            <h4 class="ec-page-title mb-1">Attendance Report</h4>
            <div class="ec-page-subtitle">Monthly register, percentages and defaulters — read from daily attendance</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Summary cards -->
    <div class="row g-3 mb-4">
      <div class="col-6 col-lg-3">
        <div class="ar-card">
          <div class="ar-card-ic bg-label-primary" style="color:var(--ec-primary);"><i class="bx bx-calendar"></i></div>
          <div><div class="ar-card-val" id="cDays">—</div><div class="ar-card-lbl">School Days</div></div>
        </div>
      </div>
      <div class="col-6 col-lg-3">
        <div class="ar-card">
          <div class="ar-card-ic bg-label-success text-success"><i class="bx bx-trending-up"></i></div>
          <div><div class="ar-card-val" id="cAvg">—</div><div class="ar-card-lbl">Class Average</div></div>
        </div>
      </div>
      <div class="col-6 col-lg-3">
        <div class="ar-card">
          <div class="ar-card-ic bg-label-info text-info"><i class="bx bx-group"></i></div>
          <div><div class="ar-card-val" id="cStudents">—</div><div class="ar-card-lbl">Students</div></div>
        </div>
      </div>
      <div class="col-6 col-lg-3">
        <div class="ar-card alert-card">
          <div class="ar-card-ic bg-label-danger text-danger"><i class="bx bx-error-circle"></i></div>
          <div><div class="ar-card-val" id="cDefault">—</div><div class="ar-card-lbl">Defaulters &lt; 75%</div></div>
        </div>
      </div>
    </div>

    <!-- Main -->
    <div class="ec-card mb-0">
      <div class="ec-card-header">
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-2 mb-3">
          <div class="ec-section-title-wrap">
            <span class="ec-section-icon"><i class="bx bx-book-open"></i></span>
            <div>
              <div class="ec-section-title" id="regTitle">Attendance Register</div>
              <div class="ec-section-subtitle" id="resultText">Loading…</div>
            </div>
          </div>
          <div class="ar-seg" id="viewSeg">
            <button data-v="register" class="on"><i class="bx bx-table"></i>Register</button>
            <button data-v="defaulters"><i class="bx bx-user-x"></i>Defaulters</button>
            <button data-v="summary"><i class="bx bx-list-ul"></i>Summary</button>
          </div>
        </div>

        <div class="ar-fbar mb-2">
          <select class="ar-select" id="fClass">
            <option>Class 5</option><option selected>Class 9</option><option>Class 10</option><option>Class 12</option>
          </select>
          <select class="ar-select" id="fSection"><option selected>A</option><option>B</option><option>C</option></select>
          <select class="ar-select" id="fMonth"></select>
          <select class="ar-select" id="fYear"><option>2026</option><option selected>2025</option></select>
          <button class="ar-btn" id="btnPrint"><i class="bx bx-printer"></i>Print</button>
          <button class="ar-btn" id="btnExport"><i class="bx bx-spreadsheet"></i>Export</button>
        </div>

        <div class="ar-legend">
          <span><span class="ar-key m-P">P</span>Present</span>
          <span><span class="ar-key m-A">A</span>Absent</span>
          <span><span class="ar-key m-L">L</span>Leave</span>
          <span><span class="ar-key m-H">H</span>Holiday</span>
        </div>
      </div>

      <div class="ec-card-body pt-2">

        <!-- Register grid -->
        <div class="ar-wrap" id="viewRegister">
          <table class="ar-reg" id="regTable"></table>
        </div>

        <!-- Defaulters -->
        <div class="d-none" id="viewDefaulters">
          <div class="row g-2" id="defList"></div>
          <div class="ar-empty d-none" id="defEmpty">
            <div class="ar-empty-ic"><i class="bx bx-check-shield"></i></div>
            <h6 class="fw-bold mb-1" style="color:var(--ec-text-dark);">No defaulters 🎉</h6>
            <p class="text-muted small mb-0">Every student is at or above 75% this month.</p>
          </div>
        </div>

        <!-- Summary (per-student list) -->
        <div class="d-none" id="viewSummary">
          <div class="ar-hist" id="histList"></div>
        </div>

      </div>
    </div>

  </div>
</div>

@section PageScripts {
<script>
(function(){
'use strict';

var MONTHS=['January','February','March','April','May','June','July','August','September','October','November','December'];
var THRESHOLD=75;
var view='register';

/* Mock roster (would come from Classes & Sections roster) */
var STUDENTS=[
  {id:1,name:'Akash Verma',roll:'01'},{id:2,name:'Priya Singh',roll:'02'},{id:3,name:'Ravi Kumar',roll:'03'},
  {id:4,name:'Neha Gupta',roll:'04'},{id:5,name:'Arjun Patel',roll:'05'},{id:6,name:'Sunita Yadav',roll:'06'},
  {id:7,name:'Mohit Sharma',roll:'07'},{id:8,name:'Kavita Joshi',roll:'08'},{id:9,name:'Rahul Tiwari',roll:'09'},
  {id:10,name:'Pooja Mishra',roll:'10'},{id:11,name:'Amit Rajput',roll:'11'},{id:12,name:'Anjali Dubey',roll:'12'}
];

var avatarColors=['primary','success','info','warning','danger','secondary'];
function ini(n){ return n.split(' ').slice(0,2).map(function(w){return w[0];}).join('').toUpperCase(); }
function esc(s){ return String(s).replace(/[&<>"]/g,function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c];}); }
function toast(t,m){ if(typeof toastr!=='undefined') toastr[t](m); }

/* deterministic pseudo-random so the same student+day is stable across re-renders */
function seeded(n){ var x=Math.sin(n)*10000; return x-Math.floor(x); }

/* Build the month's daily marks per student (mock; would come from saved daily attendance SP) */
var DATA={};   // studentId -> array of marks per day ['P','A','L','H',...]
var daysInMonth=0, schoolDays=0, monthIdx=0, year=2025;

function buildMonth(){
  monthIdx=parseInt(document.getElementById('fMonth').value,10);
  year=parseInt(document.getElementById('fYear').value,10);
  daysInMonth=new Date(year,monthIdx+1,0).getDate();
  DATA={}; schoolDays=0;
  /* mark Sundays as holiday for everyone */
  var holiday=[];
  for(var d=1; d<=daysInMonth; d++){ holiday[d]=(new Date(year,monthIdx,d).getDay()===0); }
  for(var d2=1; d2<=daysInMonth; d2++){ if(!holiday[d2]) schoolDays++; }

  STUDENTS.forEach(function(s){
    var arr=[];
    for(var d=1; d<=daysInMonth; d++){
      if(holiday[d]){ arr.push('H'); continue; }
      var r=seeded(s.id*100+d+monthIdx*7);
      /* most present; a few students absent more often to create defaulters */
      var absentBias=(s.id%5===0)?0.30:(s.id%4===0?0.18:0.07);
      var leaveBias=0.04;
      if(r<absentBias) arr.push('A');
      else if(r<absentBias+leaveBias) arr.push('L');
      else arr.push('P');
    }
    DATA[s.id]=arr;
  });
}

function statsFor(id){
  var arr=DATA[id], p=0,a=0,l=0;
  arr.forEach(function(m){ if(m==='P')p++; else if(m==='A')a++; else if(m==='L')l++; });
  var pct = schoolDays? Math.round(p/schoolDays*100) : 0;
  return {p:p,a:a,l:l,pct:pct};
}
function pctCls(pct){ return pct>=THRESHOLD?'good':(pct>=60?'warn':'bad'); }

/* month dropdown */
(function(){ var m=document.getElementById('fMonth'); MONTHS.forEach(function(n,i){ var o=document.createElement('option'); o.value=i; o.textContent=n; if(i===10)o.selected=true; m.appendChild(o); }); })();

function updateCards(){
  var totPct=0, defs=0;
  STUDENTS.forEach(function(s){ var st=statsFor(s.id); totPct+=st.pct; if(st.pct<THRESHOLD) defs++; });
  var avg=STUDENTS.length?Math.round(totPct/STUDENTS.length):0;
  document.getElementById('cDays').textContent=schoolDays;
  document.getElementById('cAvg').textContent=avg+'%';
  document.getElementById('cStudents').textContent=STUDENTS.length;
  document.getElementById('cDefault').textContent=defs;
}

function renderRegister(){
  var t=document.getElementById('regTable');
  var head='<thead><tr><th class="ar-stick">Student</th>';
  for(var d=1; d<=daysInMonth; d++){
    var wknd=(new Date(year,monthIdx,d).getDay()===0);
    head+='<th class="'+(wknd?'wknd':'')+'">'+d+'</th>';
  }
  head+='<th class="ar-totcol">P</th><th class="ar-totcol">A</th><th class="ar-totcol">%</th></tr></thead>';

  var body='<tbody>';
  STUDENTS.forEach(function(s){
    var arr=DATA[s.id], st=statsFor(s.id);
    body+='<tr><td class="ar-stick"><div class="ar-nm">'+esc(s.name)+'</div><div class="ar-rl">Roll '+esc(s.roll)+'</div></td>';
    for(var d=0; d<arr.length; d++){ body+='<td><span class="ar-mark m-'+arr[d]+'">'+arr[d]+'</span></td>'; }
    body+='<td class="ar-totcol" style="color:#157347;">'+st.p+'</td><td class="ar-totcol" style="color:#b02a37;">'+st.a+'</td>'
       +'<td><span class="ar-pct '+pctCls(st.pct)+'">'+st.pct+'%</span></td></tr>';
  });
  t.innerHTML=head+body+'</tbody>';
}

function renderDefaulters(){
  var box=document.getElementById('defList'), empty=document.getElementById('defEmpty');
  var defs=STUDENTS.map(function(s){ return {s:s,st:statsFor(s.id)}; })
                   .filter(function(x){ return x.st.pct<THRESHOLD; })
                   .sort(function(a,b){ return a.st.pct-b.st.pct; });
  if(!defs.length){ box.innerHTML=''; empty.classList.remove('d-none'); return; }
  empty.classList.add('d-none');
  box.innerHTML=defs.map(function(x){
    return '<div class="col-12 col-md-6 col-xl-4"><div class="ar-def">'
      +'<div class="ar-def-av">'+ini(x.s.name)+'</div>'
      +'<div class="flex-grow-1"><div class="ar-nm">'+esc(x.s.name)+'</div>'
      +  '<div class="ar-rl">Roll '+esc(x.s.roll)+' · '+x.st.a+' absent · '+x.st.l+' leave</div>'
      +  '<div class="ar-def-bar"><div class="ar-def-fill" style="width:'+x.st.pct+'%"></div></div></div>'
      +'<span class="ar-pct bad">'+x.st.pct+'%</span>'
      +'</div></div>';
  }).join('');
}

function renderSummary(){
  var box=document.getElementById('histList');
  var list=STUDENTS.map(function(s){ return {s:s,st:statsFor(s.id)}; }).sort(function(a,b){ return b.st.pct-a.st.pct; });
  box.innerHTML=list.map(function(x,i){
    var col=avatarColors[i%avatarColors.length];
    return '<div class="ar-hrow">'
      +'<div class="ar-hrow-av bg-label-'+col+' text-'+col+'">'+ini(x.s.name)+'</div>'
      +'<div class="flex-grow-1"><div class="ar-nm">'+esc(x.s.name)+'</div>'
      +  '<div class="ar-hrow-mini"><span>Roll <b>'+esc(x.s.roll)+'</b></span><span>Present <b>'+x.st.p+'</b></span><span>Absent <b>'+x.st.a+'</b></span><span>Leave <b>'+x.st.l+'</b></span></div></div>'
      +'<span class="ar-pct '+pctCls(x.st.pct)+'">'+x.st.pct+'%</span>'
      +'</div>';
  }).join('');
}

function render(){
  buildMonth(); updateCards();
  document.getElementById('viewRegister').classList.toggle('d-none',view!=='register');
  document.getElementById('viewDefaulters').classList.toggle('d-none',view!=='defaulters');
  document.getElementById('viewSummary').classList.toggle('d-none',view!=='summary');
  if(view==='register') renderRegister();
  else if(view==='defaulters') renderDefaulters();
  else renderSummary();

  var titleMap={register:'Attendance Register',defaulters:'Defaulters (below '+THRESHOLD+'%)',summary:'Student Summary'};
  document.getElementById('regTitle').textContent=titleMap[view];
  document.getElementById('resultText').textContent=document.getElementById('fClass').value+' – '+document.getElementById('fSection').value
    +' · '+MONTHS[monthIdx]+' '+year+' · '+schoolDays+' school days';
}

/* listeners */
document.querySelectorAll('#viewSeg button').forEach(function(b){
  b.addEventListener('click',function(){
    view=this.dataset.v;
    document.querySelectorAll('#viewSeg button').forEach(function(x){ x.classList.toggle('on',x===b); });
    render();
  });
});
['fClass','fSection','fMonth','fYear'].forEach(function(id){ document.getElementById(id).addEventListener('change',render); });
document.getElementById('btnPrint').addEventListener('click',function(){ window.print(); });
document.getElementById('btnExport').addEventListener('click',function(){ toast('info','Exporting '+MONTHS[monthIdx]+' register for '+document.getElementById('fClass').value+' – '+document.getElementById('fSection').value+'…'); });

/* init */
render();

})();
</script>
}
