/* ── Admission Modal JS ──────────────────────── */
(function(){
    var feeStructures={
        "2026-2027":{
            "Grade 9":[
                {id:1,name:"Admission Fee",group:"One Time Payable Now",cycle:"One Time",amount:1500,mandatory:true,selected:true,stage:"Admission"},
                {id:2,name:"Tuition Fee",group:"Monthly Recurring",cycle:"Monthly",amount:2500,mandatory:true,selected:true,stage:"Monthly"},
                {id:3,name:"Exam Fee",group:"Yearly Charges",cycle:"Yearly",amount:1800,mandatory:true,selected:true,stage:"Yearly"},
                {id:4,name:"Activity Fee",group:"Optional Charges",cycle:"Yearly",amount:800,mandatory:false,selected:false,stage:"Yearly"},
                {id:5,name:"Transport Fee",group:"Optional Charges",cycle:"Monthly",amount:1200,mandatory:false,selected:false,stage:"Monthly"}
            ],
            "Grade 10":[
                {id:1,name:"Admission Fee",group:"One Time Payable Now",cycle:"One Time",amount:1500,mandatory:true,selected:true,stage:"Admission"},
                {id:2,name:"Tuition Fee",group:"Monthly Recurring",cycle:"Monthly",amount:2600,mandatory:true,selected:true,stage:"Monthly"},
                {id:3,name:"Exam Fee",group:"Yearly Charges",cycle:"Yearly",amount:1800,mandatory:true,selected:true,stage:"Yearly"},
                {id:4,name:"Board Fee",group:"One Time Payable Now",cycle:"Yearly",amount:2500,mandatory:true,selected:true,stage:"Admission"},
                {id:5,name:"Activity Fee",group:"Optional Charges",cycle:"Yearly",amount:800,mandatory:false,selected:false,stage:"Yearly"}
            ],
            "Grade 11":[
                {id:1,name:"Admission Fee",group:"One Time Payable Now",cycle:"One Time",amount:1500,mandatory:true,selected:true,stage:"Admission"},
                {id:2,name:"Tuition Fee",group:"Monthly Recurring",cycle:"Monthly",amount:3200,mandatory:true,selected:true,stage:"Monthly"},
                {id:3,name:"Lab Fee",group:"Yearly Charges",cycle:"Yearly",amount:3000,mandatory:true,selected:true,stage:"Yearly"},
                {id:4,name:"Practical Fee",group:"Yearly Charges",cycle:"Yearly",amount:2200,mandatory:true,selected:true,stage:"Yearly"}
            ],
            "Grade 12":[
                {id:1,name:"Admission Fee",group:"One Time Payable Now",cycle:"One Time",amount:1500,mandatory:true,selected:true,stage:"Admission"},
                {id:2,name:"Tuition Fee",group:"Monthly Recurring",cycle:"Monthly",amount:3400,mandatory:true,selected:true,stage:"Monthly"},
                {id:3,name:"Exam Fee",group:"Yearly Charges",cycle:"Yearly",amount:2000,mandatory:true,selected:true,stage:"Yearly"},
                {id:4,name:"Board Fee",group:"One Time Payable Now",cycle:"Yearly",amount:3000,mandatory:true,selected:true,stage:"Admission"}
            ]
        }
    };

    var academicYearSelect=document.getElementById("academicYearSelect"),
        classSelect=document.getElementById("classSelect"),
        admDateInput=document.getElementById("admissionDate"),
        feeContent=document.getElementById("feeContent"),
        annualTotalText=document.getElementById("annualTotalText"),
        concessionPanel=document.getElementById("concessionPanel"),
        discountType=document.getElementById("discountType"),
        discountValue=document.getElementById("discountValue"),
        discountApplyTo=document.getElementById("discountApplyTo"),
        discountReason=document.getElementById("discountReason"),
        ledgerJson=document.getElementById("ledgerJson"),
        admissionForm=document.getElementById("admissionForm");

    /* ── Render the Admission Kit from the shared inventory catalog ──
       Prices now come from one source (Inventory master), not hard-coded
       here, so a price change in Inventory flows through to admission. */
    (function renderKit(){
        var grid=document.getElementById("admissionKitGrid");
        if(!grid||!window.EduInventory) return;
        var kit=window.EduInventory.admissionKit();
        grid.innerHTML=kit.map(function(it){
            var meta=(it.subCategory||it.category)+" · "+(it.stock>0?"In stock":"Out of stock");
            return '<div class="col-12 col-md-6"><label class="admission-kit-card">'
                + '<input type="checkbox" class="form-check-input kit-checkbox mt-1" data-amount="'+it.selling+'" name="SelectedKitItems" value="'+it.name+'"'+(it.mandatory?' checked':'')+'>'
                + '<div class="w-100"><div class="d-flex justify-content-between gap-2"><div class="kit-title">'+it.name+'</div>'
                + '<div class="kit-price">₹'+Number(it.selling).toLocaleString("en-IN")+'</div></div>'
                + '<div class="kit-meta">'+meta+'</div></div></label></div>';
        }).join('');
    })();

    var currentFees=[];

    function fmt(n){return "₹"+Math.round(Number(n||0)).toLocaleString("en-IN");}
    function annualAmt(fee){return fee.cycle==="Monthly"?Number(fee.amount||0)*12:Number(fee.amount||0);}
    function calcDiscount(base){
        var v=Number(discountValue.value||0);
        if(v<=0)return 0;
        if(discountType.value==="percentage")return Math.round((base*Math.min(v,100))/100);
        return Math.min(v,base);
    }
    function kitTotal(){
        var t=0;
        document.querySelectorAll(".kit-checkbox:checked").forEach(function(el){t+=Number(el.dataset.amount||0);});
        return t;
    }

    function renderEmpty(){
        currentFees=[];
        annualTotalText.textContent="₹0";
        concessionPanel.classList.add("d-none");
        ledgerJson.value="";
        feeContent.innerHTML='<div class="fee-empty"><i class="bx bx-wallet"></i><h6>Select Year &amp; Class</h6><p class="mb-0">Fee structure will appear here.</p></div>';
    }

    function loadFee(){
        var yr=academicYearSelect.value,cls=classSelect.value;
        if(!yr||!cls){renderEmpty();return;}
        var struct=feeStructures[yr]&&feeStructures[yr][cls];
        if(!struct){
            currentFees=[];annualTotalText.textContent="₹0";concessionPanel.classList.add("d-none");ledgerJson.value="";
            feeContent.innerHTML='<div class="fee-empty"><i class="bx bx-error-circle"></i><h6>No Fee Structure</h6><p class="mb-0">Configure fee structure for this class first.</p></div>';
            return;
        }
        currentFees=JSON.parse(JSON.stringify(struct));
        concessionPanel.classList.remove("d-none");
        renderFees();
    }

    function renderFees(){
        if(!currentFees.length){renderEmpty();return;}
        var groups=["One Time Payable Now","Monthly Recurring","Yearly Charges","Optional Charges"];
        var html="",payNow=0,monthly=0,yearly=0,annual=0;

        groups.forEach(function(grp){
            var gFees=currentFees.filter(function(f){return f.group===grp;});
            if(!gFees.length)return;
            var gHtml="";
            gFees.forEach(function(fee){
                var gi=currentFees.indexOf(fee);
                if(!fee.mandatory){
                    gHtml+='<div class="fee-check-row"><div class="d-flex gap-2"><input class="form-check-input optional-fee-checkbox" type="checkbox" data-index="'+gi+'" '+(fee.selected?"checked":"")+'>'+
                        '<div><div class="fw-bold" style="color:var(--ec-heading)">'+fee.name+'</div><small>'+fee.cycle+' · '+fee.stage+'</small></div></div>'+
                        '<strong>'+fmt(fee.amount)+(fee.cycle==="Monthly"?"/mo":"")+'</strong></div>';
                } else if(fee.selected){
                    gHtml+='<div class="fee-row"><div><div class="fw-bold" style="color:var(--ec-heading)">'+fee.name+'</div><small>'+fee.cycle+' · '+fee.stage+'</small></div>'+
                        '<strong>'+fmt(fee.amount)+(fee.cycle==="Monthly"?"/mo":"")+'</strong></div>';
                }
            });
            if(gHtml) html+='<div><div class="fee-group-title">'+grp+'</div>'+gHtml+'</div>';
        });

        currentFees.forEach(function(f){
            if(!f.selected)return;
            annual+=annualAmt(f);
            if(f.stage==="Admission")payNow+=Number(f.amount||0);
            if(f.stage==="Monthly")monthly+=Number(f.amount||0);
            if(f.stage==="Yearly")yearly+=Number(f.amount||0);
        });

        var kit=kitTotal();
        var discBase=discountApplyTo.value==="annual"?annual:payNow;
        var disc=calcDiscount(discBase);
        var payToday=payNow+kit+(discountApplyTo.value==="payToday"?-disc:0);
        var estAnnual=annual+kit+(discountApplyTo.value==="annual"?-disc:0);

        html+='<div class="fee-summary">'+
            '<div class="summary-line"><span>Pay Today</span><strong>'+fmt(payToday)+'</strong></div>'+
            '<div class="summary-line"><span>Monthly</span><strong>'+fmt(monthly)+'/mo</strong></div>'+
            '<div class="summary-line"><span>Yearly</span><strong>'+fmt(yearly)+'/yr</strong></div>'+
            '<div class="summary-line"><span>Kit</span><strong>'+fmt(kit)+'</strong></div>'+
            '<div class="summary-line"><span>Concession</span><strong>- '+fmt(disc)+'</strong></div>'+
            '<hr class="opacity-25"><div class="summary-line"><span>Estimated Annual</span><strong>'+fmt(estAnnual)+'</strong></div></div>';

        annualTotalText.textContent=fmt(estAnnual);
        feeContent.innerHTML=html;
        ledgerJson.value=JSON.stringify({academicYear:academicYearSelect.value,className:classSelect.value,estAnnual:estAnnual,payToday:payToday});

        document.querySelectorAll(".optional-fee-checkbox").forEach(function(el){
            el.onchange=function(){currentFees[Number(this.dataset.index)].selected=this.checked;renderFees();};
        });
    }

    academicYearSelect.addEventListener("change",loadFee);
    classSelect.addEventListener("change",loadFee);
    admDateInput.addEventListener("change",renderFees);
    discountType.addEventListener("change",renderFees);
    discountValue.addEventListener("input",renderFees);
    discountApplyTo.addEventListener("change",renderFees);
    discountReason.addEventListener("input",renderFees);
    document.querySelectorAll(".kit-checkbox").forEach(function(el){el.addEventListener("change",renderFees);});

    document.getElementById("studentAdmissionModal").addEventListener("hidden.bs.modal",function(){
        admissionForm.reset();
        admissionForm.classList.remove("was-validated");
        renderEmpty();
    });

    admissionForm.addEventListener("submit",function(e){
        e.preventDefault();

        if(!admissionForm.checkValidity()){admissionForm.classList.add("was-validated");return;}

        if(Number(discountValue.value||0)>0&&!discountReason.value.trim()){
            discountReason.focus();
            if(typeof toastr!=="undefined")toastr.error("Please enter a concession reason.");
            return;
        }
        if(!ledgerJson.value){
            if(typeof toastr!=="undefined")toastr.error("Please select Academic Year and Class.");
            return;
        }

        /* ── Add new student to the live list ── */
        var colors=['primary','info','success','warning','danger','secondary'];
        var sl=window._sl;
        var newId=sl?sl.students.length+1:Date.now();
        var name=document.getElementById("adm_StudentName").value.trim();
        var cls=classSelect.value;
        var today=new Date();
        var admDate=admDateInput.value||today.toISOString().slice(0,10);

        var newStudent={
            id:newId,
            name:name,
            roll:document.getElementById("adm_RollNo").value.trim()||('R-'+String(newId).padStart(3,'0')),
            cls:cls,
            sec:document.getElementById("adm_Section").value,
            gender:document.getElementById("adm_Gender").value,
            admDate:admDate,
            guardian:document.getElementById("adm_GuardianName").value.trim(),
            phone:document.getElementById("adm_MobileNumber").value.trim(),
            feeSt:'Pending',
            feeDue:0,
            attend:0,
            status:'Active',
            admYear:today.getFullYear(),
            color:colors[newId%colors.length]
        };

        if(sl){
            sl.students.unshift(newStudent);
            sl.refresh();
        }

        bootstrap.Modal.getInstance(document.getElementById("studentAdmissionModal")).hide();

        if(typeof toastr!=="undefined"){
            toastr.success('<strong>'+name+'</strong> admitted successfully. Fee ledger created.','Admission Saved');
        }
    });

    renderEmpty();
})();
</script>
}
