/* ── Helpers ─────────────────────────────────── */
var MO=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
function fmtDate(d){var x=new Date(d);return String(x.getDate()).padStart(2,'0')+' '+MO[x.getMonth()]+' '+x.getFullYear();}
function ini(n){return n.split(' ').slice(0,2).map(function(w){return w[0];}).join('').toUpperCase();}
function attCls(p){return p>=75?'att-hi':p>=50?'att-mi':'att-lo';}
function feeB(f){var m={Paid:'b-paid',Partial:'b-partial',Pending:'b-pending'};return '<span class="sl-bdg '+(m[f]||'b-pending')+'">'+f+'</span>';}
function statB(s){var m={Active:'b-active',Inactive:'b-inactive',Transfer:'b-transfer'};return '<span class="sl-bdg '+(m[s]||'b-inactive')+'">'+s+'</span>';}
function gHtml(g){
  var m={Male:['gm','bx-male'],Female:['gf','bx-female'],Other:['go','bx-user']},c=m[g]||m.Other;
  return '<span class="sl-gen '+c[0]+'"><i class="bx '+c[1]+'"></i>'+g+'</span>';
}
function attHtml(p){
  var c=attCls(p);
  return '<div class="sl-att '+c+'"><div class="sl-att-b"><div class="sl-att-f" style="width:'+p+'%"></div></div><span class="sl-att-p">'+p+'%</span></div>';
}
function inr(n){return n===0?'₹ 0':'₹ '+n.toLocaleString('en-IN');}
function toast(t,m){if(typeof toastr!=='undefined')toastr[t](m);}

/* ── Sort ────────────────────────────────────── */
function doSort(list){
  if(!sortCol)return list;
  return list.slice().sort(function(a,b){
    var va=a[sortCol],vb=b[sortCol];
    if(sortCol==='admDate'){va=new Date(va);vb=new Date(vb);}
    return sortDir==='asc'?(va<vb?-1:va>vb?1:0):(va>vb?-1:va<vb?1:0);
  });
}
function updateSortIcons(){
  ['name','admDate','attend'].forEach(function(c){
    var el=document.getElementById('si-'+c);
    if(!el)return;
    el.className='bx bx-sort sl-si';
    if(c===sortCol) el.className='bx '+(sortDir==='asc'?'bx-sort-up':'bx-sort-down')+' sl-si sl-si-on';
  });
}

/* ── Filter ──────────────────────────────────── */
function applyFilters(){
  var q=document.getElementById('slSearch').value.toLowerCase().trim(),
      cls=document.getElementById('fClass').value,
      gen=document.getElementById('fGender').value,
      fee=document.getElementById('fFee').value,
      yr=document.getElementById('fYear').value;

  filtered=students.filter(function(s){
    return(!q||s.name.toLowerCase().includes(q)||s.roll.toLowerCase().includes(q)||s.cls.toLowerCase().includes(q))
      &&(!cls||s.cls===cls)&&(!gen||s.gender===gen)
      &&(!fee||s.feeSt===fee)&&(!yr||s.admYear===parseInt(yr));
  });

  /* highlight active chips */
  ['fClass','fGender','fFee','fYear'].forEach(function(id){
    var el=document.getElementById(id);
    if(el) el.classList.toggle('active-filter', el.value!=='');
  });

  /* show/hide clear button */
  var hasFilter=cls||gen||fee||yr||q;
  var cb=document.getElementById('clearBtn');
  if(cb) cb.classList.toggle('d-none',!hasFilter);

  updateCards();PAGE=1;render();
}
function updateCards(){
  var src=filtered.length?filtered:students;
  document.getElementById('sumTotal').textContent=src.length;
  document.getElementById('sumMale').textContent=src.filter(function(s){return s.gender==='Male';}).length;
  document.getElementById('sumFemale').textContent=src.filter(function(s){return s.gender==='Female';}).length;
  document.getElementById('sumActive').textContent=src.filter(function(s){return s.status==='Active';}).length;
}

/* ── Render ──────────────────────────────────── */
function render(){
  var sorted=doSort(filtered),total=sorted.length;
  PER=parseInt(document.getElementById('perPage').value);
  var pages=Math.ceil(total/PER)||1;
  if(PAGE>pages)PAGE=pages;
  var start=(PAGE-1)*PER,end=Math.min(start+PER,total),slice=sorted.slice(start,end);
  renderDesk(slice,total,start,end);
  renderMob(slice);
  renderPag(pages,total,start,end);
  document.getElementById('resultText').textContent=total?'Showing '+(start+1)+'–'+end+' of '+total+' students':'No students found';
}

function dashUrl(id){
  return '@Url.Action("Dashboard","Student",new{area="ERP"})' + '/' + id;
}

function renderDesk(slice,total,start,end){
  var tb=document.getElementById('tblBody'),em=document.getElementById('emptyDesk');
  if(!slice.length){tb.innerHTML='';em.classList.remove('d-none');document.getElementById('pgWrap').classList.add('d-none');return;}
  em.classList.add('d-none');document.getElementById('pgWrap').classList.remove('d-none');
  tb.innerHTML=slice.map(function(s){
    return '<tr>'
      +'<td onclick="event.stopPropagation()"><input type="checkbox" class="form-check-input" data-id="'+s.id+'"></td>'
      +'<td>'
      +  '<a href="'+dashUrl(s.id)+'" class="d-flex align-items-center gap-2 text-decoration-none" style="cursor:pointer;">'
      +    '<span class="sl-av bg-label-'+s.color+' text-'+s.color+'">'+ini(s.name)+'</span>'
      +    '<div><div class="sl-nm">'+s.name+'</div><div class="sl-rl">'+s.roll+'</div></div>'
      +  '</a>'
      +'</td>'
      +'<td><span class="fw-bold">'+s.cls+'</span> <span class="text-muted">– '+s.sec+'</span></td>'
      +'<td>'+gHtml(s.gender)+'</td>'
      +'<td>'+fmtDate(s.admDate)+'</td>'
      +'<td>'+s.guardian+'</td>'
      +'<td>'+s.phone+'</td>'
      +'<td>'+feeB(s.feeSt)+'</td>'
      +'<td>'+attHtml(s.attend)+'</td>'
      +'<td>'+statB(s.status)+'</td>'
      +'<td><a href="'+dashUrl(s.id)+'" class="sl-view-btn"><i class="bx bx-layout"></i>Dashboard</a></td>'
      +'</tr>';
  }).join('');
}

function renderMob(slice){
  var list=document.getElementById('mobList'),em=document.getElementById('emptyMob');
  if(!slice.length){list.innerHTML='';em.classList.remove('d-none');return;}
  em.classList.add('d-none');
  list.innerHTML=slice.map(function(s){
    return '<div class="sl-mob-card">'
      +'<div class="sl-mob-top">'
      +  '<span class="sl-mob-av bg-label-'+s.color+' text-'+s.color+'">'+ini(s.name)+'</span>'
      +  '<div class="flex-grow-1"><div class="sl-nm">'+s.name+'</div><div class="sl-rl">'+s.roll+' · '+s.cls+' '+s.sec+'</div></div>'
      +  statB(s.status)
      +'</div>'
      +'<div class="sl-mob-grid">'
      +  '<div class="sl-mob-field"><label>Guardian</label><span>'+s.guardian+'</span></div>'
      +  '<div class="sl-mob-field"><label>Contact</label><span>'+s.phone+'</span></div>'
      +  '<div class="sl-mob-field"><label>Admitted</label><span>'+fmtDate(s.admDate)+'</span></div>'
      +  '<div class="sl-mob-field"><label>Gender</label><span>'+s.gender+'</span></div>'
      +  '<div class="sl-mob-field"><label>Fee Status</label>'+feeB(s.feeSt)+'</div>'
      +  '<div class="sl-mob-field"><label>Attendance</label>'+attHtml(s.attend)+'</div>'
      +'</div>'
      +'<a href="'+dashUrl(s.id)+'" class="btn btn-sm btn-primary w-100"><i class="bx bx-layout me-1"></i>View Dashboard</a>'
      +'</div>';
  }).join('');
}

function renderPag(pages,total,start,end){
  var info=document.getElementById('pgInfo'),btns=document.getElementById('pgBtns');
  info.textContent='Showing '+(start+1)+'–'+end+' of '+total+' students';
  if(pages<=1){btns.innerHTML='';return;}
  var h='<button class="sl-pg-btn" id="pPrev" '+(PAGE===1?'disabled':'')+'><i class="bx bx-chevron-left"></i></button>';
  var fr=Math.max(1,PAGE-2),to=Math.min(pages,fr+4);fr=Math.max(1,to-4);
  if(fr>1)h+='<button class="sl-pg-btn" data-p="1">1</button>'+(fr>2?'<span class="sl-pg-info px-1">…</span>':'');
  for(var i=fr;i<=to;i++)h+='<button class="sl-pg-btn'+(i===PAGE?' active':'')+'" data-p="'+i+'">'+i+'</button>';
  if(to<pages)h+=(to<pages-1?'<span class="sl-pg-info px-1">…</span>':'')+'<button class="sl-pg-btn" data-p="'+pages+'">'+pages+'</button>';
  h+='<button class="sl-pg-btn" id="pNext" '+(PAGE===pages?'disabled':'')+'><i class="bx bx-chevron-right"></i></button>';
  btns.innerHTML=h;
  btns.querySelectorAll('[data-p]').forEach(function(b){b.addEventListener('click',function(){PAGE=parseInt(this.dataset.p);render();});});
  var pv=btns.querySelector('#pPrev'),nx=btns.querySelector('#pNext');
  if(pv)pv.addEventListener('click',function(){if(PAGE>1){PAGE--;render();}});
  if(nx)nx.addEventListener('click',function(){if(PAGE<pages){PAGE++;render();}});
}

