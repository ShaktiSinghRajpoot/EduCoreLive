@{
    ViewData["Title"] = "All Students";
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
}

@section PageStyles {
<link href="~/css/educore-theme.css" rel="stylesheet" />
<style>
/* -- override global mobile btn-width only for this page's specific controls -- */
@@media (max-width:575.98px){
    .sl-pg-btn,.sl-view-btn,.sl-filter-row .btn,.dropdown-item{ width:auto !important; }
}
.dropdown-toggle::after{ display:none; }

/* summary cards */ 
.sl-card{
    border:1px solid var(--ec-border); border-radius:var(--ec-radius);
    background:#fff; padding:1.1rem 1.2rem;
    display:flex; align-items:center; gap:.9rem;
    transition:var(--ec-transition); height:100%;
}
.sl-card:hover{ transform:translateY(-2px); box-shadow:var(--ec-shadow); border-color:rgba(255,138,0,.22); }
.sl-card-ic{ width:46px; height:46px; flex:0 0 46px; border-radius:13px; display:flex; align-items:center; justify-content:center; font-size:1.3rem; }
.sl-card-val{ font-size:1.5rem; font-weight:800; color:var(--ec-text-dark); line-height:1.1; }
.sl-card-lbl{ font-size:.71rem; font-weight:800; color:var(--ec-text-muted); text-transform:uppercase; letter-spacing:.05em; }

/* ── Filter bar ─────────────────────────────── */
.sl-fbar{
    display:flex; align-items:center; gap:.5rem; flex-wrap:wrap;
}

/* Search input with icon */
.sl-srch-wrap{
    position:relative; flex:1 1 180px; max-width:260px;
}
.sl-srch-ic{
    position:absolute; left:.65rem; top:50%; transform:translateY(-50%);
    color:var(--ec-text-muted); font-size:1rem; pointer-events:none; line-height:1;
}
.sl-srch-inp{
    width:100%; height:34px;
    padding:0 .75rem 0 2rem;
    border-radius:8px; border:1px solid var(--ec-border);
    background:#fafaf8; font-size:.82rem; font-weight:600;
    color:var(--ec-text); outline:none;
    transition:var(--ec-transition);
}
.sl-srch-inp::placeholder{ color:var(--ec-text-muted); }
.sl-srch-inp:focus{
    border-color:rgba(255,138,0,.55); background:#fff;
    box-shadow:0 0 0 3px rgba(255,138,0,.1);
}

/* Thin divider between search and chips */
.sl-fbar-div{
    width:1px; height:22px; background:var(--ec-border);
    flex-shrink:0;
}

/* Chip-style select */
.sl-chip{
    height:34px; padding:0 .65rem;
    border-radius:8px; border:1px solid var(--ec-border);
    background:#fafaf8; font-size:.78rem; font-weight:700;
    color:var(--ec-text-muted); cursor:pointer;
    outline:none; transition:var(--ec-transition);
    white-space:nowrap; flex-shrink:0;
    appearance:auto; -webkit-appearance:auto;
}
.sl-chip:hover{
    border-color:rgba(255,138,0,.4); background:#fff;
    color:var(--ec-text);
}
.sl-chip:focus{
    border-color:var(--ec-primary);
    box-shadow:0 0 0 3px rgba(255,138,0,.1);
    background:#fff;
}
.sl-chip.active-filter{
    background:var(--ec-primary-light);
    border-color:rgba(255,138,0,.45);
    color:var(--ec-primary);
}

/* Clear filters btn */
.sl-clear-btn{
    height:34px; padding:0 .75rem;
    border-radius:8px; border:1px solid #f5c2c7;
    background:#fff0f0; color:#dc3545;
    font-size:.76rem; font-weight:700;
    cursor:pointer; outline:none;
    display:inline-flex; align-items:center; gap:.3rem;
    transition:var(--ec-transition); flex-shrink:0;
}
.sl-clear-btn:hover{ background:#fde8e8; border-color:#dc3545; }

/* Export icon buttons */
.sl-export-btn{
    height:34px; width:34px;
    border-radius:8px; border:1px solid var(--ec-border);
    background:#fafaf8; color:var(--ec-text-muted);
    font-size:1rem; cursor:pointer; outline:none;
    display:inline-flex; align-items:center; justify-content:center;
    transition:var(--ec-transition); flex-shrink:0;
}
.sl-export-btn:hover{ background:#fff; color:var(--ec-primary); border-color:rgba(255,138,0,.4); }
.sl-export-btn.xl:hover{ color:#198754; border-color:#198754; }
.sl-export-btn.pdf:hover{ color:#dc3545; border-color:#dc3545; }

/* Active filter count bubble */
.sl-filter-count{
    display:inline-flex; align-items:center; justify-content:center;
    width:18px; height:18px; border-radius:50%;
    background:var(--ec-primary); color:#fff;
    font-size:.65rem; font-weight:800;
    margin-left:.2rem; flex-shrink:0;
}

@@media (max-width:991.98px){
    .sl-srch-wrap{ max-width:100%; }
    .sl-fbar-div{ display:none; }
}
@@media (max-width:575.98px){
    .sl-fbar{ gap:.4rem; }
    .sl-srch-wrap{ flex:1 1 100%; max-width:100%; }
    .sl-chip{ font-size:.75rem; height:32px; }
    .sl-clear-btn{ height:32px; }
    .sl-export-btn{ height:32px; width:32px; }
}

/* table */
.sl-tbl-wrap{ overflow-x:auto; -webkit-overflow-scrolling:touch; }
.sl-tbl{ min-width:920px; width:100%; }
.sl-tbl thead th{
    background:linear-gradient(180deg,#fffaf3,#fff6ea);
    color:var(--ec-text-light); font-size:.7rem;
    text-transform:uppercase; letter-spacing:.06em; font-weight:800;
    padding:.8rem .9rem; border-bottom:1px solid var(--ec-border);
    white-space:nowrap; user-select:none;
}
.sl-sortable{ cursor:pointer; }
.sl-sortable:hover{ background:#fff0e0; color:var(--ec-primary); }
.sl-si{ font-size:.85rem; opacity:.35; vertical-align:middle; margin-left:3px; }
.sl-si-on{ opacity:1; color:var(--ec-primary); }
.sl-tbl tbody td{
    padding:.78rem .9rem; vertical-align:middle;
    border-bottom:1px solid #f4f0eb;
    font-size:.84rem; font-weight:600; color:var(--ec-text);
}
.sl-tbl tbody tr:hover td{ background:#fffaf3; cursor:pointer; }
.sl-tbl tbody tr.sl-row-active td{ background:#fff4e6; }

/* student cell */
.sl-av{
    width:36px; height:36px; flex:0 0 36px;
    border-radius:50%;
    display:inline-flex; align-items:center; justify-content:center;
    font-size:.72rem; font-weight:800;
}
.sl-nm{ font-weight:800; color:var(--ec-text-dark); font-size:.87rem; line-height:1.2; }
.sl-rl{ font-size:.72rem; color:var(--ec-text-muted); }

/* gender */
.sl-gen{ display:inline-flex; align-items:center; gap:.3rem; font-size:.82rem; }
.sl-gen i{ font-size:.95rem; }
.gm{ color:#2196f3; } .gf{ color:#e83e8c; } .go{ color:#8592a3; }

/* attendance bar */
.sl-att{ display:flex; align-items:center; gap:.4rem; }
.sl-att-b{ width:52px; height:5px; background:#ede8e3; border-radius:999px; overflow:hidden; flex-shrink:0; }
.sl-att-f{ height:100%; border-radius:inherit; }
.att-hi .sl-att-f{ background:#28c76f; } .att-hi .sl-att-p{ color:#155724; font-weight:800; font-size:.8rem; }
.att-mi .sl-att-f{ background:#ff9f43; } .att-mi .sl-att-p{ color:#856404; font-weight:800; font-size:.8rem; }
.att-lo .sl-att-f{ background:#ea5455; } .att-lo .sl-att-p{ color:#842029; font-weight:800; font-size:.8rem; }

/* badges */
.sl-bdg{
    display:inline-flex; align-items:center; gap:.28rem;
    padding:.26rem .65rem; border-radius:999px;
    font-size:.69rem; font-weight:800; white-space:nowrap;
}
.sl-bdg::before{ content:''; width:5px; height:5px; border-radius:50%; flex-shrink:0; }
.b-active  { background:#d4edda; color:#155724; } .b-active::before  { background:#28a745; }
.b-inactive{ background:#e2e3e5; color:#495057; } .b-inactive::before{ background:#6c757d; }
.b-transfer{ background:#cfe2ff; color:#084298; } .b-transfer::before{ background:#0d6efd; }
.b-paid    { background:#d1f0e0; color:#0a5a35; } .b-paid::before    { background:#198754; }
.b-partial { background:#fff3cd; color:#664d03; } .b-partial::before { background:#ffc107; }
.b-pending { background:#fde8e8; color:#842029; } .b-pending::before { background:#dc3545; }

/* view dashboard btn */
.sl-view-btn{
    display:inline-flex; align-items:center; gap:.28rem;
    padding:.28rem .7rem; border-radius:8px; font-size:.77rem; font-weight:700;
    background:var(--ec-primary-light); color:var(--ec-primary);
    border:1px solid rgba(255,138,0,.2);
    cursor:pointer; transition:var(--ec-transition); white-space:nowrap;
    text-decoration:none;
}
.sl-view-btn:hover{ background:#ffe0b2; color:#e65c00; }

/* pagination */
.sl-pg-wrap{ display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:.65rem; padding-top:1rem; border-top:1px solid var(--ec-border); }
.sl-pg-info{ font-size:.81rem; color:var(--ec-text-muted); font-weight:650; }
.sl-pg-btn{
    width:32px !important; height:32px;
    border-radius:7px; border:1px solid var(--ec-border);
    background:#fff; color:var(--ec-text); font-size:.8rem; font-weight:700;
    display:inline-flex; align-items:center; justify-content:center;
    cursor:pointer; transition:var(--ec-transition); padding:0;
}
.sl-pg-btn:hover:not(:disabled){ background:var(--ec-primary-light); border-color:var(--ec-primary); color:var(--ec-primary); }
.sl-pg-btn.active{ background:var(--ec-primary); border-color:var(--ec-primary); color:#fff; }
.sl-pg-btn:disabled{ opacity:.35; cursor:not-allowed; }

/* empty state */
.sl-empty{ padding:3rem 1rem; text-align:center; }
.sl-empty-ic{ width:64px; height:64px; border-radius:18px; background:var(--ec-primary-light); color:var(--ec-primary); display:inline-flex; align-items:center; justify-content:center; font-size:1.8rem; margin-bottom:.9rem; }

/* mobile cards */
.sl-mob-list{ display:none; }
.sl-mob-card{ border:1px solid var(--ec-border); border-radius:var(--ec-radius); background:#fff; padding:.95rem; margin-bottom:.7rem; }
.sl-mob-top{ display:flex; align-items:center; gap:.7rem; margin-bottom:.7rem; }
.sl-mob-av{ width:42px; height:42px; flex:0 0 42px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:.82rem; font-weight:800; }
.sl-mob-grid{ display:grid; grid-template-columns:1fr 1fr; gap:.45rem .7rem; margin-bottom:.7rem; }
.sl-mob-field label{ font-size:.67rem; text-transform:uppercase; letter-spacing:.05em; font-weight:800; color:var(--ec-text-light); display:block; }
.sl-mob-field span { font-size:.82rem; font-weight:700; color:var(--ec-text); }

/* print */
@@media print{
    .layout-menu,.layout-navbar,.ec-page-header,
    .sl-filter-section,.sl-pg-wrap,.sl-sum-section,
    .sl-view-btn{ display:none !important; }
    .sl-tbl-wrap{ overflow:visible !important; }
    .sl-tbl{ min-width:100% !important; font-size:.75rem; }
    .ec-page-shell{ box-shadow:none !important; border:none !important; }
}

/* responsive */
@@media (max-width:767.98px){
    .sl-tbl-wrap{ display:none; }
    .sl-mob-list{ display:block; }
    .sl-pg-wrap{ justify-content:center; }
    .sl-pg-info{ width:100%; text-align:center; }
}
@@media (max-width:575.98px){
    .sl-card{ padding:.85rem 1rem; }
    .sl-card-val{ font-size:1.3rem; }
    .sl-mob-grid{ grid-template-columns:1fr; }
}

/* ── Admission Modal (brought in from ManageAdmission) ── */
.student-admission-page{
    --ec-primary:#ff8a00;--ec-primary-soft:#fff4e6;--ec-cream:#fff7ed;
    --ec-soft-bg:#f8f7f5;--ec-panel:#ffffff;--ec-border:#ececf5;
    --ec-heading:#2b1b12;--ec-text:#2b2c40;--ec-muted:#8b8175;--ec-label:#9a938b;
    color:var(--ec-text);
}
.student-admission-page .ec-card,.student-admission-page .ec-detail-box,.student-admission-page .admission-kit-card{transition:transform .2s ease,box-shadow .2s ease,border-color .2s ease;}
.student-admission-page .ec-card:hover,.student-admission-page .ec-detail-box:hover,.student-admission-page .admission-kit-card:hover{transform:translateY(-2px);box-shadow:0 16px 34px rgba(43,27,18,.08);border-color:rgba(255,138,0,.22);}
.student-admission-page .ec-page-icon,.student-admission-page .ec-section-icon,.student-admission-page .ec-detail-icon{background:var(--ec-primary-soft);color:var(--ec-primary);}
.student-admission-page .btn-primary{background:linear-gradient(135deg,#ff8a00,#ff9f2f);border:0;color:#fff;border-radius:999px;font-weight:800;box-shadow:0 12px 24px rgba(255,138,0,.22);transition:transform .2s ease,box-shadow .2s ease;}
.student-admission-page .btn-primary:hover{color:#fff;transform:translateY(-1px);box-shadow:0 16px 30px rgba(255,138,0,.28);}
.student-admission-page .btn-outline-secondary{border-color:rgba(43,27,18,.14);color:var(--ec-text);background:#fff;border-radius:999px;font-weight:800;transition:all .2s ease;}
.student-admission-page .btn-outline-secondary:hover{background:var(--ec-primary-soft);border-color:rgba(255,138,0,.35);color:var(--ec-heading);}
.student-admission-page .form-label{color:var(--ec-label);font-size:.76rem;font-weight:800;letter-spacing:.01em;margin-bottom:.4rem;}
.student-admission-page .required::after{content:" *";color:#ea5455;}
.student-admission-page .form-control,.student-admission-page .form-select{border:1px solid var(--ec-border);border-radius:14px;min-height:46px;color:var(--ec-text);font-weight:650;font-size:.9rem;background-color:#fff;transition:border-color .2s ease,box-shadow .2s ease;}
.student-admission-page textarea.form-control{min-height:96px;}
.student-admission-page .form-control:focus,.student-admission-page .form-select:focus{border-color:rgba(255,138,0,.65);box-shadow:0 0 0 4px rgba(255,138,0,.13);}
.modal-content{border:0;border-radius:28px;overflow:hidden;height:92vh;background:linear-gradient(135deg,#ffffff 0%,#fff7ed 100%);box-shadow:0 28px 70px rgba(43,27,18,.2);}
.admission-modal-header{min-height:78px;padding:1.25rem 1.5rem;border-bottom:1px solid var(--ec-border);background:rgba(255,255,255,.9);backdrop-filter:blur(14px);flex-shrink:0;}
.admission-modal-body{padding:clamp(1rem,2vw,1.5rem);overflow-y:auto;overflow-x:hidden;max-height:calc(92vh - 154px);}
.admission-modal-body::-webkit-scrollbar{width:8px;}
.admission-modal-body::-webkit-scrollbar-thumb{background:rgba(255,138,0,.25);border-radius:999px;}
.admission-kit-card{display:flex;gap:.85rem;height:100%;cursor:pointer;background:#fff;border:1px solid var(--ec-border);border-radius:18px;padding:.95rem;}
.kit-title{color:var(--ec-heading);font-weight:900;font-size:.88rem;}
.kit-meta{color:var(--ec-muted);font-size:.76rem;font-weight:650;}
.kit-price{color:var(--ec-primary);font-weight:900;white-space:nowrap;}
.fee-preview-sidebar{position:sticky;top:0;background:linear-gradient(180deg,#ffffff,#fff7ed 100%);border:1px solid rgba(255,138,0,.18);box-shadow:0 18px 40px rgba(43,27,18,.08);}
.fee-total{font-size:clamp(1.8rem,4vw,2.45rem);line-height:1.1;font-weight:950;letter-spacing:-.04em;color:var(--ec-heading);}
.fee-empty{min-height:280px;display:flex;align-items:center;justify-content:center;flex-direction:column;text-align:center;color:var(--ec-muted);border:1px dashed rgba(255,138,0,.28);border-radius:20px;background:rgba(255,255,255,.72);padding:1.5rem;}
.fee-empty i{font-size:3rem;color:var(--ec-primary);margin-bottom:.75rem;}
.fee-empty h6{color:var(--ec-heading);font-weight:950;margin-bottom:.3rem;}
.fee-group-title{color:var(--ec-label);font-size:.72rem;text-transform:uppercase;letter-spacing:.08em;font-weight:950;margin:1rem 0 .55rem;}
.fee-row,.fee-check-row{border:1px solid var(--ec-border);border-radius:16px;background:rgba(255,255,255,.86);padding:.85rem;margin-bottom:.7rem;display:flex;justify-content:space-between;align-items:center;gap:.75rem;}
.fee-row small,.fee-check-row small{color:var(--ec-muted);font-weight:650;}
.fee-summary{background:#fff;border:1px solid rgba(255,138,0,.16);border-radius:18px;padding:1rem;margin-top:1rem;}
.summary-line{display:flex;justify-content:space-between;gap:1rem;font-size:.86rem;margin-bottom:.75rem;color:var(--ec-muted);}
.summary-line:last-child{margin-bottom:0;}
.summary-line strong{color:var(--ec-heading);font-weight:950;white-space:nowrap;}
.admission-footer-hint{color:var(--ec-muted);font-size:.8rem;font-weight:650;}
.ec-sticky-actions{min-height:76px;padding:1rem 1.5rem;border-top:1px solid var(--ec-border);background:rgba(255,255,255,.92);backdrop-filter:blur(14px);flex-shrink:0;}
.mandatory-chip{background:#fff4e6;color:#ff8a00;border-radius:999px;font-size:.68rem;font-weight:800;padding:.2rem .6rem;}
.optional-chip{background:#e8f4fd;color:#0d6efd;border-radius:999px;font-size:.68rem;font-weight:800;padding:.2rem .6rem;}
.stage-chip{background:#f0f0f0;color:#495057;border-radius:999px;font-size:.68rem;font-weight:700;padding:.2rem .6rem;}
@@media (max-width:991.98px){
    .modal-content{height:94vh;border-radius:24px;}
    .admission-modal-body{max-height:calc(94vh - 154px);}
    .fee-preview-sidebar{position:static;}
}
@@media (max-width:575.98px){
    .modal-dialog{margin:.5rem;max-width:calc(100vw - 1rem);}
    .modal-content{height:96vh;border-radius:20px;}
    .admission-modal-header,.ec-sticky-actions{padding:1rem;}
    .admission-modal-body{padding:1rem;max-height:calc(96vh - 160px);}
    .ec-sticky-actions{flex-direction:column;align-items:stretch !important;}
    .ec-sticky-actions .btn{width:100% !important;}
}
</style>
}

<div class="ec-page-shell">
  <div class="ec-page-content">

    <div class="ec-page-header">
      <div class="ec-page-header-inner">
        <div class="ec-page-title-wrap">
          <div class="ec-page-icon rounded-4 d-flex align-items-center justify-content-center">
            <i class="bx bx-group fs-4"></i>
          </div>
          <div>
            <h4 class="ec-page-title mb-1">All Students</h4>
            <div class="ec-page-subtitle">Click a student row or View Dashboard to open the full student panel</div>
          </div>
        </div>
        <button class="btn btn-primary d-flex align-items-center gap-1"
                data-bs-toggle="modal" data-bs-target="#studentAdmissionModal">
          <i class="bx bx-user-plus"></i><span>New Admission</span>
        </button>
      </div>
    </div>

    <div class="row g-3 mb-4 sl-sum-section">
      <div class="col-6 col-lg-3">
        <div class="sl-card">
          <div class="sl-card-ic bg-label-primary text-primary"><i class="bx bx-group"></i></div>
          <div><div class="sl-card-val" id="sumTotal">—</div><div class="sl-card-lbl">Total Students</div></div>
        </div>
      </div>
      <div class="col-6 col-lg-3">
        <div class="sl-card">
          <div class="sl-card-ic bg-label-info text-info"><i class="bx bx-male"></i></div>
          <div><div class="sl-card-val" id="sumMale">—</div><div class="sl-card-lbl">Male</div></div>
        </div>
      </div>
      <div class="col-6 col-lg-3">
        <div class="sl-card">
          <div class="sl-card-ic bg-label-danger" style="color:#e83e8c;"><i class="bx bx-female"></i></div>
          <div><div class="sl-card-val" id="sumFemale">—</div><div class="sl-card-lbl">Female</div></div>
        </div>
      </div>
      <div class="col-6 col-lg-3">
        <div class="sl-card">
          <div class="sl-card-ic bg-label-success text-success"><i class="bx bx-user-check"></i></div>
          <div><div class="sl-card-val" id="sumActive">—</div><div class="sl-card-lbl">Active</div></div>
        </div>
      </div>
    </div>

    <div class="ec-card mb-0">

      <div class="ec-card-header">
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-2 mb-3">
          <div class="ec-section-title-wrap">
            <span class="ec-section-icon"><i class="bx bx-list-ul"></i></span>
            <div>
              <div class="ec-section-title">Student Records</div>
              <div class="ec-section-subtitle" id="resultText">Loading…</div>
            </div>
          </div>
        </div>

        <div class="sl-fbar">

          <div class="sl-srch-wrap">
            <i class="bx bx-search sl-srch-ic"></i>
            <input type="search" class="sl-srch-inp" id="slSearch" placeholder="Search name, roll no, class…">
          </div>

          <div class="sl-fbar-div"></div>

          <select class="sl-chip" id="fClass">
            <option value="">Class</option>
            <option>Grade UKG</option><option>Grade 1</option><option>Grade 2</option>
            <option>Grade 3</option><option>Grade 4</option><option>Grade 5</option>
            <option>Grade 6</option><option>Grade 7</option><option>Grade 8</option>
            <option>Grade 9</option><option>Grade 10</option><option>Grade 11</option>
            <option>Grade 12</option>
          </select>

          <select class="sl-chip" id="fGender">
            <option value="">Gender</option>
            <option>Male</option><option>Female</option><option>Other</option>
          </select>

          <select class="sl-chip" id="fFee">
            <option value="">Fee</option>
            <option>Paid</option><option>Partial</option><option>Pending</option>
          </select>

          <select class="sl-chip" id="fYear">
            <option value="">Year</option>
            <option value="2026">2025–26</option>
            <option value="2025">2024–25</option>
          </select>

          <select class="sl-chip" id="perPage" title="Rows per page">
            <option value="10">10</option>
            <option value="25">25</option>
            <option value="50">50</option>
          </select>

          <button class="sl-clear-btn d-none" id="clearBtn" title="Clear all filters">
            <i class="bx bx-x"></i>Clear
          </button>

          <div class="ms-auto d-flex gap-1 align-items-center">
            <button class="sl-export-btn xl" id="btnExcel" title="Export to Excel">
              <i class="bx bx-spreadsheet"></i>
            </button>
