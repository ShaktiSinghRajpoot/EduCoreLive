@{
    ViewData["Title"] = "Student Dashboard";
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
    int studentId = ViewBag.StudentId ?? 1;
}

@section VendorScripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
}

@section PageStyles {
<link href="~/css/educore-theme.css" rel="stylesheet" />
<style>
/* -- btn width override on mobile -- */
@@media (max-width:575.98px){
    .sd-tab-btn,.sd-pg-btn,.sd-dash .btn,.dropdown-item{width:auto !important;}
}
.dropdown-toggle::after{display:none;}

/* ── Dashboard shell ────────────────────────── */
.sd-shell{
    border:1px solid var(--ec-border);border-radius:var(--ec-radius-lg);
    background:#fff;overflow:hidden;
}

/* ── Sticky header ──────────────────────────── */
.sd-hdr{
    position:sticky;top:0;z-index:20;
    background:linear-gradient(135deg,var(--ec-primary-soft) 0%,#fff 65%);
    border-bottom:1px solid var(--ec-border);
    padding:1rem 1.5rem;
    display:flex;align-items:center;gap:1rem;flex-wrap:wrap;
}
.sd-hdr-av{
    width:58px;height:58px;flex:0 0 58px;
    border-radius:50%;border:2px solid rgba(255,138,0,.3);
    display:flex;align-items:center;justify-content:center;
    font-size:1.15rem;font-weight:800;
}
.sd-hdr-nm{font-size:1rem;font-weight:800;color:var(--ec-text-dark);margin-bottom:.15rem;}
.sd-hdr-sub{font-size:.78rem;color:var(--ec-text-muted);}
.sd-back-btn{
    margin-left:auto;
    display:inline-flex;align-items:center;gap:.3rem;
    padding:.4rem .9rem;border-radius:8px;font-size:.8rem;font-weight:700;
    background:#f5f5f5;border:1px solid var(--ec-border);color:var(--ec-text-muted);
    cursor:pointer;transition:var(--ec-transition);text-decoration:none;
    white-space:nowrap;
}
.sd-back-btn:hover{background:#fee2e2;color:#dc3545;border-color:#f5c2c7;}

/* ── Loading overlay ────────────────────────── */
.sd-loader{
    position:absolute;inset:0;background:rgba(255,255,255,.85);
    display:flex;align-items:center;justify-content:center;
    z-index:30;backdrop-filter:blur(3px);border-radius:var(--ec-radius-lg);
}

/* ── Tab nav ────────────────────────────────── */
.sd-tab-nav{
    position:sticky;top:88px;z-index:19;
    background:#fff;border-bottom:1px solid var(--ec-border);
    display:flex;overflow-x:auto;scrollbar-width:none;
}
.sd-tab-nav::-webkit-scrollbar{display:none;}
.sd-tab-btn{
    flex-shrink:0;padding:.65rem 1.1rem;
    font-size:.78rem;font-weight:700;color:var(--ec-text-muted);
    border:0;border-bottom:2px solid transparent;
    background:transparent;cursor:pointer;white-space:nowrap;
    transition:var(--ec-transition);
}
.sd-tab-btn:hover{color:var(--ec-primary);background:var(--ec-primary-light);}
.sd-tab-btn.active{color:var(--ec-primary);border-bottom-color:var(--ec-primary);background:var(--ec-primary-light);}

/* ── Tab content ────────────────────────────── */
.sd-tc{padding:1.25rem 1.5rem;}
.sd-pane{display:none;}
.sd-pane.active{display:block;}

/* ── Metric cards ───────────────────────────── */
.sd-metric{
    border:1px solid var(--ec-border);border-radius:var(--ec-radius-sm);
    padding:.85rem 1rem;text-align:center;
    transition:var(--ec-transition);
}
.sd-metric:hover{border-color:rgba(255,138,0,.3);box-shadow:var(--ec-shadow-sm);}
.sd-metric-val{font-size:1.4rem;font-weight:800;color:var(--ec-text-dark);line-height:1;}
.sd-metric-lbl{font-size:.67rem;font-weight:800;color:var(--ec-text-muted);text-transform:uppercase;letter-spacing:.04em;margin-top:.3rem;}

/* ── Subject bars ───────────────────────────── */
.sd-subj-row{margin-bottom:.75rem;}
.sd-subj-hd{display:flex;justify-content:space-between;font-size:.81rem;font-weight:700;color:var(--ec-text-dark);margin-bottom:.3rem;}
.sd-bar-wrap{height:8px;background:#f0ebe5;border-radius:999px;overflow:hidden;}
.sd-bar-fill{height:100%;border-radius:inherit;transition:width .6s ease;}

/* ── Activity feed ──────────────────────────── */
.sd-act-item{display:flex;gap:.75rem;padding:.6rem 0;border-bottom:1px dashed #eee3d8;}
.sd-act-item:last-child{border-bottom:0;}
.sd-act-ic{width:32px;height:32px;flex:0 0 32px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:.9rem;}
.sd-act-title{font-size:.83rem;font-weight:700;color:var(--ec-text-dark);}
.sd-act-time{font-size:.73rem;color:var(--ec-text-muted);}

/* ── Info grid ──────────────────────────────── */
.sd-info-grid{display:grid;grid-template-columns:1fr 1fr;gap:.5rem;}
.sd-ic{background:#fafaf8;border:1px solid var(--ec-border);border-radius:var(--ec-radius-sm);padding:.6rem .8rem;}
.sd-ic-lbl{font-size:.67rem;text-transform:uppercase;letter-spacing:.04em;font-weight:800;color:var(--ec-text-light);}
.sd-ic-val{font-size:.84rem;font-weight:700;color:var(--ec-text-dark);margin-top:.15rem;}

/* ── Attendance calendar ────────────────────── */
.sd-cal{display:grid;grid-template-columns:repeat(7,1fr);gap:4px;}
.sd-day{height:30px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:.69rem;font-weight:700;}
.aP{background:#d4edda;color:#155724;}
.aA{background:#fde8e8;color:#842029;}
.aH{background:#e2e3e5;color:#495057;}
.aL{background:#fff3cd;color:#664d03;}
.aX{background:#f5f5f5;color:#adb5bd;}
.aW{background:transparent;color:#8b8175;font-weight:800;}

/* ── Timetable ──────────────────────────────── */
.sd-tt-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch;}
.sd-tt{min-width:700px;width:100%;}
.sd-tt th{font-size:.7rem;text-transform:uppercase;letter-spacing:.04em;font-weight:800;color:var(--ec-text-light);padding:.65rem .8rem;background:#fafaf8;border:1px solid var(--ec-border);text-align:center;white-space:nowrap;}
.sd-tt td{padding:.6rem .7rem;border:1px solid var(--ec-border);text-align:center;font-size:.78rem;vertical-align:middle;}
.sd-tt .today-col td{background:rgba(255,138,0,.06);}
.sd-tt .today-col th{background:var(--ec-primary-light);color:var(--ec-primary);}
.sd-subj-cell{border-radius:6px;padding:.3rem .5rem;font-size:.75rem;font-weight:700;display:inline-block;}

/* ── Generic table style ────────────────────── */
.sd-tbl th{font-size:.7rem;text-transform:uppercase;letter-spacing:.04em;font-weight:800;color:var(--ec-text-light);padding:.65rem .8rem;background:#fafaf8;border-bottom:1px solid var(--ec-border);white-space:nowrap;}
.sd-tbl td{font-size:.82rem;font-weight:650;padding:.65rem .8rem;border-bottom:1px solid #f4f0eb;vertical-align:middle;}
.sd-tbl tr:hover td{background:#fffaf3;}

/* ── Grade badges ───────────────────────────── */
.gA{background:#d4edda;color:#155724;} .gB{background:#cce5ff;color:#004085;}
.gC{background:#fff3cd;color:#664d03;} .gD{background:#fde8e8;color:#842029;}

/* ── Badges (reuse from list) ───────────────── */
.sd-bdg{display:inline-flex;align-items:center;gap:.28rem;padding:.26rem .65rem;border-radius:999px;font-size:.69rem;font-weight:800;white-space:nowrap;}
.sd-bdg::before{content:'';width:5px;height:5px;border-radius:50%;flex-shrink:0;}
.b-paid   {background:#d1f0e0;color:#0a5a35;} .b-paid::before   {background:#198754;}
.b-partial{background:#fff3cd;color:#664d03;} .b-partial::before{background:#ffc107;}
.b-pending{background:#fde8e8;color:#842029;} .b-pending::before{background:#dc3545;}
.b-active {background:#d4edda;color:#155724;} .b-active::before {background:#28a745;}
.b-inactive{background:#e2e3e5;color:#495057;} .b-inactive::before{background:#6c757d;}
.b-transfer{background:#cfe2ff;color:#084298;} .b-transfer::before{background:#0d6efd;}

/* ── Doc rows ───────────────────────────────── */
.sd-doc-row{display:flex;align-items:center;gap:.75rem;padding:.75rem;border:1px solid var(--ec-border);border-radius:var(--ec-radius-sm);margin-bottom:.6rem;transition:var(--ec-transition);}
.sd-doc-row:hover{border-color:rgba(255,138,0,.3);}
.sd-doc-ic{width:38px;height:38px;flex:0 0 38px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;}

/* ── Profile grid ───────────────────────────── */
.sd-prof-grid{display:grid;grid-template-columns:1fr 1fr;gap:.5rem;}
.sd-pf{background:#fafaf8;border:1px solid var(--ec-border);border-radius:var(--ec-radius-sm);padding:.6rem .8rem;}
.sd-pf label{font-size:.67rem;text-transform:uppercase;letter-spacing:.04em;font-weight:800;color:var(--ec-text-light);display:block;margin-bottom:.1rem;}
.sd-pf span{font-size:.84rem;font-weight:700;color:var(--ec-text-dark);}

/* ── Warning banner ─────────────────────────── */
.sd-warn{background:#fde8e8;border:1px solid #f5c2c7;border-radius:var(--ec-radius-sm);padding:.75rem 1rem;color:#842029;font-size:.84rem;font-weight:700;}

/* ── Responsive ─────────────────────────────── */
@@media (max-width:767.98px){
    .sd-hdr{padding:.85rem 1rem;}
    .sd-tc{padding:1rem;}
    .sd-info-grid,.sd-prof-grid{grid-template-columns:1fr;}
    .sd-tab-btn{padding:.6rem .8rem;font-size:.74rem;}
}
@@media (max-width:575.98px){
    .sd-hdr-av{width:48px;height:48px;font-size:.95rem;}
    .sd-hdr-nm{font-size:.9rem;}
}
</style>
}

<div class="sd-shell" style="position:relative;">

    <div class="sd-hdr" id="sdHdr">
                <div class="sd-hdr-av bg-label-primary text-primary" id="sdAv">AV</div>
                <div>
                    <div class="sd-hdr-nm" id="sdName">Loading…</div>
                    <div class="sd-hdr-sub" id="sdMeta">—</div>
                    <div class="d-flex gap-1 flex-wrap mt-1" id="sdBadges"></div>
                </div>
                <a asp-area="ERP" asp-controller="Student" asp-action="StudentList"
                   class="sd-back-btn ms-auto">
                    <i class="bx bx-arrow-back"></i><span class="d-none d-sm-inline">Back to List</span>
                </a>
            </div>

            <nav class="sd-tab-nav" id="sdTabNav">
                <button class="sd-tab-btn active" data-tab="overview">Overview</button>
                <button class="sd-tab-btn" data-tab="academic">Academic</button>
                <button class="sd-tab-btn" data-tab="attendance">Attendance</button>
                <button class="sd-tab-btn" data-tab="timetable">Timetable</button>
                <button class="sd-tab-btn" data-tab="exams">Exam Results</button>
                <button class="sd-tab-btn" data-tab="fee">Fee Details</button>
                <button class="sd-tab-btn" data-tab="profile">Profile</button>
            </nav>

            <div class="sd-tc" id="sdTC">

                <div class="sd-pane active" id="tab-overview">
                    <div class="row g-2 mb-4" id="ov-metrics"></div>
                    <div class="row g-4">
                        <div class="col-12 col-lg-6">
                            <div class="ec-detail-box mb-0">
                                <div class="ec-detail-title">Subject Performance</div>
                                <div id="ov-bars" class="mt-2"></div>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6">
                            <div class="ec-detail-box mb-3">
                                <div class="ec-detail-title">Recent Activity</div>
                                <div id="ov-activity"></div>
                            </div>
                            <div class="ec-detail-box mb-0">
                                <div class="ec-detail-title">Quick Info</div>
                                <div class="sd-info-grid mt-2" id="ov-qinfo"></div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="sd-pane" id="tab-academic">
                    <div class="ec-detail-box mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div class="ec-detail-title mb-0">Term-wise Performance</div>
                            <small class="text-muted">— Class Average</small>
                        </div>
                        <canvas id="acChart" height="230"></canvas>
                    </div>
                    <div class="ec-detail-box mb-0">
                        <div class="ec-detail-title">Subject-wise Grades</div>
                        <div class="table-responsive">
                            <table class="table sd-tbl align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Subject</th><th>Term 1</th><th>Term 2</th>
                                        <th>Annual</th><th>Total/300</th><th>Grade</th>
                                        <th>vs Last Term</th><th>Result</th>
                                    </tr>
                                </thead>
                                <tbody id="acGradeBody"></tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="sd-pane" id="tab-attendance">
                    <div id="att-warn" class="sd-warn d-none mb-3">
                        <i class="bx bx-error me-2"></i>
                        Attendance is below 75%. Student may not be eligible for exams.
                    </div>
                    <div class="row g-2 mb-4" id="att-metrics"></div>
                    <div class="ec-detail-box mb-4">
                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                            <div class="ec-detail-title mb-0">Monthly Calendar</div>
                            <select class="form-select form-select-sm" id="attMonSel" style="width:auto;">
                                <option value="4">May 2026</option>
                                <option value="3">April 2026</option>
                                <option value="2">March 2026</option>
                            </select>
                        </div>
                        <div class="d-flex gap-3 mb-3 flex-wrap" style="font-size:.75rem;">
                            <span><span style="display:inline-block;width:10px;height:10px;background:#d4edda;border-radius:3px;"></span> Present (P)</span>
                            <span><span style="display:inline-block;width:10px;height:10px;background:#fde8e8;border-radius:3px;"></span> Absent (A)</span>
                            <span><span style="display:inline-block;width:10px;height:10px;background:#fff3cd;border-radius:3px;"></span> Half-day (H)</span>
                            <span><span style="display:inline-block;width:10px;height:10px;background:#e2e3e5;border-radius:3px;"></span> Holiday</span>
                        </div>
                        <div class="sd-cal" id="attCal"></div>
                    </div>
                    <div class="ec-detail-box mb-0">
                        <div class="ec-detail-title">Subject-wise Attendance</div>
                        <div class="table-responsive">
                            <table class="table sd-tbl align-middle mb-0">
                                <thead><tr><th>Subject</th><th>Total Classes</th><th>Present</th><th>Absent</th><th>Attendance %</th></tr></thead>
                                <tbody id="attSubjBody"></tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="sd-pane" id="tab-timetable">
                    <div class="ec-detail-box mb-0">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div class="ec-detail-title mb-0">Weekly Timetable</div>
                            <small class="text-muted fw-bold">Today highlighted in orange</small>
                        </div>
                        <div class="sd-tt-wrap">
                            <table class="sd-tt" id="ttTable">
                                <thead id="ttHead"></thead>
                                <tbody id="ttBody"></tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="sd-pane" id="tab-exams">
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
                        <div class="ec-detail-title mb-0">Exam Results</div>
                        <select class="form-select form-select-sm" id="examSel" style="width:auto;">
                            <option value="final">Annual Exam 2025–26</option>
                            <option value="mid">Mid-Term Exam</option>
                            <option value="unit1">Unit Test 1</option>
                        </select>
                    </div>
                    <div class="row g-2 mb-4" id="exam-summary"></div>
                    <div class="ec-detail-box mb-4">
                        <div class="ec-detail-title">Subject-wise Results</div>
                        <div class="table-responsive">
                            <table class="table sd-tbl align-middle mb-0">
                                <thead><tr><th>Subject</th><th>Max Marks</th><th>Obtained</th><th>%</th><th>Grade</th><th>Class Rank</th><th>Result</th></tr></thead>
                                <tbody id="examBody"></tbody>
                            </table>
                        </div>
                    </div>
                    <div class="ec-detail-box mb-0">
                        <div class="ec-detail-title">Previous Exam Comparison</div>
                        <div class="table-responsive">
                            <table class="table sd-tbl align-middle mb-0">
                                <thead><tr><th>Subject</th><th>Current</th><th>Previous</th><th>Change</th></tr></thead>
                                <tbody id="examCompBody"></tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="sd-pane" id="tab-fee">
                    <div class="row g-2 mb-4" id="fee-metrics"></div>
                    <div class="ec-detail-box mb-4">
                        <div class="ec-detail-title">Fee Structure</div>
                        <div class="table-responsive">
                            <table class="table sd-tbl align-middle mb-0">
                                <thead><tr><th>Fee Head</th><th>Total</th><th>Paid</th><th>Balance</th></tr></thead>
                                <tbody id="feeStructBody"></tbody>
                            </table>
                        </div>
                    </div>
                    <div class="ec-detail-box mb-4">
                        <div class="ec-detail-title">Payment History</div>
                        <div class="table-responsive">
                            <table class="table sd-tbl align-middle mb-0">
                                <thead><tr><th>Date</th><th>Fee Head</th><th>Amount</th><th>Mode</th><th>Receipt No</th><th>Paid By</th><th></th></tr></thead>
                                <tbody id="feeHistBody"></tbody>
                            </table>
                        </div>
                    </div>
                    <div id="concessionBox" class="d-none">
                        <div class="ec-detail-box mb-0" style="border-color:rgba(255,193,7,.4);background:#fffde7;">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="ec-detail-title">Concession / Scholarship</div>
                                    <div class="text-muted small mt-1" id="concessionDesc">Merit scholarship applied</div>
                                </div>
                                <div class="text-success fw-bold fs-6" id="concessionAmt">—</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="sd-pane" id="tab-profile">
                    <div class="mb-3 text-end">
                        <a asp-area="ERP" asp-controller="Student" asp-action="EditStudent"
                           asp-route-id="@studentId"
                           class="btn btn-primary btn-sm">
                            <i class="bx bx-edit me-1"></i>Edit Profile
                        </a>
                    </div>
                    <div id="profileContent"></div>
                </div>

            </div>

            <div class="sd-loader d-none" id="sdLoader">
                <div class="text-center">
                    <div class="spinner-border text-primary mb-2" style="width:2.5rem;height:2.5rem;"></div>
                    <div class="text-muted small fw-bold">Loading student dashboard…</div>
                </div>
            </div>

</div>

@section PageScripts {
<script>
