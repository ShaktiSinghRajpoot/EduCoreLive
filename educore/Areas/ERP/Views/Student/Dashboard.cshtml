/* ── Helpers ─────────────────────────────────── */
var MO=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
function fmtDate(d){var x=new Date(d);return String(x.getDate()).padStart(2,'0')+' '+MO[x.getMonth()]+' '+x.getFullYear();}
function ini(n){return n.split(' ').slice(0,2).map(function(w){return w[0];}).join('').toUpperCase();}
function inr(n){return n===0?'₹ 0':'₹ '+n.toLocaleString('en-IN');}
function feeB(f){var m={Paid:'b-paid',Partial:'b-partial',Pending:'b-pending'};return '<span class="sd-bdg '+(m[f]||'b-pending')+'">'+f+'</span>';}
function statB(s){var m={Active:'b-active',Inactive:'b-inactive',Transfer:'b-transfer'};return '<span class="sd-bdg '+(m[s]||'b-inactive')+'">'+s+'</span>';}
function pct(a,b){return b===0?0:Math.round(a/b*100);}
function attHtml(p){
  var c=p>=75?'#28c76f':p>=50?'#ff9f43':'#ea5455';
  var tc=p>=75?'#155724':p>=50?'#856404':'#842029';
  return '<div style="display:flex;align-items:center;gap:.4rem;">'
    +'<div style="width:55px;height:5px;background:#ede8e3;border-radius:999px;overflow:hidden;">'
    +'<div style="height:100%;width:'+p+'%;background:'+c+';border-radius:inherit;"></div></div>'
    +'<span style="font-weight:800;font-size:.8rem;color:'+tc+'">'+p+'%</span></div>';
}
function badge(txt,cls){return '<span class="sd-bdg '+cls+'">'+txt+'</span>';}

/* ── Mock detail data ────────────────────────── */
var subjs=['Mathematics','Science','English','Hindi','Social Studies','Computer'];
var subjColors=['#696cff','#28c76f','#ff9f43','#03c3ec','#e83e8c','#ea5455'];

function rand(min,max){return Math.floor(Math.random()*(max-min+1))+min;}

function getDetail(s){
    var seed=s.id;
    var marks=subjs.map(function(nm,i){
        var t1=rand(45,98),t2=rand(45,98),ann=rand(50,100);
        var tot=t1+t2+ann,p=Math.round(tot/3);
        var prev=rand(40,95);
        return{subject:nm,color:subjColors[i],t1:t1,t2:t2,annual:ann,total:tot,pct:p,
               prevPct:prev,grade:p>=85?'A':p>=70?'B':p>=55?'C':'D',pass:p>=35};
    });
    var avgScore=Math.round(marks.reduce(function(a,m){return a+m.pct;},0)/marks.length);
    var classAvg=subjs.map(function(){return rand(60,85);});

    var feeStructure=[
        {head:'Admission Fee',  total:1500, paid:1500,balance:0},
        {head:'Tuition Fee',    total:30000,paid:s.feeDue>0?30000-s.feeDue+1500:30000,balance:s.feeDue>0?s.feeDue-1500:0},
        {head:'Exam Fee',       total:1800, paid:1800,balance:0},
        {head:'Activity Fee',   total:800,  paid:s.feeDue>0?0:800,balance:s.feeDue>0?800:0}
    ];
    var totalPaid=feeStructure.reduce(function(a,f){return a+f.paid;},0);
    var totalFee=feeStructure.reduce(function(a,f){return a+f.total;},0);

    var feeHistory=[
        {date:'01 Apr 2026',head:'Admission Fee',amt:1500,mode:'Cash',   receipt:'RCP-2026-001',by:'Father'},
        {date:'01 Apr 2026',head:'Tuition Fee',  amt:2500,mode:'Online', receipt:'RCP-2026-002',by:'Father'},
        {date:'15 Apr 2026',head:'Exam Fee',     amt:1800,mode:'Cash',   receipt:'RCP-2026-003',by:'Mother'},
        {date:'05 May 2026',head:'Tuition Fee',  amt:2500,mode:'Cheque', receipt:'RCP-2026-004',by:'Father'}
    ];

    var attSubj=subjs.map(function(nm){
        var total=rand(80,100),present=Math.round(total*s.attend/100);
        return{subject:nm,total:total,present:present,absent:total-present};
    });

    var ttSubjSet=['Maths','Science','English','Hindi','SST','Computer','P.E.','—'];
    var ttColors={'Maths':'#e8f4fd','Science':'#e8f8ee','English':'#fff8e1','Hindi':'#fce4ec','SST':'#f3e5f5','Computer':'#e0f7fa','P.E.':'#fff3e0','—':'#f5f5f5'};
    var days=['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
    var periods=['P-1\n8:00','P-2\n8:45','P-3\n9:30','P-4\n10:30','P-5\n11:15','P-6\n12:00','P-7\n1:00','P-8\n1:45'];
    var teachers=['Mr. Sharma','Ms. Patel','Mr. Singh','Ms. Gupta','Mr. Verma','Ms. Rao'];
    var tt=days.map(function(){
        return periods.map(function(p,pi){
            var sj=ttSubjSet[pi%ttSubjSet.length];
            return{subj:sj,teacher:sj!=='—'?teachers[Math.floor(Math.random()*teachers.length)]:''};
        });
    });
    var todayIdx=Math.min(new Date().getDay()-1,5); // Mon=0
    if(todayIdx<0)todayIdx=0;

    return{
        dob:'15 Mar '+(2026-16+seed%3),age:(16-seed%3)+' yrs',blood:['A+','B+','O+','AB+'][seed%4],
        religion:'Hindu',category:['General','OBC','SC'][seed%3],nationality:'Indian',
        aadhaar:'1234 XXXX XXXX',motherTongue:'Hindi',caste:'—',
        fatherName:s.guardian,motherName:'Savita '+(s.name.split(' ')[1]||'Devi'),
        guardianName:s.guardian,occupation:['Farmer','Govt. Employee','Businessman','Teacher'][seed%4],
        income:['₹ 1,80,000','₹ 2,40,000','₹ 3,60,000','₹ 5,00,000'][seed%4],
        email:'parent'+s.id+'@@example.com',
        prevSchool:'Govt. High School, District',prevBoard:'UP Board',
        prevClass:'Grade '+(parseInt(s.cls.replace('Grade ',''))-1||'9'),
        tcNo:'TC-2025-0'+s.id,tcDate:'20 Mar 2025',
        rank:rand(1,40),avgScore:avgScore,marks:marks,classAvg:classAvg,
        feeStructure:feeStructure,feeHistory:feeHistory,
        totalFee:totalFee,totalPaid:totalPaid,
        hasConcession:s.feeDue>5000,concessionAmt:s.feeDue>5000?rand(500,2000):0,
        attSubj:attSubj,
        tt:tt,todayIdx:todayIdx,days:days,periods:periods,ttColors:ttColors,
        docs:[
            {name:'Birth Certificate', type:'PDF',status:'Uploaded',date:'01 Apr 2026'},
            {name:'Transfer Certificate',type:'PDF',status:'Uploaded',date:'25 Mar 2025'},
            {name:'Aadhaar Card',       type:'IMG',status:'Uploaded',date:'01 Apr 2026'},
            {name:'Passport Photo',     type:'IMG',status:'Uploaded',date:'01 Apr 2026'},
            {name:'Address Proof',      type:'PDF',status:'Pending', date:'—'}
        ]
    };
}

/* ── Load dashboard ──────────────────────────── */
function loadDashboard(id){
    var s=students.find(function(x){return x.id===id;});
    if(!s){document.getElementById('sdName').textContent='Student not found';return;}

    document.getElementById('sdLoader').classList.remove('d-none');

    /* header */
    var av=document.getElementById('sdAv');
    av.textContent=ini(s.name);
    av.className='sd-hdr-av bg-label-'+s.color+' text-'+s.color;
    document.getElementById('sdName').textContent=s.name;
    document.getElementById('sdMeta').textContent=s.roll+' · '+s.cls+' – '+s.sec+' · ADM-2026-00'+s.id;
    document.getElementById('sdBadges').innerHTML=statB(s.status)+' '+feeB(s.feeSt);

    /* simulate AJAX delay */
    setTimeout(function(){
        document.getElementById('sdLoader').classList.add('d-none');
        var d=getDetail(s);
        renderOverview(s,d);
        renderAcademic(s,d);
        renderAttendance(s,d);
        renderTimetable(d);
        renderExams(s,d);
        renderFee(s,d);
        renderProfile(s,d);
        activateTab('overview');
    },700);
}

/* ── Tabs ────────────────────────────────────── */
function activateTab(name){
    document.querySelectorAll('.sd-tab-btn').forEach(function(b){b.classList.toggle('active',b.dataset.tab===name);});
    document.querySelectorAll('.sd-pane').forEach(function(p){p.classList.toggle('active',p.id==='tab-'+name);});
    if(name==='academic' && charts.ac) charts.ac.resize();
    if(name==='attendance' && charts.att) charts.att.resize();
}
document.getElementById('sdTabNav').addEventListener('click',function(e){
    var btn=e.target.closest('.sd-tab-btn');
    if(btn) activateTab(btn.dataset.tab);
});

/* ── Tab 1: Overview ─────────────────────────── */
function renderOverview(s,d){
    document.getElementById('ov-metrics').innerHTML=
        mc('Attendance',s.attend+'%','bg-label-success text-success','bx-user-check')
       +mc('Avg Score',  d.avgScore+'%','bg-label-info text-info','bx-book-open')
       +mc('Class Rank', '#'+d.rank,'bg-label-warning text-warning','bx-medal')
       +mc('Fee Due',    inr(s.feeDue),(s.feeDue>0?'bg-label-danger text-danger':'bg-label-success text-success'),'bx-wallet');

    document.getElementById('ov-bars').innerHTML=d.marks.map(function(m){
        var col=m.pct>=85?'#28c76f':m.pct>=70?'#2196f3':m.pct>=55?'#ff9f43':'#ea5455';
        return '<div class="sd-subj-row">'
            +'<div class="sd-subj-hd"><span>'+m.subject+'</span><span>'+m.pct+'%</span></div>'
            +'<div class="sd-bar-wrap"><div class="sd-bar-fill" style="width:'+m.pct+'%;background:'+col+'"></div></div>'
            +'</div>';
    }).join('');

    document.getElementById('ov-activity').innerHTML=
        ai('bx-file','bg-label-info text-info','Last Exam: Annual Exam','Score: '+d.avgScore+'% · 15 May 2026')
       +ai('bx-wallet','bg-label-success text-success','Last Fee Payment','Paid '+inr(2500)+' · 05 May 2026')
       +ai('bx-user-x','bg-label-danger text-danger','Last Absent','18 May 2026')
       +ai('bx-user-plus','bg-label-primary text-primary','Admission',fmtDate(s.admDate));

    document.getElementById('ov-qinfo').innerHTML=
        ic('DOB',d.dob)+ic('Age',d.age)+ic('Blood Group',d.blood)+ic('Religion',d.religion)
       +ic('Category',d.category)+ic('Nationality',d.nationality)
       +ic('Aadhaar No',d.aadhaar)+ic('Mother Tongue',d.motherTongue);
}
function mc(lbl,val,cls,icon){
    return '<div class="col-6 col-sm-3"><div class="sd-metric">'
        +'<div class="d-flex justify-content-center mb-1">'
        +'<span class="'+cls+'" style="width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;">'
        +'<i class="bx '+icon+'"></i></span></div>'
        +'<div class="sd-metric-val">'+val+'</div>'
        +'<div class="sd-metric-lbl">'+lbl+'</div>'
        +'</div></div>';
}
function ai(icon,cls,title,time){
    return '<div class="sd-act-item"><div class="sd-act-ic '+cls+'"><i class="bx '+icon+'"></i></div>'
        +'<div><div class="sd-act-title">'+title+'</div><div class="sd-act-time">'+time+'</div></div></div>';
}
function ic(lbl,val){
    return '<div class="sd-ic"><div class="sd-ic-lbl">'+lbl+'</div><div class="sd-ic-val">'+val+'</div></div>';
}

/* ── Tab 2: Academic ─────────────────────────── */
function renderAcademic(s,d){
    if(charts.ac){charts.ac.destroy();charts.ac=null;}
    var ctx=document.getElementById('acChart').getContext('2d');
    charts.ac=new Chart(ctx,{
        type:'bar',
        data:{
            labels:subjs.map(function(x){return x.slice(0,5)+'.';}),
            datasets:[
                {type:'bar',  label:'Term 1', data:d.marks.map(function(m){return m.t1;}),   backgroundColor:'rgba(105,108,255,.75)',borderRadius:4},
                {type:'bar',  label:'Term 2', data:d.marks.map(function(m){return m.t2;}),   backgroundColor:'rgba(40,199,111,.75)', borderRadius:4},
                {type:'bar',  label:'Annual', data:d.marks.map(function(m){return m.annual;}),backgroundColor:'rgba(255,159,67,.75)',borderRadius:4},
                {type:'line', label:'Class Avg',data:d.classAvg,borderColor:'#ea5455',backgroundColor:'transparent',borderWidth:2,pointRadius:4,tension:.4}
            ]
        },
        options:{
            responsive:true,
            plugins:{legend:{position:'bottom',labels:{boxWidth:10,font:{size:11}}}},
            scales:{y:{beginAtZero:true,max:100,ticks:{font:{size:10}}},x:{ticks:{font:{size:10}}}}
        }
    });

    document.getElementById('acGradeBody').innerHTML=d.marks.map(function(m){
        var trend=m.pct>m.prevPct
            ?'<span class="text-success fw-bold">&#8593; +'+Math.abs(m.pct-m.prevPct)+'%</span>'
            :(m.pct<m.prevPct
                ?'<span class="text-danger fw-bold">&#8595; -'+Math.abs(m.pct-m.prevPct)+'%</span>'
                :'<span class="text-muted">—</span>');
        return '<tr>'
            +'<td class="fw-bold">'+m.subject+'</td>'
            +'<td>'+m.t1+'</td><td>'+m.t2+'</td><td>'+m.annual+'</td>'
            +'<td class="fw-bold">'+m.total+' <span class="text-muted fw-normal">/300</span></td>'
            +'<td><span class="sd-bdg g'+m.grade+'">'+m.grade+'</span></td>'
            +'<td>'+trend+'</td>'
            +'<td>'+(m.pass?'<span class="sd-bdg b-active">Pass</span>':'<span class="sd-bdg b-pending">Fail</span>')+'</td>'
            +'</tr>';
    }).join('');
}

/* ── Tab 3: Attendance ───────────────────────── */
function renderAttendance(s,d){
    if(s.attend<75) document.getElementById('att-warn').classList.remove('d-none');
    else document.getElementById('att-warn').classList.add('d-none');

    document.getElementById('att-metrics').innerHTML=
        mc('Attendance',s.attend+'%',(s.attend>=75?'bg-label-success text-success':'bg-label-danger text-danger'),'bx-user-check')
       +mc('Present','22 days','bg-label-success text-success','bx-check-circle')
       +mc('Absent','5 days','bg-label-danger text-danger','bx-x-circle')
       +mc('Half Day','2 days','bg-label-warning text-warning','bx-time');

    buildCalendar(s);

    document.getElementById('attSubjBody').innerHTML=d.attSubj.map(function(r){
        var p=pct(r.present,r.total);
        return '<tr>'
            +'<td class="fw-bold">'+r.subject+'</td>'
            +'<td>'+r.total+'</td>'
            +'<td class="text-success fw-bold">'+r.present+'</td>'
            +'<td class="text-danger fw-bold">'+r.absent+'</td>'
            +'<td>'+attHtml(p)+'</td>'
            +'</tr>';
    }).join('');

    if(charts.att){charts.att.destroy();charts.att=null;}
}

function buildCalendar(){
    var statuses=['W','W','W','P','P','P','P','A','P','P','H','P','P','W','W','P','P','P','A','P','P','W','W','L','P','P','P','P','P','P','W','W','W'];
    var days=['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
    var cal=document.getElementById('attCal');
    cal.innerHTML=days.map(function(d){return '<div class="sd-day aW">'+d+'</div>';}).join('');
    statuses.slice(0,31).forEach(function(st,i){
        var cls=st==='P'?'aP':st==='A'?'aA':st==='H'?'aL':st==='L'?'aL':'aH';
        if(st==='W')cls='aW';
        cal.innerHTML+='<div class="sd-day '+cls+'">'+(st==='W'?'':i+1)+'</div>';
    });
}

/* ── Tab 4: Timetable ───────────────────────── */
function renderTimetable(d){
    var pLabels=['8:00–8:45','8:45–9:30','9:30–10:15','Break','10:30–11:15','11:15–12:00','12:00–12:45','Lunch'];
    var thead='<tr><th>Period</th>'+d.days.map(function(day,i){
        return '<th'+(i===d.todayIdx?' style="color:var(--ec-primary);background:var(--ec-primary-light);"':'')+'>'
            +day+(i===d.todayIdx?' ★':'')+'</th>';
    }).join('')+'</tr>';
    document.getElementById('ttHead').innerHTML=thead;

    var tbody=pLabels.map(function(p,pi){
        return '<tr>'
            +'<td class="fw-bold text-muted" style="font-size:.75rem;white-space:nowrap;">'+p+'</td>'
            +d.days.map(function(day,di){
                var cell=d.tt[di][pi];
                var bg=d.ttColors[cell.subj]||'#f5f5f5';
                var todayCls=di===d.todayIdx?'border-left:2px solid var(--ec-primary);':'';
                if(!cell.subj||cell.subj==='—') return '<td style="'+todayCls+'"><span class="text-muted" style="font-size:.75rem;">—</span></td>';
                return '<td style="'+todayCls+'">'
                    +'<span class="sd-subj-cell" style="background:'+bg+'">'+cell.subj+'</span>'
                    +'<div class="text-muted mt-1" style="font-size:.68rem;">'+cell.teacher+'</div>'
                    +'</td>';
            }).join('')
            +'</tr>';
    }).join('');
    document.getElementById('ttBody').innerHTML=tbody;
}

/* ── Tab 5: Exam Results ─────────────────────── */
function renderExams(s,d){
    var totalObt=d.marks.reduce(function(a,m){return a+m.annual;},0);
    var totalMax=d.marks.length*100;
    var overallPct=pct(totalObt,totalMax);
    var division=overallPct>=60?'First Division':overallPct>=48?'Second Division':overallPct>=36?'Third Division':'Fail';
    var passed=d.marks.every(function(m){return m.pass;});

    document.getElementById('exam-summary').innerHTML=
        mc('Total Marks',totalObt+'/'+totalMax,'bg-label-primary text-primary','bx-calculator')
       +mc('Percentage',  overallPct+'%','bg-label-info text-info','bx-bar-chart-alt')
       +mc('Division',    division,'bg-label-warning text-warning','bx-trophy')
       +mc('Result',      passed?'PASS':'FAIL',(passed?'bg-label-success text-success':'bg-label-danger text-danger'),'bx-check-shield');

    document.getElementById('examBody').innerHTML=d.marks.map(function(m,i){
        return '<tr>'
            +'<td class="fw-bold">'+m.subject+'</td>'
            +'<td>100</td>'
            +'<td class="fw-bold">'+m.annual+'</td>'
            +'<td>'+m.pct+'%</td>'
            +'<td><span class="sd-bdg g'+m.grade+'">'+m.grade+'</span></td>'
            +'<td>'+rand(1,40)+'</td>'
            +'<td>'+(m.pass?'<span class="sd-bdg b-active">Pass</span>':'<span class="sd-bdg b-pending">Fail</span>')+'</td>'
            +'</tr>';
    }).join('');

    document.getElementById('examCompBody').innerHTML=d.marks.map(function(m){
        var diff=m.pct-m.prevPct;
        var arrow=diff>0?'<span class="text-success">&#8593; +'+diff+'%</span>':diff<0?'<span class="text-danger">&#8595; '+diff+'%</span>':'<span class="text-muted">—</span>';
        return '<tr><td class="fw-bold">'+m.subject+'</td><td>'+m.pct+'%</td><td>'+m.prevPct+'%</td><td>'+arrow+'</td></tr>';
    }).join('');
}

/* ── Tab 6: Fee ──────────────────────────────── */
function renderFee(s,d){
    document.getElementById('fee-metrics').innerHTML=
        mc('Total Fee', inr(d.totalFee),'bg-label-primary text-primary','bx-calculator')
       +mc('Paid',      inr(d.totalPaid),'bg-label-success text-success','bx-check-shield')
       +mc('Balance',   inr(s.feeDue),(s.feeDue>0?'bg-label-danger text-danger':'bg-label-success text-success'),'bx-error-circle')
       +mc('Receipts',  d.feeHistory.length+' txn','bg-label-info text-info','bx-receipt');

    document.getElementById('feeStructBody').innerHTML=d.feeStructure.map(function(f){
        var balStyle=f.balance>0?' class="text-danger fw-bold"':'';
        return '<tr>'
            +'<td class="fw-bold">'+f.head+'</td>'
            +'<td>'+inr(f.total)+'</td>'
            +'<td class="text-success fw-bold">'+inr(f.paid)+'</td>'
            +'<td'+balStyle+'>'+inr(f.balance)+(f.balance>0?' ⚠':'')+'</td>'
            +'</tr>';
    }).join('');

    document.getElementById('feeHistBody').innerHTML=d.feeHistory.map(function(f){
        return '<tr>'
            +'<td>'+f.date+'</td>'
            +'<td class="fw-bold">'+f.head+'</td>'
            +'<td class="text-success fw-bold">'+inr(f.amt)+'</td>'
            +'<td>'+f.mode+'</td>'
            +'<td>'+f.receipt+'</td>'
            +'<td>'+f.by+'</td>'
            +'<td><button class="btn btn-sm btn-outline-secondary" onclick="window.print()" title="Print Receipt"><i class="bx bx-printer"></i></button></td>'
            +'</tr>';
    }).join('');

    if(s.feeDue>0){
        document.getElementById('feeHistBody').innerHTML+=
            '<tr style="background:#fde8e8;">'
            +'<td colspan="2" class="fw-bold text-danger">Outstanding Balance</td>'
            +'<td colspan="5" class="text-danger fw-bold fs-6">'+inr(s.feeDue)+'</td>'
            +'</tr>';
    }

    if(d.hasConcession&&d.concessionAmt>0){
        document.getElementById('concessionBox').classList.remove('d-none');
        document.getElementById('concessionAmt').textContent='- '+inr(d.concessionAmt);
    }
}

/* ── Tab 7: Profile ──────────────────────────── */
function renderProfile(s,d){
    document.getElementById('profileContent').innerHTML=
        ps('Personal Details',[
            ['Full Name',s.name],['Roll No',s.roll],['Class / Section',s.cls+' – '+s.sec],
            ['DOB',d.dob],['Age',d.age],['Gender',s.gender],
            ['Blood Group',d.blood],['Mother Tongue',d.motherTongue],
            ['Religion',d.religion],['Caste',d.caste],
            ['Category',d.category],['Nationality',d.nationality],
            ['Aadhaar',d.aadhaar],['Address','Village Mathura, UP – 281001']
        ])
       +ps('Parent / Guardian',[
            ['Father Name',d.fatherName],['Mother Name',d.motherName],
            ['Guardian',d.guardianName],['Occupation',d.occupation],
            ['Annual Income',d.income],['Contact',s.phone],['Email',d.email]
        ])
       +ps('Previous School',[
            ['School Name',d.prevSchool],['Board',d.prevBoard],
            ['Last Class',d.prevClass],['TC Number',d.tcNo],['TC Date',d.tcDate]
        ])
       +docsSection(d.docs);
}
function ps(title,rows){
    return '<div class="mb-4">'
        +'<div class="ec-detail-title mb-2">'+title+'</div>'
        +'<div class="sd-prof-grid">'
        +rows.map(function(r){return '<div class="sd-pf"><label>'+r[0]+'</label><span>'+r[1]+'</span></div>';}).join('')
        +'</div></div>';
}
function docsSection(docs){
    var html='<div class="mb-4"><div class="ec-detail-title mb-2">Documents</div>';
    html+=docs.map(function(doc){
        var ic=doc.type==='PDF'?'bx-file-pdf':'bx-image';
        var icCol=doc.type==='PDF'?'bg-label-danger text-danger':'bg-label-info text-info';
        var stCol=doc.status==='Uploaded'?'b-active':'b-partial';
        return '<div class="sd-doc-row">'
            +'<div class="sd-doc-ic '+icCol+'"><i class="bx '+ic+'"></i></div>'
            +'<div class="flex-grow-1"><div class="fw-bold" style="font-size:.85rem;">'+doc.name+'</div>'
            +'<div class="text-muted" style="font-size:.73rem;">'+doc.type+' · '+doc.date+'</div></div>'
            +'<span class="sd-bdg '+stCol+'">'+doc.status+'</span>'
            +(doc.status==='Uploaded'
                ?'<button class="btn btn-sm btn-outline-secondary ms-2" title="Download"><i class="bx bx-download"></i></button>'
                :'<button class="btn btn-sm btn-outline-warning ms-2" title="Upload"><i class="bx bx-upload"></i></button>')
            +'</div>';
    }).join('');
    return html+'</div>';
}

/* ── Exam selector ───────────────────────────── */
document.getElementById('examSel').addEventListener('change',function(){
    var s=students.find(function(x){return x.id===STUDENT_ID;});
    if(s) renderExams(s,getDetail(s));
});

/* ── Init ────────────────────────────────────── */
loadDashboard(STUDENT_ID||1);

})();
</script>
}
