@model List<EduCoreDataAccessLayer.Models.StaffListItem>
@{
    ViewData["Title"] = "Inactive Staff";
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
}

@section PageStyles {
<link href="~/css/educore-theme.css" rel="stylesheet" />
}

<div class="ec-page-shell">
  <div class="ec-page-content">

    <div class="ec-page-header">
      <div class="ec-page-header-inner">
        <div class="ec-page-title-wrap">
          <div class="ec-page-icon rounded-4 d-flex align-items-center justify-content-center">
            <i class="bx bx-user-x fs-4"></i>
          </div>
          <div>
            <h4 class="ec-page-title mb-1">Inactive Staff</h4>
            <div class="ec-page-subtitle">Deactivated staff members — reactivate to restore access</div>
          </div>
        </div>
        <a class="btn btn-outline-secondary d-flex align-items-center gap-1"
           asp-area="ERP" asp-controller="Staff" asp-action="StaffList">
          <i class="bx bx-arrow-back"></i><span>All Staff</span>
        </a>
      </div>
    </div>

    <div class="ec-card">
      <div class="ec-card-body">
        @if (!Model.Any())
        {
            <div class="text-center text-muted py-5">
              <i class="bx bx-user-check" style="font-size:2.5rem;"></i>
              <p class="mt-2 mb-0">No inactive staff. Everyone is active.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
              <table class="table align-middle mb-0">
                <thead>
                  <tr>
                    <th>Name</th><th>Emp ID</th><th>Designation</th><th>Department</th><th>Contact</th><th class="text-end">Action</th>
                  </tr>
                </thead>
                <tbody>
                  @foreach (var s in Model)
                  {
                    <tr>
                      <td class="fw-bold">@s.FullName</td>
                      <td>@s.EmployeeCode</td>
                      <td>@s.Designation</td>
                      <td>@s.Department</td>
                      <td>@s.Mobile</td>
                      <td class="text-end">
                        <form asp-area="ERP" asp-controller="Staff" asp-action="Reactivate" method="post" class="d-inline">
                          @Html.AntiForgeryToken()
                          <input type="hidden" name="id" value="@s.StaffId" />
                          <button type="submit" class="btn btn-sm btn-primary">
                            <i class="bx bx-refresh me-1"></i>Reactivate
                          </button>
                        </form>
                      </td>
                    </tr>
                  }
                </tbody>
              </table>
            </div>
        }
      </div>
    </div>

  </div>
</div>
