@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model EduCoreDataAccessLayer.Models.StaffModel
@{
    ViewData["Title"] = "Staff Profile";
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
    int staffId = Model.StaffId;

    string Dash(string? v) => string.IsNullOrWhiteSpace(v) ? "—" : v;
    string initials = string.Concat(Model.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries)
        .Take(2).Select(w => w[0])).ToUpper();
    if (string.IsNullOrEmpty(initials)) { initials = "—"; }
    string statusClass = Model.Status == "Active" ? "b-active" : "b-active";
    string dob = Model.DateOfBirth?.ToString("dd MMM yyyy") ?? "—";
    string joinDate = Model.JoiningDate?.ToString("dd MMM yyyy") ?? "—";
    string exp = Model.ExperienceYears.HasValue ? $"{Model.ExperienceYears} yrs" : "—";
}

@section PageStyles {
<link href="~/css/educore-theme.css" rel="stylesheet" />
<style>
.sp-page{ color:var(--ec-text); }
.sp-breadcrumb{ display:flex; align-items:center; gap:.4rem; font-size:.76rem; font-weight:700; color:var(--ec-text-muted); margin-bottom:.35rem; }
.sp-breadcrumb a{ color:var(--ec-text-muted); text-decoration:none; }
.sp-breadcrumb a:hover{ color:var(--ec-primary); }
.sp-breadcrumb span{ color:var(--ec-text-dark); }

.sp-hero{ border:1px solid var(--ec-border); border-radius:var(--ec-radius); background:linear-gradient(135deg,var(--ec-primary-soft) 0%,#fff 65%); padding:1.5rem; display:flex; align-items:center; gap:1.25rem; flex-wrap:wrap; margin-bottom:1.25rem; }
.sp-av{ width:84px; height:84px; flex:0 0 84px; border-radius:22px; display:flex; align-items:center; justify-content:center; font-size:1.9rem; font-weight:900; }
.sp-name{ font-size:1.35rem; font-weight:900; color:var(--ec-text-dark); line-height:1.2; }
.sp-sub{ font-size:.85rem; font-weight:700; color:var(--ec-text-muted); }
.sp-bdg{ display:inline-flex; align-items:center; gap:.28rem; padding:.26rem .65rem; border-radius:999px; font-size:.69rem; font-weight:800; }
.sp-bdg::before{ content:''; width:5px; height:5px; border-radius:50%; }
.b-active{ background:#d4edda; color:#155724; } .b-active::before{ background:#28a745; }

.sp-card{ border:1px solid var(--ec-border); border-radius:var(--ec-radius); background:#fff; margin-bottom:1.25rem; }
.sp-card-hdr{ display:flex; align-items:center; gap:.85rem; padding:1rem 1.25rem .75rem; border-bottom:1px solid var(--ec-border); }
.sp-sec-ic{ width:38px; height:38px; flex:0 0 38px; border-radius:11px; background:var(--ec-primary-light); color:var(--ec-primary); display:flex; align-items:center; justify-content:center; font-size:1rem; }
.sp-sec-title{ font-size:.9rem; font-weight:900; color:var(--ec-text-dark); }
.sp-card-body{ padding:1.1rem 1.25rem; }
.sp-field{ margin-bottom:1rem; }
.sp-field label{ font-size:.68rem; text-transform:uppercase; letter-spacing:.05em; font-weight:800; color:var(--ec-text-light); display:block; margin-bottom:.2rem; }
.sp-field span{ font-size:.9rem; font-weight:700; color:var(--ec-text-dark); }

.sp-stat{ border:1px solid var(--ec-border); border-radius:14px; padding:1rem; text-align:center; height:100%; }
.sp-stat-val{ font-size:1.4rem; font-weight:900; color:var(--ec-text-dark); }
.sp-stat-lbl{ font-size:.7rem; font-weight:800; text-transform:uppercase; letter-spacing:.04em; color:var(--ec-text-muted); }
.sp-link{ display:flex; align-items:center; gap:.75rem; padding:.6rem .7rem; border:1px solid var(--ec-border); border-radius:13px; text-decoration:none; transition:all .16s ease; background:#fff; }
.sp-link:hover{ border-color:rgba(255,138,0,.4); background:#fffaf3; transform:translateX(2px); }
.sp-link-ic{ width:38px; height:38px; flex:0 0 38px; border-radius:11px; display:flex; align-items:center; justify-content:center; font-size:1.15rem; }
.sp-link-txt{ flex:1 1 auto; min-width:0; display:flex; flex-direction:column; }
.sp-link-t{ font-size:.86rem; font-weight:800; color:var(--ec-text-dark); }
.sp-link-s{ font-size:.72rem; font-weight:600; color:var(--ec-text-muted); }
.sp-link-go{ font-size:1.2rem; color:var(--ec-text-muted); transition:color .16s; }
.sp-link:hover .sp-link-go{ color:var(--ec-primary); }
</style>
}

<div class="ec-page-shell">
  <div class="ec-page-content sp-page">

    <div class="sp-breadcrumb">
      <a asp-area="ERP" asp-controller="Staff" asp-action="StaffList">All Staff</a>
      <i class="bx bx-chevron-right"></i><span>Profile</span>
    </div>

    <div class="sp-hero">
      <div class="sp-av bg-label-primary text-primary">@initials</div>
      <div class="flex-grow-1">
        <div class="sp-name">@Model.FullName</div>
        <div class="sp-sub">@Dash(Model.Designation) · @Dash(Model.Department)</div>
        <div class="mt-2 d-flex gap-2 flex-wrap">
          <span class="sp-bdg @statusClass">@Dash(Model.Status)</span>
          <span class="text-muted" style="font-size:.8rem;font-weight:700;">@Dash(Model.EmployeeCode)</span>
          @if (Model.UserId is not null)
          {
            <span class="sp-bdg b-active"><i class="bx bx-log-in-circle me-1"></i>Has Login</span>
          }
        </div>
      </div>
      <div class="d-flex gap-2">
        <a class="btn btn-primary d-flex align-items-center gap-1"
           asp-area="ERP" asp-controller="Staff" asp-action="EditStaff" asp-route-id="@staffId">
          <i class="bx bx-edit"></i><span>Edit Profile</span>
        </a>
        @if (Model.Status != "Inactive")
        {
          <form asp-area="ERP" asp-controller="Staff" asp-action="Deactivate" method="post"
                onsubmit="return confirm('Deactivate this staff member?');">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@staffId" />
            <button type="submit" class="btn btn-outline-danger d-flex align-items-center gap-1">
              <i class="bx bx-user-x"></i><span>Deactivate</span>
            </button>
          </form>
        }
      </div>
    </div>

    <div class="row g-0 g-lg-3">
      <div class="col-12 col-lg-7">

        <div class="sp-card">
          <div class="sp-card-hdr">
            <div class="sp-sec-ic"><i class="bx bx-user"></i></div>
            <div class="sp-sec-title">Personal Details</div>
          </div>
          <div class="sp-card-body">
            <div class="row">
              <div class="col-6 col-md-4 sp-field"><label>Gender</label><span>@Dash(Model.Gender)</span></div>
              <div class="col-6 col-md-4 sp-field"><label>Date of Birth</label><span>@dob</span></div>
              <div class="col-6 col-md-4 sp-field"><label>Blood Group</label><span>@Dash(Model.BloodGroup)</span></div>
              <div class="col-6 col-md-4 sp-field"><label>Mobile</label><span>@Dash(Model.Mobile)</span></div>
              <div class="col-12 col-md-8 sp-field"><label>Email</label><span>@Dash(Model.Email)</span></div>
              <div class="col-12 sp-field mb-0"><label>Address</label><span>@Dash(Model.Address)</span></div>
            </div>
          </div>
        </div>

        <div class="sp-card">
          <div class="sp-card-hdr">
            <div class="sp-sec-ic"><i class="bx bx-briefcase"></i></div>
            <div class="sp-sec-title">Employment Details</div>
          </div>
          <div class="sp-card-body">
            <div class="row">
              <div class="col-6 col-md-4 sp-field"><label>Designation</label><span>@Dash(Model.Designation)</span></div>
              <div class="col-6 col-md-4 sp-field"><label>Staff Type</label><span>@Dash(Model.StaffType)</span></div>
              <div class="col-6 col-md-4 sp-field"><label>Department</label><span>@Dash(Model.Department)</span></div>
              <div class="col-6 col-md-4 sp-field"><label>Joining Date</label><span>@joinDate</span></div>
              <div class="col-6 col-md-4 sp-field"><label>Qualification</label><span>@Dash(Model.Qualification)</span></div>
              <div class="col-6 col-md-4 sp-field mb-0"><label>Experience</label><span>@exp</span></div>
            </div>
          </div>
        </div>

      </div>

      <div class="col-12 col-lg-5">

        <div class="sp-card">
          <div class="sp-card-hdr">
            <div class="sp-sec-ic"><i class="bx bx-bar-chart-alt-2"></i></div>
            <div class="sp-sec-title">HR Snapshot</div>
          </div>
          <div class="sp-card-body">
            <div class="row g-2">
              <div class="col-6"><div class="sp-stat"><div class="sp-stat-val" id="spAttend">—</div><div class="sp-stat-lbl">Attendance</div></div></div>
              <div class="col-6"><div class="sp-stat"><div class="sp-stat-val" id="spLeaves">—</div><div class="sp-stat-lbl">Leaves Taken</div></div></div>
            </div>
          </div>
        </div>

        <div class="sp-card">
          <div class="sp-card-hdr">
            <div class="sp-sec-ic"><i class="bx bx-link-external"></i></div>
            <div class="sp-sec-title">HR Quick Links</div>
          </div>
          <div class="sp-card-body">
            <div class="d-flex flex-column gap-2">
              <a class="sp-link" asp-area="ERP" asp-controller="Attendance" asp-action="StaffAttendance" asp-route-id="@staffId">
                <span class="sp-link-ic" style="background:#e7f0ff;color:#3b82f6;"><i class="bx bx-user-voice"></i></span>
                <span class="sp-link-txt"><span class="sp-link-t">Staff Attendance</span><span class="sp-link-s">View daily attendance</span></span>
                <i class="bx bx-chevron-right sp-link-go"></i>
              </a>
              <a class="sp-link" asp-area="ERP" asp-controller="Leave" asp-action="LeaveManagement" asp-route-id="@staffId">
                <span class="sp-link-ic" style="background:#fce7f3;color:#be185d;"><i class="bx bx-calendar-minus"></i></span>
                <span class="sp-link-txt"><span class="sp-link-t">Leave History</span><span class="sp-link-s">Requests &amp; balance</span></span>
                <i class="bx bx-chevron-right sp-link-go"></i>
              </a>
              <a class="sp-link" asp-area="ERP" asp-controller="Payroll" asp-action="PayrollManagement" asp-route-id="@staffId">
                <span class="sp-link-ic" style="background:#dcfce7;color:#16a34a;"><i class="bx bx-money"></i></span>
                <span class="sp-link-txt"><span class="sp-link-t">Payroll / Payslips</span><span class="sp-link-s">Salary &amp; deductions</span></span>
                <i class="bx bx-chevron-right sp-link-go"></i>
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>

  </div>
</div>

