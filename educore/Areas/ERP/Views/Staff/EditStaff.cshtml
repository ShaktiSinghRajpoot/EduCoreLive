@{
    ViewData["Title"] = "Edit Staff";
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
    int staffId = ViewBag.StaffId ?? 0;
}

@section PageStyles {
<link href="~/css/educore-theme.css" rel="stylesheet" />
<style>
@@media (max-width:575.98px){
    .es-sticky .btn{ width:100% !important; }
    .es-sticky{ flex-direction:column; align-items:stretch !important; }
}
.es-page{ color:var(--ec-text); }
.es-breadcrumb{ display:flex; align-items:center; gap:.4rem; font-size:.76rem; font-weight:700; color:var(--ec-text-muted); margin-bottom:.35rem; }
.es-breadcrumb a{ color:var(--ec-text-muted); text-decoration:none; }
.es-breadcrumb a:hover{ color:var(--ec-primary); }
.es-breadcrumb span{ color:var(--ec-text-dark); }
.es-card{ border:1px solid var(--ec-border); border-radius:var(--ec-radius); background:#fff; margin-bottom:1.25rem; transition:var(--ec-transition); }
.es-card:hover{ border-color:rgba(255,138,0,.2); box-shadow:0 8px 24px rgba(43,27,18,.06); }
.es-card-hdr{ display:flex; align-items:center; gap:.85rem; padding:1rem 1.25rem .75rem; border-bottom:1px solid var(--ec-border); }
.es-sec-ic{ width:38px; height:38px; flex:0 0 38px; border-radius:11px; background:var(--ec-primary-light); color:var(--ec-primary); display:flex; align-items:center; justify-content:center; font-size:1rem; }
.es-sec-title{ font-size:.9rem; font-weight:900; color:var(--ec-text-dark); }
.es-sec-sub{ font-size:.74rem; font-weight:650; color:var(--ec-text-muted); margin-top:.08rem; }
.es-card-body{ padding:1.1rem 1.25rem; }
.es-label{ font-size:.72rem; font-weight:800; text-transform:uppercase; letter-spacing:.04em; color:var(--ec-text-muted); margin-bottom:.38rem; display:block; }
.es-label.required::after{ content:" *"; color:#ea5455; }
.es-page .form-control,.es-page .form-select{ border:1px solid var(--ec-border); border-radius:12px; min-height:46px; font-size:.88rem; font-weight:650; color:var(--ec-text); background:#fff; transition:border-color .2s,box-shadow .2s; }
.es-page .form-control:focus,.es-page .form-select:focus{ border-color:rgba(255,138,0,.6); box-shadow:0 0 0 4px rgba(255,138,0,.11); }
.es-readonly{ background:#f9f8f6 !important; color:var(--ec-text-muted) !important; cursor:not-allowed; }
.es-sticky{ position:sticky; bottom:0; background:rgba(255,255,255,.95); backdrop-filter:blur(10px); border-top:1px solid var(--ec-border); padding:1rem 1.25rem; display:flex; justify-content:flex-end; gap:.75rem; border-radius:0 0 var(--ec-radius) var(--ec-radius); z-index:5; }
</style>
}

<div class="ec-page-shell">
  <div class="ec-page-content es-page">

    <div class="ec-page-header">
      <div class="ec-page-header-inner">
        <div class="ec-page-title-wrap">
          <div class="ec-page-icon rounded-4 d-flex align-items-center justify-content-center">
            <i class="bx bx-edit fs-4"></i>
          </div>
          <div>
            <div class="es-breadcrumb">
              <a asp-area="ERP" asp-controller="Staff" asp-action="StaffList">All Staff</a>
              <i class="bx bx-chevron-right"></i>
              <a asp-area="ERP" asp-controller="Staff" asp-action="StaffProfile" asp-route-id="@staffId">Profile</a>
              <i class="bx bx-chevron-right"></i><span>Edit</span>
            </div>
            <h4 class="ec-page-title mb-0">Edit Staff Member</h4>
          </div>
        </div>
        <a class="btn btn-outline-secondary d-flex align-items-center gap-1"
           asp-area="ERP" asp-controller="Staff" asp-action="StaffProfile" asp-route-id="@staffId">
          <i class="bx bx-arrow-back"></i><span>Back</span>
        </a>
      </div>
    </div>

    <form asp-area="ERP" asp-controller="Staff" asp-action="EditStaff" method="post" novalidate>
      @Html.AntiForgeryToken()
      <input type="hidden" name="id" value="@staffId" />

      <div class="es-card">
        <div class="es-card-hdr">
          <div class="es-sec-ic"><i class="bx bx-user"></i></div>
          <div><div class="es-sec-title">Personal Details</div><div class="es-sec-sub">Identity and contact information</div></div>
        </div>
        <div class="es-card-body">
          <div class="row g-3">
            <div class="col-12 col-md-4">
              <label class="es-label required">Full Name</label>
              <input type="text" id="f_FullName" name="FullName" class="form-control" required>
            </div>
            <div class="col-12 col-md-4">
              <label class="es-label required">Gender</label>
              <select id="f_Gender" name="Gender" class="form-select" required>
                <option value="">Select</option><option>Male</option><option>Female</option><option>Other</option>
              </select>
            </div>
            <div class="col-12 col-md-4">
              <label class="es-label required">Mobile Number</label>
              <input type="tel" id="f_MobileNumber" name="MobileNumber" maxlength="10" pattern="[0-9]{10}" class="form-control" required>
            </div>
            <div class="col-12 col-md-4">
              <label class="es-label required">Email</label>
              <input type="email" id="f_Email" name="Email" class="form-control" required>
            </div>
            <div class="col-12">
              <label class="es-label">Address</label>
              <textarea id="f_Address" name="Address" class="form-control" rows="2"></textarea>
            </div>
          </div>
        </div>
      </div>

      <div class="es-card">
        <div class="es-card-hdr">
          <div class="es-sec-ic"><i class="bx bx-briefcase"></i></div>
          <div><div class="es-sec-title">Employment Details</div><div class="es-sec-sub">Role, department and joining</div></div>
        </div>
        <div class="es-card-body">
          <div class="row g-3">
            <div class="col-12 col-md-4">
              <label class="es-label">Employee ID</label>
              <input type="text" id="f_EmployeeId" name="EmployeeId" class="form-control es-readonly" readonly>
            </div>
            <div class="col-12 col-md-4">
              <label class="es-label required">Designation</label>
              <input type="text" id="f_Designation" name="Designation" class="form-control" required>
            </div>
            <div class="col-12 col-md-4">
              <label class="es-label required">Staff Type</label>
              <select id="f_StaffType" name="StaffType" class="form-select" required>
                <option value="">Select</option><option>Teaching</option><option>Non-Teaching</option>
              </select>
            </div>
            <div class="col-12 col-md-4">
              <label class="es-label required">Department</label>
              <select id="f_Department" name="Department" class="form-select" required>
                <option value="">Select</option>
                <option>Teaching</option><option>Administration</option><option>Accounts</option>
                <option>Library</option><option>Transport</option><option>Support Staff</option>
              </select>
            </div>
            <div class="col-12 col-md-4">
              <label class="es-label required">Joining Date</label>
              <input type="date" id="f_JoiningDate" name="JoiningDate" class="form-control" required>
            </div>
            <div class="col-12 col-md-4">
              <label class="es-label">Employment Status</label>
              <select id="f_Status" name="Status" class="form-select">
                <option>Active</option><option>On Leave</option><option>Inactive</option>
              </select>
            </div>
          </div>
        </div>
      </div>

      <div class="es-sticky">
        <a class="btn btn-outline-secondary px-4" asp-area="ERP" asp-controller="Staff" asp-action="StaffProfile" asp-route-id="@staffId">Cancel</a>
        <button type="submit" class="btn btn-primary px-4"><i class="bx bx-check me-1"></i>Save Changes</button>
      </div>

    </form>

  </div>
</div>

@section PageScripts {
<script>
(function(){
  /* Mock prefill — replace with model binding once the SP is ready. */
  var STAFF={
    1:{name:'Sunita Rao',gender:'Female',phone:'9876500011',email:'sunita.rao@school.edu',addr:'12 MG Road, Pune',emp:'EMP-001',desig:'Principal',type:'Non-Teaching',dept:'Administration',join:'2015-06-01',status:'Active'},
    3:{name:'Anita Desai',gender:'Female',phone:'9876500013',email:'anita.desai@school.edu',addr:'8 Park Street, Pune',emp:'EMP-003',desig:'Senior Teacher',type:'Teaching',dept:'Teaching',join:'2017-07-15',status:'Active'},
    4:{name:'Vikram Joshi',gender:'Male',phone:'9876500014',email:'vikram.joshi@school.edu',addr:'45 Lake View, Pune',emp:'EMP-004',desig:'Maths Teacher',type:'Teaching',dept:'Teaching',join:'2018-06-20',status:'Active'}
  };
  var id=@staffId;
  var s=STAFF[id]||{name:'',gender:'',phone:'',email:'',addr:'',emp:'EMP-'+String(id).padStart(3,'0'),desig:'',type:'',dept:'',join:'',status:'Active'};
  function set(elId,val){var el=document.getElementById(elId);if(el)el.value=val||'';}
  set('f_FullName',s.name); set('f_Gender',s.gender); set('f_MobileNumber',s.phone);
  set('f_Email',s.email); set('f_Address',s.addr); set('f_EmployeeId',s.emp);
  set('f_Designation',s.desig); set('f_StaffType',s.type); set('f_Department',s.dept);
  set('f_JoiningDate',s.join); set('f_Status',s.status);
})();
</script>
}
