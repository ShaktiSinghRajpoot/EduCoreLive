@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model EduCoreDataAccessLayer.Models.StaffModel
@{
    ViewData["Title"] = "Add Staff";
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
    var dd = ViewBag.Dropdowns as EduCoreDataAccessLayer.Models.StaffDropdowns ?? new EduCoreDataAccessLayer.Models.StaffDropdowns();
    var designationsJson = System.Text.Json.JsonSerializer.Serialize(dd.Designations);
}

@section PageStyles {
<link href="~/css/educore-theme.css" rel="stylesheet" />
<style>
@@media (max-width:575.98px){
    .es-sticky .btn{ width:100% !important; }
    .es-sticky{ flex-direction:column; align-items:stretch !important; }
}
.es-page{ color:var(--ec-text); }
.es-breadcrumb{ display:flex; align-items:center; gap:.4rem; font-size:.76rem; font-weight:700; color:var(--ec-text-muted); margin-bottom:.35rem; }
.es-breadcrumb a{ color:var(--ec-text-muted); text-decoration:none; }
.es-breadcrumb a:hover{ color:var(--ec-primary); }
.es-breadcrumb span{ color:var(--ec-text-dark); }
.es-card{ border:1px solid var(--ec-border); border-radius:var(--ec-radius); background:#fff; margin-bottom:1.25rem; transition:var(--ec-transition); }
.es-card:hover{ border-color:rgba(255,138,0,.2); box-shadow:0 8px 24px rgba(43,27,18,.06); }
.es-card-hdr{ display:flex; align-items:center; gap:.85rem; padding:1rem 1.25rem .75rem; border-bottom:1px solid var(--ec-border); }
.es-sec-ic{ width:38px; height:38px; flex:0 0 38px; border-radius:11px; background:var(--ec-primary-light); color:var(--ec-primary); display:flex; align-items:center; justify-content:center; font-size:1rem; }
.es-sec-title{ font-size:.9rem; font-weight:900; color:var(--ec-text-dark); }
.es-sec-sub{ font-size:.74rem; font-weight:650; color:var(--ec-text-muted); margin-top:.08rem; }
.es-card-body{ padding:1.1rem 1.25rem; }
.es-label{ font-size:.72rem; font-weight:800; text-transform:uppercase; letter-spacing:.04em; color:var(--ec-text-muted); margin-bottom:.38rem; display:block; }
.es-label.required::after{ content:" *"; color:#ea5455; }
.es-page .form-control,.es-page .form-select{ border:1px solid var(--ec-border); border-radius:12px; min-height:46px; font-size:.88rem; font-weight:650; color:var(--ec-text); background:#fff; transition:border-color .2s,box-shadow .2s; }
.es-page .form-control:focus,.es-page .form-select:focus{ border-color:rgba(255,138,0,.6); box-shadow:0 0 0 4px rgba(255,138,0,.11); }
.es-page .form-control::placeholder{ color:var(--ec-text-muted); opacity:1; }
.es-page textarea.form-control{ min-height:90px; resize:vertical; }
.es-sticky{ position:sticky; bottom:0; background:rgba(255,255,255,.95); backdrop-filter:blur(10px); border-top:1px solid var(--ec-border); padding:1rem 1.25rem; display:flex; justify-content:flex-end; gap:.75rem; border-radius:0 0 var(--ec-radius) var(--ec-radius); z-index:5; }
.es-login-toggle{ display:flex; align-items:center; gap:.6rem; }
</style>
}

<div class="ec-page-shell">
  <div class="ec-page-content es-page">

    <div class="ec-page-header">
      <div class="ec-page-header-inner">
        <div class="ec-page-title-wrap">
          <div class="ec-page-icon rounded-4 d-flex align-items-center justify-content-center">
            <i class="bx bx-user-plus fs-4"></i>
          </div>
          <div>
            <div class="es-breadcrumb">
              <a asp-area="ERP" asp-controller="Staff" asp-action="StaffList">All Staff</a>
              <i class="bx bx-chevron-right"></i><span>Add Staff</span>
            </div>
            <h4 class="ec-page-title mb-0">Add New Staff Member</h4>
          </div>
        </div>
        <a class="btn btn-outline-secondary d-flex align-items-center gap-1"
           asp-area="ERP" asp-controller="Staff" asp-action="StaffList">
          <i class="bx bx-arrow-back"></i><span>Back</span>
        </a>
      </div>
    </div>

    <div asp-validation-summary="All" class="alert alert-danger" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

    <form asp-area="ERP" asp-controller="Staff" asp-action="AddStaff" method="post" novalidate>
      @Html.AntiForgeryToken()

      <div class="row g-0">
        <div class="col-12">

          <!-- Personal -->
          <div class="es-card">
            <div class="es-card-hdr">
              <div class="es-sec-ic"><i class="bx bx-user"></i></div>
              <div><div class="es-sec-title">Personal Details</div><div class="es-sec-sub">Identity and contact information</div></div>
            </div>
            <div class="es-card-body">
              <div class="row g-3">
                <div class="col-12 col-md-4">
                  <label class="es-label required">Full Name</label>
                  <input asp-for="FullName" class="form-control" placeholder="Enter full name">
                </div>
                <div class="col-12 col-md-4">
                  <label class="es-label">Gender</label>
                  <select asp-for="Gender" class="form-select">
                    <option value="">Select</option><option>Male</option><option>Female</option><option>Other</option>
                  </select>
                </div>
                <div class="col-12 col-md-4">
                  <label class="es-label">Date of Birth</label>
                  <input asp-for="DateOfBirth" type="date" class="form-control">
                </div>
                <div class="col-12 col-md-4">
                  <label class="es-label">Mobile Number</label>
                  <input asp-for="Mobile" maxlength="10" class="form-control" placeholder="10 digit mobile">
                </div>
                <div class="col-12 col-md-4">
                  <label class="es-label">Email</label>
                  <input asp-for="Email" type="email" class="form-control" placeholder="name@school.edu">
                </div>
                <div class="col-12 col-md-4">
                  <label class="es-label">Blood Group</label>
                  <select asp-for="BloodGroup" class="form-select">
                    <option value="">Select</option><option>A+</option><option>A-</option><option>B+</option><option>B-</option><option>O+</option><option>O-</option><option>AB+</option><option>AB-</option>
                  </select>
                </div>
                <div class="col-12">
                  <label class="es-label">Address</label>
                  <textarea asp-for="Address" class="form-control" rows="2" placeholder="Complete address"></textarea>
                </div>
              </div>
            </div>
          </div>

          <!-- Employment -->
          <div class="es-card">
            <div class="es-card-hdr">
              <div class="es-sec-ic"><i class="bx bx-briefcase"></i></div>
              <div><div class="es-sec-title">Employment Details</div><div class="es-sec-sub">Designation, department and joining</div></div>
            </div>
            <div class="es-card-body">
              <div class="row g-3">
                <div class="col-12 col-md-4">
                  <label class="es-label">Employee ID</label>
                  <input asp-for="EmployeeCode" class="form-control" placeholder="e.g. EMP-021">
                </div>
                <div class="col-12 col-md-4">
                  <label class="es-label required">Designation</label>
                  <select asp-for="Designation" id="ddDesignation" class="form-select">
                    <option value="">Select designation</option>
                    @foreach (var g in dd.Designations)
                    {
                        <option value="@g.Name">@g.Name</option>
                    }
                  </select>
                </div>
                <div class="col-12 col-md-4">
                  <label class="es-label">Staff Type</label>
                  <select asp-for="StaffType" id="ddStaffType" class="form-select">
                    <option value="">Select</option>
                    <option>Teaching</option><option>Non-Teaching</option><option>Transport</option><option>Support</option>
                  </select>
                </div>
                <div class="col-12 col-md-4">
                  <label class="es-label required">Department</label>
                  <select asp-for="Department" class="form-select">
                    <option value="">Select department</option>
                    @foreach (var d in dd.Departments)
                    {
                        <option value="@d">@d</option>
                    }
                  </select>
                </div>
                <div class="col-12 col-md-4">
                  <label class="es-label">Joining Date</label>
                  <input asp-for="JoiningDate" type="date" class="form-control">
                </div>
                <div class="col-12 col-md-4">
                  <label class="es-label">Highest Qualification</label>
                  <input asp-for="Qualification" class="form-control" placeholder="e.g. M.Sc, B.Ed">
                </div>
                <div class="col-12 col-md-4">
                  <label class="es-label">Experience (years)</label>
                  <input asp-for="ExperienceYears" type="number" min="0" class="form-control" placeholder="0">
                </div>
                <div class="col-12 col-md-4">
                  <label class="es-label">Employment Status</label>
                  <select asp-for="Status" class="form-select">
                    <option>Active</option><option>On Leave</option><option>Inactive</option>
                  </select>
                </div>
              </div>
            </div>
          </div>

          <!-- Payroll / Bank -->
          <div class="es-card">
            <div class="es-card-hdr">
              <div class="es-sec-ic"><i class="bx bx-money"></i></div>
              <div><div class="es-sec-title">Payroll &amp; Bank</div><div class="es-sec-sub">Salary and account details for payroll</div></div>
            </div>
            <div class="es-card-body">
              <div class="row g-3">
                <div class="col-12 col-md-4">
                  <label class="es-label">Monthly Salary (₹)</label>
                  <input asp-for="MonthlySalary" type="number" min="0" class="form-control" placeholder="e.g. 35000">
                </div>
                <div class="col-12 col-md-4">
                  <label class="es-label">Bank Account No</label>
                  <input asp-for="BankAccountNo" class="form-control" placeholder="Account number">
                </div>
                <div class="col-12 col-md-4">
                  <label class="es-label">IFSC Code</label>
                  <input asp-for="IfscCode" class="form-control" placeholder="e.g. SBIN0001234">
                </div>
                <div class="col-12 col-md-4">
                  <label class="es-label">PAN</label>
                  <input asp-for="Pan" class="form-control" placeholder="ABCDE1234F">
                </div>
                <div class="col-12 col-md-4">
                  <label class="es-label">Aadhaar No</label>
                  <input asp-for="Aadhaar" maxlength="12" class="form-control" placeholder="12 digit Aadhaar">
                </div>
              </div>
            </div>
          </div>

          <!-- App Login (optional) -->
          <div class="es-card">
            <div class="es-card-hdr">
              <div class="es-sec-ic"><i class="bx bx-log-in-circle"></i></div>
              <div><div class="es-sec-title">App Login (optional)</div><div class="es-sec-sub">Give this staff member access to EduCore. Leave off for drivers, peons, etc.</div></div>
            </div>
            <div class="es-card-body">
              <div class="es-login-toggle mb-3">
                <input asp-for="CreateLogin" type="checkbox" class="form-check-input mt-0" id="chkLogin" style="width:2.4em;height:1.3em;">
                <label for="chkLogin" class="fw-bold mb-0" style="color:var(--ec-text-dark);">Create a login for this staff member</label>
              </div>
              <div class="row g-3" id="loginFields" style="display:none;">
                <div class="col-12 col-md-4">
                  <label class="es-label required">Login Email</label>
                  <div class="text-muted small">Uses the Email entered above.</div>
                </div>
                <div class="col-12 col-md-4">
                  <label class="es-label required">Temporary Password</label>
                  <input asp-for="LoginPassword" type="password" class="form-control" placeholder="At least 8 characters" autocomplete="new-password">
                </div>
                <div class="col-12">
                  <label class="es-label required">Role(s)</label>
                  <div class="d-flex flex-wrap gap-3">
                    @foreach (var r in dd.Roles)
                    {
                      <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="RoleIds" value="@r.RoleId" id="role_@r.RoleId" checked="@Model.RoleIds.Contains(r.RoleId)">
                        <label class="form-check-label" for="role_@r.RoleId">@r.RoleName</label>
                      </div>
                    }
                  </div>
                  <div class="text-muted small mt-1">Pick one or more — the person gets the combined access of every role selected.</div>
                </div>
              </div>
            </div>
          </div>

          <div class="es-sticky">
            <a class="btn btn-outline-secondary px-4" asp-area="ERP" asp-controller="Staff" asp-action="StaffList">Cancel</a>
            <button type="submit" class="btn btn-primary px-4"><i class="bx bx-check me-1"></i>Save Staff</button>
          </div>

        </div>
      </div>
    </form>

  </div>
</div>

@section PageScripts {
<partial name="_ValidationScriptsPartial" />
<script>
(function(){
  var designations = @Html.Raw(designationsJson);
  var ddDes = document.getElementById('ddDesignation');
  var ddType = document.getElementById('ddStaffType');
  // Auto-fill Staff Type from the chosen designation's default bucket.
  if (ddDes && ddType){
    ddDes.addEventListener('change', function(){
      var match = designations.find(function(d){ return d.Name === ddDes.value; });
      if (match && !ddType.value) ddType.value = match.StaffType;
      else if (match) ddType.value = match.StaffType;
    });
  }
  // Toggle login fields.
  var chk = document.getElementById('chkLogin');
  var box = document.getElementById('loginFields');
  function sync(){ if(box) box.style.display = chk && chk.checked ? 'flex' : 'none'; }
  if (chk){ chk.addEventListener('change', sync); sync(); }
})();
</script>
}
