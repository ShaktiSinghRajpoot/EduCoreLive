@{
    ViewData["Title"] = "Purchase Entry";
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
}

@section PageStyles {
<link href="~/css/educore-theme.css" rel="stylesheet" />
<style>
@@media (max-width:575.98px){ .purchase-footer-actions .btn{ width:auto !important; } }

/* ── summary cards (mirrors StudentList / Inventory) ───────── */
.iv-card{
    border:1px solid var(--ec-border); border-radius:14px; background:#fff;
    padding:1.1rem 1.2rem; display:flex; align-items:center; gap:.9rem;
    transition:var(--ec-transition); height:100%;
}
.iv-card:hover{ transform:translateY(-2px); box-shadow:var(--ec-shadow); border-color:rgba(255,138,0,.22); }
.iv-card-ic{ width:46px; height:46px; flex:0 0 46px; border-radius:13px; display:flex; align-items:center; justify-content:center; font-size:1.3rem; }
.iv-card-val{ font-size:1.5rem; font-weight:800; color:var(--ec-text-dark); line-height:1.1; }
.iv-card-lbl{ font-size:.71rem; font-weight:800; color:var(--ec-text-muted); text-transform:uppercase; letter-spacing:.05em; }

/* ── compact form controls (match Inventory) ───────────────── */
.purchase-page .form-control,
.purchase-page .form-select{ min-height:40px; border-radius:10px; border-color:#ececf5; font-weight:650; font-size:.85rem; }
.purchase-page .form-control:focus,
.purchase-page .form-select:focus{ border-color:#ff8a00; box-shadow:0 0 0 3px rgba(255,138,0,.12); }

/* ── items grid ────────────────────────────────────────────── */
.purchase-page .purchase-grid-wrap{ overflow-x:auto; -webkit-overflow-scrolling:touch; }
.purchase-page .purchase-grid{ min-width:980px; margin-bottom:0; }
.purchase-page .purchase-grid thead th{
    background:linear-gradient(180deg,#fffaf3,#fff6ea);
    color:var(--ec-text-light); font-size:.7rem; text-transform:uppercase; letter-spacing:.06em; font-weight:800;
    padding:.7rem .9rem; border-bottom:1px solid var(--ec-border); white-space:nowrap;
}
.purchase-page .purchase-grid td{ vertical-align:middle; border-bottom:1px solid #f4f0eb; padding:.55rem .9rem; }
.purchase-page .purchase-grid tbody tr:hover{ background:#fffaf3; }

.purchase-page .purchase-item-thumb{
    width:34px; height:34px; flex:0 0 34px; border-radius:10px; background:#fff4e6; color:#ff8a00;
    display:inline-flex; align-items:center; justify-content:center; font-size:1.05rem;
}
.purchase-page .grid-remove-btn{
    width:32px; height:32px; border-radius:8px; border:1px solid var(--ec-border);
    background:#fff; color:var(--ec-text-muted); font-size:.95rem;
    display:inline-flex; align-items:center; justify-content:center; cursor:pointer; transition:var(--ec-transition);
}
.purchase-page .grid-remove-btn:hover{ background:#fff0f0; color:#dc3545; border-color:#f5c2c7; }

/* ── totals box ────────────────────────────────────────────── */
.purchase-page .purchase-total-box{ border-radius:16px; border:1px solid var(--ec-border); background:linear-gradient(180deg,#fff,#fffaf5); }
.purchase-page .purchase-total-row{
    display:flex; justify-content:space-between; align-items:center; gap:1rem;
    padding:.65rem 0; border-bottom:1px solid #f1f1f5; font-weight:800;
}
.purchase-page .purchase-total-row:last-child{ border-bottom:0; }
.purchase-page .purchase-total-row span{ color:var(--ec-text-muted); }
.purchase-page .purchase-total-row strong{ color:var(--ec-text-dark); }

.purchase-page .purchase-sticky-footer{
    position:sticky; bottom:0; z-index:15; background:rgba(255,255,255,.95);
    backdrop-filter:blur(12px); border-top:1px solid var(--ec-border);
}
@@media (max-width:575.98px){
    .purchase-page .ec-page-header-inner{ align-items:stretch !important; }
    .purchase-page .header-actions{ width:100%; }
    .purchase-page .header-actions .btn{ flex:1; }
}
</style>
}

<div class="ec-page-shell purchase-page">
    <div class="ec-page-content">

        <div class="ec-page-header">
            <div class="ec-page-header-inner">
                <div class="ec-page-title-wrap d-flex align-items-center gap-3">
                    <div class="ec-page-icon rounded-4 d-flex align-items-center justify-content-center">
                        <i class="bx bx-cart-download fs-4"></i>
                    </div>
                    <div>
                        <h4 class="ec-page-title mb-1">Purchase Entry</h4>
                        <div class="ec-page-subtitle">Record supplier purchases and automatically increase inventory stock.</div>
                    </div>
                </div>
                <div class="header-actions d-flex gap-2 flex-wrap">
                    <button type="button" class="btn btn-outline-secondary d-flex align-items-center gap-1" id="historyBtn">
                        <i class="bx bx-history"></i><span>Purchase History</span>
                    </button>
                    <button type="button" class="btn btn-primary d-flex align-items-center gap-1" id="printBtn">
                        <i class="bx bx-printer"></i><span>Print Preview</span>
                    </button>
                </div>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-6 col-xl-3">
                <div class="iv-card">
                    <div class="iv-card-ic bg-label-primary text-primary"><i class="bx bx-rupee"></i></div>
                    <div><div class="iv-card-val">₹42,500</div><div class="iv-card-lbl">Today's Purchases</div></div>
                </div>
            </div>
            <div class="col-6 col-xl-3">
                <div class="iv-card">
                    <div class="iv-card-ic bg-label-info text-info"><i class="bx bx-receipt"></i></div>
                    <div><div class="iv-card-val">18</div><div class="iv-card-lbl">Purchase Bills</div></div>
                </div>
            </div>
            <div class="col-6 col-xl-3">
                <div class="iv-card">
                    <div class="iv-card-ic bg-label-success text-success"><i class="bx bx-package"></i></div>
                    <div><div class="iv-card-val">560</div><div class="iv-card-lbl">Items Purchased</div></div>
                </div>
            </div>
            <div class="col-6 col-xl-3">
                <div class="iv-card">
                    <div class="iv-card-ic bg-label-warning text-warning"><i class="bx bx-store"></i></div>
                    <div><div class="iv-card-val">12</div><div class="iv-card-lbl">Suppliers</div></div>
                </div>
            </div>
        </div>

        <div class="ec-card mb-3">
            <div class="ec-card-header">
                <div class="ec-section-title-wrap d-flex align-items-center gap-2">
                    <div class="ec-section-icon"><i class="bx bx-file"></i></div>
                    <div>
                        <div class="ec-section-title">Purchase Information</div>
                        <div class="ec-section-subtitle">Supplier invoice and purchase details.</div>
                    </div>
                </div>
            </div>
            <div class="ec-card-body">
                <div class="row g-3">
                    <div class="col-12 col-md-6 col-lg-3">
                        <label class="form-label">Supplier</label>
                        <select class="form-select" id="supplierId">
                            <option value="">Select Supplier</option>
                            <option>ABC Uniform House</option>
                            <option>NCERT Distributor</option>
                            <option>Sports World</option>
                        </select>
                    </div>
                    <div class="col-12 col-md-6 col-lg-3">
                        <label class="form-label">Purchase Date</label>
                        <input type="date" class="form-control" id="purchaseDate">
                    </div>
                    <div class="col-12 col-md-6 col-lg-3">
                        <label class="form-label">Invoice Number</label>
                        <input type="text" class="form-control" id="invoiceNumber" placeholder="INV-2026-001">
                    </div>
                    <div class="col-12 col-md-6 col-lg-3">
                        <label class="form-label">Payment Mode</label>
                        <select class="form-select" id="paymentMode">
                            <option>Cash</option><option>Bank Transfer</option><option>UPI</option><option>Cheque</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Remarks</label>
                        <textarea class="form-control" id="purchaseRemarks" rows="2" placeholder="Purchase remarks"></textarea>
                    </div>
                </div>
            </div>
        </div>

        <div class="ec-card mb-3">
            <div class="ec-card-header">
                <div class="d-flex justify-content-between gap-3 flex-wrap align-items-center">
                    <div class="ec-section-title-wrap d-flex align-items-center gap-2">
                        <div class="ec-section-icon"><i class="bx bx-grid-alt"></i></div>
                        <div>
                            <div class="ec-section-title">Purchase Items</div>
                            <div class="ec-section-subtitle">Add inventory items for stock purchase.</div>
                        </div>
                    </div>
                    <button type="button" class="btn btn-primary d-flex align-items-center gap-1" id="addPurchaseRowBtn">
                        <i class="bx bx-plus"></i><span>Add Item</span>
                    </button>
                </div>
            </div>
            <div class="ec-card-body p-0">
                <div class="purchase-grid-wrap">
                    <table class="table purchase-grid">
                        <thead>
                            <tr>
                                <th>Item</th>
                                <th width="150">Quantity</th>
                                <th width="160">Unit Price</th>
                                <th width="140">Tax %</th>
                                <th width="180">Total</th>
                                <th width="70"></th>
                            </tr>
                        </thead>
                        <tbody id="purchaseGridBody"></tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="row g-3">
            <div class="col-12 col-lg-7">
                <div class="ec-card h-100 mb-0">
                    <div class="ec-card-body">
                        <div class="ec-section-title-wrap d-flex align-items-center gap-2 mb-3">
                            <div class="ec-section-icon"><i class="bx bx-info-circle"></i></div>
                            <div>
                                <div class="ec-section-title">Purchase Notes</div>
                                <div class="ec-section-subtitle">Inventory stock will increase after purchase save.</div>
                            </div>
                        </div>
                        <div class="ec-detail-box">
                            <ul class="mb-0 ps-3 small fw-semibold">
                                <li>Every purchase creates inventory transaction history.</li>
                                <li>Stock is automatically updated after save.</li>
                                <li>Invoice number should be unique per supplier.</li>
                                <li>Purchase can later be linked with accounts module.</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-lg-5">
                <div class="purchase-total-box p-3 h-100">
                    <div class="purchase-total-row"><span>Sub Total</span><strong id="subTotalAmount">₹0</strong></div>
                    <div class="purchase-total-row"><span>Total Tax</span><strong id="taxAmount">₹0</strong></div>
                    <div class="purchase-total-row"><span>Grand Total</span><strong class="fs-5" id="grandTotalAmount">₹0</strong></div>
                </div>
            </div>
        </div>

        <div class="purchase-sticky-footer mt-3 p-3 rounded-4">
            <div class="d-flex justify-content-end gap-2 flex-wrap purchase-footer-actions">
                <button type="button" class="btn btn-outline-secondary px-4" id="cancelPurchaseBtn">Cancel</button>
                <button type="button" class="btn btn-primary px-4" id="savePurchaseBtn">
                    <i class="bx bx-save me-1"></i> Save Purchase
                </button>
            </div>
        </div>

    </div>
</div>

@section PageScripts {
<script src="~/js/inventory-catalog.js" asp-append-version="true"></script>
<script>
$(document).ready(function () {

    var purchaseRows = [];

    /* Item list comes from the shared inventory catalog (single source of truth). */
    var catalog = (window.EduInventory ? window.EduInventory.all() : []);
    var itemOptions = catalog.map(function (i) { return i.name; });

    function money(v){ return "₹" + Number(v||0).toLocaleString("en-IN"); }
    function toastSuccess(m){ if(typeof toastr!=="undefined") toastr.success(m); else console.log(m); }
    function toastError(m){ if(typeof toastr!=="undefined") toastr.error(m); else console.error(m); }

    function rowTotals(row){
        var amount=Number(row.qty)*Number(row.rate);
        var tax=amount*(Number(row.tax)/100);
        return { amount:amount, tax:tax, total:amount+tax };
    }

    function addRow(){
        purchaseRows.push({ id:Date.now()+Math.random(), item:"", qty:1, rate:0, tax:0 });
        renderRows();
    }

    function renderRows(){
        var html="";
        purchaseRows.forEach(function(row){
            var t=rowTotals(row);
            html += '<tr data-id="'+row.id+'">'
                + '<td><div class="d-flex align-items-center gap-2">'
                +   '<div class="purchase-item-thumb"><i class="bx bx-package"></i></div>'
                +   '<div class="flex-grow-1"><select class="form-select item-select"><option value="">Select Item</option>'
                +     itemOptions.map(function(x){return '<option value="'+x+'" '+(x===row.item?'selected':'')+'>'+x+'</option>';}).join('')
                +   '</select></div></div></td>'
                + '<td><input type="number" class="form-control qty-input" min="1" value="'+row.qty+'"></td>'
                + '<td><input type="number" class="form-control rate-input" min="0" value="'+row.rate+'"></td>'
                + '<td><input type="number" class="form-control tax-input" min="0" value="'+row.tax+'"></td>'
                + '<td><div class="fw-bold row-total">'+money(t.total)+'</div><small class="text-muted row-tax">Tax: '+money(t.tax)+'</small></td>'
                + '<td class="text-center"><button type="button" class="grid-remove-btn remove-row-btn"><i class="bx bx-trash"></i></button></td>'
                + '</tr>';
        });
        if(!html){
            html = '<tr><td colspan="6" class="text-center py-5">'
                 + '<div class="text-muted fw-bold mb-2">No items added yet</div>'
                 + '<button type="button" class="btn btn-primary" id="emptyAddRowBtn"><i class="bx bx-plus me-1"></i>Add Purchase Item</button>'
                 + '</td></tr>';
        }
        $("#purchaseGridBody").html(html);
        calculateTotals();
    }

    function calculateTotals(){
        var subTotal=0, taxTotal=0;
        purchaseRows.forEach(function(row){ var t=rowTotals(row); subTotal+=t.amount; taxTotal+=t.tax; });
        $("#subTotalAmount").text(money(subTotal));
        $("#taxAmount").text(money(taxTotal));
        $("#grandTotalAmount").text(money(subTotal+taxTotal));
    }

    $(document).on("click", "#addPurchaseRowBtn, #emptyAddRowBtn", addRow);

    $(document).on("click", ".remove-row-btn", function(){
        var rowId=Number($(this).closest("tr").data("id"));
        purchaseRows=purchaseRows.filter(function(x){return x.id!==rowId;});
        renderRows();
    });

    /* Update the model + ONLY the affected row's total cell — no full re-render,
       so the input keeps focus while typing. */
    $(document).on("input", ".qty-input, .rate-input, .tax-input", function(){
        var tr=$(this).closest("tr"), rowId=Number(tr.data("id"));
        var row=purchaseRows.find(function(x){return x.id===rowId;});
        if(!row) return;
        row.qty=Number(tr.find(".qty-input").val()||0);
        row.rate=Number(tr.find(".rate-input").val()||0);
        row.tax=Number(tr.find(".tax-input").val()||0);
        var t=rowTotals(row);
        tr.find(".row-total").text(money(t.total));
        tr.find(".row-tax").text("Tax: "+money(t.tax));
        calculateTotals();
    });

    $(document).on("change", ".item-select", function(){
        var tr=$(this).closest("tr"), rowId=Number(tr.data("id"));
        var row=purchaseRows.find(function(x){return x.id===rowId;});
        if(!row) return;
        row.item=tr.find(".item-select").val();
        /* Pre-fill unit price with the item's cost price (purchases are at cost). */
        var cat=catalog.find(function(c){return c.name===row.item;});
        if(cat && (!row.rate || row.rate<=0)){
            row.rate=Number(cat.cost||0);
            renderRows();
        }
    });

    $("#savePurchaseBtn").on("click", function(){
        if(!$("#supplierId").val()){ toastError("Please select supplier."); return; }
        if(!$("#purchaseDate").val()){ toastError("Please select purchase date."); return; }
        if(!purchaseRows.length){ toastError("Please add at least one item."); return; }
        var invalid=purchaseRows.some(function(x){return !x.item || x.qty<=0 || x.rate<=0;});
        if(invalid){ toastError("Please complete all purchase item rows."); return; }
        toastSuccess("Purchase entry saved successfully.");
        console.log({
            supplier:$("#supplierId").val(), purchaseDate:$("#purchaseDate").val(),
            invoiceNumber:$("#invoiceNumber").val(), paymentMode:$("#paymentMode").val(),
            remarks:$("#purchaseRemarks").val(), items:purchaseRows
        });
    });

    $("#cancelPurchaseBtn").on("click", function(){
        if(!confirm("Discard this purchase entry?")) return;
        $("#supplierId, #paymentMode").prop("selectedIndex",0);
        $("#purchaseDate, #invoiceNumber, #purchaseRemarks").val("");
        purchaseRows=[]; addRow();
    });

    $("#printBtn").on("click", function(){ window.print(); });
    $("#historyBtn").on("click", function(){ toastError("Purchase History screen is coming soon."); });

    if(typeof toastr!=="undefined") toastr.options={closeButton:true,progressBar:true,positionClass:'toast-top-right',timeOut:3000};

    addRow();
});
</script>
}
