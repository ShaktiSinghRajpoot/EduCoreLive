                        { receiptNo: "RCPT-2026-0007", amount: 3200, mode: "UPI", date: "05 Feb 2026", desc: "Tuition Fee - February", allocations: ["Tuition Fee - February 2026"] }
                    ]
                },
                {
                    id: 4,
                    name: "Deepak Sherma",
                    className: "11th",
                    section: "A",
                    admissionNo: "ADM20260207002",
                    parent: "Ramesh Sherma",
                    parentMobile: "9876500033",
                    lastPaymentDate: "08 Feb 2026",
                    advanceBalance: 0,
                    ledger: [
                        { id: 401, feeHead: "Lab Fee", period: "2026-27", cycle: "Yearly", type: "Mandatory", dueDate: "05 Mar 2026", originalAmount: 3000, concessionAmount: 0, paidAmount: 3000, source: "Fee Structure" },
                        { id: 402, feeHead: "Tuition Fee", period: "March 2026", cycle: "Monthly", type: "Mandatory", dueDate: "10 Mar 2026", originalAmount: 3900, concessionAmount: 0, paidAmount: 0, source: "Monthly Scheduler" }
                    ],
                    history: [
                        { receiptNo: "RCPT-2026-0009", amount: 3900, mode: "Cash", date: "08 Feb 2026", desc: "Tuition Fee - February", allocations: ["Tuition Fee - February 2026"] }
                    ]
                }
            ];

            /* ═══════════════════ STATE ═══════════════════ */
            const schoolName = "EduCore Public School";
            const avatarPalette = [
                "linear-gradient(135deg, #ffb45c, #ff8a00)",
                "linear-gradient(135deg, #54dceb, #00bad1)",
                "linear-gradient(135deg, #5be49b, #28c76f)",
                "linear-gradient(135deg, #a78bfa, #7c3aed)",
                "linear-gradient(135deg, #f58e8f, #ea5455)"
            ];

            let selectedStudentId = 2;
            let activeDueFilter = "All";
            let receiptCounter = 25;
            let paymentMode = "Cash";
            let pendingPaymentContext = null;
            let activeReceipt = null;      // { student, item } shown in receipt modal
            let voidTarget = null;         // { student, item } pending void

            const today = new Date();
            today.setHours(0, 0, 0, 0);

            /* Snapshot opening paid amounts so "Paid So Far" never double counts
               new receipts (a new payment updates both ledger and history). */
            students.forEach(function (student) {
                student.openingPaid = student.ledger.reduce(function (sum, due) {
                    return sum + Number(due.paidAmount || 0);
                }, 0);
            });

            /* ═══════════════════ HELPERS ═══════════════════ */
            function formatINR(amount) {
                return "₹" + Number(amount || 0).toLocaleString("en-IN");
            }

            function formatDate(date) {
                return date.toLocaleDateString("en-GB", { day: "2-digit", month: "short", year: "numeric" });
            }

            function escapeHtml(value) {
                return String(value == null ? "" : value)
                    .replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;")
                    .replace(/"/g, "&quot;").replace(/'/g, "&#39;");
            }

            function balanceOf(due) {
                return Math.max(0, Number(due.originalAmount || 0) - Number(due.concessionAmount || 0) - Number(due.paidAmount || 0));
            }

            function daysOverdue(due) {
                const dueDate = new Date(due.dueDate);
                if (isNaN(dueDate)) return 0;
                dueDate.setHours(0, 0, 0, 0);
                return Math.floor((today - dueDate) / 86400000);
            }

            /* Status is computed live from balance, payments and due date —
               never stored, so it can never go stale. */
            function statusOf(due) {
                if (balanceOf(due) <= 0) return "Paid";
                if (Number(due.paidAmount || 0) > 0 || Number(due.concessionAmount || 0) > 0) return "Partial";
                if (daysOverdue(due) > 0) return "Overdue";
                return "Pending";
            }

            function getSelectedStudent() {
                return students.find(function (x) { return x.id === selectedStudentId; }) || students[0];
            }

            function studentPending(student) {
                return student.ledger.reduce(function (sum, due) { return sum + balanceOf(due); }, 0);
            }

            function receiptsOf(student) {
                return student.history.filter(function (item) { return item.receiptNo && !item.voided; });
            }

            /* Money actually received = opening ledger payments + live receipts. */
            function studentPaid(student) {
                return student.openingPaid + receiptsOf(student).reduce(function (sum, item) {
                    return sum + Number(item.amount || 0);
                }, 0);
            }

            function studentTotalLedger(student) {
                return student.ledger.reduce(function (sum, due) { return sum + Number(due.originalAmount || 0); }, 0);
            }

            function getStudentStatus(student) {
                if (studentPending(student) <= 0) return "Paid";
                const hasOverdue = student.ledger.some(function (due) {
                    return balanceOf(due) > 0 && daysOverdue(due) > 0;
                });
                return hasOverdue ? "Overdue" : "Pending";
            }

            function getSelectedDues() {
                return getSelectedStudent().ledger.filter(function (due) { return due.selected && balanceOf(due) > 0; });
            }

            /* Amount the cashier intends to collect against this due in THIS
               transaction. Defaults to the full balance, but can be reduced
               per-due via the inline input (clamped to 0..balance). */
            function payAmountOf(due) {
                const bal = balanceOf(due);
                let p = (typeof due.payAmount === "number") ? due.payAmount : bal;
                if (isNaN(p) || p < 0) p = 0;
                if (p > bal) p = bal;
                return p;
            }

            function selectedDuesTotal() {
                return getSelectedDues().reduce(function (sum, due) { return sum + payAmountOf(due); }, 0);
            }

            function selectedConcessionTotal() {
                return getSelectedDues().reduce(function (sum, due) { return sum + Number(due.concessionAmount || 0); }, 0);
            }

            function avatarOf(student) {
                const parts = student.name.trim().split(/\s+/);
                return (parts[0][0] + (parts[1] ? parts[1][0] : "")).toUpperCase();
            }

            function avatarBg(student) {
                return avatarPalette[student.id % avatarPalette.length];
            }

            function pillClassFor(status) {
                return status === "Overdue" ? "pill-overdue"
                    : status === "Partial" ? "pill-partial"
                    : status === "Paid" ? "pill-paid"
                    : "pill-pending";
            }

            function modeIcon(mode) {
                switch (mode) {
                    case "Cash": return "bx-money";
                    case "UPI": return "bx-qr-scan";
                    case "Card": return "bx-credit-card-front";
                    case "Bank Transfer": return "bx-buildings";
                    case "Cheque": return "bx-notepad";
                    default: return "bx-purchase-tag-alt";
                }
            }

            /* ═══════════════════ PAYMENT CONTEXT ═══════════════════
               One source of truth for the whole payment math:
               advance first (if switched on), then cash; excess cash → advance. */
            function buildPaymentContext() {
                const student = getSelectedStudent();
                const selected = getSelectedDues();
                const selectedAmount = selectedDuesTotal();
                const useAdvance = $("#useAdvanceSwitch").is(":checked") && selectedAmount > 0;
                const advanceUsed = useAdvance ? Math.min(Number(student.advanceBalance || 0), selectedAmount) : 0;
                const remainingAfterAdvance = selectedAmount - advanceUsed;
                const amount = Number($("#paymentAmount").val() || 0);
                const adjustedFromCash = Math.min(amount, remainingAfterAdvance);
                const advanceAdded = Math.max(0, amount - remainingAfterAdvance);
                const totalAdjusted = advanceUsed + adjustedFromCash;

                let type = "Fee Collection";
                if (selectedAmount <= 0 && amount > 0) {
                    type = "Advance Payment";
                } else if (amount <= 0 && advanceUsed > 0) {
                    type = "Advance Adjustment";
                } else if (totalAdjusted < selectedAmount) {
                    type = "Partial Payment";
                } else if (advanceAdded > 0) {
                    type = "Fee Collection + Advance";
                }

                return {
                    selected: selected,
                    selectedAmount: selectedAmount,
                    amount: amount,
                    advanceUsed: advanceUsed,
                    adjustedFromCash: adjustedFromCash,
                    totalAdjusted: totalAdjusted,
                    advanceAdded: advanceAdded,
                    remaining: Math.max(0, selectedAmount - totalAdjusted),
                    mode: paymentMode,
                    referenceNo: ($("#paymentReferenceNo").val() || "").trim(),
                    remarks: ($("#paymentRemarks").val() || "").trim(),
                    collectionType: type
                };
            }

            function setCollectionType(type) {
                const pill = $("#collectionModePill");
                pill.removeClass("advance partial");

                if (type === "Advance Payment") {
                    $("#paymentSectionTitle").text("Advance Payment");
                    pill.addClass("advance").html('<i class="bx bx-wallet"></i> Advance');
                } else if (type === "Advance Adjustment") {
                    $("#paymentSectionTitle").text("Advance Adjustment");
                    pill.addClass("advance").html('<i class="bx bx-transfer"></i> From Advance');
                } else if (type === "Partial Payment") {
                    $("#paymentSectionTitle").text("Collect Payment");
                    pill.addClass("partial").html('<i class="bx bx-adjust"></i> Partial');
                } else {
                    $("#paymentSectionTitle").text("Collect Payment");
                    pill.html('<i class="bx bx-list-check"></i> Selected Dues');
                }
            }

            /* ═══════════════════ RENDER: STUDENTS ═══════════════════ */
            function buildClassSectionFilters() {
                const classes = [];
                const sections = [];

                students.forEach(function (student) {
                    if (classes.indexOf(student.className) < 0) classes.push(student.className);
                    if (sections.indexOf(student.section) < 0) sections.push(student.section);
                });

                classes.sort(function (a, b) { return parseInt(a) - parseInt(b); });
                sections.sort();

                $("#filterClass").html('<option>All Classes</option>' + classes.map(function (c) { return "<option>" + escapeHtml(c) + "</option>"; }).join(""));
                $("#filterSection").html('<option>All Sections</option>' + sections.map(function (s) { return "<option>" + escapeHtml(s) + "</option>"; }).join(""));
            }

            function renderStudentList() {
                const selectedClass = $("#filterClass").val();
                const selectedSection = $("#filterSection").val();
                const search = ($("#studentSearch").val() || "").toLowerCase();

                const matched = students.filter(function (student) {
                    const classMatch = selectedClass === "All Classes" || student.className === selectedClass;
                    const sectionMatch = selectedSection === "All Sections" || student.section === selectedSection;
                    const searchMatch =
                        student.name.toLowerCase().indexOf(search) >= 0 ||
                        student.admissionNo.toLowerCase().indexOf(search) >= 0 ||
                        (student.parent || "").toLowerCase().indexOf(search) >= 0;
                    const statusMatch = activeDueFilter === "All" || getStudentStatus(student) === activeDueFilter;
                    return classMatch && sectionMatch && searchMatch && statusMatch;
                });

                let html = "";

                matched.forEach(function (student) {
                    const pending = studentPending(student);
                    const total = studentTotalLedger(student);
                    const concession = student.ledger.reduce(function (sum, due) { return sum + Number(due.concessionAmount || 0); }, 0);
                    const settledPct = total > 0 ? Math.min(100, Math.round((total - pending) / total * 100)) : 100;
                    const status = getStudentStatus(student);

                    html +=
                        '<div class="student-item ' + (student.id === selectedStudentId ? "active" : "") + '" data-student-id="' + student.id + '">' +
                            '<div class="student-mini-avatar" style="background:' + avatarBg(student) + '">' + escapeHtml(avatarOf(student)) + '</div>' +
                            '<div class="flex-grow-1" style="min-width:0">' +
                                '<div class="d-flex justify-content-between align-items-start gap-2">' +
                                    '<div class="student-name">' + escapeHtml(student.name) + '</div>' +
                                    '<span class="pill ' + pillClassFor(status) + '">' + status + '</span>' +
                                '</div>' +
                                '<div class="student-meta">' + escapeHtml(student.className) + ' - ' + escapeHtml(student.section) + ' • ' + escapeHtml(student.admissionNo) + '</div>' +
                                '<div class="student-bottom">' +
                                    '<span class="student-due ' + (pending <= 0 ? "clear" : "") + '">' +
                                        (pending <= 0 ? '<i class="bx bx-check-circle"></i> No dues' : 'Due: ' + formatINR(pending)) +
                                    '</span>' +
                                    (Number(student.advanceBalance || 0) > 0
                                        ? '<span class="pill pill-advance"><i class="bx bx-wallet"></i> ' + formatINR(student.advanceBalance) + '</span>'
                                        : '') +
                                '</div>' +
                                '<div class="student-progress"><span style="width:' + settledPct + '%"></span></div>' +
                            '</div>' +
                        '</div>';
                });

                if (!html) {
                    html =
                        '<div class="empty-state">' +
                            '<i class="bx bx-search"></i>' +
                            '<h6>No students found</h6>' +
                            '<p>Try another search or filter.</p>' +
                        '</div>';
                }

                $("#studentList").html(html);
                $("#studentCount").text(matched.length + " of " + students.length);
            }

            /* ═══════════════════ RENDER: SELECTED STUDENT ═══════════════════ */
            function renderSelectedStudent() {
                const student = getSelectedStudent();
                const status = getStudentStatus(student);

                $("#selectedAvatar").text(avatarOf(student)).css("background", avatarBg(student));
                $("#selectedName").text(student.name);
                $("#selectedInfo").text("Class " + student.className + " - " + student.section + " • " + student.admissionNo + " • Parent: " + student.parent);
                $("#selectedStatusPill").attr("class", "pill " + pillClassFor(status)).text(status === "Paid" ? "All Clear" : status);
                $("#totalLedgerCharges").text(formatINR(studentTotalLedger(student)));
                $("#paidSoFar").text(formatINR(studentPaid(student)));
                $("#pendingDue").text(formatINR(studentPending(student)));
                $("#advanceBalance").text(formatINR(student.advanceBalance || 0));

                renderDues();
                renderHistory();
                updatePaymentSummary();
            }

            /* ═══════════════════ RENDER: DUES ═══════════════════ */
            function renderDues() {
                const student = getSelectedStudent();
                let html = "";

                student.ledger
                    .filter(function (due) { return balanceOf(due) > 0; })
                    .sort(function (a, b) { return new Date(a.dueDate) - new Date(b.dueDate); })
                    .forEach(function (due) {
                        const status = statusOf(due);
                        const overdueDays = daysOverdue(due);
                        const isExtra = due.source === "Extra Charge";
                        const accent = status === "Overdue" ? "acc-overdue" : status === "Partial" ? "acc-partial" : "acc-pending";

                        html +=
                            '<label class="due-item ' + accent + (due.selected ? " checked" : "") + '">' +
                                '<input class="form-check-input due-check" type="checkbox" data-due-id="' + due.id + '" ' + (due.selected ? "checked" : "") + '>' +
                                '<div style="min-width:0">' +
                                    '<div class="due-title">' + escapeHtml(due.feeHead) + ' - ' + escapeHtml(due.period) + '</div>' +
                                    '<div class="due-sub">Due on: ' + escapeHtml(due.dueDate) + '</div>' +
                                    '<div class="due-badges">' +
                                        '<span class="pill ' + pillClassFor(status) + '">' + status + '</span>' +
                                        (overdueDays > 0 ? '<span class="pill pill-overdue"><i class="bx bx-time-five"></i> ' + overdueDays + 'd late</span>' : '') +
                                        '<span class="pill pill-cycle">' + escapeHtml(due.cycle) + '</span>' +
                                        '<span class="pill pill-neutral">' + escapeHtml(due.type) + '</span>' +
                                        (isExtra ? '<span class="pill pill-extra">Extra Charge</span>' : '') +
                                    '</div>' +
                                '</div>' +
                                '<div class="due-amount">' +
                                    formatINR(balanceOf(due)) +
                                    '<span class="due-small">Original ' + formatINR(due.originalAmount) + '</span>' +
                                    (Number(due.concessionAmount || 0) > 0 ? '<span class="due-small">Concession ' + formatINR(due.concessionAmount) + '</span>' : '') +
                                    (Number(due.paidAmount || 0) > 0 ? '<span class="due-small">Paid ' + formatINR(due.paidAmount) + '</span>' : '') +
                                    (due.selected
                                        ? '<div class="due-pay-field">' +
                                            '<span class="due-pay-label">Pay ₹</span>' +
                                            '<input type="number" class="due-pay-input" data-due-id="' + due.id + '" value="' + payAmountOf(due) + '" min="0" max="' + balanceOf(due) + '">' +
                                          '</div>'
                                        : '') +
                                '</div>' +
                            '</label>';
                    });

                if (!html) {
                    html =
                        '<div class="empty-state">' +
                            '<i class="bx bx-check-circle"></i>' +
                            '<h6>No pending dues</h6>' +
                            '<p>This student has no pending fee dues. Any payment will be saved as advance.</p>' +
                        '</div>';
                }

                $("#dueList").html(html);
            }

            /* ═══════════════════ RENDER: HISTORY ═══════════════════ */
            function renderHistory() {
                const student = getSelectedStudent();
                const search = ($("#historySearch").val() || "").toLowerCase();
                let html = "";
                let count = 0;

                student.history.forEach(function (item, index) {
                    const haystack = ((item.receiptNo || "") + " " + (item.mode || "") + " " + (item.desc || "")).toLowerCase();
                    if (search && haystack.indexOf(search) < 0) return;

                    count++;

                    const isReceipt = !!item.receiptNo;
                    const allocations = item.allocations || [];
                    const allocationHtml = allocations.length
                        ? allocations.map(function (allocation) {
                            const label = typeof allocation === "string" ? allocation : allocation.label;
                            return '<span class="pill pill-cycle me-1 mb-1">' + escapeHtml(label) + '</span>';
                        }).join("")
                        : '<span class="pill pill-neutral me-1 mb-1">Advance Balance</span>';

                    html +=
                        '<div class="history-item ' + (item.voided ? "voided" : "") + '" data-history-index="' + index + '">' +
                            '<div class="history-top">' +
                                '<div class="d-flex gap-2" style="min-width:0">' +
                                    '<div class="history-mode-icon"><i class="bx ' + modeIcon(item.mode) + '"></i></div>' +
                                    '<div style="min-width:0">' +
                                        '<div class="receipt-no">' + escapeHtml(item.receiptNo || item.type || "LEDGER") +
                                            (item.voided ? ' <span class="pill pill-void">VOID</span>' : '') +
                                        '</div>' +
                                        '<div class="history-amount">' + formatINR(item.amount || item.concessionApplied || 0) + '</div>' +
                                    '</div>' +
                                '</div>' +
                                '<div class="history-date">' + escapeHtml(item.date) + '</div>' +
                            '</div>' +
                            '<div class="history-desc">' + escapeHtml(item.desc) + '</div>' +
                            (item.referenceNo ? '<div class="history-date mt-1">Ref: ' + escapeHtml(item.referenceNo) + '</div>' : '') +
                            (item.advanceUsed ? '<div class="history-date mt-1">Advance Adjusted: ' + formatINR(item.advanceUsed) + '</div>' : '') +
                            (typeof item.adjustedAgainstDues !== "undefined" ? '<div class="history-date mt-1">Adjusted Against Dues: ' + formatINR(item.adjustedAgainstDues) + '</div>' : '') +
                            (item.advanceAdded ? '<div class="history-date mt-1">Advance Added: ' + formatINR(item.advanceAdded) + '</div>' : '') +
                            (item.concessionApplied ? '<div class="history-date mt-1">Concession Applied: ' + formatINR(item.concessionApplied) + '</div>' : '') +
                            (item.voided ? '<div class="history-date mt-1">Voided: ' + escapeHtml(item.voidReason || "") + '</div>' : '') +
                            '<div class="mt-2">' + allocationHtml + '</div>' +
                            (isReceipt && !item.voided
                                ? '<div class="history-actions">' +
                                    '<button type="button" class="icon-btn history-view-btn" title="View / Print Receipt"><i class="bx bx-printer"></i></button>' +
                                    '<button type="button" class="icon-btn history-whatsapp-btn" title="Share on WhatsApp"><i class="bx bxl-whatsapp"></i></button>' +
                                    '<button type="button" class="icon-btn history-download-btn" title="Save as PDF"><i class="bx bx-download"></i></button>' +
                                    (item.canVoid ? '<button type="button" class="icon-btn danger history-void-btn" title="Void Receipt"><i class="bx bx-x-circle"></i></button>' : '') +
                                  '</div>'
                                : '') +
                        '</div>';
                });

                if (!html) {
                    html =
                        '<div class="empty-state">' +
                            '<i class="bx bx-receipt"></i>' +
                            '<h6>' + (search ? "No matching receipts" : "No payments yet") + '</h6>' +
                            '<p>' + (search ? "Try another receipt number or mode." : "Transaction history will appear here.") + '</p>' +
                        '</div>';
                }

                $("#historyList").html(html);
                $("#historyCount").text(count);
            }

            /* ═══════════════════ RENDER: PAYMENT SUMMARY ═══════════════════ */
            function updatePaymentSummary() {
                const student = getSelectedStudent();
                const selected = getSelectedDues();
                const selectedAmount = selectedDuesTotal();
                const advanceAvailable = Number(student.advanceBalance || 0);

                /* Advance toggle visibility */
                $("#advanceToggleBox").toggleClass("show", advanceAvailable > 0 && selectedAmount > 0);
                $("#advanceAvailableLabel").text(formatINR(advanceAvailable));
                if (!(advanceAvailable > 0 && selectedAmount > 0)) {
                    $("#useAdvanceSwitch").prop("checked", false);
                }

                /* Auto-fill the cash amount with whatever is still needed after advance. */
                const useAdvance = $("#useAdvanceSwitch").is(":checked") && selectedAmount > 0;
                const advancePreview = useAdvance ? Math.min(advanceAvailable, selectedAmount) : 0;
                const cashNeeded = Math.max(0, selectedAmount - advancePreview);

                if ($("#paymentAmount").data("auto") !== false && selectedAmount > 0) {
                    $("#paymentAmount").val(cashNeeded > 0 ? cashNeeded : "");
                }

                const ctx = buildPaymentContext();
                setCollectionType(ctx.collectionType);

                $("#selectedPayableAmount").text(formatINR(ctx.selectedAmount));
                $("#concessionAppliedAmount").text(formatINR(selectedConcessionTotal()));
                $("#advanceUsedAmount").text(formatINR(ctx.advanceUsed));
                $("#payingNowAmount").text(formatINR(ctx.amount));
                $("#remainingBalanceAmount").text(formatINR(ctx.remaining));
                $("#advanceAddedAmount").text(formatINR(ctx.advanceAdded));
                $("#selectedDueCount").text(selected.length + (selected.length === 1 ? " due" : " dues"));

                $("#advanceUsedRow").toggle(ctx.advanceUsed > 0);
                $("#remainingBalanceRow").toggle(ctx.selectedAmount > 0);
                $("#advanceAddedRow").toggle(ctx.advanceAdded > 0 || (ctx.selectedAmount <= 0 && ctx.amount > 0));

                $("#noDueInfoBox").toggleClass("show", ctx.selectedAmount <= 0 && ctx.amount > 0);
                $("#partialInfoBox").toggleClass("show", ctx.selectedAmount > 0 && (ctx.amount > 0 || ctx.advanceUsed > 0) && ctx.totalAdjusted < ctx.selectedAmount);
                $("#advanceInfoBox").toggleClass("show", ctx.advanceAdded > 0);

                /* Reference no becomes mandatory for non-cash modes. */
                $("#referenceNoLabel").toggleClass("required", paymentMode !== "Cash");

                /* Sticky collect bar — mirrors the collectable amount, always reachable. */
                const stickyAmount = ctx.amount > 0 ? ctx.amount : ctx.advanceUsed;
                $("#stickyPayingAmount").text(formatINR(stickyAmount));
                $("#stickyCollectBar").toggleClass("show", stickyAmount > 0);

                if (!selected.length) {
                    $("#selectedDuesSummary").html("<li>No dues selected. Payment will be treated as advance payment if amount is entered.</li>");
                } else {
                    $("#selectedDuesSummary").html(selected.map(function (due) {
                        const pay = payAmountOf(due);
                        const partial = pay < balanceOf(due);
                        return "<li>" + escapeHtml(due.feeHead) + " - " + escapeHtml(due.period) + " — Paying " + formatINR(pay) +
                            (partial ? " <span style='color:#168090'>(of " + formatINR(balanceOf(due)) + ")</span>" : "") + "</li>";
                    }).join(""));
                }
            }

            /* ═══════════════════ RENDER: KPI CARDS ═══════════════════ */
            function updateTopCards() {
                const todayLabel = formatDate(today);
                let collectedToday = 0, receiptsTodayCount = 0, totalCollected = 0, pendingDue = 0, advanceHeld = 0, overdueCount = 0;

                students.forEach(function (student) {
                    receiptsOf(student).forEach(function (item) {
                        totalCollected += Number(item.amount || 0);
                        if (item.date === todayLabel) {
                            collectedToday += Number(item.amount || 0);
                            receiptsTodayCount++;
                        }
                    });

                    pendingDue += studentPending(student);
                    advanceHeld += Number(student.advanceBalance || 0);
                    if (getStudentStatus(student) === "Overdue") overdueCount++;
                });

                $("#collectedToday").text(formatINR(collectedToday));
                $("#receiptsToday").text(receiptsTodayCount);
                $("#totalCollected").text(formatINR(totalCollected));
                $("#totalPendingDue").text(formatINR(pendingDue));
                $("#overdueStudents").text(overdueCount);
                $("#totalAdvanceHeld").text(formatINR(advanceHeld));
            }

            /* ═══════════════════ DAY-END / COUNTER CLOSE ═══════════════════ */
            function renderDayEndSummary() {
                const todayLabel = formatDate(today);
                const modeOrder = ["Cash", "UPI", "Card", "Bank Transfer", "Cheque"];
                const modes = {};
                let total = 0, count = 0;

                students.forEach(function (student) {
                    receiptsOf(student).forEach(function (item) {
                        if (item.date !== todayLabel) return;
                        const m = item.mode || "Other";
                        if (!modes[m]) modes[m] = { count: 0, amount: 0 };
                        modes[m].count++;
                        modes[m].amount += Number(item.amount || 0);
                        total += Number(item.amount || 0);
                        count++;
                    });
                });

                const keys = modeOrder.filter(function (m) { return modes[m]; })
                    .concat(Object.keys(modes).filter(function (m) { return modeOrder.indexOf(m) < 0; }));

                let rows = "";
                keys.forEach(function (m) {
                    rows +=
                        "<tr>" +
                            "<td><span class='daysum-mode'><i class='bx " + modeIcon(m) + "'></i> " + escapeHtml(m) + "</span></td>" +
                            "<td class='num'>" + modes[m].count + "</td>" +
                            "<td class='num'>" + formatINR(modes[m].amount) + "</td>" +
                        "</tr>";
                });

                if (!rows) {
                    rows = "<tr><td colspan='3' style='text-align:center;color:#8b8175'>No collection today.</td></tr>";
                }

                const cashAmount = modes["Cash"] ? modes["Cash"].amount : 0;

                $("#dayEndModeRows").html(rows);
                $("#dayEndTotal").text(formatINR(total));
                $("#dayEndCount").text(count);
                $("#dayEndCash").text(formatINR(cashAmount));
                $("#dayEndFootCount").text(count);
                $("#dayEndFootAmount").text(formatINR(total));
                $("#dayEndSubtitle").text("Collection for " + todayLabel + " — grouped by payment mode.");
                $("#dayEndNote").text(count
                    ? "Cash drawer should match " + formatINR(cashAmount) + ". Digital modes (UPI / Card / Bank / Cheque) settle to the bank account."
                    : "No collection recorded today yet.");

                return { total: total, count: count, todayLabel: todayLabel, modes: modes, keys: keys };
            }

            function printDayEndSummary() {
                const s = renderDayEndSummary();
                const win = window.open("", "_blank", "width=720,height=820");
                if (!win) {
                    toastr.warning("Pop-up blocked. Please allow pop-ups to print.");
                    return;
                }

                let rows = "";
                s.keys.forEach(function (m) {
                    rows += "<tr><td>" + escapeHtml(m) + "</td><td style='text-align:right'>" + s.modes[m].count + "</td><td style='text-align:right'>" + formatINR(s.modes[m].amount) + "</td></tr>";
                });
                if (!rows) {
                    rows = "<tr><td colspan='3' style='text-align:center'>No collection today.</td></tr>";
                }

                win.document.write(
                    "<html><head><title>Day Summary " + escapeHtml(s.todayLabel) + "<\/title>" +
                    "<style>" +
                        "body{font-family:Segoe UI,Arial,sans-serif;color:#2b2c40;padding:24px;font-size:13px}" +
                        "h3{margin:0 0 4px}" +
                        "table{width:100%;border-collapse:collapse;margin-top:12px}" +
                        "th,td{border:1px solid #ddd;padding:7px 9px}" +
                        "th{background:#f7f7f7;text-align:left}" +
                        "tfoot td{font-weight:700}" +
                    "<\/style><\/head><body>" +
                        "<h3>" + escapeHtml(schoolName) + "</h3>" +
                        "<div>Day-End Collection Summary — " + escapeHtml(s.todayLabel) + "</div>" +
                        "<table>" +
                            "<thead><tr><th>Payment Mode</th><th style='text-align:right'>Receipts</th><th style='text-align:right'>Amount</th></tr></thead>" +
                            "<tbody>" + rows + "</tbody>" +
                            "<tfoot><tr><td>Total</td><td style='text-align:right'>" + s.count + "</td><td style='text-align:right'>" + formatINR(s.total) + "</td></tr></tfoot>" +
                        "</table>" +
                        "<p style='margin-top:28px'>Counter Signature: ____________________</p>" +
                    "<\/body><\/html>"
                );
                win.document.close();
                win.focus();
                setTimeout(function () { win.print(); }, 250);
            }

            /* ═══════════════════ PAYMENT FLOW ═══════════════════ */
            function resetPaymentForm() {
                setCollectionType("Fee Collection");
                paymentMode = "Cash";
                $(".mode-pill").removeClass("active").filter('[data-mode="Cash"]').addClass("active");
                $("#paymentReferenceNo").val("");
                $("#paymentRemarks").val("");
                $("#useAdvanceSwitch").prop("checked", false);
                $("#paymentAmount").val("").data("auto", true);
                pendingPaymentContext = null;
                $("#noDueInfoBox, #advanceInfoBox, #partialInfoBox").removeClass("show");
                $("#stickyCollectBar").removeClass("show");
            }

            function validatePaymentContext(ctx) {
                if (ctx.amount < 0) {
                    toastr.error("Amount cannot be negative.");
                    return false;
                }

                if (ctx.amount <= 0 && ctx.advanceUsed <= 0) {
                    toastr.error("Enter a payment amount or use advance balance.");
                    return false;
                }

                if (ctx.amount > 0 && ctx.mode !== "Cash" && !ctx.referenceNo) {
                    toastr.error("Reference number is required for " + ctx.mode + " payments.");
                    $("#paymentReferenceNo").trigger("focus");
                    return false;
                }

                return true;
            }

            function showPaymentConfirmModal(ctx) {
                $("#paymentConfirmTitle").text("Confirm " + ctx.collectionType);
                $("#paymentConfirmSubtitle").text("Review payment allocation before collection.");
                $("#confirmCollectedAmount").text(formatINR(ctx.amount));
                $("#confirmAdvanceUsed").text(formatINR(ctx.advanceUsed));
                $("#confirmAdjustedAmount").text(formatINR(ctx.totalAdjusted));
                $("#confirmAdvanceAdded").text(formatINR(ctx.advanceAdded));
                $("#confirmCollectionType").text(ctx.collectionType);

                let note;
                if (ctx.collectionType === "Advance Payment") {
                    note = "No dues selected — full amount will be stored as advance balance and can be adjusted in future fee dues.";
                } else if (ctx.advanceUsed > 0 && ctx.advanceAdded > 0) {
                    note = "Advance balance will be adjusted first, then cash. Extra cash returns to advance balance.";
                } else if (ctx.advanceUsed > 0) {
                    note = "Advance balance of " + formatINR(ctx.advanceUsed) + " will be consumed against selected dues (oldest first).";
                } else if (ctx.advanceAdded > 0) {
                    note = "Extra " + formatINR(ctx.advanceAdded) + " will be stored as advance balance for future dues.";
                } else if (ctx.collectionType === "Partial Payment") {
                    note = "Amount is less than selected dues. Payment will be adjusted oldest due first; the rest stays pending.";
                } else {
                    note = "Payment will be adjusted against selected dues using oldest due first.";
                }
                $("#confirmNote").text(note);

                pendingPaymentContext = ctx;
                $("#paymentConfirmModal").modal("show");
            }

            function processPayment(ctx) {
                const student = getSelectedStudent();
                let remaining = ctx.totalAdjusted;
                const allocationObjects = [];

                ctx.selected
                    .slice()
                    .sort(function (a, b) { return new Date(a.dueDate) - new Date(b.dueDate); })
                    .forEach(function (due) {
                        if (remaining <= 0) return;

                        const applied = Math.min(balanceOf(due), payAmountOf(due), remaining);
                        due.paidAmount = Number(due.paidAmount || 0) + applied;
                        remaining -= applied;
                        due.selected = false;
                        delete due.payAmount;

                        allocationObjects.push({
                            ledgerId: due.id,
                            label: due.feeHead + " - " + due.period,
                            appliedAmount: applied,
                            balanceAfter: balanceOf(due)
                        });
                    });

                if (ctx.advanceUsed > 0) {
                    student.advanceBalance = Math.max(0, Number(student.advanceBalance || 0) - ctx.advanceUsed);
                }
                if (ctx.advanceAdded > 0) {
                    student.advanceBalance = Number(student.advanceBalance || 0) + ctx.advanceAdded;
                }

                receiptCounter++;
                const todayLabel = formatDate(today);
                student.lastPaymentDate = todayLabel;

                const desc = ctx.collectionType === "Advance Payment" ? "Advance Payment Receipt"
                    : ctx.collectionType === "Advance Adjustment" ? "Advance Adjustment Receipt"
                    : ctx.collectionType === "Partial Payment" ? "Partial Payment Receipt"
                    : ctx.collectionType === "Fee Collection + Advance" ? "Fee Collection + Advance Receipt"
                    : "Fee Collection Receipt";

                const receipt = {
                    receiptNo: "RCPT-2026-" + String(receiptCounter).padStart(4, "0"),
                    amount: ctx.amount,
                    mode: ctx.mode,
                    date: todayLabel,
                    desc: ctx.remarks ? desc + " - " + ctx.remarks : desc,
                    referenceNo: ctx.referenceNo,
                    advanceUsed: ctx.advanceUsed,
                    adjustedAgainstDues: ctx.totalAdjusted,
                    advanceAdded: ctx.advanceAdded,
                    allocations: allocationObjects,
                    canVoid: true
                };

                student.history.unshift(receipt);

                resetPaymentForm();
                refreshAll();

                toastr.success("Receipt " + receipt.receiptNo + " — " + ctx.collectionType + " recorded.");
                openReceiptModal(student, receipt);
            }

            /* ═══════════════════ RECEIPT PREVIEW / PRINT ═══════════════════ */
            function buildReceiptHtml(student, item) {
                const allocations = item.allocations || [];
                let rows = "";

                allocations.forEach(function (allocation, i) {
                    const label = typeof allocation === "string" ? allocation : allocation.label;
                    const applied = typeof allocation === "string" ? "" : formatINR(allocation.appliedAmount);
                    const after = (typeof allocation === "string" || typeof allocation.balanceAfter === "undefined") ? "" : formatINR(allocation.balanceAfter);

                    rows +=
                        "<tr>" +
                            "<td>" + (i + 1) + "</td>" +
                            "<td>" + escapeHtml(label) + "</td>" +
                            "<td style='text-align:right'>" + applied + "</td>" +
                            "<td style='text-align:right'>" + after + "</td>" +
                        "</tr>";
                });

                if (!rows) {
                    rows = "<tr><td colspan='4' style='text-align:center'>Stored as advance balance</td></tr>";
                }

                return (
                    '<div class="receipt-school">' +
                        "<h5>" + escapeHtml(schoolName) + "</h5>" +
                        "<small>Fee Receipt • Session 2026-27</small>" +
                    "</div>" +
                    '<div class="receipt-meta">' +
                        "<div>Receipt No: <strong>" + escapeHtml(item.receiptNo) + "</strong></div>" +
                        "<div>Date: <strong>" + escapeHtml(item.date) + "</strong></div>" +
                    "</div>" +
                    '<div class="receipt-meta">' +
                        "<div>Student: <strong>" + escapeHtml(student.name) + "</strong> (" + escapeHtml(student.className) + " - " + escapeHtml(student.section) + ")</div>" +
                        "<div>Adm No: <strong>" + escapeHtml(student.admissionNo) + "</strong></div>" +
                    "</div>" +
                    '<table class="receipt-table">' +
                        "<thead><tr><th>#</th><th>Fee Head</th><th style='text-align:right'>Adjusted</th><th style='text-align:right'>Balance After</th></tr></thead>" +
                        "<tbody>" + rows + "</tbody>" +
                    "</table>" +
                    '<div class="receipt-totals">' +
                        (item.advanceUsed ? "<div>Advance Adjusted: " + formatINR(item.advanceUsed) + "</div>" : "") +
                        "<div>Amount Collected (" + escapeHtml(item.mode || "-") + "): <span style='font-size:1rem'>" + formatINR(item.amount) + "</span></div>" +
                        (item.advanceAdded ? "<div>Advance Added: " + formatINR(item.advanceAdded) + "</div>" : "") +
                        (item.referenceNo ? "<div>Ref No: " + escapeHtml(item.referenceNo) + "</div>" : "") +
                    "</div>" +
                    '<div class="receipt-foot">' +
                        "<span>Parent: " + escapeHtml(student.parent || "-") + "</span>" +
                        "<span>Authorised Signatory</span>" +
                    "</div>"
                );
            }

            function openReceiptModal(student, item) {
                activeReceipt = { student: student, item: item };
                $("#receiptModalSubtitle").text(item.receiptNo + " • " + student.name);
                $("#receiptPaper").html(buildReceiptHtml(student, item));
                $("#receiptModal").modal("show");
            }

            function printReceipt(autoPrint) {
                if (!activeReceipt) return;

                const win = window.open("", "_blank", "width=760,height=900");
                if (!win) {
                    toastr.warning("Pop-up blocked. Please allow pop-ups to print receipts.");
                    return;
                }

                const copy = function (label) {
                    return "<div class='receipt-copy'>" +
                        "<div class='copy-tag'>" + label + "</div>" +
                        buildReceiptHtml(activeReceipt.student, activeReceipt.item) +
                    "</div>";
                };

                win.document.write(
                    "<html><head><title>" + activeReceipt.item.receiptNo + "<\/title>" +
                    "<style>" +
                        "body{font-family:Segoe UI,Arial,sans-serif;color:#2b2c40;padding:24px;font-size:13px}" +
                        ".receipt-school{text-align:center;border-bottom:2px dashed #ccc;padding-bottom:10px;margin-bottom:10px}" +
                        ".receipt-school h5{margin:0 0 2px;font-size:18px}" +
                        ".receipt-meta{display:flex;justify-content:space-between;margin-bottom:10px}" +
                        ".receipt-table{width:100%;border-collapse:collapse;margin-bottom:10px}" +
                        ".receipt-table th,.receipt-table td{border:1px solid #ddd;padding:6px 8px;font-size:12px}" +
                        ".receipt-table th{background:#f7f7f7}" +
                        ".receipt-totals{text-align:right;font-weight:700}" +
                        ".receipt-totals div{margin-bottom:3px}" +
                        ".receipt-foot{border-top:2px dashed #ccc;margin-top:14px;padding-top:10px;display:flex;justify-content:space-between;color:#777;font-size:11px}" +
                        ".copy-tag{display:inline-block;background:#fff4e6;color:#eb7d00;border:1px solid #ffd9a8;border-radius:20px;padding:2px 10px;font-size:11px;font-weight:700;margin-bottom:8px}" +
                        ".receipt-copy{page-break-inside:avoid}" +
                        ".copy-divider{border-top:1px dashed #bbb;margin:20px 0}" +
                    "<\/style><\/head><body>" +
                        copy("PARENT COPY") +
                        "<div class='copy-divider'><\/div>" +
                        copy("OFFICE COPY") +
                    "<\/body><\/html>"
                );
                win.document.close();
                win.focus();

                if (autoPrint) {
                    setTimeout(function () { win.print(); }, 250);
                }
            }

            function shareReceiptWhatsApp(student, item) {
                const text =
                    schoolName + " - Fee Receipt\n" +
                    "Receipt: " + item.receiptNo + "\n" +
                    "Student: " + student.name + " (" + student.className + "-" + student.section + ")\n" +
                    "Amount: " + formatINR(item.amount) + " via " + (item.mode || "-") + "\n" +
                    "Date: " + item.date + "\n" +
                    "Pending Due: " + formatINR(studentPending(student));

                const phone = (student.parentMobile || "").replace(/\D/g, "");
                const url = phone
                    ? "https://wa.me/91" + phone + "?text=" + encodeURIComponent(text)
                    : "https://wa.me/?text=" + encodeURIComponent(text);

                window.open(url, "_blank");
            }

            /* ═══════════════════ VOID RECEIPT ═══════════════════ */
            function voidReceipt(student, item, reason) {
                (item.allocations || []).forEach(function (allocation) {
                    if (typeof allocation === "string" || !allocation.ledgerId) return;

                    const due = student.ledger.find(function (row) { return row.id === allocation.ledgerId; });
                    if (due) {
                        due.paidAmount = Math.max(0, Number(due.paidAmount || 0) - Number(allocation.appliedAmount || 0));
                    }
                });

                /* Return consumed advance, remove added advance. */
                if (item.advanceUsed) {
                    student.advanceBalance = Number(student.advanceBalance || 0) + Number(item.advanceUsed);
                }
                if (item.advanceAdded) {
                    student.advanceBalance = Math.max(0, Number(student.advanceBalance || 0) - Number(item.advanceAdded));
                }

                item.voided = true;
                item.canVoid = false;
                item.voidReason = reason;

                refreshAll();
                toastr.success("Receipt " + item.receiptNo + " voided and allocations reversed.");
            }

            /* ═══════════════════ CONCESSION ═══════════════════ */
            function updateConcessionPreview() {
                const selectedAmount = selectedDuesTotal();
                const enteredAmount = Number($("#concessionAmount").val() || 0);
                const concession = Math.min(selectedAmount, enteredAmount);

                $("#concessionSelectedDuesAmount").text(formatINR(selectedAmount));
                $("#concessionPreviewAmount").text(formatINR(concession));
                $("#concessionBalanceAfterAmount").text(formatINR(Math.max(0, selectedAmount - concession)));

                return concession;
            }

            function refreshAll() {
                updateTopCards();
                renderStudentList();
                renderSelectedStudent();
            }

            /* ═══════════════════ EVENTS ═══════════════════ */
            $(document).on("click", ".student-item", function () {
                selectedStudentId = Number($(this).data("student-id"));
                getSelectedStudent().ledger.forEach(function (due) { due.selected = false; delete due.payAmount; });
                resetPaymentForm();
                $("#historySearch").val("");
                renderStudentList();
                renderSelectedStudent();
            });

            $(document).on("click", ".quick-filter", function () {
                activeDueFilter = $(this).data("filter");
                $(".quick-filter").removeClass("active");
                $(this).addClass("active");
                renderStudentList();
            });

            $(document).on("change", ".due-check", function () {
                const dueId = Number($(this).data("due-id"));
                const due = getSelectedStudent().ledger.find(function (item) { return item.id === dueId; });

                if (due) {
                    due.selected = $(this).is(":checked");
                    if (due.selected) {
                        due.payAmount = balanceOf(due);
                    } else {
                        delete due.payAmount;
                    }
                }

                $("#paymentAmount").data("auto", true);
                renderDues();
                updatePaymentSummary();
            });

            /* Per-due amount — lets the cashier pay a specific amount against a
               specific fee head instead of the default oldest-first split. */
            $(document).on("input", ".due-pay-input", function () {
                const dueId = Number($(this).data("due-id"));
                const due = getSelectedStudent().ledger.find(function (item) { return item.id === dueId; });
                if (!due) return;

                const bal = balanceOf(due);
                let val = Number($(this).val());
                if (isNaN(val) || val < 0) val = 0;
                if (val > bal) { val = bal; $(this).val(bal); }
                due.payAmount = val;

                $("#paymentAmount").data("auto", true);
                updatePaymentSummary();
            });

            $("#selectAllDuesBtn").on("click", function () {
                const student = getSelectedStudent();
                let any = false;

                student.ledger.forEach(function (due) {
                    if (balanceOf(due) > 0) {
                        due.selected = true;
                        due.payAmount = balanceOf(due);
                        any = true;
                    }
                });

                if (!any) {
                    toastr.info("No pending dues to select.");
                    return;
                }

                $("#paymentAmount").data("auto", true);
                renderDues();
                updatePaymentSummary();
            });

            $("#clearDuesBtn").on("click", function () {
                getSelectedStudent().ledger.forEach(function (due) { due.selected = false; delete due.payAmount; });
                $("#paymentAmount").data("auto", true);
                renderDues();
                updatePaymentSummary();
            });

            $("#filterClass, #filterSection").on("change", renderStudentList);
            $("#studentSearch").on("input", renderStudentList);
            $("#historySearch").on("input", renderHistory);

            /* "/" anywhere focuses the student search — fast counter workflow. */
            $(document).on("keydown", function (e) {
                if (e.key === "/" && !$(e.target).is("input, textarea, select")) {
                    e.preventDefault();
                    $("#studentSearch").trigger("focus");
                }
            });

            $(document).on("click", ".mode-pill", function () {
                paymentMode = $(this).data("mode");
                $(".mode-pill").removeClass("active");
                $(this).addClass("active");
                updatePaymentSummary();
            });

            $("#paymentAmount").on("input", function () {
                $(this).data("auto", false);
                updatePaymentSummary();
            });

            $("#useAdvanceSwitch").on("change", function () {
                $("#paymentAmount").data("auto", true);
                updatePaymentSummary();
            });

            $("#confirmPaymentBtn, #stickyCollectBtn").on("click", function () {
                const ctx = buildPaymentContext();
                if (!validatePaymentContext(ctx)) return;
                showPaymentConfirmModal(ctx);
            });

            $("#finalConfirmPaymentBtn").on("click", function () {
                if (!pendingPaymentContext) return;
                $("#paymentConfirmModal").modal("hide");
                processPayment(pendingPaymentContext);
            });

            /* ── Concession ── */
            $("#openGlobalConcessionBtn").on("click", function () {
                if (!getSelectedDues().length || selectedDuesTotal() <= 0) {
                    toastr.warning("Select at least one due before applying concession.");
                    return;
                }

                $("#concessionLedgerTitle").text("Concession will be distributed across selected dues using oldest due first.");
                $("#concessionAmount").val("");
                $("#concessionReason").val("");
                $("#concessionType").val("Concession");
                updateConcessionPreview();
                $("#concessionModal").modal("show");
            });

            $("#concessionAmount").on("input", updateConcessionPreview);

            $("#saveConcessionBtn").on("click", function () {
                const student = getSelectedStudent();
                const selected = getSelectedDues();
                const amount = updateConcessionPreview();
                const reason = ($("#concessionReason").val() || "").trim();
                const type = $("#concessionType").val();

                if (!selected.length) {
                    toastr.warning("Select at least one due.");
                    return;
                }

                if (amount <= 0) {
                    toastr.error("Enter a valid concession amount.");
                    return;
                }

                if (!reason) {
                    toastr.error("Approval / reason is required.");
                    return;
                }

                let remainingConcession = amount;
                const allocationObjects = [];

                selected
                    .slice()
                    .sort(function (a, b) { return new Date(a.dueDate) - new Date(b.dueDate); })
                    .forEach(function (due) {
                        if (remainingConcession <= 0) return;

                        const applied = Math.min(balanceOf(due), remainingConcession);
                        due.concessionAmount = Number(due.concessionAmount || 0) + applied;
                        remainingConcession -= applied;

                        allocationObjects.push({
                            ledgerId: due.id,
                            label: due.feeHead + " - " + due.period,
                            appliedAmount: 0,
                            concessionAmount: applied,
                            balanceAfter: balanceOf(due)
                        });
                    });

                student.history.unshift({
                    type: type,
                    amount: 0,
                    mode: type,
                    date: formatDate(today),
                    desc: type + " Applied - " + reason,
                    concessionApplied: amount,
                    allocations: allocationObjects
                });

                $("#concessionModal").modal("hide");
                $("#paymentAmount").data("auto", true);
                refreshAll();

                toastr.success(type + " applied successfully.");
            });

            /* ── Extra charge ── */
            $("#saveExtraChargeBtn").on("click", function () {
                const student = getSelectedStudent();
                const chargeType = $("#extraChargeType").val();
                const amount = Number($("#extraChargeAmount").val() || 0);
                const reason = ($("#extraChargeReason").val() || "").trim();
                const dueDateRaw = $("#extraChargeDueDate").val();

                if (amount <= 0) {
                    toastr.error("Enter a valid extra charge amount.");
                    return;
                }

                if (!reason) {
                    toastr.error("Reason for the extra charge is required.");
                    return;
                }

                const dueDate = dueDateRaw ? formatDate(new Date(dueDateRaw)) : formatDate(today);

                student.ledger.push({
                    id: Date.now(),
                    feeHead: chargeType,
                    period: today.toLocaleDateString("en-GB", { month: "long", year: "numeric" }),
                    cycle: "One Time",
                    type: "Manual",
                    dueDate: dueDate,
                    originalAmount: amount,
                    concessionAmount: 0,
                    paidAmount: 0,
                    source: "Extra Charge",
                    selected: true,
                    reason: reason
                });

                $("#extraChargeAmount").val("");
                $("#extraChargeReason").val("");
                $("#extraChargeDueDate").val("");
                $("#extraChargeModal").modal("hide");

                $("#paymentAmount").data("auto", true);
                refreshAll();

                toastr.success(chargeType + " of " + formatINR(amount) + " added to ledger.");
            });

            /* ── History actions ── */
            function historyItemFromEvent(el) {
                const index = Number($(el).closest(".history-item").data("history-index"));
                const student = getSelectedStudent();
                return { student: student, item: student.history[index] };
            }

            $(document).on("click", ".history-view-btn", function () {
                const target = historyItemFromEvent(this);
                openReceiptModal(target.student, target.item);
            });

            $(document).on("click", ".history-whatsapp-btn", function () {
                const target = historyItemFromEvent(this);
                shareReceiptWhatsApp(target.student, target.item);
            });

            $(document).on("click", ".history-download-btn", function () {
                const target = historyItemFromEvent(this);
                activeReceipt = target;
                printReceipt(true);
                toastr.info("Use 'Save as PDF' as the printer destination to download.");
            });

            $(document).on("click", ".history-void-btn", function () {
                voidTarget = historyItemFromEvent(this);
                $("#voidReceiptNo").text(voidTarget.item.receiptNo);
                $("#voidReceiptAmount").text(formatINR(voidTarget.item.amount));
                $("#voidReason").val("");
                $("#voidReceiptModal").modal("show");
            });

            $("#confirmVoidBtn").on("click", function () {
                if (!voidTarget) return;

                const reason = ($("#voidReason").val() || "").trim();
                if (!reason) {
                    toastr.error("Reason is required to void a receipt.");
                    return;
                }

                $("#voidReceiptModal").modal("hide");
                voidReceipt(voidTarget.student, voidTarget.item, reason);
                voidTarget = null;
            });

            /* ── Receipt modal actions ── */
            $("#receiptPrintBtn").on("click", function () { printReceipt(true); });
            $("#receiptDownloadBtn").on("click", function () {
                printReceipt(true);
                toastr.info("Use 'Save as PDF' as the printer destination to download.");
            });
            $("#receiptWhatsAppBtn").on("click", function () {
                if (activeReceipt) shareReceiptWhatsApp(activeReceipt.student, activeReceipt.item);
            });

            /* ── Day-end summary ── */
            $("#dayEndBtn").on("click", function () {
                renderDayEndSummary();
                $("#dayEndModal").modal("show");
            });

            $("#dayEndPrintBtn").on("click", printDayEndSummary);

            /* ═══════════════════ INIT ═══════════════════ */
            buildClassSectionFilters();
            resetPaymentForm();
            refreshAll();
        });
    </script>
}
