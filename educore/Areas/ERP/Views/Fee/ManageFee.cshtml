@{
    ViewData["Title"] = "Fee Collection";
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
}

@section PageStyles {
    <style>
        :root {
            --edu-primary:       #ff8a00;
            --edu-primary-dark:  #eb7d00;
            --edu-primary-soft:  #fff4e6;
            --edu-heading:       #2b1b12;
            --edu-text:          #2b2c40;
            --edu-muted:         #8b8175;
            --edu-bg:            #f8f7f5;
            --edu-card:          #ffffff;
            --edu-border:        #ececf5;
            --edu-success:       #28c76f;
            --edu-success-soft:  #e9f9f0;
            --edu-danger:        #ea5455;
            --edu-danger-soft:   #fff0f0;
            --edu-warning:       #ffab00;
            --edu-warning-soft:  #fff7e6;
            --edu-info:          #00bad1;
            --edu-info-soft:     #e9fbfd;
            --edu-dark:          #2b1b12;
        }

        .btn-premium {
            border-radius: 13px;
            font-size: .84rem;
            font-weight: 800;
            padding: .72rem 1.05rem;
        }

        .btn-primary {
            background: var(--edu-primary);
            border-color: var(--edu-primary);
            box-shadow: 0 10px 20px rgba(255, 138, 0, .2);
        }

            .btn-primary:hover {
                background: var(--edu-primary-dark);
                border-color: var(--edu-primary-dark);
            }

        .metric-card {
            background: var(--edu-card);
            border: 1px solid var(--edu-border);
            border-radius: 20px;
            padding: 1.15rem;
            height: 100%;
            box-shadow: 0 8px 24px rgba(67, 89, 113, .055);
            position: relative;
            overflow: hidden;
        }

        .metric-label {
            color:         var(--edu-muted);
            font-size:     .72rem;
            font-weight:   800;
            text-transform: uppercase;
            letter-spacing: .04em;
            margin-bottom: .65rem;
        }

        .metric-value {
            color:       var(--edu-heading);
            font-size:   1.6rem;
            font-weight: 800;
            line-height: 1;
        }

        .metric-note {
            color:       var(--edu-muted);
            font-size:   .76rem;
            font-weight: 600;
            margin-top:  .55rem;
        }

        .metric-icon {
            width: 44px;
            height: 44px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.25rem;
        }

        .metric-top {
            display: flex;
            justify-content: space-between;
            gap: .75rem;
        }

        .icon-primary {
            background: var(--edu-primary-soft);
            color: var(--edu-primary);
        }

        .icon-success {
            background: var(--edu-success-soft);
            color: var(--edu-success);
        }

        .icon-danger {
            background: var(--edu-danger-soft);
            color: var(--edu-danger);
        }

        .main-grid {
            display: grid;
            grid-template-columns: 330px minmax(0, 1fr) 330px;
            gap: 1.25rem;
            align-items: stretch;
            margin-top: 1.25rem;
        }

        .erp-panel {
            background: var(--edu-card);
            border: 1px solid var(--edu-border);
            border-radius: 22px;
            box-shadow: 0 10px 28px rgba(67, 89, 113, .06);
            overflow: hidden;
            min-height: 700px;
        }

        .panel-header {
            padding: 1.05rem 1.15rem;
            border-bottom: 1px solid var(--edu-border);
            background: #fff;
        }

        .panel-title {
            color:         var(--edu-heading);
            font-size:     1rem;
            font-weight:   700;
            margin-bottom: .2rem;
        }

        .panel-subtitle {
            color:       var(--edu-muted);
            font-size:   .76rem;
            font-weight: 600;
        }

        .panel-body {
            padding: 1.05rem;
        }

        .student-filter-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: .65rem;
            margin-bottom: .75rem;
        }

        .quick-filter-row {
            display: flex;
            gap: .45rem;
            flex-wrap: wrap;
            margin-bottom: .85rem;
        }

        .quick-filter {
            border: 1px solid var(--edu-border);
            background: #fff;
            color: var(--edu-muted);
            border-radius: 999px;
            padding: .35rem .7rem;
            font-size: .72rem;
            font-weight: 800;
            letter-spacing: .01em;
        }

            .quick-filter.active {
                border-color: var(--edu-primary);
                background: var(--edu-primary-soft);
                color: var(--edu-primary);
            }

        .form-label {
            color: #3d2c24;
            font-size: .78rem;
            font-weight: 800;
            margin-bottom: .42rem;
        }

        .required::after {
            content: " *";
            color: var(--edu-danger);
        }

        .form-control,
        .form-select {
            border:           1px solid #d9dee3;
            border-radius:    9px;
            min-height:       44px;
            color:            var(--edu-text);
            font-size:        .9rem;
            font-weight:      500;
            background-color: #fff;
        }

            .form-control::placeholder {
                color:   var(--edu-muted);
                opacity: 1;
            }

            .form-control:focus,
            .form-select:focus {
                border-color: #ffb866;
                box-shadow:   0 0 0 .18rem rgba(255, 138, 0, .12);
            }

        .search-wrap {
            position: relative;
            margin-bottom: .85rem;
        }

            .search-wrap i {
                position: absolute;
                left: 13px;
                top: 50%;
                transform: translateY(-50%);
                color: var(--edu-muted);
                font-size: 1rem;
            }

            .search-wrap .form-control {
                padding-left: 40px;
            }

        .student-list,
        .history-list,
        .due-list {
            overflow-y: auto;
            padding-right: .25rem;
        }

        .student-list {
            max-height: 510px;
        }

        .history-list {
            max-height: 590px;
        }

        .due-list {
            max-height: 255px;
            margin-bottom: 1rem;
        }

            .student-list::-webkit-scrollbar,
            .history-list::-webkit-scrollbar,
            .due-list::-webkit-scrollbar {
                width: 7px;
            }

            .student-list::-webkit-scrollbar-thumb,
            .history-list::-webkit-scrollbar-thumb,
            .due-list::-webkit-scrollbar-thumb {
                background: rgba(255, 138, 0, .22);
                border-radius: 30px;
            }

        .student-item {
            border: 1px solid var(--edu-border);
            border-radius: 16px;
            padding: .85rem;
            margin-bottom: .7rem;
            cursor: pointer;
            background: #fff;
            transition: .18s ease;
        }

            .student-item:hover {
                border-color: rgba(255, 138, 0, .40);
                background: #fffaf5;
                transform: translateY(-1px);
            }

            .student-item.active {
                border-color: var(--edu-primary);
                background: var(--edu-primary-soft);
                box-shadow: 0 8px 18px rgba(255, 138, 0, .10);
            }

        .student-name {
            color: var(--edu-heading);
            font-size: .9rem;
            font-weight: 800;
            margin-bottom: .2rem;
        }

        .student-meta,
        .student-extra {
            color: var(--edu-muted);
            font-size: .74rem;
            font-weight: 600;
        }

        .student-extra {
            margin-top: .2rem;
        }

        .student-due {
            color: var(--edu-danger);
            font-size: .78rem;
            font-weight: 800;
            margin-top: .45rem;
        }

        .collection-hero {
            padding: 1.15rem;
            border-bottom: 1px solid var(--edu-border);
            background: linear-gradient(180deg, #fff7ed, #ffffff);
        }

        .selected-student {
            display: flex;
            gap: .9rem;
            align-items: center;
            margin-bottom: 1rem;
        }

        .student-avatar {
            width: 56px;
            height: 56px;
            border-radius: 18px;
            background: var(--edu-primary);
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            font-size: 1rem;
            box-shadow: 0 10px 20px rgba(255, 138, 0, .22);
            flex-shrink: 0;
        }

        .selected-name {
            color: var(--edu-heading);
            font-size: 1.08rem;
            font-weight: 800;
            margin-bottom: .15rem;
        }

        .selected-info {
            color: var(--edu-muted);
            font-size: .8rem;
            font-weight: 600;
        }

        .ledger-summary {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            border: 1px solid var(--edu-border);
            border-radius: 18px;
            background: #fff;
            overflow: hidden;
        }

        .ledger-box {
            padding: .9rem;
            border-right: 1px solid var(--edu-border);
        }

            .ledger-box:last-child {
                border-right: 0;
            }

        .ledger-label {
            color: var(--edu-muted);
            font-size: .72rem;
            font-weight: 800;
            margin-bottom: .3rem;
        }

        .ledger-value {
            color: var(--edu-heading);
            font-size: 1.08rem;
            font-weight: 800;
        }

            .ledger-value.success {
                color: var(--edu-success);
            }

            .ledger-value.danger {
                color: var(--edu-danger);
            }

        .collection-body {
            padding: 1.15rem;
        }

        .section-heading {
            color: var(--edu-heading);
            font-size: .9rem;
            font-weight: 800;
            margin-bottom: .75rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: .75rem;
            flex-wrap: wrap;
        }

        .section-note {
            color: var(--edu-muted);
            font-size: .74rem;
            font-weight: 600;
        }

        .due-item {
            display: grid;
            grid-template-columns: 28px minmax(0, 1fr) auto;
            gap: .75rem;
            align-items: center;
            padding: .8rem;
            border: 1px solid var(--edu-border);
            border-radius: 16px;
            margin-bottom: .65rem;
            background: #fff;
            cursor: pointer;
        }

        .due-title {
            color: var(--edu-heading);
            font-size: .86rem;
            font-weight: 800;
            margin-bottom: .15rem;
        }

        .due-sub {
            color: var(--edu-muted);
            font-size: .72rem;
            font-weight: 600;
        }

        .due-amount {
            color: var(--edu-heading);
            font-size: .92rem;
            font-weight: 800;
            text-align: right;
        }

        .due-small {
            color: var(--edu-muted);
            display: block;
            font-size: .69rem;
            font-weight: 600;
            margin-top: .12rem;
        }

        .due-badges {
            display: flex;
            flex-wrap: wrap;
            gap: .32rem;
            margin-top: .35rem;
        }

        .due-status,
        .due-badge {
            display: inline-flex;
            padding: .25rem .55rem;
            border-radius: 999px;
            font-size: .66rem;
            font-weight: 800;
            letter-spacing: .01em;
        }

        .status-overdue {
            background: var(--edu-danger-soft);
            color: var(--edu-danger);
        }

        .status-pending {
            background: var(--edu-warning-soft);
            color: var(--edu-warning);
        }

        .status-partial {
            background: var(--edu-info-soft);
            color: var(--edu-info);
        }

        .status-paid {
            background: var(--edu-success-soft);
            color: var(--edu-success);
        }

        .badge-cycle {
            background: var(--edu-primary-soft);
            color: var(--edu-primary);
        }

        .badge-optional {
            background: #f2f3f5;
            color: var(--edu-muted);
        }

        .badge-extra {
            background: var(--edu-warning-soft);
            color: #b86f00;
        }

        .payment-card {
            background: #fff;
            border: 1px solid var(--edu-border);
            border-radius: 18px;
            padding: 1rem;
        }

        .amount-input-group {
            position: relative;
        }

        .amount-prefix {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--edu-muted);
            font-size: 1.1rem;
            font-weight: 800;
            z-index: 2;
        }

        .amount-input {
            padding-left: 38px;
            font-size: 1rem;
            font-weight: 800;
            color: var(--edu-heading);
        }

        .selected-dues-box,
        .balance-box {
            border-radius: 16px;
            padding: .85rem;
            margin-top: .8rem;
        }

        .selected-dues-box {
            background: var(--edu-primary-soft);
            border: 1px solid rgba(255, 138, 0, .14);
        }

            .selected-dues-box ul {
                margin: .45rem 0 0;
                padding-left: 1.1rem;
                color: var(--edu-text);
                font-size: .78rem;
                font-weight: 600;
            }

        .balance-box {
            background: #fff7ed;
            border: 1px solid rgba(255, 138, 0, .16);
        }

        .balance-row {
            display: flex;
            justify-content: space-between;
            gap: .75rem;
            margin-bottom: .5rem;
            font-size: .78rem;
            font-weight: 800;
        }

            .balance-row:last-child {
                margin-bottom: 0;
            }

            .balance-row span {
                color: var(--edu-muted);
                font-weight: 800;
            }

            .balance-row strong {
                color: var(--edu-heading);
            }

            .balance-row.primary strong {
                color: var(--edu-primary);
                font-size: 1rem;
            }

            .balance-row.danger strong {
                color: var(--edu-danger);
            }

            .balance-row.success strong {
                color: var(--edu-success);
            }

        .history-item {
            border: 1px solid var(--edu-border);
            border-radius: 17px;
            padding: .9rem;
            background: #fff;
            margin-bottom: .75rem;
            transition: .18s ease;
        }

            .history-item:hover {
                border-color: rgba(255, 138, 0, .30);
                box-shadow: 0 8px 18px rgba(67, 89, 113, .055);
            }

        .history-top {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: .75rem;
            margin-bottom: .55rem;
        }

        .receipt-no {
            color: var(--edu-primary);
            font-size: .72rem;
            font-weight: 800;
            margin-bottom: .2rem;
        }

        .history-amount {
            color: var(--edu-heading);
            font-size: 1rem;
            font-weight: 800;
        }

        .history-date,
        .history-mode {
            color: var(--edu-muted);
            font-size: .72rem;
            font-weight: 800;
        }

        .history-mode {
            text-transform: uppercase;
        }

        .history-desc {
            color: var(--edu-text);
            font-size: .78rem;
            font-weight: 600;
        }

        .history-actions {
            display: flex;
            gap: .45rem;
            margin-top: .75rem;
        }

        .icon-btn {
            width: 34px;
            height: 34px;
            border-radius: 11px;
            border: 1px solid var(--edu-border);
            background: #fff;
            color: var(--edu-primary);
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .history-chip {
            border-radius: 999px;
            padding: .25rem .55rem;
            font-size: .66rem;
            font-weight: 800;
            background: var(--edu-success-soft);
            color: var(--edu-success);
        }

        .empty-state {
            text-align: center;
            padding: 2rem 1rem;
            color: var(--edu-muted);
            font-weight: 700;
        }

            .empty-state i {
                font-size: 2.5rem;
                color: var(--edu-primary);
                margin-bottom: .6rem;
            }

            .empty-state h6 {
                color: var(--edu-heading);
                font-weight: 800;
                margin-bottom: .25rem;
            }

            .empty-state p {
                font-size: .82rem;
                margin: 0;
                font-weight: 700;
            }

        .modal-content {
            border: 0;
            border-radius: 22px;
            overflow: hidden;
            box-shadow: 0 22px 60px rgba(23, 33, 60, .22);
        }

        .modal-header {
            border-bottom: 1px solid var(--edu-border);
            padding: 1.1rem 1.25rem;
        }

        .modal-title {
            color: var(--edu-heading);
            font-weight: 800;
        }

        .modal-footer {
            border-top: 1px solid var(--edu-border);
            padding: 1rem 1.25rem;
        }

        .collection-mode-pill {
            display: inline-flex;
            align-items: center;
            gap: .35rem;
            border-radius: 999px;
            padding: .3rem .65rem;
            font-size: .68rem;
            font-weight: 800;
            background: var(--edu-primary-soft);
            color: var(--edu-primary);
        }

            .collection-mode-pill.advance {
                background: var(--edu-success-soft);
                color: var(--edu-success);
            }

            .collection-mode-pill.partial {
                background: var(--edu-info-soft);
                color: var(--edu-info);
            }

        .soft-info-box {
            border-radius: 14px;
            padding: .75rem .85rem;
            font-size: .76rem;
            font-weight: 600;
            margin-top: .8rem;
            display: none;
            line-height: 1.45;
        }

            .soft-info-box.show {
                display: block;
            }

        .advance-info-box {
            background: #eefbf3;
            color: #1f8f55;
            border: 1px solid #d7f3e3;
        }

        .no-due-info-box {
            background: var(--edu-primary-soft);
            color: var(--edu-heading);
            border: 1px solid rgba(255, 138, 0, .18);
        }

        .partial-info-box {
            background: var(--edu-info-soft);
            color: #168090;
            border: 1px solid #cceff4;
        }

        .confirm-summary {
            background: #faf9f7;
            border: 1px solid var(--edu-border);
            border-radius: 16px;
            padding: .9rem;
        }

        .confirm-row {
            display: flex;
            justify-content: space-between;
            gap: 1rem;
            padding: .45rem 0;
            border-bottom: 1px solid var(--edu-border);
            font-size: .82rem;
            font-weight: 800;
        }

            .confirm-row:last-child {
                border-bottom: 0;
            }

            .confirm-row span {
                color: var(--edu-muted);
                font-weight: 800;
            }

            .confirm-row strong {
                color: var(--edu-heading);
            }

            .confirm-row.success strong {
                color: var(--edu-success);
            }

            .confirm-row.primary strong {
                color: var(--edu-primary);
            }

        .confirm-note,
        .concession-help {
            border-radius: 14px;
            padding: .8rem .9rem;
            background: var(--edu-primary-soft);
            color: var(--edu-heading);
            border: 1px solid rgba(255, 138, 0, .18);
            font-size: .78rem;
            font-weight: 600;
            margin-top: .85rem;
            line-height: 1.45;
        }

        @@media(max-width: 1199px) {
            .main-grid {
                grid-template-columns: 310px minmax(0, 1fr);
            }

            .history-panel {
                grid-column: 1 / -1;
                min-height: auto;
            }

            .history-list {
                max-height: 360px;
            }
        }

        @@media(max-width: 991px) {
            .main-grid {
                grid-template-columns: 1fr;
            }

            .erp-panel {
                min-height: auto;
            }

            .student-list,
            .history-list {
                max-height: 360px;
            }

            .due-list {
                max-height: none;
            }
        }

        @@media(max-width: 575px) {
            .page-header {
                align-items: stretch;
            }

                .page-header .btn,
                .page-header > div:last-child {
                    width: 100%;
                }

                .page-header > div:last-child {
                    display: grid !important;
                    grid-template-columns: 1fr;
                }

            .ledger-summary {
                grid-template-columns: 1fr;
            }

            .ledger-box {
                border-right: 0;
                border-bottom: 1px solid var(--edu-border);
            }

                .ledger-box:last-child {
                    border-bottom: 0;
                }

            .student-filter-row {
                grid-template-columns: 1fr;
            }

            .due-item {
                grid-template-columns: 28px minmax(0, 1fr);
            }

            .due-amount {
                grid-column: 2;
                text-align: left;
            }

            .selected-student {
                align-items: flex-start;
            }
        }
    </style>
}

<div class="container-fluid flex-grow-1 container-p-y">
<div class="ec-page-shell">
<div class="ec-page-content fee-page">

    <div class="ec-page-header mb-4">
        <div class="ec-page-header-inner">
            <div class="d-flex align-items-center gap-3">
                <div class="ec-page-icon">
                    <i class="bx bx-wallet"></i>
                </div>
                <div>
                    <h4 class="ec-page-title mb-1">Fee Collection</h4>
                    <p class="ec-page-subtitle mb-0">Operational fee counter — collect dues, apply concession, record advance payments and print receipts.</p>
                </div>
            </div>
        </div>
    </div>

        <div class="row g-4">
            <div class="col-lg-4 col-md-6">
                <div class="metric-card">
                    <div class="metric-top">
                        <div>
                            <div class="metric-label">Collected Today</div>
                            <div class="metric-value" id="collectedToday">₹0</div>
                            <div class="metric-note">Server timestamp will decide collection date</div>
                        </div>
                        <div class="metric-icon icon-primary">
                            <i class="bx bx-rupee"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 col-md-6">
                <div class="metric-card">
                    <div class="metric-top">
                        <div>
                            <div class="metric-label">Collected This Month</div>
                            <div class="metric-value text-success" id="collectedMonth">₹0</div>
                            <div class="metric-note">Across all payment modes</div>
                        </div>
                        <div class="metric-icon icon-success">
                            <i class="bx bx-credit-card"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 col-md-12">
                <div class="metric-card">
                    <div class="metric-top">
                        <div>
                            <div class="metric-label">Total Pending Due</div>
                            <div class="metric-value text-danger" id="totalPendingDue">₹0</div>
                            <div class="metric-note">Pending balance from student ledger</div>
                        </div>
                        <div class="metric-icon icon-danger">
                            <i class="bx bx-calendar-exclamation"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="main-grid">
            <div class="erp-panel">
                <div class="panel-header">
                    <div class="panel-title">Students</div>
                    <div class="panel-subtitle">Search and select student ledger</div>
                </div>

                <div class="panel-body">
                    <div class="student-filter-row">
