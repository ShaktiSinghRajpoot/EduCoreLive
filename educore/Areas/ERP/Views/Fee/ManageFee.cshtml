                        { receiptNo: "RCPT-2026-0003", amount: 1500, mode: "UPI", date: "10 Jan 2026", desc: "Admission Fee", allocations: ["Admission Fee"] }
                    ]
                },
                {
                    id: 2,
                    name: "Akash Verma",
                    className: "9th",
                    section: "B",
                    admissionNo: "ADM20260207004",
                    parent: "Bhukal Verma",
                    lastPaymentDate: "05 Mar 2026",
                    avatar: "AV",
                    advanceBalance: 0,
                    ledger: [
                        { id: 201, feeHead: "Tuition Fee", period: "March 2026", cycle: "Monthly", type: "Mandatory", dueDate: "10 Mar 2026", originalAmount: 2500, concessionAmount: 0, paidAmount: 0, status: "Overdue", source: "Monthly Scheduler" },
                        { id: 202, feeHead: "Transport Fee", period: "March 2026", cycle: "Monthly", type: "Optional", dueDate: "10 Mar 2026", originalAmount: 1200, concessionAmount: 0, paidAmount: 0, status: "Overdue", source: "Monthly Scheduler" },
                        { id: 203, feeHead: "Activity Fee", period: "2026-27", cycle: "Yearly", type: "Optional", dueDate: "20 Mar 2026", originalAmount: 774, concessionAmount: 0, paidAmount: 0, status: "Pending", source: "Fee Structure" }
                    ],
                    history: [
                        { receiptNo: "RCPT-2026-0019", amount: 5500, mode: "Cash", date: "12 Feb 2026", desc: "Admission + Exam Fee", allocations: ["Admission Fee", "Exam Fee"] },
                        { receiptNo: "RCPT-2026-0017", amount: 1200, mode: "UPI", date: "12 Feb 2026", desc: "Transport Fee", allocations: ["Transport Fee - February 2026"] },
                        { receiptNo: "RCPT-2026-0014", amount: 540, mode: "Cash", date: "24 Feb 2026", desc: "Partial Monthly Fee", allocations: ["Tuition Fee - February 2026"] },
                        { receiptNo: "RCPT-2026-0013", amount: 2500, mode: "Bank Transfer", date: "05 Mar 2026", desc: "Tuition Fee - February", allocations: ["Tuition Fee - February 2026"] }
                    ]
                },
                {
                    id: 3,
                    name: "Sikender Gupta",
                    className: "10th",
                    section: "A",
                    admissionNo: "ADM20260207003",
                    parent: "Mahesh Gupta",
                    lastPaymentDate: "15 Feb 2026",
                    avatar: "SG",
                    advanceBalance: 4000,
                    ledger: [
                        { id: 301, feeHead: "Board Fee", period: "2026-27", cycle: "Yearly", type: "Mandatory", dueDate: "01 Mar 2026", originalAmount: 2500, concessionAmount: 500, paidAmount: 0, status: "Overdue", source: "Fee Structure" },
                        { id: 302, feeHead: "Tuition Fee", period: "March 2026", cycle: "Monthly", type: "Mandatory", dueDate: "10 Mar 2026", originalAmount: 3200, concessionAmount: 0, paidAmount: 1200, status: "Partial", source: "Monthly Scheduler" },
                        { id: 303, feeHead: "Exam Fee", period: "2026-27", cycle: "Yearly", type: "Mandatory", dueDate: "15 Mar 2026", originalAmount: 2600, concessionAmount: 0, paidAmount: 0, status: "Pending", source: "Fee Structure" }
                    ],
                    history: [
                        { receiptNo: "RCPT-2026-0011", amount: 6000, mode: "Cash", date: "15 Feb 2026", desc: "Admission Fee", allocations: ["Admission Fee"] },
                        { receiptNo: "RCPT-2026-0007", amount: 3200, mode: "UPI", date: "05 Feb 2026", desc: "Tuition Fee - February", allocations: ["Tuition Fee - February 2026"] }
                    ]
                },
                {
                    id: 4,
                    name: "Deepak Sherma",
                    className: "11th",
                    section: "A",
                    admissionNo: "ADM20260207002",
                    parent: "Ramesh Sherma",
                    lastPaymentDate: "08 Feb 2026",
                    avatar: "DS",
                    advanceBalance: 0,
                    ledger: [
                        { id: 401, feeHead: "Lab Fee", period: "2026-27", cycle: "Yearly", type: "Mandatory", dueDate: "05 Mar 2026", originalAmount: 3000, concessionAmount: 0, paidAmount: 3000, status: "Paid", source: "Fee Structure" },
                        { id: 402, feeHead: "Tuition Fee", period: "March 2026", cycle: "Monthly", type: "Mandatory", dueDate: "10 Mar 2026", originalAmount: 3900, concessionAmount: 0, paidAmount: 0, status: "Pending", source: "Monthly Scheduler" }
                    ],
                    history: [
                        { receiptNo: "RCPT-2026-0009", amount: 3900, mode: "Cash", date: "08 Feb 2026", desc: "Tuition Fee - February", allocations: ["Tuition Fee - February 2026"] }
                    ]
                }
            ];

            let selectedStudentId = 2;
            let activeDueFilter = "All";
            let receiptCounter = 25;
            let collectionType = "Fee Collection";
            let pendingPaymentContext = null;

            function formatINR(amount) {
                return "₹" + Number(amount || 0).toLocaleString("en-IN");
            }

            function balanceOf(due) {
                return Math.max(
                    0,
                    Number(due.originalAmount || 0) -
                    Number(due.concessionAmount || 0) -
                    Number(due.paidAmount || 0)
                );
            }

            function concessionOf(due) {
                return Number(due.concessionAmount || 0);
            }

            function getSelectedStudent() {
                return students.find(x => x.id === selectedStudentId) || students[0];
            }

            function studentPending(student) {
                return student.ledger.reduce((sum, due) => sum + balanceOf(due), 0);
            }

            function studentPaid(student) {
                return student.ledger.reduce((sum, due) => sum + Number(due.paidAmount || 0), 0) +
                    student.history.reduce((sum, item) => sum + Number(item.amount || 0), 0);
            }

            function studentTotalLedger(student) {
                return student.ledger.reduce((sum, due) => sum + Number(due.originalAmount || 0), 0);
            }

            function getStudentStatus(student) {
                const pending = studentPending(student);
                const hasOverdue = student.ledger.some(due => balanceOf(due) > 0 && due.status === "Overdue");

                if (pending <= 0) return "Paid";
                if (hasOverdue) return "Overdue";
                return "Pending";
            }

            function refreshDueStatus(due) {
                if (balanceOf(due) <= 0) {
                    due.status = "Paid";
                } else if (Number(due.paidAmount || 0) > 0 || Number(due.concessionAmount || 0) > 0) {
                    due.status = "Partial";
                } else if (due.status !== "Overdue") {
                    due.status = "Pending";
                }
            }

            function getSelectedDues() {
                return getSelectedStudent().ledger.filter(due => due.selected && balanceOf(due) > 0);
            }

            function selectedDuesTotal() {
                return getSelectedDues().reduce((sum, due) => sum + balanceOf(due), 0);
            }

            function selectedConcessionTotal() {
                return getSelectedDues().reduce((sum, due) => sum + concessionOf(due), 0);
            }

            function setCollectionType(type) {
                collectionType = type;
                $("#collectionType").val(type);

                const pill = $("#collectionModePill");
                pill.removeClass("advance partial");

                if (type === "Advance Payment") {
                    $("#paymentSectionTitle").text("Advance Payment");
                    pill.addClass("advance").html('<i class="bx bx-wallet"></i> Advance');
                } else if (type === "Partial Payment") {
                    $("#paymentSectionTitle").text("Collect Payment");
                    pill.addClass("partial").html('<i class="bx bx-adjust"></i> Partial');
                } else {
                    $("#paymentSectionTitle").text("Collect Payment");
                    pill.html('<i class="bx bx-list-check"></i> Selected Dues');
                }
            }

            function renderStudentList() {
                const selectedClass = $("#filterClass").val();
                const selectedSection = $("#filterSection").val();
                const search = ($("#studentSearch").val() || "").toLowerCase();

                let html = "";

                students
                    .filter(student => {
                        const classMatch = selectedClass === "All Classes" || student.className === selectedClass;
                        const sectionMatch = selectedSection === "All Sections" || student.section === selectedSection;
                        const searchMatch = student.name.toLowerCase().includes(search) || student.admissionNo.toLowerCase().includes(search);
                        const statusMatch = activeDueFilter === "All" || getStudentStatus(student) === activeDueFilter;

                        return classMatch && sectionMatch && searchMatch && statusMatch;
                    })
                    .forEach(student => {
                        html += `
                            <div class="student-item ${student.id === selectedStudentId ? "active" : ""}" data-student-id="${student.id}">
                                <div class="student-name">${student.name}</div>
                                <div class="student-meta">${student.className} - ${student.section} • ${student.admissionNo}</div>
                                <div class="student-extra">Last payment: ${student.lastPaymentDate || "No payment"}</div>
                                <div class="student-extra">Advance: ${formatINR(student.advanceBalance || 0)}</div>
                                <div class="student-due">Due: ${formatINR(studentPending(student))}</div>
                            </div>`;
                    });

                if (!html) {
                    html = `
                        <div class="empty-state">
                            <i class="bx bx-search"></i>
                            <h6>No students found</h6>
                            <p>Try another search or filter.</p>
                        </div>`;
                }

                $("#studentList").html(html);
            }

            function renderSelectedStudent() {
                const student = getSelectedStudent();

                $("#selectedAvatar").text(student.avatar);
                $("#selectedName").text(student.name);
                $("#selectedInfo").text(`Class ${student.className} - ${student.section} • ${student.admissionNo} • Parent: ${student.parent}`);
                $("#totalLedgerCharges").text(formatINR(studentTotalLedger(student)));
                $("#paidSoFar").text(formatINR(studentPaid(student)));
                $("#pendingDue").text(formatINR(studentPending(student)));
                $("#advanceBalance").text(formatINR(student.advanceBalance || 0));

                renderDues();
                renderHistory();
                updatePaymentSummary();
            }

            function renderDues() {
                const student = getSelectedStudent();
                let html = "";

                student.ledger
                    .filter(due => balanceOf(due) > 0)
                    .forEach(due => {
                        const statusClass = due.status === "Overdue"
                            ? "status-overdue"
                            : due.status === "Partial"
                                ? "status-partial"
                                : due.status === "Paid"
                                    ? "status-paid"
                                    : "status-pending";

                        const isExtra = due.source === "Extra Charge";

                        html += `
                            <label class="due-item">
                                <input class="form-check-input due-check" type="checkbox" data-due-id="${due.id}" ${due.selected ? "checked" : ""}>
                                <div>
                                    <div class="due-title">${due.feeHead} - ${due.period}</div>
                                    <div class="due-sub">Due on: ${due.dueDate}</div>
                                    <div class="due-badges">
                                        <span class="due-status ${statusClass}">${due.status}</span>
                                        <span class="due-badge badge-cycle">${due.cycle}</span>
                                        <span class="due-badge badge-optional">${due.type}</span>
                                        ${isExtra ? `<span class="due-badge badge-extra">Extra Charge</span>` : ""}
                                    </div>
                                </div>
                                <div class="due-amount">
                                    ${formatINR(balanceOf(due))}
                                    <span class="due-small">Original ${formatINR(due.originalAmount)}</span>
                                    <span class="due-small">Concession ${formatINR(due.concessionAmount || 0)}</span>
                                    <span class="due-small">Paid ${formatINR(due.paidAmount || 0)}</span>
                                    <span class="due-small">Balance ${formatINR(balanceOf(due))}</span>
                                </div>
                            </label>`;
                    });

                if (!html) {
                    html = `
                        <div class="empty-state">
                            <i class="bx bx-check-circle"></i>
                            <h6>No pending dues</h6>
                            <p>This student has no pending fee dues.</p>
                        </div>`;
                }

                $("#dueList").html(html);
            }

            function renderHistory() {
                const student = getSelectedStudent();
                let html = "";

                student.history.forEach(item => {
                    html += `
                        <div class="history-item">
                            <div class="history-top">
                                <div>
                                    <div class="receipt-no">${item.receiptNo || item.type || "LEDGER"}</div>
                                    <div class="history-amount">${formatINR(item.amount || item.concessionApplied || 0)}</div>
                                    <div class="history-mode">${item.mode || item.type || "Ledger"}</div>
                                </div>
                                <div class="history-date">${item.date}</div>
                            </div>

                            <div class="history-desc">${item.desc}</div>

                            ${item.referenceNo ? `<div class="history-date mt-1">Ref: ${item.referenceNo}</div>` : ""}
                            ${typeof item.adjustedAgainstDues !== "undefined" ? `<div class="history-date mt-1">Adjusted Against Dues: ${formatINR(item.adjustedAgainstDues)}</div>` : ""}
                            ${item.advanceAdded ? `<div class="history-date mt-1">Advance Added: ${formatINR(item.advanceAdded)}</div>` : ""}
                            ${item.concessionApplied ? `<div class="history-date mt-1">Concession Applied: ${formatINR(item.concessionApplied)}</div>` : ""}

                            <div class="mt-2">
                                ${(item.allocations || []).length
                                    ? (item.allocations || []).map(allocation => `<span class="due-badge badge-cycle me-1 mb-1">${typeof allocation === "string" ? allocation : allocation.label}</span>`).join("")
                                    : `<span class="due-badge badge-optional me-1 mb-1">Advance Balance</span>`}
                            </div>

                            <div class="history-actions">
                                <button type="button" class="icon-btn" title="Print"><i class="bx bx-printer"></i></button>
                                <button type="button" class="icon-btn" title="WhatsApp"><i class="bx bxl-whatsapp"></i></button>
                                <button type="button" class="icon-btn" title="Download"><i class="bx bx-download"></i></button>
                            </div>
                        </div>`;
                });

                if (!html) {
                    html = `
                        <div class="empty-state">
                            <i class="bx bx-receipt"></i>
                            <h6>No payments yet</h6>
                            <p>Transaction history will appear here.</p>
                        </div>`;
                }

                $("#historyList").html(html);
            }

            function updatePaymentSummary() {
                const selected = getSelectedDues();
                const selectedAmount = selectedDuesTotal();
                const concessionAmount = selectedConcessionTotal();

                if ($("#paymentAmount").data("auto") !== false && selectedAmount > 0) {
                    $("#paymentAmount").val(selectedAmount);
                }

                const actualPayingNow = Number($("#paymentAmount").val() || 0);
                const remaining = Math.max(0, selectedAmount - actualPayingNow);
                const advanceAdded = Math.max(0, actualPayingNow - selectedAmount);

                if (selectedAmount <= 0 && actualPayingNow > 0) {
                    setCollectionType("Advance Payment");
                } else if (selectedAmount > 0 && actualPayingNow > 0 && actualPayingNow < selectedAmount) {
                    setCollectionType("Partial Payment");
                } else {
                    setCollectionType("Fee Collection");
                }

                $("#selectedPayableAmount").text(formatINR(selectedAmount));
                $("#concessionAppliedAmount").text(formatINR(concessionAmount));
                $("#payingNowAmount").text(formatINR(actualPayingNow));
                $("#remainingBalanceAmount").text(formatINR(remaining));
                $("#advanceAddedAmount").text(formatINR(advanceAdded));
                $("#selectedDueCount").text(selected.length + (selected.length === 1 ? " due" : " dues"));

                $("#remainingBalanceRow").toggle(selectedAmount > 0);
                $("#advanceAddedRow").toggle(advanceAdded > 0 || (selectedAmount <= 0 && actualPayingNow > 0));

                $("#noDueInfoBox").toggleClass("show", selectedAmount <= 0 && actualPayingNow > 0);
                $("#partialInfoBox").toggleClass("show", selectedAmount > 0 && actualPayingNow > 0 && actualPayingNow < selectedAmount);
                $("#advanceInfoBox").toggleClass("show", advanceAdded > 0);

                if (!selected.length) {
                    $("#selectedDuesSummary").html("<li>No dues selected. Payment will be treated as advance payment if amount is entered.</li>");
                    return;
                }

                $("#selectedDuesSummary").html(selected.map(due => `<li>${due.period} ${due.feeHead} - Balance ${formatINR(balanceOf(due))}</li>`).join(""));
            }

            function updateTopCards() {
                const collectedMonth = students.reduce((sum, student) => {
                    return sum + student.history
                        .filter(item => item.receiptNo)
                        .reduce((innerSum, item) => innerSum + Number(item.amount || 0), 0);
                }, 0);

                const pendingDue = students.reduce((sum, student) => sum + studentPending(student), 0);

                $("#collectedToday").text(formatINR(0));
                $("#collectedMonth").text(formatINR(collectedMonth));
                $("#totalPendingDue").text(formatINR(pendingDue));
            }

            function resetPaymentForm() {
                setCollectionType("Fee Collection");
                $("#paymentMode").val("Cash");
                $("#paymentReferenceNo").val("");
                $("#paymentRemarks").val("");
                $("#paymentAmount").val("").data("auto", true);
                pendingPaymentContext = null;
                $("#noDueInfoBox, #advanceInfoBox, #partialInfoBox").removeClass("show");
            }

            function buildPaymentContext() {
                const selected = getSelectedDues();
                const selectedAmount = selectedDuesTotal();
                const amount = Number($("#paymentAmount").val() || 0);
                const adjustedAgainstDues = Math.min(amount, selectedAmount);
                const advanceAdded = Math.max(0, amount - selectedAmount);

                let type = "Fee Collection";

                if (selectedAmount <= 0 && amount > 0) {
                    type = "Advance Payment";
                } else if (amount < selectedAmount) {
                    type = "Partial Payment";
                } else if (amount > selectedAmount) {
                    type = "Fee Collection + Advance";
                }

                return {
                    selected,
                    selectedAmount,
                    amount,
                    adjustedAgainstDues,
                    advanceAdded,
                    mode: $("#paymentMode").val(),
                    referenceNo: $("#paymentReferenceNo").val(),
                    remarks: $("#paymentRemarks").val(),
                    collectionType: type
                };
            }

            function showPaymentConfirmModal(ctx) {
                const isAdvance = ctx.selectedAmount <= 0 || ctx.advanceAdded > 0;

                $("#paymentConfirmTitle").text("Confirm Payment");
                $("#paymentConfirmSubtitle").text("Review payment allocation before collection.");
                $("#confirmCollectedAmount").text(formatINR(ctx.amount));
                $("#confirmAdjustedAmount").text(formatINR(ctx.adjustedAgainstDues));
                $("#confirmAdvanceAdded").text(formatINR(ctx.advanceAdded));
                $("#confirmCollectionType").text(ctx.collectionType);
                $("#confirmNote").text(
                    isAdvance
                        ? "Advance amount will be stored as student advance balance and can be adjusted in future fee dues."
                        : "Payment will be adjusted against selected dues using oldest due first."
                );

                pendingPaymentContext = ctx;
                $("#paymentConfirmModal").modal("show");
            }

            function processPayment(ctx) {
                const student = getSelectedStudent();
                let remaining = Math.min(ctx.amount, ctx.selectedAmount);
                const allocationObjects = [];

                ctx.selected
                    .sort((a, b) => new Date(a.dueDate) - new Date(b.dueDate))
                    .forEach(due => {
                        if (remaining <= 0) return;

                        const before = balanceOf(due);
                        const applied = Math.min(before, remaining);

                        due.paidAmount = Number(due.paidAmount || 0) + applied;
                        remaining -= applied;
                        due.selected = false;

                        refreshDueStatus(due);

                        allocationObjects.push({
                            ledgerId: due.id,
                            label: `${due.feeHead} - ${due.period}`,
                            appliedAmount: applied,
                            concessionAmount: concessionOf(due),
                            balanceAfter: balanceOf(due)
                        });
                    });

                receiptCounter++;
                student.lastPaymentDate = new Date().toLocaleDateString("en-GB", {
                    day: "2-digit",
                    month: "short",
                    year: "numeric"
                });

                if (ctx.advanceAdded > 0) {
                    student.advanceBalance = Number(student.advanceBalance || 0) + ctx.advanceAdded;
                }

                const desc = ctx.selectedAmount <= 0
                    ? "Advance Payment Receipt"
                    : ctx.amount < ctx.selectedAmount
                        ? "Partial Payment Receipt"
                        : ctx.advanceAdded > 0
                            ? "Fee Collection + Advance Receipt"
                            : "Fee Collection Receipt";

                student.history.unshift({
                    receiptNo: "RCPT-2026-" + String(receiptCounter).padStart(4, "0"),
                    amount: ctx.amount,
                    mode: ctx.mode,
                    date: student.lastPaymentDate,
                    desc: ctx.remarks ? `${desc} - ${ctx.remarks}` : desc,
                    referenceNo: ctx.referenceNo,
                    adjustedAgainstDues: ctx.adjustedAgainstDues,
                    advanceAdded: ctx.advanceAdded,
                    allocations: allocationObjects
                });

                resetPaymentForm();
                updateTopCards();
                renderStudentList();
                renderSelectedStudent();

                toastr.success("Receipt generated — " + ctx.collectionType + " recorded.");
            }

            function updateConcessionPreview() {
                const selectedAmount = selectedDuesTotal();
                const enteredAmount = Number($("#concessionAmount").val() || 0);
                const concession = Math.min(selectedAmount, enteredAmount);

                $("#concessionSelectedDuesAmount").text(formatINR(selectedAmount));
                $("#concessionPreviewAmount").text(formatINR(concession));
                $("#concessionBalanceAfterAmount").text(formatINR(Math.max(0, selectedAmount - concession)));

                return concession;
            }

            $(document).on("click", ".student-item", function () {
                selectedStudentId = Number($(this).data("student-id"));
                resetPaymentForm();
                renderStudentList();
                renderSelectedStudent();
            });

            $(document).on("click", ".quick-filter", function () {
                activeDueFilter = $(this).data("filter");
                $(".quick-filter").removeClass("active");
                $(this).addClass("active");
                renderStudentList();
            });

            $(document).on("change", ".due-check", function () {
                const dueId = Number($(this).data("due-id"));
                const due = getSelectedStudent().ledger.find(item => item.id === dueId);

                if (due) {
                    due.selected = $(this).is(":checked");
                }

                $("#paymentAmount").data("auto", true);
                updatePaymentSummary();
            });

            $("#filterClass, #filterSection").on("change", renderStudentList);
            $("#studentSearch").on("input", renderStudentList);

            $("#paymentAmount").on("input", function () {
                $(this).data("auto", false);
                updatePaymentSummary();
            });

            $("#openGlobalConcessionBtn").on("click", function () {
                const selected = getSelectedDues();

                if (!selected.length || selectedDuesTotal() <= 0) {
                    toastr.warning("Select at least one due before applying concession.");
                    return;
                }

                $("#concessionLedgerTitle").text("Concession will be distributed across selected dues using oldest due first.");
                $("#concessionAmount").val("");
                $("#concessionReason").val("");
                $("#concessionType").val("Concession");
                updateConcessionPreview();
                $("#concessionModal").modal("show");
            });

            $("#concessionAmount").on("input", updateConcessionPreview);

            $("#saveConcessionBtn").on("click", function () {
                const student = getSelectedStudent();
                const selected = getSelectedDues();
                const amount = updateConcessionPreview();
                const reason = ($("#concessionReason").val() || "").trim();
                const type = $("#concessionType").val();

                if (!selected.length) {
                    toastr.warning("Select at least one due.");
                    return;
                }

                if (amount <= 0) {
                    toastr.error("Enter a valid concession amount.");
                    return;
                }

                if (!reason) {
                    toastr.error("Approval / reason is required.");
                    return;
                }

                let remainingConcession = amount;
                const allocationObjects = [];

                selected
                    .sort((a, b) => new Date(a.dueDate) - new Date(b.dueDate))
                    .forEach(due => {
                        if (remainingConcession <= 0) return;

                        const before = balanceOf(due);
                        const applied = Math.min(before, remainingConcession);

                        due.concessionAmount = Number(due.concessionAmount || 0) + applied;
                        remainingConcession -= applied;

                        refreshDueStatus(due);

                        allocationObjects.push({
                            ledgerId: due.id,
                            label: `${due.feeHead} - ${due.period}`,
                            appliedAmount: 0,
                            concessionAmount: applied,
                            balanceAfter: balanceOf(due)
                        });
                    });

                student.history.unshift({
                    type: type,
                    amount: 0,
                    mode: type,
                    date: new Date().toLocaleDateString("en-GB", {
                        day: "2-digit",
                        month: "short",
                        year: "numeric"
                    }),
                    desc: `${type} Applied - ${reason}`,
                    concessionApplied: amount,
                    allocations: allocationObjects
                });

                $("#concessionModal").modal("hide");
                $("#paymentAmount").data("auto", true);
                updateTopCards();
                renderStudentList();
                renderSelectedStudent();

                toastr.success(type + " applied successfully.");
            });

            $("#confirmPaymentBtn").on("click", function () {
                const amount = Number($("#paymentAmount").val() || 0);

                if (amount <= 0) {
                    toastr.error("Enter a valid payment amount.");
                    return;
                }

                const ctx = buildPaymentContext();

                if (ctx.advanceAdded > 0 || ctx.selectedAmount <= 0) {
                    showPaymentConfirmModal(ctx);
                } else {
                    processPayment(ctx);
                }
            });

            $("#finalConfirmPaymentBtn").on("click", function () {
                if (!pendingPaymentContext) return;

                $("#paymentConfirmModal").modal("hide");
                processPayment(pendingPaymentContext);
            });

            $("#saveExtraChargeBtn").on("click", function () {
                const student = getSelectedStudent();
                const chargeType = $("#extraChargeType").val();
                const amount = Number($("#extraChargeAmount").val() || 0);
                const reason = ($("#extraChargeReason").val() || "").trim();
                const dueDateRaw = $("#extraChargeDueDate").val();

                if (amount <= 0) {
                    toastr.error("Enter a valid extra charge amount.");
                    return;
                }

                if (!reason) {
                    toastr.error("Reason for the extra charge is required.");
                    return;
                }

                const dueDate = dueDateRaw
                    ? new Date(dueDateRaw).toLocaleDateString("en-GB", {
                        day: "2-digit",
                        month: "short",
                        year: "numeric"
                    })
                    : new Date().toLocaleDateString("en-GB", {
                        day: "2-digit",
                        month: "short",
                        year: "numeric"
                    });

                student.ledger.push({
                    id: Date.now(),
                    feeHead: chargeType,
                    period: new Date().toLocaleDateString("en-GB", {
                        month: "long",
                        year: "numeric"
                    }),
                    cycle: "One Time",
                    type: "Manual",
                    dueDate: dueDate,
                    originalAmount: amount,
                    concessionAmount: 0,
                    paidAmount: 0,
                    status: "Pending",
                    source: "Extra Charge",
                    selected: true,
                    reason: reason
                });

                $("#extraChargeAmount").val("");
                $("#extraChargeReason").val("");
                $("#extraChargeDueDate").val("");
                $("#extraChargeModal").modal("hide");

                $("#paymentAmount").data("auto", true);
                updateTopCards();
                renderStudentList();
                renderSelectedStudent();
            });

            resetPaymentForm();
            updateTopCards();
            renderStudentList();
            renderSelectedStudent();
        });
    </script>
}
