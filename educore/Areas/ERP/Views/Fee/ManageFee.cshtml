@{
    ViewData["Title"] = "Fee Collection";
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
}

@*
   ─────────────────────────────────────────────────────────────────────────
   FEE COLLECTION — clean, single-student counter
   Filters:  Session (pre-selected) · Admission No · Class · Section · Student
   Load ONE student → see dues by cycle (Monthly/Quarterly/Yearly) → collect.
   PHASE 1: layout + interactions on SAMPLE data. Every data fetch is isolated
   in an api.* stub below — swap each for a real $.getJSON in Phase 2 without
   touching the UI. Look for "PHASE 2:" markers.
   ─────────────────────────────────────────────────────────────────────────
*@

@section PageStyles {
<link href="~/css/educore-theme.css" rel="stylesheet" />
<style>
.fee-collect-page{
    --ec-primary:#ff8a00;--ec-primary-soft:#fff4e6;--ec-soft-bg:#f8f7f5;
    --ec-panel:#fff;--ec-border:#ececf5;--ec-heading:#2b1b12;--ec-text:#2b2c40;
    --ec-muted:#8b8175;--ec-label:#9a938b;--ec-success:#28c76f;--ec-danger:#ea5455;
    color:var(--ec-text);
}
.fee-collect-page .form-label{color:var(--ec-label);font-size:.74rem;font-weight:800;letter-spacing:.02em;text-transform:uppercase;margin-bottom:.35rem;}
.fee-collect-page .form-select,.fee-collect-page .form-control{border:1px solid var(--ec-border);border-radius:12px;min-height:46px;font-weight:650;font-size:.9rem;background-color:#fff;transition:border-color .2s,box-shadow .2s;}
.fee-collect-page .form-select:focus,.fee-collect-page .form-control:focus{border-color:rgba(255,138,0,.6);box-shadow:0 0 0 4px rgba(255,138,0,.12);}
.fee-collect-page .form-select:disabled,.fee-collect-page .form-control:disabled{background:#faf9f7;color:var(--ec-muted);}
.fee-collect-page .btn-primary{background:linear-gradient(135deg,#ff8a00,#ff9f2f);border:0;color:#fff;border-radius:999px;font-weight:800;box-shadow:0 12px 24px rgba(255,138,0,.22);}
.fee-collect-page .btn-primary:hover{color:#fff;transform:translateY(-1px);}
.fee-collect-page .btn-primary:disabled{opacity:.5;box-shadow:none;transform:none;}
.fee-collect-page .btn-outline-secondary{border-color:rgba(43,27,18,.14);color:var(--ec-text);background:#fff;border-radius:999px;font-weight:800;}

/* filter bar */
.filter-bar{background:linear-gradient(180deg,#fff,#fff7ed);border:1px solid rgba(255,138,0,.18);border-radius:18px;box-shadow:0 12px 30px rgba(43,27,18,.06);}
.adm-search{display:flex;gap:.4rem;}
.adm-search input{flex:1;min-width:0;}
.adm-search button{flex:none;width:46px;border:1px solid var(--ec-border);background:var(--ec-primary-soft);color:var(--ec-primary);border-radius:12px;font-size:1.15rem;display:flex;align-items:center;justify-content:center;}
.adm-search button:hover{background:var(--ec-primary);color:#fff;}

/* student header */
.stu-head{display:flex;align-items:center;gap:1rem;flex-wrap:wrap;}
.stu-head .big-avatar{width:56px;height:56px;border-radius:16px;background:var(--ec-primary-soft);color:var(--ec-primary);display:flex;align-items:center;justify-content:center;font-weight:900;font-size:1.25rem;flex:none;}
.stu-sub{font-size:.78rem;color:var(--ec-muted);font-weight:650;}
.outstanding-box{margin-left:auto;text-align:right;}
.outstanding-box .amt{font-size:1.7rem;font-weight:950;color:var(--ec-heading);letter-spacing:-.03em;line-height:1;}
.outstanding-box .lbl{font-size:.72rem;font-weight:800;text-transform:uppercase;color:var(--ec-muted);}

/* cycle tabs */
.cycle-tabs{display:flex;gap:.4rem;flex-wrap:wrap;}
.cycle-tab{border:1px solid var(--ec-border);background:#fff;border-radius:999px;padding:.4rem .95rem;font-size:.8rem;font-weight:800;color:var(--ec-text);cursor:pointer;transition:all .15s;}
.cycle-tab:hover{border-color:rgba(255,138,0,.45);}
.cycle-tab.active{background:var(--ec-primary);border-color:var(--ec-primary);color:#fff;}

/* dues */
.due-group-title{font-size:.72rem;text-transform:uppercase;letter-spacing:.07em;font-weight:950;color:var(--ec-label);margin:1.1rem 0 .5rem;display:flex;align-items:center;gap:.4rem;}
.due-row{display:flex;align-items:center;gap:.85rem;border:1px solid var(--ec-border);border-radius:14px;padding:.75rem .9rem;margin-bottom:.55rem;background:#fff;cursor:pointer;transition:border-color .15s;}
.due-row.sel{border-color:var(--ec-primary);background:var(--ec-primary-soft);}
.due-row .form-check-input{margin-top:0;flex:none;}
.due-info{flex:1;min-width:0;}
.due-label{font-weight:800;color:var(--ec-heading);font-size:.9rem;}
.due-meta{font-size:.76rem;color:var(--ec-muted);font-weight:650;}
.due-amt{font-weight:900;color:var(--ec-heading);white-space:nowrap;}
.due-overdue{color:var(--ec-danger);font-weight:800;}

/* collect bar */
.collect-bar{position:sticky;bottom:0;background:#fff;border-top:1px solid var(--ec-border);margin:1rem -1.25rem -1.25rem;padding:1rem 1.25rem;border-radius:0 0 18px 18px;}
.collect-total .amt{font-size:1.5rem;font-weight:950;color:var(--ec-primary);letter-spacing:-.03em;line-height:1;}
.collect-total .lbl{font-size:.72rem;font-weight:800;text-transform:uppercase;color:var(--ec-muted);}

/* empty / receipt */
.empty-pane{min-height:300px;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;color:var(--ec-muted);padding:2rem 1.5rem;}
.empty-pane i{font-size:3rem;color:var(--ec-primary);margin-bottom:.6rem;}
.empty-pane h6{color:var(--ec-heading);font-weight:900;margin-bottom:.25rem;}
.receipt-paper{font-family:'Segoe UI',sans-serif;color:#222;}
.receipt-paper .r-school{text-align:center;border-bottom:2px dashed #ddd;padding-bottom:.6rem;margin-bottom:.6rem;}
.receipt-paper .r-school h5{font-weight:900;margin:0;color:var(--ec-heading);}
.receipt-paper table{width:100%;border-collapse:collapse;font-size:.85rem;}
.receipt-paper td{padding:.25rem 0;}
.receipt-paper .r-line td{border-bottom:1px solid #eee;}
.receipt-paper .r-total{font-weight:900;font-size:1rem;border-top:2px solid #333;}
@@media (max-width:991.98px){ .collect-bar{position:static;margin:1rem 0 0;border-radius:14px;border:1px solid var(--ec-border);} }
</style>
}

<div class="ec-page-shell fee-collect-page">
  <div class="ec-page-content">

    <div class="ec-page-header">
      <div class="ec-page-header-inner">
        <div class="ec-page-title-wrap d-flex align-items-center gap-2">
          <div class="ec-page-icon rounded-4 d-flex align-items-center justify-content-center" style="background:var(--ec-primary-soft);color:var(--ec-primary);">
            <i class="bx bx-wallet fs-4"></i>
          </div>
          <div>
            <h4 class="ec-page-title mb-1">Fee Collection</h4>
            <div class="ec-page-subtitle">Find a student by admission no, or drill down Class → Section → Student</div>
          </div>
        </div>
      </div>
    </div>

    <!-- ── Filters: Session · Admission No · Class · Section · Student ── -->
    <div class="filter-bar p-3 p-lg-4 mb-4">
      <div class="row g-3 align-items-end">
        <div class="col-12 col-md-6 col-lg">
          <label class="form-label">Academic Session</label>
          <select id="fSession" class="form-select"></select>
        </div>
        <div class="col-12 col-md-6 col-lg">
          <label class="form-label">Admission Number</label>
          <div class="adm-search">
            <input type="text" id="fAdm" class="form-control" placeholder="Type &amp; press Enter">
            <button type="button" id="admGo" title="Find student"><i class="bx bx-search"></i></button>
          </div>
        </div>
        <div class="col-6 col-md-4 col-lg">
          <label class="form-label">Class</label>
          <select id="fClass" class="form-select"><option value="">Select Class</option></select>
        </div>
        <div class="col-6 col-md-4 col-lg">
          <label class="form-label">Section</label>
          <select id="fSection" class="form-select" disabled><option value="">Select class first</option></select>
        </div>
        <div class="col-12 col-md-4 col-lg">
          <label class="form-label">Student</label>
          <select id="fStudent" class="form-select" disabled><option value="">Select section first</option></select>
        </div>
      </div>
    </div>

    <!-- ── Single student: dues + collect ── -->
    <div class="ec-card">
      <div class="ec-card-body p-3 p-lg-4 d-flex flex-column">

        <div id="duesEmpty" class="empty-pane">
          <i class="bx bx-user-circle"></i>
          <h6>No student selected</h6>
          <p class="mb-0">Search an admission number above, or choose Class → Section → Student.</p>
        </div>

        <div id="duesPane" class="d-none flex-grow-1 d-flex flex-column">
          <!-- student header -->
          <div class="stu-head mb-3 pb-3" style="border-bottom:1px solid var(--ec-border)">
            <div class="big-avatar" id="dAvatar">—</div>
            <div>
              <div class="fw-bold" style="color:var(--ec-heading);font-size:1.05rem" id="dName">—</div>
              <div class="stu-sub" id="dSub">—</div>
            </div>
            <div class="outstanding-box">
              <div class="amt" id="dOutstanding">₹0</div>
              <div class="lbl">Total Outstanding</div>
            </div>
          </div>

          <!-- cycle filter -->
          <div class="cycle-tabs mb-2">
            <div class="cycle-tab active" data-cycle="all">All Dues</div>
            <div class="cycle-tab" data-cycle="Monthly">Monthly</div>
            <div class="cycle-tab" data-cycle="Quarterly">Quarterly</div>
            <div class="cycle-tab" data-cycle="Yearly">Yearly</div>
          </div>

          <!-- dues list -->
          <div id="duesList" class="flex-grow-1"></div>

          <!-- collect bar -->
          <div class="collect-bar">
            <div class="row g-3 align-items-end">
              <div class="col-6 col-lg-3">
                <div class="collect-total">
                  <div class="amt" id="selTotal">₹0</div>
                  <div class="lbl"><span id="selCount">0</span> item(s) selected</div>
                </div>
              </div>
              <div class="col-6 col-lg-3">
                <label class="form-label">Mode</label>
                <select id="pMode" class="form-select">
                  <option>Cash</option><option>UPI</option><option>Card</option>
                  <option>Cheque</option><option>Demand Draft</option><option>Bank Transfer</option>
                </select>
              </div>
              <div class="col-12 col-lg-3" id="pRefRow" style="display:none;">
                <label class="form-label">Reference</label>
                <input type="text" id="pRef" class="form-control" placeholder="Txn / cheque no">
              </div>
              <div class="col-12 col-lg-3">
                <button type="button" id="collectBtn" class="btn btn-primary w-100" disabled>
                  <i class="bx bx-check-circle me-1"></i>Collect &amp; Receipt
                </button>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>

  </div>
</div>

<!-- ── Receipt modal ── -->
<div class="modal fade" id="receiptModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content" style="border-radius:18px;">
      <div class="modal-header">
        <h5 class="modal-title">Payment Receipt</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="receipt-paper" id="receiptPaper"></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary btn-premium" data-bs-dismiss="modal">Close</button>
        <button type="button" class="btn btn-primary btn-premium" id="printReceiptBtn"><i class="bx bx-printer me-1"></i>Print</button>
      </div>
    </div>
  </div>
</div>

@Html.AntiForgeryToken()

@section PageScripts {
<script>
/* =========================================================================
   FEE COLLECTION — interactions wired to the real Fee endpoints.
   Filters → student → dues (core.student_ledger) → collect (core.fee_payments).
========================================================================= */
$(function () {
    'use strict';

    function money(n){ return '₹' + Math.round(Number(n||0)).toLocaleString('en-IN'); }
    function initials(name){ return (name||'?').trim().split(/\s+/).map(function(w){return w[0];}).slice(0,2).join('').toUpperCase(); }
    function notify(t,m){ if (typeof toastr!=='undefined') toastr[t](m); }

    /* ───────────────────────── endpoints ───────────────────────── */
    var TODAY = new Date().toISOString().slice(0, 10);
    var CSRF  = $('input[name="__RequestVerificationToken"]').val();
    var URL = {
        sessions:  '@Url.Action("GetSessions","Fee",new{area="ERP"})',
        classes:   '@Url.Action("GetClasses","Fee",new{area="ERP"})',
        sections:  '@Url.Action("GetSections","Fee",new{area="ERP"})',
        students:  '@Url.Action("GetStudents","Fee",new{area="ERP"})',
        findByAdm: '@Url.Action("FindByAdmission","Fee",new{area="ERP"})',
        dues:      '@Url.Action("GetStudentDues","Fee",new{area="ERP"})',
        pay:       '@Url.Action("RecordPayment","Fee",new{area="ERP"})'
    };

    var api = {
        sessions:  function(){ return $.getJSON(URL.sessions); },
        classes:   function(session){ return $.getJSON(URL.classes, { session: session }); },
        sections:  function(session, cls){ return $.getJSON(URL.sections, { session: session, className: cls }); },
        students:  function(session, cls, sec){ return $.getJSON(URL.students, { session: session, className: cls, section: sec }); },
        findByAdm: function(session, adm){ return $.getJSON(URL.findByAdm, { session: session, admissionNo: adm }); },
        dues:      function(studentId){ return $.getJSON(URL.dues, { studentId: studentId }); },
        pay:       function(payload){
            return $.ajax({
                url: URL.pay, type: 'POST', contentType: 'application/json',
                headers: { 'RequestVerificationToken': CSRF },
                data: JSON.stringify(payload)
            });
        }
    };

    /* ───────────────────────── elements / state ───────────────────────── */
    var $session=$('#fSession'), $class=$('#fClass'), $section=$('#fSection'), $student=$('#fStudent'), $adm=$('#fAdm');
    var $duesEmpty=$('#duesEmpty'), $duesPane=$('#duesPane'), $duesList=$('#duesList');
    var students=[], currentStudent=null, currentDues=null, activeCycle='all', selected={};

    function fillSelect($el, items, placeholder){
        var html = placeholder ? '<option value="">'+placeholder+'</option>' : '';
        items.forEach(function(x){ html += '<option value="'+x+'">'+x+'</option>'; });
        $el.html(html);
    }

    /* ───────────────────────── filter cascade ───────────────────────── */
    api.sessions().done(function(s){ fillSelect($session, s, null); $session.val(s[0]); loadClasses(); });

    function loadClasses(){
        clearStudentView(); students=[];
        $section.prop('disabled',true).html('<option value="">Select class first</option>');
        $student.prop('disabled',true).html('<option value="">Select section first</option>');
        api.classes($session.val()).done(function(c){ fillSelect($class, c, 'Select Class'); });
    }
    function loadSections(){
        clearStudentView(); students=[];
        $student.prop('disabled',true).html('<option value="">Select section first</option>');
        if(!$class.val()){ $section.prop('disabled',true).html('<option value="">Select class first</option>'); return; }
        api.sections($session.val(),$class.val()).done(function(sec){
            fillSelect($section, sec, 'Select Section'); $section.prop('disabled', sec.length===0);
        });
    }
    function loadStudentSelect(){
        clearStudentView();
        if(!$section.val()){ $student.prop('disabled',true).html('<option value="">Select section first</option>'); return; }
        api.students($session.val(),$class.val(),$section.val()).done(function(list){
            students = list || [];
            fillStudentSelect();
        });
    }
    function fillStudentSelect(){
        var html='<option value="">'+(students.length?'Select Student':'No students')+'</option>';
        students.forEach(function(s){ html += '<option value="'+s.id+'">Roll '+(s.roll||'—')+' — '+s.name+' ('+s.admNo+')</option>'; });
        $student.html(html).prop('disabled', students.length===0);
    }

    $session.on('change', loadClasses);
    $class.on('change', loadSections);
    $section.on('change', loadStudentSelect);
    $student.on('change', function(){
        var id=Number($(this).val());
        if(!id){ clearStudentView(); return; }
        loadStudentById(id);
    });

    function loadStudentById(id){
        currentStudent = students.find(function(s){ return s.id===id; }) || null;
        if(currentStudent) api.dues(currentStudent.id).done(openStudent)
            .fail(function(){ notify('error','Could not load dues for this student.'); });
    }

    /* ───────────────────────── admission-number search ───────────────────────── */
    function doAdmSearch(){
        var adm=$adm.val().trim();
        if(!adm){ notify('warning','Enter an admission number to search.'); return; }
        api.findByAdm($session.val(), adm).done(function(r){
            if(!r){ notify('error','No student found for "'+adm+'" in '+$session.val()+'.'); return; }
            // mirror the drill-down selects so context is clear, then load the student
            $class.val(r.className);
            api.sections($session.val(),r.className).done(function(sec){
                fillSelect($section, sec, 'Select Section'); $section.val(r.section).prop('disabled',false);
                api.students($session.val(),r.className,r.section).done(function(list){
                    students=list||[]; fillStudentSelect(); $student.val(r.student.id);
                    loadStudentById(r.student.id);
                });
            });
        });
    }
    $('#admGo').on('click', doAdmSearch);
    $adm.on('keydown', function(e){ if(e.key==='Enter'){ e.preventDefault(); doAdmSearch(); } });

    /* ───────────────────────── dues + collect ───────────────────────── */
    function studentOutstanding(s){
        var t=0; ['Monthly','Quarterly','Yearly'].forEach(function(c){ (s.dues[c]||[]).forEach(function(d){ t+=d.amount; }); }); return t;
    }
    function clearStudentView(){
        currentStudent=null; selected={};
        $duesPane.addClass('d-none'); $duesEmpty.removeClass('d-none');
    }
    function openStudent(dues){
        // dues are fetched separately from the student row, so attach them so the
        // outstanding total and post-payment refresh can read currentStudent.dues.
        currentStudent.dues = dues;
        currentDues = dues; selected={}; activeCycle='all';
        $('.cycle-tab').removeClass('active').filter('[data-cycle="all"]').addClass('active');
        $('#dAvatar').text(initials(currentStudent.name));
        $('#dName').text(currentStudent.name);
        $('#dSub').text(currentStudent.admNo + ' · ' + $class.val() + ' - ' + $section.val() + ' · Roll ' + (currentStudent.roll||'—'));
        $('#dOutstanding').text(money(studentOutstanding(currentStudent)));
        $duesEmpty.addClass('d-none'); $duesPane.removeClass('d-none');
        renderDues(); updateCollect();
    }
    function renderDues(){
        var cycles = activeCycle==='all' ? ['Monthly','Quarterly','Yearly'] : [activeCycle];
        var icon={ Monthly:'bx-calendar', Quarterly:'bx-calendar-event', Yearly:'bx-calendar-star' };
        var html='', any=false;
        cycles.forEach(function(c){
            var list=(currentDues[c]||[]); if(!list.length) return; any=true;
            html += '<div class="due-group-title"><i class="bx '+icon[c]+'"></i>'+c+' Dues</div>';
            list.forEach(function(d){
                var sel=!!selected[d.id];
                html += '<label class="due-row'+(sel?' sel':'')+'" data-id="'+d.id+'">'+
                    '<input class="form-check-input due-chk" type="checkbox" data-id="'+d.id+'" data-amt="'+d.amount+'" data-label="'+d.label.replace(/"/g,'&quot;')+'"'+(sel?' checked':'')+'>'+
                    '<div class="due-info"><div class="due-label">'+d.label+'</div>'+
                    '<div class="due-meta">Due '+d.dueDate+(d.overdue?' · <span class="due-overdue">Overdue</span>':'')+'</div></div>'+
                    '<div class="due-amt">'+money(d.amount)+'</div></label>';
            });
        });
        if(!any) html = '<div class="empty-pane"><i class="bx bx-check-circle" style="color:var(--ec-success)"></i><h6>No '+(activeCycle==='all'?'':activeCycle.toLowerCase()+' ')+'dues</h6><p class="mb-0">This student is all clear here.</p></div>';
        $duesList.html(html);
    }
    $('.cycle-tab').on('click', function(){
        $('.cycle-tab').removeClass('active'); $(this).addClass('active');
        activeCycle=$(this).data('cycle'); renderDues();
    });
    $duesList.on('change','.due-chk', function(){
        var id=$(this).data('id');
        if(this.checked) selected[id]={ label:$(this).data('label'), amount:Number($(this).data('amt')) };
        else delete selected[id];
        $(this).closest('.due-row').toggleClass('sel', this.checked);
        updateCollect();
    });
    function selectedList(){ return Object.keys(selected).map(function(k){ return selected[k]; }); }
    function selectedTotal(){ return selectedList().reduce(function(s,x){ return s+x.amount; },0); }
    function updateCollect(){
        var list=selectedList();
        $('#selTotal').text(money(selectedTotal()));
        $('#selCount').text(list.length);
        $('#collectBtn').prop('disabled', list.length===0);
    }
    $('#pMode').on('change', function(){ $('#pRefRow').toggle($(this).val()!=='Cash'); }).trigger('change');

    /* ───────────────────────── collect → receipt ───────────────────────── */
    $('#collectBtn').on('click', function(){
        var list=selectedList(), tot=selectedTotal(); if(!list.length) return;
        var $btn=$(this), old=$btn.html();
        $btn.prop('disabled',true).html('<i class="bx bx-loader-circle bx-spin me-1"></i>Collecting…');
        api.pay({ studentId:currentStudent.id, amount:tot, mode:$('#pMode').val(), reference:$('#pRef').val(),
                  session:$session.val(), items:list })
        .done(function(res){
            $btn.prop('disabled',false).html(old);
            if(!res || !res.success){ notify('error', (res&&res.message)||'Could not record payment.'); return; }
            notify('success', 'Payment of '+money(tot)+' collected. Receipt '+res.receiptNo+'.');
            showReceipt(res.receiptNo, list, tot);
            // Re-fetch dues from the ledger so paid/partly-paid rows reflect the
            // server-side allocation (oldest-first) rather than guessing locally.
            selected={};
            api.dues(currentStudent.id).done(openStudent);
        })
        .fail(function(){ $btn.prop('disabled',false).html(old); notify('error','Could not record payment.'); });
    });
    function showReceipt(rcp, list, tot){
        var rows = list.map(function(it){ return '<tr class="r-line"><td>'+it.label+'</td><td style="text-align:right">'+money(it.amount)+'</td></tr>'; }).join('');
        $('#receiptPaper').html(
            '<div class="r-school"><h5>EduCore School</h5><small>Fee Payment Receipt</small></div>'+
            '<table style="margin-bottom:.5rem"><tr><td>Receipt No</td><td style="text-align:right"><strong>'+rcp+'</strong></td></tr>'+
            '<tr><td>Date</td><td style="text-align:right">'+TODAY+'</td></tr>'+
            '<tr><td>Student</td><td style="text-align:right">'+currentStudent.name+'</td></tr>'+
            '<tr><td>Class</td><td style="text-align:right">'+$class.val()+' - '+$section.val()+'</td></tr>'+
            '<tr><td>Mode</td><td style="text-align:right">'+$('#pMode').val()+'</td></tr></table>'+
            '<table>'+rows+'<tr class="r-total"><td>Total Paid</td><td style="text-align:right">'+money(tot)+'</td></tr></table>'+
            '<p style="text-align:center;margin-top:.8rem;font-size:.75rem;color:#888">Thank you. This is a system-generated receipt.</p>'
        );
        new bootstrap.Modal(document.getElementById('receiptModal')).show();
    }
    $('#printReceiptBtn').on('click', function(){
        var w=window.open('','_blank','width=420,height=640');
        w.document.write('<html><head><title>Receipt</title></head><body>'+document.getElementById('receiptPaper').innerHTML+'</body></html>');
        w.document.close(); w.focus(); w.print();
    });

    if (typeof toastr !== 'undefined') {
        toastr.options = { closeButton:true, progressBar:true, positionClass:'toast-top-right', timeOut:3000 };
    }
});
</script>
}
