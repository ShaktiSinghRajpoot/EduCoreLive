@{
    ViewData["Title"] = "Fee Collection";
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
}

@*
   ─────────────────────────────────────────────────────────────────────────
   FEE COLLECTION — single-student counter (settlement-based, educore theme).
   Search stays the SAME cascade: Session → Admission No → Class → Section →
   Student. Pick a PERIOD (1/3/6/12) → dues auto-select → one Settlement panel
   does the maths: Dues − Discount (modal: flat/%/reason) + Extra charges
   (modal) = Payable, paid via split tender. Collect → receipt. History re-prints.

   NOTE: this commit is the DESIGN/VIEW port only. Split-tender + advance are
   UI-present but not yet persisted; Collect still uses the existing per-item
   endpoint (discount spread oldest-first as concession). Backend comes next.
   ─────────────────────────────────────────────────────────────────────────
*@

@section PageStyles {
<link href="~/css/educore-theme.css" rel="stylesheet" />
<style>
.fee-collect-page{ --ec-suc:#28c76f;--ec-suc-soft:#e8fadf;--ec-dng:#ea5455;--ec-amb:#ff9f43;--ec-amb-soft:#fff1e0; color:var(--ec-text); }

/* command bar */
.fee-collect-page .cmd{ display:flex;align-items:center;gap:.75rem;flex-wrap:wrap;background:linear-gradient(135deg,var(--ec-primary-soft),#fff 65%);border:1px solid #f4e3cf;border-radius:16px;padding:.85rem 1.1rem;margin-bottom:1.1rem; }
.fee-collect-page .cmd .ec-page-icon{ width:42px;height:42px;font-size:20px; }
.fee-collect-page .cmd .title{ font-weight:800;color:var(--ec-text-dark);font-size:1.05rem;line-height:1.1; }
.fee-collect-page .cmd .sub{ font-size:.72rem;color:var(--ec-text-muted);font-weight:650; }
.fee-collect-page .today{ margin-left:auto;display:flex;align-items:center;gap:.6rem;background:#fff;border:1px solid var(--ec-border);border-radius:12px;padding:.45rem .85rem; }
.fee-collect-page .today .n{ font-weight:900;color:var(--ec-text-dark);font-size:1.05rem;line-height:1; }
.fee-collect-page .today .l{ font-size:.62rem;font-weight:800;text-transform:uppercase;color:var(--ec-text-muted);letter-spacing:.04em; }
.fee-collect-page .today .dot{ width:34px;height:34px;border-radius:10px;background:var(--ec-suc-soft);color:var(--ec-suc);display:flex;align-items:center;justify-content:center;font-size:1.1rem; }

/* filter bar (same cascade as before) */
.fee-collect-page .filter-bar{ background:linear-gradient(180deg,#fff,#fff7ed);border:1px solid rgba(255,138,0,.18);border-radius:16px; }
.fee-collect-page .adm-search{ display:flex;gap:.4rem; }
.fee-collect-page .adm-search .form-control{ flex:1;min-width:0; }
.fee-collect-page .adm-search button{ flex:none;width:44px;border:1px solid var(--ec-border);background:var(--ec-primary-light);color:var(--ec-primary);border-radius:9px;font-size:1.1rem; }
.fee-collect-page .adm-search button:hover{ background:var(--ec-primary);color:#fff; }

/* student strip */
.fee-collect-page .stu-strip{ display:flex;align-items:center;gap:1rem;flex-wrap:wrap; }
.fee-collect-page .stu-av{ width:50px;height:50px;border-radius:13px;background:var(--ec-primary-light);color:var(--ec-primary);display:flex;align-items:center;justify-content:center;font-weight:900;font-size:1.15rem;flex:none; }
.fee-collect-page .stu-name{ font-weight:800;color:var(--ec-text-dark);font-size:1.02rem;line-height:1.15; }
.fee-collect-page .stu-sub{ font-size:.76rem;color:var(--ec-text-muted);font-weight:650; }
.fee-collect-page .stu-out{ margin-left:auto;text-align:right; }
.fee-collect-page .stu-out .amt{ font-size:1.6rem;font-weight:950;color:var(--ec-text-dark);letter-spacing:-.03em;line-height:1; }
.fee-collect-page .stu-out .lbl{ font-size:.68rem;font-weight:800;text-transform:uppercase;color:var(--ec-text-muted);letter-spacing:.04em; }

/* view tabs */
.fee-collect-page .view-tabs{ display:flex;gap:.4rem;border-bottom:1px solid var(--ec-border);margin-bottom:1rem; }
.fee-collect-page .view-tab{ border:0;background:none;padding:.55rem .25rem;margin-right:1rem;font-size:.9rem;font-weight:850;color:var(--ec-text-muted);cursor:pointer;border-bottom:3px solid transparent; }
.fee-collect-page .view-tab.active{ color:var(--ec-primary);border-bottom-color:var(--ec-primary); }

/* dues */
.fee-collect-page .period{ display:flex;gap:.45rem;flex-wrap:wrap;margin-bottom:.9rem;align-items:center; }
.fee-collect-page .period .l{ font-size:.7rem;font-weight:800;text-transform:uppercase;color:var(--ec-text-light); }
.fee-collect-page .chip{ border:1.5px solid var(--ec-border);background:#fff;border-radius:999px;padding:.4rem 1rem;font-size:.82rem;font-weight:800;color:var(--ec-text);cursor:pointer;transition:.15s; }
.fee-collect-page .chip:hover{ border-color:#ffc98a; }
.fee-collect-page .chip.active{ background:var(--ec-primary);border-color:var(--ec-primary);color:#fff;box-shadow:0 5px 12px rgba(255,138,0,.25); }
.fee-collect-page .period-clear{ margin-left:auto;border:0;background:none;color:var(--ec-text-muted);font-weight:800;font-size:.78rem;cursor:pointer;text-decoration:underline; }

.fee-collect-page .grp{ font-size:.68rem;text-transform:uppercase;letter-spacing:.05em;font-weight:900;color:var(--ec-text-light);margin:.9rem 0 .45rem;display:flex;align-items:center;gap:.4rem; }
.fee-collect-page .due{ border:1px solid var(--ec-border);border-radius:12px;padding:.6rem .8rem;margin-bottom:.45rem;background:#fff;cursor:pointer;transition:.12s; }
.fee-collect-page .due:hover{ border-color:#ffc98a; }
.fee-collect-page .due.sel{ border-color:var(--ec-primary);background:var(--ec-primary-soft); }
.fee-collect-page .due-main{ display:flex;align-items:center;gap:.75rem;margin:0; }
.fee-collect-page .due .form-check-input{ margin:0;flex:none;width:1.15rem;height:1.15rem; }
.fee-collect-page .due .form-check-input:checked{ background-color:var(--ec-primary);border-color:var(--ec-primary); }
.fee-collect-page .due-info{ flex:1;min-width:0; }
.fee-collect-page .due-label{ font-weight:750;color:var(--ec-text-dark);font-size:.87rem; }
.fee-collect-page .due-meta{ font-size:.72rem;color:var(--ec-text-muted);font-weight:650; }
.fee-collect-page .due-amt{ font-weight:800;color:var(--ec-text-dark);white-space:nowrap;font-size:.88rem; }
.fee-collect-page .overdue{ color:var(--ec-dng);font-weight:800; }
.fee-collect-page .deposit-tag{ font-size:.62rem;font-weight:800;color:var(--ec-suc);background:var(--ec-suc-soft);padding:1px 7px;border-radius:6px;margin-left:.4rem; }

/* read-only line items (extras added via modal) */
.fee-collect-page .li{ display:flex;align-items:center;gap:.7rem;border:1px solid var(--ec-border);border-radius:11px;padding:.55rem .8rem;margin-bottom:.45rem;background:#fff; }
.fee-collect-page .li-info{ flex:1;min-width:0; }
.fee-collect-page .li-label{ font-weight:750;color:var(--ec-text-dark);font-size:.86rem; }
.fee-collect-page .li-sub{ font-size:.7rem;color:var(--ec-text-muted);font-weight:650; }
.fee-collect-page .li-amt{ font-weight:800;white-space:nowrap;font-size:.88rem; }
.fee-collect-page .li-rm{ border:0;background:none;color:var(--ec-text-muted);cursor:pointer;font-size:1.15rem;line-height:1; }
.fee-collect-page .li-rm:hover{ color:var(--ec-dng); }
.fee-collect-page .empty-line{ font-size:.78rem;color:var(--ec-text-light);font-weight:650;padding:.2rem 0 .4rem; }

/* settlement */
.fee-collect-page .settle{ position:sticky;top:16px; }
.fee-collect-page .settle .ec-card-body{ padding:1.15rem 1.25rem; }
.fee-collect-page .s-scope-lbl{ font-size:.7rem;color:var(--ec-text-light);font-weight:800;text-transform:uppercase;letter-spacing:.04em; }
.fee-collect-page .s-scope{ font-weight:800;color:var(--ec-text-dark);font-size:.92rem;margin-bottom:.9rem; }
.fee-collect-page .s-line{ display:flex;justify-content:space-between;align-items:center;padding:.42rem 0;font-size:.88rem;font-weight:700; }
.fee-collect-page .s-line.muted{ color:var(--ec-text-muted); } .fee-collect-page .s-line .v{ font-variant-numeric:tabular-nums; }
.fee-collect-page .s-line.suc .v{ color:var(--ec-suc); }
.fee-collect-page .s-pay{ display:flex;justify-content:space-between;align-items:center;background:var(--ec-primary-light);border-radius:13px;padding:.8rem 1rem;margin:.55rem 0 .9rem; }
.fee-collect-page .s-pay .k{ font-size:.7rem;font-weight:900;text-transform:uppercase;color:var(--ec-primary);letter-spacing:.05em; }
.fee-collect-page .s-pay .v{ font-size:1.75rem;font-weight:950;color:var(--ec-primary);letter-spacing:-.03em;font-variant-numeric:tabular-nums; }

.fee-collect-page .tender-head{ display:flex;justify-content:space-between;align-items:center;font-size:.68rem;font-weight:900;text-transform:uppercase;color:var(--ec-text-light);margin:.2rem 0 .5rem; }
.fee-collect-page .tender-row{ display:flex;gap:.45rem;align-items:center;margin-bottom:.45rem; }
.fee-collect-page .tender-row select{ width:42%; } .fee-collect-page .tender-row .t-amt{ flex:1; }
.fee-collect-page .add-tender{ font-size:.76rem;font-weight:800;color:var(--ec-primary);background:none;border:0;cursor:pointer;padding:.1rem 0; }

.fee-collect-page .s-foot{ border-top:1px dashed var(--ec-border);margin-top:.6rem;padding-top:.6rem; }
.fee-collect-page .s-foot .row1{ display:flex;justify-content:space-between;font-size:.84rem;font-weight:800;padding:.12rem 0; }
.fee-collect-page .s-adv{ font-size:.74rem;font-weight:800;color:var(--ec-suc);margin-top:.25rem;display:none; }
.fee-collect-page .collect-cta{ width:100%;padding:.8rem;font-size:1rem;font-weight:800;border-radius:12px;margin-top:.7rem; }

/* discount cell */
.fee-collect-page .add-link{ border:1px dashed #ffc98a;background:var(--ec-primary-soft);color:var(--ec-primary);border-radius:8px;padding:.15rem .6rem;font-size:.76rem;font-weight:800;cursor:pointer; }
.fee-collect-page .add-link:hover{ background:var(--ec-primary-light); }
.fee-collect-page .disc-set{ display:inline-flex;align-items:center;gap:.5rem; }
.fee-collect-page .disc-set .e{ color:var(--ec-text-muted);cursor:pointer;font-size:.95rem; } .fee-collect-page .disc-set .e:hover{ color:var(--ec-primary); }
.fee-collect-page .disc-set .x{ color:var(--ec-text-muted);cursor:pointer;font-size:1rem; } .fee-collect-page .disc-set .x:hover{ color:var(--ec-dng); }

/* history */
.fee-collect-page .hist-row{ display:flex;align-items:center;gap:.85rem;border:1px solid var(--ec-border);border-radius:14px;padding:.75rem .9rem;margin-bottom:.55rem;background:#fff; }
.fee-collect-page .hist-info{ flex:1;min-width:0; }
.fee-collect-page .hist-rcp{ font-weight:850;color:var(--ec-text-dark);font-size:.9rem; }
.fee-collect-page .hist-meta{ font-size:.76rem;color:var(--ec-text-muted);font-weight:650; }
.fee-collect-page .hist-amt{ font-weight:900;color:var(--ec-text-dark);white-space:nowrap; }
.fee-collect-page .hist-row.cancelled{ background:#fcfbfa;opacity:.75; }
.fee-collect-page .strike{ text-decoration:line-through;color:var(--ec-text-muted)!important; }

.fee-collect-page .empty-pane{ min-height:280px;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;color:var(--ec-text-muted);padding:2rem 1.5rem; }
.fee-collect-page .empty-pane i{ font-size:3rem;color:var(--ec-primary);margin-bottom:.6rem; }
.fee-collect-page .empty-pane h6{ color:var(--ec-text-dark);font-weight:900;margin-bottom:.25rem; }

/* modals (segmented toggle) */
.fc-seg-toggle{ display:flex;gap:.5rem; }
.fc-seg{ flex:1;border:1.5px solid var(--ec-border);background:#fff;border-radius:10px;padding:.55rem;font-weight:800;cursor:pointer;font-size:.85rem;color:#2b2c40; }
.fc-seg.active{ background:#fff4e6;border-color:#ffc98a;color:#ff8a00; }

@@media (max-width:991.98px){ .fee-collect-page .settle{ position:static; } }
</style>
}

<div class="ec-page-shell fee-collect-page">
  <div class="ec-page-content">

    <!-- command bar -->
    <div class="cmd">
      <div class="ec-page-icon"><i class="bx bx-wallet"></i></div>
      <div><div class="title">Fee Collection</div><div class="sub">Find a student, choose how many months to collect, then take payment</div></div>
      <div class="today"><div class="dot"><i class="bx bx-rupee"></i></div><div><div class="n" id="todayN">₹0</div><div class="l">This session · <span id="todayC">0</span> receipts</div></div></div>
      <a href="@Url.Action("DayClose","Fee",new{area="ERP"})" class="btn btn-sm ec-btn-soft"><i class="bx bx-lock-open-alt me-1"></i>Day close</a>
      <a href="@Url.Action("Reports","Fee",new{area="ERP"})" class="btn btn-sm ec-btn-soft"><i class="bx bx-bar-chart-alt-2 me-1"></i>Reports</a>
    </div>

    <!-- Filters — SAME cascade: Session → Admission No → Class → Section → Student -->
    <div class="filter-bar p-3 p-lg-4 mb-4">
      <div class="row g-3 align-items-end">
        <div class="col-12 col-md-6 col-lg">
          <label class="form-label">Academic Session</label>
          <select id="fSession" class="form-select"></select>
        </div>
        <div class="col-12 col-md-6 col-lg">
          <label class="form-label">Admission Number</label>
          <div class="adm-search">
            <input type="text" id="fAdm" class="form-control" placeholder="Type &amp; press Enter">
            <button type="button" id="admGo" title="Find student"><i class="bx bx-search"></i></button>
          </div>
        </div>
        <div class="col-6 col-md-4 col-lg">
          <label class="form-label">Class</label>
          <select id="fClass" class="form-select"><option value="">Select Class</option></select>
        </div>
        <div class="col-6 col-md-4 col-lg">
          <label class="form-label">Section</label>
          <select id="fSection" class="form-select" disabled><option value="">Select class first</option></select>
        </div>
        <div class="col-12 col-md-4 col-lg">
          <label class="form-label">Student</label>
          <select id="fStudent" class="form-select" disabled><option value="">Select section first</option></select>
        </div>
      </div>
    </div>

    <!-- empty state -->
    <div id="duesEmpty" class="ec-card"><div class="ec-card-body">
      <div class="empty-pane">
        <i class="bx bx-user-circle"></i>
        <h6>No student selected</h6>
        <p class="mb-0">Search an admission number above, or choose Class → Section → Student.</p>
      </div>
    </div></div>

    <div id="duesPane" class="d-none">
      <!-- student strip -->
      <div class="ec-card"><div class="ec-card-body">
        <div class="stu-strip">
          <div class="stu-av" id="dAvatar">—</div>
          <div>
            <div class="stu-name" id="dName">—</div>
            <div class="stu-sub" id="dSub">—</div>
          </div>
          <div class="stu-out"><div class="amt" id="dOutstanding">₹0</div><div class="lbl">Total Outstanding</div></div>
        </div>
        <div class="view-tabs mt-3">
          <button type="button" class="view-tab active" data-view="dues">Dues &amp; Collect</button>
          <button type="button" class="view-tab" data-view="history">Payment History</button>
        </div>
      </div></div>

      <!-- DUES VIEW: two pane -->
      <div id="viewDues">
        <div class="row g-4">
          <!-- LEFT: dues -->
          <div class="col-12 col-lg-7">
            <div class="ec-card">
              <div class="ec-card-header"><div class="ec-section-title-wrap">
                <div class="ec-section-icon"><i class="bx bx-calendar-check"></i></div>
                <div><h6 class="ec-section-title">What are you collecting?</h6><div class="ec-section-subtitle">Pick a period — the matching months load automatically</div></div>
              </div></div>
              <div class="ec-card-body">
                <div class="period"><span class="l">Pay for:</span>
                  <button type="button" class="chip" data-n="1">1 Month</button>
                  <button type="button" class="chip" data-n="3">3 Months</button>
                  <button type="button" class="chip" data-n="6">6 Months</button>
                  <button type="button" class="chip" data-n="12">Full Year</button>
                  <button type="button" class="period-clear" id="clearSel">Clear</button>
                </div>
                <div id="duesList"></div>
                <div class="grp"><i class="bx bx-plus-circle"></i>Extra charges</div>
                <div id="extraList"></div>
                <button type="button" class="btn btn-sm ec-btn-soft rounded-pill" id="openExtra"><i class="bx bx-plus"></i> Add extra charge</button>
              </div>
            </div>
          </div>

          <!-- RIGHT: settlement -->
          <div class="col-12 col-lg-5">
            <div class="ec-card settle">
              <div class="ec-card-header"><div class="ec-section-title-wrap">
                <div class="ec-section-icon"><i class="bx bx-calculator"></i></div>
                <div><h6 class="ec-section-title">Settlement</h6><div class="ec-section-subtitle">Everything adds up here</div></div>
              </div></div>
              <div class="ec-card-body">
                <div class="s-scope-lbl">Collecting</div>
                <div class="s-scope" id="scope">—</div>

                <div class="s-line muted"><span>Dues selected (<span id="selCount">0</span>)</span><span class="v" id="duesSel">₹0</span></div>
                <div class="s-line suc"><span>Discount <small class="text-muted" id="discReason"></small></span><span class="v" id="discCell"><button type="button" class="add-link" id="openDisc">+ Add</button></span></div>
                <div class="s-line muted"><span>Extra charges</span><span class="v" id="extraSum">₹0</span></div>

                <div class="s-pay"><span class="k">Payable</span><span class="v" id="payable">₹0</span></div>

                <div class="s-line suc" id="advUseRow" style="display:none;"><span><i class="bx bx-wallet"></i> Use advance <small class="text-muted" id="advAvail"></small></span><span><input type="number" min="0" id="advUse" class="form-control s-disc" value="0"></span></div>

                <div class="tender-head"><span>Payment</span><span id="tenderSum">₹0 of ₹0</span></div>
                <div id="tenders"></div>
                <button type="button" class="add-tender" id="addTender"><i class="bx bx-plus"></i> Split payment (add mode)</button>

                <div class="mt-2"><label class="form-label">Remarks</label><input type="text" id="pRemarks" class="form-control" placeholder="Optional note"></div>

                <div class="s-foot">
                  <div class="row1"><span>Paid</span><span id="paidV">₹0</span></div>
                  <div class="row1 muted"><span id="balLbl">Balance</span><span id="balV">₹0</span></div>
                  <div class="s-adv" id="advRow"><i class="bx bx-wallet"></i> <span id="advV">₹0</span> will be saved as advance</div>
                </div>

                <button type="button" class="btn btn-primary collect-cta" id="collectBtn" disabled><i class="bx bx-check-circle me-1"></i>Collect &amp; Receipt</button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- HISTORY VIEW -->
      <div id="viewHistory" class="d-none">
        <div class="ec-card"><div class="ec-card-body">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="fw-bold" style="color:var(--ec-text-dark)">Receipts</div>
            <button type="button" id="openRefund" class="btn btn-sm btn-outline-warning"><i class="bx bx-money-withdraw me-1"></i>Refund deposit / payment</button>
          </div>
          <div id="histList"></div>
        </div></div>
      </div>
    </div>

  </div>
</div>

<!-- discount modal -->
<div class="modal fade" id="discModal" tabindex="-1"><div class="modal-dialog modal-dialog-centered" style="max-width:380px"><div class="modal-content">
  <div class="modal-header py-2"><h6 class="modal-title fw-bold"><i class="bx bx-purchase-tag me-1 text-warning"></i>Add discount</h6><button class="btn-close" data-bs-dismiss="modal"></button></div>
  <div class="modal-body">
    <label class="form-label">Discount type</label>
    <div class="fc-seg-toggle mb-3">
      <button type="button" class="fc-seg active" data-t="flat">Flat ₹</button>
      <button type="button" class="fc-seg" data-t="pct">Percentage %</button>
    </div>
    <label class="form-label" id="discValLbl">Amount (₹)</label>
    <input type="number" min="0" class="form-control mb-3" id="discVal" placeholder="0">
    <label class="form-label">Reason <span class="text-danger">*</span></label>
    <input class="form-control" id="discReasonIn" placeholder="e.g. Principal approved / merit / staff ward">
    <div class="form-text mt-2" id="discPreview"></div>
  </div>
  <div class="modal-footer py-2">
    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
    <button type="button" class="btn btn-primary" id="applyDisc">Apply discount</button>
  </div>
</div></div></div>

<!-- cancel receipt modal -->
<div class="modal fade" id="cancelModal" tabindex="-1"><div class="modal-dialog modal-dialog-centered" style="max-width:430px"><div class="modal-content">
  <div class="modal-header py-2"><h6 class="modal-title fw-bold text-danger"><i class="bx bx-x-circle me-1"></i>Cancel receipt <span id="cmNo"></span></h6><button class="btn-close" data-bs-dismiss="modal"></button></div>
  <div class="modal-body">
    <div class="alert alert-warning py-2 small mb-3"><i class="bx bx-error me-1"></i>This reverses the <b id="cmAmt">₹0</b> payment and <b>re-opens the dues</b>. The receipt stays on record marked <b>Cancelled</b> (never deleted).</div>
    <label class="form-label">Reason for cancellation <span class="text-danger">*</span></label>
    <input class="form-control mb-3" id="cmReason" placeholder="e.g. Wrong student / duplicate / mode change">
    <label class="form-label">Authorised by</label>
    <select class="form-select" id="cmAuth"><option value="">— not specified —</option><option>Principal</option><option>Accountant</option><option>Admin</option></select>
  </div>
  <div class="modal-footer py-2">
    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Keep receipt</button>
    <button type="button" class="btn btn-danger" id="cmConfirm"><i class="bx bx-x-circle me-1"></i>Cancel receipt</button>
  </div>
</div></div></div>

<!-- refund modal -->
<div class="modal fade" id="refundModal" tabindex="-1"><div class="modal-dialog modal-dialog-centered" style="max-width:430px"><div class="modal-content">
  <div class="modal-header py-2"><h6 class="modal-title fw-bold"><i class="bx bx-money-withdraw me-1 text-warning"></i>Refund</h6><button class="btn-close" data-bs-dismiss="modal"></button></div>
  <div class="modal-body">
    <label class="form-label">Refund from <span class="text-danger">*</span></label>
    <select class="form-select mb-1" id="rfItem"></select>
    <div class="form-text mb-3" id="rfAvail">—</div>
    <label class="form-label">Amount to refund <span class="text-danger">*</span></label>
    <input type="number" min="0" class="form-control mb-3" id="rfAmt" placeholder="0">
    <div class="row g-2 mb-3">
      <div class="col-6"><label class="form-label">Refund via</label>
        <select class="form-select" id="rfMode"><option>Cash</option><option>Bank Transfer</option><option>Cheque</option><option>UPI</option></select></div>
      <div class="col-6"><label class="form-label">Authorised by</label>
        <select class="form-select" id="rfAuth"><option value="">— not specified —</option><option>Principal</option><option>Accountant</option><option>Admin</option></select></div>
    </div>
    <label class="form-label">Reason <span class="text-danger">*</span></label>
    <input class="form-control" id="rfReason" placeholder="e.g. TC issued / deposit returned / overpayment">
  </div>
  <div class="modal-footer py-2">
    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
    <button type="button" class="btn btn-primary" id="rfConfirm"><i class="bx bx-check me-1"></i>Refund</button>
  </div>
</div></div></div>

<!-- extra charge modal -->
<div class="modal fade" id="extraModal" tabindex="-1"><div class="modal-dialog modal-dialog-centered" style="max-width:380px"><div class="modal-content">
  <div class="modal-header py-2"><h6 class="modal-title fw-bold"><i class="bx bx-plus-circle me-1 text-warning"></i>Add extra charge</h6><button class="btn-close" data-bs-dismiss="modal"></button></div>
  <div class="modal-body">
    <label class="form-label">Charge for <span class="text-danger">*</span></label>
    <input class="form-control mb-3" id="extraLabel" placeholder="e.g. Late fine, Lost book, ID card">
    <label class="form-label">Amount (₹) <span class="text-danger">*</span></label>
    <input type="number" min="0" class="form-control mb-3" id="extraAmt" placeholder="0">
    <label class="form-label">Note (optional)</label>
    <input class="form-control" id="extraNote" placeholder="Optional remark">
  </div>
  <div class="modal-footer py-2">
    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
    <button type="button" class="btn btn-primary" id="applyExtra">Add charge</button>
  </div>
</div></div></div>

@await Html.PartialAsync("_FeeReceiptModal")
@Html.AntiForgeryToken()

@section PageScripts {
<script src="~/js/fee-receipt.js"></script>
<script>
$(function () {
    'use strict';

    function money(n){ return '₹' + Math.round(Number(n||0)).toLocaleString('en-IN'); }
    function num(n){ n = Number(n); return isFinite(n) && n > 0 ? n : 0; }
    function initials(name){ return (name||'?').trim().split(/\s+/).map(function(w){return w[0];}).slice(0,2).join('').toUpperCase(); }
    function esc(s){ return String(s==null?'':s).replace(/[&<>"]/g,function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c];}); }
    function notify(t,m){ if (typeof toastr!=='undefined') toastr[t](m); }

    var CSRF = $('input[name="__RequestVerificationToken"]').val();
    var URL = {
        sessions:  '@Url.Action("GetSessions","Fee",new{area="ERP"})',
        classes:   '@Url.Action("GetClasses","Fee",new{area="ERP"})',
        sections:  '@Url.Action("GetSections","Fee",new{area="ERP"})',
        students:  '@Url.Action("GetStudents","Fee",new{area="ERP"})',
        findByAdm: '@Url.Action("FindByAdmission","Fee",new{area="ERP"})',
        dues:      '@Url.Action("GetStudentDues","Fee",new{area="ERP"})',
        collect:   '@Url.Action("Collect","Fee",new{area="ERP"})',
        history:    '@Url.Action("GetHistory","Fee",new{area="ERP"})',
        cancel:     '@Url.Action("CancelReceipt","Fee",new{area="ERP"})',
        refundable: '@Url.Action("GetRefundables","Fee",new{area="ERP"})',
        refund:     '@Url.Action("Refund","Fee",new{area="ERP"})',
        advance:    '@Url.Action("GetAdvance","Fee",new{area="ERP"})'
    };
    var api = {
        sessions:  function(){ return $.getJSON(URL.sessions); },
        classes:   function(s){ return $.getJSON(URL.classes,{session:s}); },
        sections:  function(s,c){ return $.getJSON(URL.sections,{session:s,className:c}); },
        students:  function(s,c,sec){ return $.getJSON(URL.students,{session:s,className:c,section:sec}); },
        findByAdm: function(s,a){ return $.getJSON(URL.findByAdm,{session:s,admissionNo:a}); },
        dues:      function(id){ return $.getJSON(URL.dues,{studentId:id}); },
        history:   function(id){ return $.getJSON(URL.history,{studentId:id}); },
        collect:   function(p){ return $.ajax({url:URL.collect,type:'POST',contentType:'application/json',headers:{'RequestVerificationToken':CSRF},data:JSON.stringify(p)}); },
        cancel:     function(p){ return $.ajax({url:URL.cancel,type:'POST',contentType:'application/json',headers:{'RequestVerificationToken':CSRF},data:JSON.stringify(p)}); },
        refundable: function(id){ return $.getJSON(URL.refundable,{studentId:id}); },
        refund:     function(p){ return $.ajax({url:URL.refund,type:'POST',contentType:'application/json',headers:{'RequestVerificationToken':CSRF},data:JSON.stringify(p)}); },
        advance:    function(id){ return $.getJSON(URL.advance,{studentId:id}); }
    };

    var $session=$('#fSession'), $class=$('#fClass'), $section=$('#fSection'), $student=$('#fStudent'), $adm=$('#fAdm');
    var $duesEmpty=$('#duesEmpty'), $duesPane=$('#duesPane');
    var students=[], currentStudent=null;
    var months=[];        // [{key,title,dues:[...]}] ascending
    var otherDues=[];
    var sel={};           // ledgerId -> {label, outstanding, dueDate}
    var extras=[];        // {label, amount, note}
    var discount=null;    // {type:'flat'|'pct', value, reason}
    var discType='flat';
    var tenders=[{mode:'Cash',amt:0}];
    var amtTouched=false, today={n:0,c:0}, advanceAvail=0;

    function fillSelect($el, items, ph){
        var h = ph ? '<option value="">'+ph+'</option>' : '';
        items.forEach(function(x){ h += '<option value="'+esc(x)+'">'+esc(x)+'</option>'; });
        $el.html(h);
    }

    /* ── cascade (unchanged: Session → Adm → Class → Section → Student) ── */
    api.sessions().done(function(s){ fillSelect($session,s,null); $session.val(s[0]); loadClasses(); });
    function loadClasses(){
        clearStudentView(); students=[];
        $section.prop('disabled',true).html('<option value="">Select class first</option>');
        $student.prop('disabled',true).html('<option value="">Select section first</option>');
        api.classes($session.val()).done(function(c){ fillSelect($class,c,'Select Class'); });
    }
    function loadSections(){
        clearStudentView(); students=[];
        $student.prop('disabled',true).html('<option value="">Select section first</option>');
        if(!$class.val()){ $section.prop('disabled',true).html('<option value="">Select class first</option>'); return; }
        api.sections($session.val(),$class.val()).done(function(sec){ fillSelect($section,sec,'Select Section'); $section.prop('disabled',sec.length===0); });
    }
    function loadStudentSelect(){
        clearStudentView();
        if(!$section.val()){ $student.prop('disabled',true).html('<option value="">Select section first</option>'); return; }
        api.students($session.val(),$class.val(),$section.val()).done(function(list){ students=list||[]; fillStudentSelect(); });
    }
    function fillStudentSelect(){
        var h='<option value="">'+(students.length?'Select Student':'No students')+'</option>';
        students.forEach(function(s){ h+='<option value="'+s.id+'">Roll '+esc(s.roll||'—')+' — '+esc(s.name)+' ('+esc(s.admNo)+')</option>'; });
        $student.html(h).prop('disabled',students.length===0);
    }
    $session.on('change',loadClasses);
    $class.on('change',loadSections);
    $section.on('change',loadStudentSelect);
    $student.on('change',function(){ var id=Number($(this).val()); if(!id){ clearStudentView(); return; } loadStudentById(id); });
    function loadStudentById(id){
        currentStudent = students.find(function(s){ return s.id===id; }) || null;
        if(currentStudent) api.dues(currentStudent.id).done(openStudent).fail(function(){ notify('error','Could not load dues.'); });
    }

    /* ── admission search ── */
    function doAdmSearch(){
        var adm=$adm.val().trim(); if(!adm){ notify('warning','Enter an admission number.'); return; }
        api.findByAdm($session.val(),adm).done(function(r){
            if(!r){ notify('error','No student found for "'+adm+'".'); return; }
            $class.val(r.className);
            api.sections($session.val(),r.className).done(function(sec){
                fillSelect($section,sec,'Select Section'); $section.val(r.section).prop('disabled',false);
                api.students($session.val(),r.className,r.section).done(function(list){
                    students=list||[]; fillStudentSelect(); $student.val(r.student.id); loadStudentById(r.student.id);
                });
            });
        });
    }
    $('#admGo').on('click',doAdmSearch);
    $adm.on('keydown',function(e){ if(e.key==='Enter'){ e.preventDefault(); doAdmSearch(); } });

    /* ── open student ── */
    function bucket(dues,c){ return (dues && (dues[c] || dues[c.toLowerCase()])) || []; }
    function clearStudentView(){ currentStudent=null; sel={}; extras=[]; discount=null; tenders=[{mode:'Cash',amt:0}]; amtTouched=false; $duesPane.addClass('d-none'); $duesEmpty.removeClass('d-none'); }
    function monthTitle(key){ var p=key.split('-'), names=['January','February','March','April','May','June','July','August','September','October','November','December']; return names[Number(p[1])-1]+' '+p[0]; }

    function openStudent(dues){
        sel={}; extras=[]; discount=null; tenders=[{mode:'Cash',amt:0}]; amtTouched=false;
        var monthly = bucket(dues,'Monthly').slice().sort(function(a,b){ return (a.dueDate||'').localeCompare(b.dueDate||''); });
        var map={}; months=[];
        monthly.forEach(function(d){
            var key=(d.dueDate||'').slice(0,7) || 'na';
            if(!map[key]){ map[key]={key:key,title:key==='na'?'Undated':monthTitle(key),dues:[]}; months.push(map[key]); }
            map[key].dues.push(d);
        });
        otherDues = bucket(dues,'Quarterly').concat(bucket(dues,'Yearly'));

        var total=0; months.forEach(function(m){ m.dues.forEach(function(d){ total+=d.amount; }); }); otherDues.forEach(function(d){ total+=d.amount; });
        $('#dAvatar').text(initials(currentStudent.name));
        $('#dName').text(currentStudent.name);
        $('#dSub').text(currentStudent.admNo + ' · ' + $class.val() + ' - ' + $section.val() + ' · Roll ' + (currentStudent.roll||'—'));
        $('#dOutstanding').text(money(total));
        $duesEmpty.addClass('d-none'); $duesPane.removeClass('d-none');
        switchView('dues');
        $('.chip').removeClass('active'); $('#scope').text('—');
        advanceAvail=0; $('#advUse').val(0); $('#advUseRow').hide();
        renderDues(); renderExtras(); renderTenders(); settle();
        api.advance(currentStudent.id).done(function(a){
            advanceAvail=Number((a&&a.balance)||0);
            if(advanceAvail>0){ $('#advAvail').text('(of '+money(advanceAvail)+' available)'); $('#advUseRow').show(); }
            else { $('#advUse').val(0); $('#advUseRow').hide(); }
            settle();
        });
    }

    /* ── view tabs ── */
    function switchView(view){
        $('.view-tab').removeClass('active').filter('[data-view="'+view+'"]').addClass('active');
        $('#viewDues').toggleClass('d-none', view!=='dues');
        $('#viewHistory').toggleClass('d-none', view!=='history');
        if(view==='history') loadHistory();
    }
    $('.view-tab').on('click', function(){ switchView($(this).data('view')); });

    /* ── dues ── */
    function allDues(){ return months.flatMap(function(m){return m.dues;}).concat(otherDues); }
    function dueRow(d,deposit){
        var s=!!sel[d.id];
        return '<div class="due'+(s?' sel':'')+'" data-id="'+d.id+'">'+
            '<label class="due-main"><input type="checkbox" class="form-check-input due-chk"'+(s?' checked':'')+'>'+
              '<div class="due-info"><div class="due-label">'+esc(d.label)+(deposit?'<span class="deposit-tag">refundable</span>':'')+'</div>'+
              '<div class="due-meta">'+(d.overdue?'<span class="overdue">Overdue</span> · ':'')+'Due '+esc(d.dueDate||'—')+'</div></div>'+
              '<div class="due-amt">'+money(d.amount)+'</div></label></div>';
    }
    function renderDues(){
        var html='';
        if(!months.length && !otherDues.length){
            html='<div class="empty-pane"><i class="bx bx-check-circle" style="color:var(--ec-suc)"></i><h6>All clear</h6><p class="mb-0">This student has no outstanding dues.</p></div>';
            $('#duesList').html(html); return;
        }
        months.forEach(function(m){
            html+='<div class="grp"><i class="bx bx-calendar"></i>'+esc(m.title)+'</div>';
            m.dues.forEach(function(d){ html+=dueRow(d,false); });
        });
        if(otherDues.length){
            html+='<div class="grp"><i class="bx bx-receipt"></i>Other dues (one-time / annual)</div>';
            otherDues.forEach(function(d){ html+=dueRow(d,false); });
        }
        $('#duesList').html(html);
    }
    $('#duesList').on('change','.due-chk', function(){
        var $row=$(this).closest('.due'), id=$row.data('id');
        if(this.checked){ var d=allDues().find(function(x){return x.id===id;}); sel[id]={label:d.label,outstanding:d.amount,dueDate:d.dueDate||''}; }
        else delete sel[id];
        $row.toggleClass('sel',this.checked); settle();
    });
    $('.chip').on('click', function(){
        $('.chip').removeClass('active'); $(this).addClass('active');
        var n=Number($(this).data('n')); sel={};
        months.forEach(function(m,i){ if(i<n) m.dues.forEach(function(d){ sel[d.id]={label:d.label,outstanding:d.amount,dueDate:d.dueDate||''}; }); });
        var names=months.slice(0,n).map(function(m){return m.title;});
        $('#scope').text(names.length? (n+' month'+(n>1?'s':'')+' · '+names[0]+(n>1?' – '+names[names.length-1]:'')) : 'Nothing to select');
        renderDues(); settle();
    });
    $('#clearSel').on('click', function(){ sel={}; $('.chip').removeClass('active'); $('#scope').text('—'); renderDues(); settle(); });

    /* ── extras (modal) ── */
    function renderExtras(){
        if(!extras.length){ $('#extraList').html('<div class="empty-line">No extra charges. Use “Add extra charge” for late fine, lost book, etc.</div>'); return; }
        var h=extras.map(function(e,i){
            return '<div class="li" data-i="'+i+'"><div class="li-info"><div class="li-label">'+esc(e.label)+'</div>'+(e.note?'<div class="li-sub">'+esc(e.note)+'</div>':'')+'</div>'+
                '<div class="li-amt">'+money(e.amount)+'</div><button type="button" class="li-rm"><i class="bx bx-x"></i></button></div>';
        }).join('');
        $('#extraList').html(h);
    }
    $('#extraList').on('click','.li-rm', function(){ extras.splice($(this).closest('.li').data('i'),1); renderExtras(); settle(); });
    var extraModal=new bootstrap.Modal(document.getElementById('extraModal'));
    $('#openExtra').on('click', function(){ $('#extraLabel').val(''); $('#extraAmt').val(''); $('#extraNote').val(''); extraModal.show(); });
    $('#applyExtra').on('click', function(){
        var label=$('#extraLabel').val().trim(), amt=num($('#extraAmt').val()), note=$('#extraNote').val().trim();
        if(!label || amt<=0){ notify('warning','Enter a charge name and amount.'); return; }
        extras.push({label:label,amount:amt,note:note}); extraModal.hide(); renderExtras(); settle();
    });

    /* ── discount (modal: flat/% + reason) ── */
    var discModal=new bootstrap.Modal(document.getElementById('discModal'));
    function setSeg(t){ discType=t;
        $('#discModal .fc-seg').each(function(){ $(this).toggleClass('active',$(this).data('t')===t); });
        $('#discValLbl').text(t==='pct'?'Percentage (%)':'Amount (₹)'); discPreview();
    }
    function discPreview(){
        var v=num($('#discVal').val()), dues=calc().dues, amt=discType==='pct'?Math.round(dues*v/100):v;
        $('#discPreview').text(v>0 ? (discType==='pct'? v+'% of '+money(dues)+' = ':'Flat ')+'discount '+money(Math.min(amt,dues)) : '');
    }
    $('#discModal .fc-seg').on('click', function(){ setSeg($(this).data('t')); });
    $('#discVal').on('input', discPreview);
    function openDiscountModal(){
        if(discount){ setSeg(discount.type); $('#discVal').val(discount.value); $('#discReasonIn').val(discount.reason||''); }
        else { setSeg('flat'); $('#discVal').val(''); $('#discReasonIn').val(''); }
        discPreview(); discModal.show();
    }
    $('#openDisc').on('click', openDiscountModal);
    $('#applyDisc').on('click', function(){
        var v=num($('#discVal').val()), reason=$('#discReasonIn').val().trim();
        if(v<=0){ notify('warning','Enter a discount value.'); return; }
        if(!reason){ notify('warning','A reason is required for a discount.'); return; }
        discount={type:discType,value:v,reason:reason}; discModal.hide(); settle();
    });
    function renderDiscount(){
        var $cell=$('#discCell'), $rsn=$('#discReason');
        if(!discount){ $cell.html('<button type="button" class="add-link">+ Add</button>'); $rsn.text('');
            $cell.find('.add-link').on('click',openDiscountModal); return; }
        var amt=calc().disc;
        $rsn.text('· '+discount.reason + (discount.type==='pct'?' ('+discount.value+'%)':''));
        $cell.html('<span class="disc-set">−'+money(amt)+' <i class="bx bx-pencil e" title="Edit"></i> <i class="bx bx-x x" title="Remove"></i></span>');
        $cell.find('.e').on('click',openDiscountModal);
        $cell.find('.x').on('click',function(){ discount=null; settle(); });
    }

    /* ── tenders (split payment) ── */
    function renderTenders(){
        var modes=['Cash','UPI','Card','Cheque','Demand Draft','Bank Transfer'];
        var h=tenders.map(function(t,i){
            return '<div class="tender-row" data-i="'+i+'"><select class="form-select form-select-sm">'+
                modes.map(function(m){return '<option'+(m===t.mode?' selected':'')+'>'+m+'</option>';}).join('')+'</select>'+
                '<input class="form-control form-control-sm t-amt" type="number" min="0" placeholder="₹" value="'+(t.amt||'')+'">'+
                (tenders.length>1?'<button type="button" class="btn btn-sm btn-outline-danger rounded-circle rm"><i class="bx bx-x"></i></button>':'')+'</div>';
        }).join('');
        $('#tenders').html(h);
    }
    $('#tenders').on('change','select', function(){ tenders[$(this).closest('.tender-row').data('i')].mode=$(this).val(); });
    $('#tenders').on('input','.t-amt', function(){ amtTouched=true; tenders[$(this).closest('.tender-row').data('i')].amt=num($(this).val()); settle(); });
    $('#tenders').on('click','.rm', function(){ tenders.splice($(this).closest('.tender-row').data('i'),1); renderTenders(); settle(); });
    $('#addTender').on('click', function(){ tenders.push({mode:'UPI',amt:0}); renderTenders(); settle(); });

    /* ── settlement maths ── */
    function selectedArr(){ return Object.keys(sel).map(function(k){ return sel[k]; }); }
    function calc(){
        var dues=selectedArr().reduce(function(t,x){return t+x.outstanding;},0), n=selectedArr().length;
        var ext=extras.filter(function(e){return e.amount>0&&(e.label||'').trim();}).reduce(function(t,e){return t+e.amount;},0);
        var disc=discount ? Math.min(discount.type==='pct'?Math.round(dues*discount.value/100):discount.value, dues) : 0;
        var payable=Math.max(0, dues-disc+ext);
        return {dues:dues,ext:ext,disc:disc,payable:payable,n:n};
    }
    function tendersTotal(){ return tenders.reduce(function(t,x){return t+num(x.amt);},0); }
    function advUseVal(c){ return Math.min(num($('#advUse').val()), advanceAvail, c.payable); }
    function settle(){
        var c=calc(); renderDiscount();
        var advUse=advUseVal(c);
        if(num($('#advUse').val())>advUse) $('#advUse').val(advUse);
        var net=Math.max(0, c.payable-advUse);
        $('#selCount').text(c.n); $('#duesSel').text(money(c.dues)); $('#extraSum').text(money(c.ext)); $('#payable').text(money(c.payable));
        if(!amtTouched && tenders.length===1){ tenders[0].amt=net; renderTenders(); }
        var paid=tendersTotal(), funded=paid+advUse;
        $('#tenderSum').text(money(paid)+' of '+money(net));
        $('#paidV').text(money(funded));
        var bal=c.payable-funded;
        $('#balLbl').text(bal>0?'Balance due':'Balance'); $('#balV').text(money(Math.max(0,bal)));
        var adv=Math.max(0,funded-c.payable);
        $('#advRow').toggle(adv>0); $('#advV').text(money(adv));
        $('#collectBtn').prop('disabled', c.payable<=0 && c.disc<=0);
    }
    $('#advUse').on('input', settle);

    /* Build per-ledger items for the existing endpoint: discount spread oldest-first
       as concession, then the paid cash spread oldest-first. */
    function buildItems(){
        var arr=selectedArr().slice().sort(function(a,b){ return (a.dueDate||'').localeCompare(b.dueDate||''); });
        var c=calc(), remD=c.disc;
        arr.forEach(function(s){ var cc=Math.min(remD,s.outstanding); s._conc=cc; remD-=cc; s._net=s.outstanding-cc; });
        var cashForDues=Math.max(0, Math.min((tendersTotal()+advUseVal(c))-c.ext, c.dues-c.disc)), remC=cashForDues;
        arr.forEach(function(s){ var p=Math.min(remC,s._net); s._pay=p; remC-=p; });
        // map back to ledger ids
        var ids=Object.keys(sel);
        return arr.map(function(s,idx){ return s; })
                  .filter(function(s){ return s._pay>0 || s._conc>0; })
                  .map(function(s){ var id=ids.find(function(k){return sel[k]===s;}); return { ledgerId:Number(id), amount:s._pay, concession:s._conc }; });
    }

    /* ── collect ── */
    $('#collectBtn').on('click', function(){
        var items=buildItems();
        var exs=extras.filter(function(e){return e.amount>0&&(e.label||'').trim();}).map(function(e){return {label:e.label,amount:e.amount};});
        if(!items.length && !exs.length){ notify('warning','Pick a due or add an extra charge.'); return; }
        var advUse=advUseVal(calc());
        var paidTenders = tenders.filter(function(t){ return num(t.amt)>0; }).map(function(t){ return { mode:t.mode, amount:num(t.amt) }; });
        var primaryMode = tenders.length>1 ? 'Mixed' : (tenders[0]&&tenders[0].mode) || 'Cash';
        var $btn=$(this), old=$btn.html();
        $btn.prop('disabled',true).html('<i class="bx bx-loader-circle bx-spin me-1"></i>Collecting…');
        api.collect({ studentId:currentStudent.id, mode:primaryMode, reference:'', remarks:$('#pRemarks').val(),
                      session:$session.val(), items:items, extras:exs,
                      discountType: discount ? (discount.type==='pct'?'Percent':'Flat') : null,
                      discountValue: discount ? discount.value : 0,
                      discountReason: discount ? discount.reason : null,
                      tenders: paidTenders, advanceUsed: advUse })
        .done(function(res){
            $btn.prop('disabled',false).html(old);
            if(!res || !res.success){ notify('error',(res&&res.message)||'Could not record payment.'); return; }
            notify('success','Collected '+money(res.amount)+'. Receipt '+res.receiptNo+'.');
            today.n+=num(res.amount); today.c++; $('#todayN').text(money(today.n)); $('#todayC').text(today.c);
            $('#pRemarks').val('');
            if(window.EcReceipt) EcReceipt.show(res.receiptNo);
            api.dues(currentStudent.id).done(openStudent);
        })
        .fail(function(){ $btn.prop('disabled',false).html(old); notify('error','Could not record payment.'); });
    });

    /* ── history ── */
    function loadHistory(){
        if(!currentStudent) return;
        $('#histList').html('<div class="text-muted small">Loading…</div>');
        api.history(currentStudent.id).done(function(rows){
            if(!rows||!rows.length){ $('#histList').html('<div class="empty-pane"><i class="bx bx-receipt"></i><h6>No payments yet</h6><p class="mb-0">Collected receipts will appear here.</p></div>'); return; }
            var h='';
            rows.forEach(function(r){
                var x=r.isCancelled;
                h+='<div class="hist-row'+(x?' cancelled':'')+'"><div class="hist-info">'+
                   '<div class="hist-rcp'+(x?' strike':'')+'">'+esc(r.receiptNo)+(x?' <span class="ec-badge ec-badge-default">Cancelled</span>':'')+'</div>'+
                   '<div class="hist-meta">'+esc(r.date||'—')+' · '+esc(r.mode)+(r.reference?' · '+esc(r.reference):'')+(r.concession>0?' · '+money(r.concession)+' off':'')+
                       (x&&r.cancelReason?' · <span class="text-danger">'+esc(r.cancelReason)+'</span>':'')+'</div></div>'+
                   '<div class="hist-amt'+(x?' strike':'')+'">'+money(r.amount)+'</div>'+
                   '<button type="button" class="btn btn-outline-secondary btn-sm hist-print" data-rcp="'+esc(r.receiptNo)+'" title="Re-print"><i class="bx bx-printer"></i></button>'+
                   (x?'':'<button type="button" class="btn btn-outline-danger btn-sm hist-cancel" data-rcp="'+esc(r.receiptNo)+'" data-amt="'+r.amount+'" title="Cancel receipt"><i class="bx bx-x-circle"></i></button>')+
                   '</div>';
            });
            $('#histList').html(h);
        });
    }
    $('#histList').on('click','.hist-print', function(){ if(window.EcReceipt) EcReceipt.show($(this).data('rcp')); });

    /* ── cancel receipt ── */
    var cancelModal=new bootstrap.Modal(document.getElementById('cancelModal'));
    $('#histList').on('click','.hist-cancel', function(){
        $('#cmNo').text($(this).data('rcp')); $('#cmAmt').text(money($(this).data('amt')));
        $('#cmReason').val(''); $('#cmAuth').val('');
        cancelModal.show();
    });
    $('#cmConfirm').on('click', function(){
        var rcp=$('#cmNo').text(), reason=$('#cmReason').val().trim(), auth=$('#cmAuth').val();
        if(!reason){ notify('warning','A reason is required.'); return; }
        var $btn=$(this), old=$btn.html(); $btn.prop('disabled',true).html('<i class="bx bx-loader-circle bx-spin"></i>');
        api.cancel({ receiptNo:rcp, reason:reason, authorizedBy:auth })
        .done(function(res){
            $btn.prop('disabled',false).html(old);
            if(!res||!res.success){ notify('error',(res&&res.message)||'Could not cancel.'); return; }
            cancelModal.hide(); notify('success',res.message||'Receipt cancelled.');
            if(currentStudent) api.dues(currentStudent.id).done(function(d){ openStudent(d); switchView('history'); });
            else loadHistory();
        })
        .fail(function(){ $btn.prop('disabled',false).html(old); notify('error','Could not cancel the receipt.'); });
    });

    /* ── refund (deposit / overpayment) ── */
    var refundModal=new bootstrap.Modal(document.getElementById('refundModal'));
    var refundables=[];
    $('#openRefund').on('click', function(){
        if(!currentStudent){ notify('warning','Select a student first.'); return; }
        api.refundable(currentStudent.id).done(function(rows){
            refundables=rows||[];
            if(!refundables.length){ notify('info','Nothing to refund — no paid amount is held for this student.'); return; }
            $('#rfItem').html(refundables.map(function(r,i){ return '<option value="'+i+'">'+(r.isRefundable?'★ ':'')+esc(r.label)+' — '+money(r.refundable)+' refundable</option>'; }).join(''));
            $('#rfReason').val(''); $('#rfAuth').val(''); $('#rfMode').val('Cash');
            refundItemChanged(); refundModal.show();
        }).fail(function(){ notify('error','Could not load refundable amounts.'); });
    });
    function refundItemChanged(){
        var r=refundables[Number($('#rfItem').val())]; if(!r) return;
        $('#rfAvail').html('Paid '+money(r.paid)+(r.refunded>0?' · already refunded '+money(r.refunded):'')+' · <b>'+money(r.refundable)+' refundable</b>');
        $('#rfAmt').val(r.refundable);
    }
    $('#rfItem').on('change', refundItemChanged);
    $('#rfConfirm').on('click', function(){
        var r=refundables[Number($('#rfItem').val())]; if(!r){ notify('warning','Pick a charge to refund.'); return; }
        var amt=num($('#rfAmt').val()), reason=$('#rfReason').val().trim();
        if(amt<=0){ notify('warning','Enter a refund amount.'); return; }
        if(amt>r.refundable+0.001){ notify('warning','Amount exceeds the refundable balance ('+money(r.refundable)+').'); return; }
        if(!reason){ notify('warning','A reason is required.'); return; }
        var $btn=$(this), old=$btn.html(); $btn.prop('disabled',true).html('<i class="bx bx-loader-circle bx-spin"></i>');
        api.refund({ studentId:currentStudent.id, ledgerId:r.ledgerId, amount:amt, mode:$('#rfMode').val(), reason:reason, authorizedBy:$('#rfAuth').val() })
        .done(function(res){
            $btn.prop('disabled',false).html(old);
            if(!res||!res.success){ notify('error',(res&&res.message)||'Could not refund.'); return; }
            refundModal.hide(); notify('success',res.message||'Refund recorded.');
            if(currentStudent) api.dues(currentStudent.id).done(function(d){ openStudent(d); switchView('history'); });
        })
        .fail(function(){ $btn.prop('disabled',false).html(old); notify('error','Could not record the refund.'); });
    });

    if (typeof toastr !== 'undefined') toastr.options = { closeButton:true, progressBar:true, positionClass:'toast-top-right', timeOut:3000 };
});
</script>
}
