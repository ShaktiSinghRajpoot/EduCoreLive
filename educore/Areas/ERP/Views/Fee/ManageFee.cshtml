@{
    ViewData["Title"] = "Fee Collection";
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
}

@section PageStyles {
    <style>
        :root {
            --edu-primary:       #ff8a00;
            --edu-primary-dark:  #eb7d00;
            --edu-primary-soft:  #fff4e6;
            --edu-heading:       #2b1b12;
            --edu-text:          #2b2c40;
            --edu-muted:         #8b8175;
            --edu-bg:            #f8f7f5;
            --edu-card:          #ffffff;
            --edu-border:        #ececf5;
            --edu-success:       #28c76f;
            --edu-success-soft:  #e9f9f0;
            --edu-danger:        #ea5455;
            --edu-danger-soft:   #fff0f0;
            --edu-warning:       #ffab00;
            --edu-warning-soft:  #fff7e6;
            --edu-info:          #00bad1;
            --edu-info-soft:     #e9fbfd;
        }

        /* ───────────────────────── Buttons ───────────────────────── */
        .btn-premium {
            border-radius: 12px;
            font-size: .84rem;
            font-weight: 800;
            padding: .7rem 1.05rem;
        }

        .btn-primary {
            background: linear-gradient(135deg, #ff9d2e, var(--edu-primary));
            border: 0;
            box-shadow: 0 10px 22px rgba(255, 138, 0, .28);
        }

            .btn-primary:hover,
            .btn-primary:focus {
                background: linear-gradient(135deg, var(--edu-primary), var(--edu-primary-dark));
                box-shadow: 0 8px 18px rgba(255, 138, 0, .32);
            }

        .btn-collect {
            font-size: .98rem;
            padding: .9rem 1.1rem;
            border-radius: 14px;
            letter-spacing: .01em;
        }

        /* ───────────────────────── Compact header ────────────────── */
        .fee-header-compact {
            padding: .7rem 1.1rem;
            border-radius: 15px;
        }

            .fee-header-compact .ec-page-icon {
                width: 38px;
                height: 38px;
                border-radius: 11px;
                font-size: 1.15rem;
            }

            .fee-header-compact .ec-page-title {
                font-size: 1.1rem;
            }

            .fee-header-compact .ec-page-subtitle {
                font-size: .76rem;
            }

        /* ───────────────────────── KPI cards ─────────────────────── */
        .kpi-card {
            position: relative;
            background: var(--edu-card);
            border: 1px solid var(--edu-border);
            border-radius: 15px;
            padding: .8rem .9rem;
            height: 100%;
            overflow: hidden;
            box-shadow: 0 8px 24px rgba(67, 89, 113, .055);
            transition: transform .18s ease, box-shadow .18s ease;
        }

            .kpi-card:hover {
                transform: translateY(-3px);
                box-shadow: 0 14px 30px rgba(67, 89, 113, .10);
            }

            .kpi-card::after {
                content: "";
                position: absolute;
                right: -42px;
                top: -42px;
                width: 130px;
                height: 130px;
                border-radius: 50%;
                background: radial-gradient(circle, var(--kpi-glow, rgba(255,138,0,.10)), transparent 70%);
                pointer-events: none;
            }

        .kpi-top {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: .75rem;
        }

        .kpi-label {
            color: var(--edu-muted);
            font-size: .67rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: .04em;
            margin-bottom: .3rem;
        }

        .kpi-value {
            color: var(--edu-heading);
            font-size: 1.25rem;
            font-weight: 800;
            line-height: 1.1;
        }

        .kpi-note {
            color: var(--edu-muted);
            font-size: .68rem;
            font-weight: 600;
            margin-top: .3rem;
        }

        .kpi-icon {
            width: 38px;
            height: 38px;
            border-radius: 11px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            flex-shrink: 0;
            color: #fff;
        }

        .kpi-primary { --kpi-glow: rgba(255,138,0,.12); }
        .kpi-success { --kpi-glow: rgba(40,199,111,.12); }
        .kpi-danger  { --kpi-glow: rgba(234,84,85,.12); }
        .kpi-info    { --kpi-glow: rgba(0,186,209,.12); }

        .kpi-primary .kpi-icon { background: linear-gradient(135deg, #ffb45c, var(--edu-primary)); box-shadow: 0 8px 16px rgba(255,138,0,.30); }
        .kpi-success .kpi-icon { background: linear-gradient(135deg, #5be49b, var(--edu-success)); box-shadow: 0 8px 16px rgba(40,199,111,.30); }
        .kpi-danger  .kpi-icon { background: linear-gradient(135deg, #f58e8f, var(--edu-danger));  box-shadow: 0 8px 16px rgba(234,84,85,.30); }
        .kpi-info    .kpi-icon { background: linear-gradient(135deg, #54dceb, var(--edu-info));    box-shadow: 0 8px 16px rgba(0,186,209,.30); }

        /* ───────────────────────── Workspace grid ────────────────── */
        .main-grid {
            display: grid;
            grid-template-columns: 330px minmax(0, 1fr) 330px;
            gap: 1.25rem;
            align-items: stretch;
            margin-top: 1rem;
        }

        .erp-panel {
            background: var(--edu-card);
            border: 1px solid var(--edu-border);
            border-radius: 22px;
            box-shadow: 0 10px 28px rgba(67, 89, 113, .06);
            overflow: hidden;
            display: flex;
            flex-direction: column;
            min-height: 700px;
        }

        .panel-header {
            padding: 1rem 1.15rem;
            border-bottom: 1px solid var(--edu-border);
            background: linear-gradient(180deg, #fffdf9, #ffffff);
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: .75rem;
        }

        .panel-title {
            color: var(--edu-heading);
            font-size: .98rem;
            font-weight: 800;
            margin-bottom: .15rem;
        }

        .panel-subtitle {
            color: var(--edu-muted);
            font-size: .74rem;
            font-weight: 600;
        }

        .panel-count {
            background: var(--edu-primary-soft);
            color: var(--edu-primary);
            border-radius: 999px;
            padding: .3rem .7rem;
            font-size: .72rem;
            font-weight: 800;
            white-space: nowrap;
        }

        .panel-body {
            padding: 1.05rem;
            flex: 1 1 auto;
            display: flex;
            flex-direction: column;
            min-height: 0;
        }

        /* ───────────────────────── Filters & search ──────────────── */
        .student-filter-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: .6rem;
            margin-bottom: .7rem;
        }

        .quick-filter-row {
            display: flex;
            gap: .4rem;
            flex-wrap: wrap;
            margin-bottom: .8rem;
        }

        .quick-filter {
            border: 1px solid var(--edu-border);
            background: #fff;
            color: var(--edu-muted);
            border-radius: 999px;
            padding: .34rem .68rem;
            font-size: .71rem;
            font-weight: 800;
            transition: .15s ease;
        }

            .quick-filter:hover {
                border-color: rgba(255, 138, 0, .45);
                color: var(--edu-primary);
            }

            .quick-filter.active {
                border-color: var(--edu-primary);
                background: linear-gradient(135deg, #ff9d2e, var(--edu-primary));
                color: #fff;
                box-shadow: 0 6px 14px rgba(255, 138, 0, .25);
            }

        .form-label {
            color: #3d2c24;
            font-size: .78rem;
            font-weight: 800;
            margin-bottom: .4rem;
        }

        .required::after {
            content: " *";
            color: var(--edu-danger);
        }

        .form-control,
        .form-select {
            border: 1px solid #d9dee3;
            border-radius: 10px;
            min-height: 44px;
            color: var(--edu-text);
            font-size: .9rem;
            font-weight: 500;
            background-color: #fff;
        }

            .form-control::placeholder {
                color: var(--edu-muted);
                opacity: 1;
            }

            .form-control:focus,
            .form-select:focus {
                border-color: #ffb866;
                box-shadow: 0 0 0 .18rem rgba(255, 138, 0, .12);
            }

        .search-wrap {
            position: relative;
            margin-bottom: .8rem;
        }

            .search-wrap i {
                position: absolute;
                left: 13px;
                top: 50%;
                transform: translateY(-50%);
                color: var(--edu-muted);
                font-size: 1rem;
            }

            .search-wrap .form-control {
                padding-left: 40px;
                padding-right: 44px;
            }

        .search-kbd {
            position: absolute;
            right: 11px;
            top: 50%;
            transform: translateY(-50%);
            border: 1px solid var(--edu-border);
            border-radius: 7px;
            background: #faf9f7;
            color: var(--edu-muted);
            font-size: .68rem;
            font-weight: 800;
            padding: .14rem .45rem;
        }

        /* ───────────────────────── Scroll areas ──────────────────── */
        .student-list,
        .history-list,
        .due-list {
            overflow-y: auto;
            padding-right: .25rem;
        }

        .student-list { max-height: 470px; }
        .history-list { max-height: 560px; }
        .due-list     { max-height: 260px; margin-bottom: 1rem; }

            .student-list::-webkit-scrollbar,
            .history-list::-webkit-scrollbar,
            .due-list::-webkit-scrollbar {
                width: 7px;
            }

            .student-list::-webkit-scrollbar-thumb,
            .history-list::-webkit-scrollbar-thumb,
            .due-list::-webkit-scrollbar-thumb {
                background: rgba(255, 138, 0, .22);
                border-radius: 30px;
            }

        /* ───────────────────────── Student cards ─────────────────── */
        .student-item {
            display: flex;
            gap: .75rem;
            border: 1px solid var(--edu-border);
            border-radius: 16px;
            padding: .8rem;
            margin-bottom: .65rem;
            cursor: pointer;
            background: #fff;
            transition: .18s ease;
        }

            .student-item:hover {
                border-color: rgba(255, 138, 0, .45);
                background: #fffaf5;
                transform: translateY(-1px);
                box-shadow: 0 8px 18px rgba(255, 138, 0, .08);
            }

            .student-item.active {
                border-color: var(--edu-primary);
                background: linear-gradient(135deg, #fff4e6, #fffdf9);
                box-shadow: 0 10px 22px rgba(255, 138, 0, .14);
            }

        .student-mini-avatar {
            width: 42px;
            height: 42px;
            border-radius: 13px;
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            font-size: .82rem;
            flex-shrink: 0;
        }

        .student-name {
            color: var(--edu-heading);
            font-size: .88rem;
            font-weight: 800;
            margin-bottom: .15rem;
        }

        .student-meta {
            color: var(--edu-muted);
            font-size: .72rem;
            font-weight: 600;
        }

        .student-bottom {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: .5rem;
            margin-top: .5rem;
        }

        .student-due {
            font-size: .78rem;
            font-weight: 800;
            color: var(--edu-danger);
        }

            .student-due.clear {
                color: var(--edu-success);
            }

        .student-progress {
            height: 5px;
            border-radius: 99px;
            background: #f1efe9;
            overflow: hidden;
            margin-top: .55rem;
        }

            .student-progress span {
                display: block;
                height: 100%;
                border-radius: 99px;
                background: linear-gradient(90deg, #5be49b, var(--edu-success));
            }

        .pill {
            display: inline-flex;
            align-items: center;
            gap: .25rem;
            padding: .22rem .55rem;
            border-radius: 999px;
            font-size: .64rem;
            font-weight: 800;
            letter-spacing: .02em;
            white-space: nowrap;
        }

        .pill-overdue  { background: var(--edu-danger-soft);  color: var(--edu-danger); }
        .pill-pending  { background: var(--edu-warning-soft); color: #b86f00; }
        .pill-partial  { background: var(--edu-info-soft);    color: #0796a8; }
        .pill-paid     { background: var(--edu-success-soft); color: var(--edu-success); }
        .pill-cycle    { background: var(--edu-primary-soft); color: var(--edu-primary); }
        .pill-neutral  { background: #f2f3f5;                 color: var(--edu-muted); }
        .pill-extra    { background: var(--edu-warning-soft); color: #b86f00; }
        .pill-advance  { background: var(--edu-success-soft); color: var(--edu-success); }
        .pill-void     { background: #f2f3f5;                 color: var(--edu-danger); }

        /* ───────────────────────── Counter hero ──────────────────── */
        .collection-hero {
            padding: 1.2rem;
            border-bottom: 1px solid var(--edu-border);
            background: linear-gradient(135deg, #fff3e2 0%, #fffaf2 55%, #ffffff 100%);
            position: relative;
            overflow: hidden;
        }

            .collection-hero::before {
                content: "";
                position: absolute;
                right: -70px;
                top: -70px;
                width: 220px;
                height: 220px;
                border-radius: 50%;
                background: radial-gradient(circle, rgba(255,138,0,.10), transparent 70%);
                pointer-events: none;
            }

        .selected-student {
            display: flex;
            gap: .95rem;
            align-items: center;
            margin-bottom: 1.05rem;
            position: relative;
        }

        .student-avatar {
            width: 60px;
            height: 60px;
            border-radius: 19px;
            background: linear-gradient(135deg, #ffb45c, var(--edu-primary));
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            font-size: 1.05rem;
            box-shadow: 0 12px 24px rgba(255, 138, 0, .30);
            border: 3px solid #fff;
            flex-shrink: 0;
        }

        .selected-name {
            color: var(--edu-heading);
            font-size: 1.1rem;
            font-weight: 800;
            margin-bottom: .15rem;
        }

        .selected-info {
            color: var(--edu-muted);
            font-size: .79rem;
            font-weight: 600;
        }

        .ledger-summary {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: .65rem;
            position: relative;
        }

        .ledger-box {
            background: rgba(255, 255, 255, .82);
            backdrop-filter: blur(3px);
            border: 1px solid rgba(255, 138, 0, .14);
            border-radius: 15px;
            padding: .8rem .85rem;
        }

        .ledger-label {
            color: var(--edu-muted);
            font-size: .68rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: .04em;
            margin-bottom: .3rem;
        }

        .ledger-value {
            color: var(--edu-heading);
            font-size: 1.05rem;
            font-weight: 800;
        }

            .ledger-value.success { color: var(--edu-success); }
            .ledger-value.danger  { color: var(--edu-danger); }

        /* ───────────────────────── Dues ──────────────────────────── */
        .collection-body {
            padding: 1.15rem;
        }

        .section-heading {
            color: var(--edu-heading);
            font-size: .9rem;
            font-weight: 800;
            margin-bottom: .75rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: .75rem;
            flex-wrap: wrap;
        }

        .section-note {
            color: var(--edu-muted);
            font-size: .73rem;
            font-weight: 600;
        }

        .due-toolbar {
            display: flex;
            gap: .4rem;
            flex-wrap: wrap;
        }

        .chip-btn {
            border: 1px solid var(--edu-border);
            background: #fff;
            color: var(--edu-muted);
            border-radius: 999px;
            padding: .32rem .7rem;
            font-size: .71rem;
            font-weight: 800;
            transition: .15s ease;
        }

            .chip-btn:hover {
                border-color: rgba(255, 138, 0, .5);
                color: var(--edu-primary);
                background: #fffaf5;
            }

        .due-item {
            display: grid;
            grid-template-columns: 26px minmax(0, 1fr) auto;
            gap: .75rem;
            align-items: center;
            padding: .8rem .85rem .8rem 1rem;
            border: 1px solid var(--edu-border);
            border-left: 4px solid var(--due-accent, var(--edu-border));
            border-radius: 14px;
            margin-bottom: .6rem;
            background: #fff;
            cursor: pointer;
            transition: .15s ease;
        }

            .due-item:hover {
                border-color: rgba(255, 138, 0, .4);
                border-left-color: var(--due-accent, var(--edu-primary));
                box-shadow: 0 8px 18px rgba(67, 89, 113, .07);
            }

            .due-item.checked {
                background: #fffaf3;
                border-color: rgba(255, 138, 0, .45);
                border-left-color: var(--edu-primary);
            }

            .due-item.acc-overdue { --due-accent: var(--edu-danger); }
            .due-item.acc-pending { --due-accent: var(--edu-warning); }
            .due-item.acc-partial { --due-accent: var(--edu-info); }

        .due-check {
            width: 19px;
            height: 19px;
            margin: 0;
            cursor: pointer;
        }

        .due-title {
            color: var(--edu-heading);
            font-size: .86rem;
            font-weight: 800;
            margin-bottom: .12rem;
        }

        .due-sub {
            color: var(--edu-muted);
            font-size: .71rem;
            font-weight: 600;
        }

        .due-badges {
            display: flex;
            flex-wrap: wrap;
            gap: .3rem;
            margin-top: .4rem;
        }

        .due-amount {
            color: var(--edu-heading);
            font-size: .95rem;
            font-weight: 800;
            text-align: right;
        }

        .due-small {
            color: var(--edu-muted);
            display: block;
            font-size: .67rem;
            font-weight: 600;
            margin-top: .1rem;
        }

        /* ───────────────────────── Payment card ──────────────────── */
        .payment-card {
            background: #fff;
            border: 1px solid var(--edu-border);
            border-radius: 18px;
            padding: 1.05rem;
            box-shadow: 0 6px 18px rgba(67, 89, 113, .05);
        }

        .collection-mode-pill {
            display: inline-flex;
            align-items: center;
            gap: .35rem;
            border-radius: 999px;
            padding: .3rem .65rem;
            font-size: .67rem;
            font-weight: 800;
            background: var(--edu-primary-soft);
            color: var(--edu-primary);
        }

            .collection-mode-pill.advance {
                background: var(--edu-success-soft);
                color: var(--edu-success);
            }

            .collection-mode-pill.partial {
                background: var(--edu-info-soft);
                color: var(--edu-info);
            }

        .mode-pills {
            display: flex;
            gap: .45rem;
            flex-wrap: wrap;
        }

        .mode-pill {
            flex: 1 1 auto;
            min-width: 76px;
            border: 1px solid #d9dee3;
            background: #fff;
            color: var(--edu-muted);
            border-radius: 12px;
            padding: .55rem .4rem;
            font-size: .73rem;
            font-weight: 800;
            text-align: center;
            transition: .15s ease;
        }

            .mode-pill i {
                display: block;
                font-size: 1.15rem;
                margin-bottom: .15rem;
            }

            .mode-pill:hover {
                border-color: rgba(255, 138, 0, .5);
                color: var(--edu-primary);
            }

            .mode-pill.active {
                border-color: var(--edu-primary);
                background: var(--edu-primary-soft);
                color: var(--edu-primary);
                box-shadow: 0 6px 14px rgba(255, 138, 0, .14);
            }

        .amount-input-group {
            position: relative;
        }

        .amount-prefix {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--edu-muted);
            font-size: 1.1rem;
            font-weight: 800;
            z-index: 2;
        }

        .amount-input {
            padding-left: 38px;
            font-size: 1.05rem;
            font-weight: 800;
            color: var(--edu-heading);
        }

        .advance-toggle {
            display: none;
            align-items: center;
            justify-content: space-between;
            gap: .75rem;
            border: 1px dashed rgba(40, 199, 111, .5);
            background: var(--edu-success-soft);
            border-radius: 14px;
            padding: .7rem .85rem;
            margin-top: .85rem;
        }

            .advance-toggle.show {
                display: flex;
            }

        .advance-toggle-label {
            font-size: .78rem;
            font-weight: 800;
            color: #1f8f55;
        }

        .advance-toggle-sub {
            font-size: .7rem;
            font-weight: 600;
            color: #1f8f55;
            opacity: .8;
        }

        .form-switch .form-check-input {
            width: 2.6em;
            height: 1.35em;
            cursor: pointer;
        }

            .form-switch .form-check-input:checked {
                background-color: var(--edu-success);
                border-color: var(--edu-success);
            }

        .soft-info-box {
            border-radius: 13px;
            padding: .72rem .85rem;
            font-size: .76rem;
            font-weight: 600;
            margin-top: .8rem;
            display: none;
            line-height: 1.45;
        }

            .soft-info-box.show {
                display: block;
            }

        .advance-info-box {
            background: #eefbf3;
            color: #1f8f55;
            border: 1px solid #d7f3e3;
        }

        .no-due-info-box {
            background: var(--edu-primary-soft);
            color: var(--edu-heading);
            border: 1px solid rgba(255, 138, 0, .18);
        }

        .partial-info-box {
            background: var(--edu-info-soft);
            color: #168090;
            border: 1px solid #cceff4;
        }

        .selected-dues-box {
            background: var(--edu-primary-soft);
            border: 1px solid rgba(255, 138, 0, .14);
            border-radius: 15px;
            padding: .85rem;
            margin-top: .85rem;
        }

            .selected-dues-box ul {
                margin: .45rem 0 0;
                padding-left: 1.1rem;
                color: var(--edu-text);
                font-size: .77rem;
                font-weight: 600;
            }

        .balance-box {
            background: linear-gradient(135deg, #fff7ed, #fffdfa);
            border: 1px solid rgba(255, 138, 0, .16);
            border-radius: 15px;
            padding: .9rem;
            margin-top: .8rem;
        }

        .balance-row {
            display: flex;
            justify-content: space-between;
            gap: .75rem;
            margin-bottom: .5rem;
            font-size: .78rem;
            font-weight: 800;
        }

            .balance-row:last-child {
                margin-bottom: 0;
            }

            .balance-row span {
                color: var(--edu-muted);
                font-weight: 800;
            }

            .balance-row strong {
                color: var(--edu-heading);
            }

            .balance-row.primary strong {
                color: var(--edu-primary);
                font-size: 1.02rem;
            }

            .balance-row.danger strong  { color: var(--edu-danger); }
            .balance-row.success strong { color: var(--edu-success); }

        .balance-divider {
            border-top: 1px dashed rgba(255, 138, 0, .3);
            margin: .55rem 0;
        }

        /* ───────────────────────── History ───────────────────────── */
        .history-item {
            border: 1px solid var(--edu-border);
            border-radius: 16px;
            padding: .9rem;
            background: #fff;
            margin-bottom: .7rem;
            transition: .18s ease;
        }

            .history-item:hover {
                border-color: rgba(255, 138, 0, .32);
                box-shadow: 0 8px 18px rgba(67, 89, 113, .06);
            }

            .history-item.voided {
                opacity: .62;
                background: #fbfbfb;
            }

                .history-item.voided .history-amount {
                    text-decoration: line-through;
                }

        .history-top {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: .75rem;
            margin-bottom: .5rem;
        }

        .history-mode-icon {
            width: 38px;
            height: 38px;
            border-radius: 12px;
            background: var(--edu-primary-soft);
            color: var(--edu-primary);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            flex-shrink: 0;
        }

        .receipt-no {
            color: var(--edu-primary);
            font-size: .71rem;
            font-weight: 800;
            margin-bottom: .15rem;
        }

        .history-amount {
            color: var(--edu-heading);
            font-size: 1rem;
            font-weight: 800;
        }

        .history-date {
            color: var(--edu-muted);
            font-size: .71rem;
            font-weight: 700;
            white-space: nowrap;
        }

        .history-desc {
            color: var(--edu-text);
            font-size: .77rem;
            font-weight: 600;
        }

        .history-actions {
            display: flex;
            gap: .45rem;
            margin-top: .7rem;
        }

        .icon-btn {
            width: 34px;
            height: 34px;
            border-radius: 11px;
            border: 1px solid var(--edu-border);
            background: #fff;
            color: var(--edu-primary);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: .15s ease;
        }

            .icon-btn:hover {
                background: var(--edu-primary-soft);
                border-color: rgba(255, 138, 0, .4);
            }

            .icon-btn.danger {
                color: var(--edu-danger);
            }

                .icon-btn.danger:hover {
                    background: var(--edu-danger-soft);
                    border-color: rgba(234, 84, 85, .4);
                }

        /* ───────────────────────── Empty state ───────────────────── */
        .empty-state {
            text-align: center;
            padding: 2rem 1rem;
            color: var(--edu-muted);
            font-weight: 700;
        }

            .empty-state i {
                font-size: 2.5rem;
                color: var(--edu-primary);
                margin-bottom: .6rem;
            }

            .empty-state h6 {
                color: var(--edu-heading);
                font-weight: 800;
                margin-bottom: .25rem;
            }

            .empty-state p {
                font-size: .8rem;
                margin: 0;
                font-weight: 600;
            }

        /* ───────────────────────── Modals ────────────────────────── */
        .modal-content {
            border: 0;
            border-radius: 22px;
            overflow: hidden;
            box-shadow: 0 22px 60px rgba(23, 33, 60, .22);
        }

        .modal-header {
            border-bottom: 1px solid var(--edu-border);
            padding: 1.1rem 1.25rem;
        }

        .modal-title {
            color: var(--edu-heading);
            font-weight: 800;
        }

        .modal-footer {
            border-top: 1px solid var(--edu-border);
            padding: 1rem 1.25rem;
        }

        .confirm-summary {
            background: #faf9f7;
            border: 1px solid var(--edu-border);
            border-radius: 16px;
            padding: .9rem;
        }

        .confirm-row {
            display: flex;
            justify-content: space-between;
            gap: 1rem;
            padding: .45rem 0;
            border-bottom: 1px solid var(--edu-border);
            font-size: .82rem;
            font-weight: 800;
        }

            .confirm-row:last-child {
                border-bottom: 0;
            }

            .confirm-row span {
                color: var(--edu-muted);
                font-weight: 800;
            }

            .confirm-row strong {
                color: var(--edu-heading);
            }

            .confirm-row.success strong { color: var(--edu-success); }
            .confirm-row.primary strong { color: var(--edu-primary); }
            .confirm-row.danger strong  { color: var(--edu-danger); }

        .confirm-note,
        .concession-help {
            border-radius: 14px;
            padding: .8rem .9rem;
            background: var(--edu-primary-soft);
            color: var(--edu-heading);
            border: 1px solid rgba(255, 138, 0, .18);
            font-size: .78rem;
            font-weight: 600;
            margin-top: .85rem;
            line-height: 1.45;
        }

        /* ───────────────────────── Receipt preview ───────────────── */
        .receipt-paper {
            border: 1px solid var(--edu-border);
            border-radius: 16px;
            background: #fff;
            padding: 1.25rem;
            font-size: .82rem;
            color: var(--edu-text);
        }

        .receipt-school {
            text-align: center;
            border-bottom: 2px dashed var(--edu-border);
            padding-bottom: .8rem;
            margin-bottom: .8rem;
        }

            .receipt-school h5 {
                color: var(--edu-heading);
                font-weight: 800;
                margin-bottom: .15rem;
            }

            .receipt-school small {
                color: var(--edu-muted);
                font-weight: 600;
            }

        .receipt-meta {
            display: flex;
            justify-content: space-between;
            gap: .75rem;
            flex-wrap: wrap;
            font-weight: 700;
            margin-bottom: .8rem;
        }

        .receipt-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: .8rem;
        }

            .receipt-table th,
            .receipt-table td {
                border: 1px solid var(--edu-border);
                padding: .45rem .6rem;
                font-size: .78rem;
            }

            .receipt-table th {
                background: #faf9f7;
                color: var(--edu-heading);
                font-weight: 800;
            }

        .receipt-totals {
            display: flex;
            flex-direction: column;
            gap: .3rem;
            align-items: flex-end;
            font-weight: 800;
        }

        .receipt-foot {
            border-top: 2px dashed var(--edu-border);
            margin-top: .9rem;
            padding-top: .7rem;
            display: flex;
            justify-content: space-between;
            color: var(--edu-muted);
            font-size: .72rem;
            font-weight: 600;
        }

        /* ───────────────────────── Per-due amount entry ──────────── */
        .due-pay-field {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            gap: .3rem;
            margin-top: .5rem;
        }

        .due-pay-label {
            color: var(--edu-muted);
            font-size: .68rem;
            font-weight: 800;
        }

        .due-pay-input {
            width: 88px;
            border: 1px solid #d9dee3;
            border-radius: 9px;
            padding: .3rem .5rem;
            font-size: .82rem;
            font-weight: 800;
            color: var(--edu-heading);
            text-align: right;
        }

            .due-pay-input:focus {
                outline: 0;
                border-color: #ffb866;
                box-shadow: 0 0 0 .15rem rgba(255, 138, 0, .12);
            }

        /* ───────────────────────── Sticky collect bar ────────────── */
        .sticky-collect-bar {
            position: sticky;
            bottom: 0;
            z-index: 20;
            display: none;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            margin: 1rem -1.15rem -1.15rem;
            padding: .85rem 1.15rem;
            background: rgba(255, 255, 255, .92);
            backdrop-filter: blur(8px);
            border-top: 1px solid var(--edu-border);
            box-shadow: 0 -8px 22px rgba(67, 89, 113, .08);
        }

            .sticky-collect-bar.show {
                display: flex;
            }

        .sticky-amount-label {
            color: var(--edu-muted);
            font-size: .7rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: .04em;
        }

        .sticky-amount-value {
            color: var(--edu-heading);
            font-size: 1.25rem;
            font-weight: 800;
            line-height: 1;
        }

        .sticky-collect-bar .btn-collect {
            margin: 0;
            width: auto;
            min-width: 200px;
        }

        /* ───────────────────────── Day-end summary ───────────────── */
        .daysum-total {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: .65rem;
            margin-bottom: 1rem;
        }

        .daysum-box {
            border: 1px solid var(--edu-border);
            border-radius: 15px;
            padding: .85rem;
            text-align: center;
        }

            .daysum-box.primary { background: var(--edu-primary-soft); border-color: rgba(255, 138, 0, .18); }
            .daysum-box.success { background: var(--edu-success-soft); border-color: rgba(40, 199, 111, .18); }

        .daysum-box .label {
            color: var(--edu-muted);
            font-size: .68rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: .04em;
        }

        .daysum-box .value {
            color: var(--edu-heading);
            font-size: 1.25rem;
            font-weight: 800;
            margin-top: .25rem;
        }

        .daysum-table {
            width: 100%;
            border-collapse: collapse;
        }

            .daysum-table th,
            .daysum-table td {
                padding: .55rem .7rem;
                font-size: .82rem;
                border-bottom: 1px solid var(--edu-border);
                text-align: left;
            }

            .daysum-table th {
                color: var(--edu-muted);
                font-weight: 800;
                text-transform: uppercase;
                font-size: .68rem;
                letter-spacing: .04em;
            }

            .daysum-table td.num,
            .daysum-table th.num {
                text-align: right;
            }

            .daysum-table tfoot td {
                font-weight: 800;
                color: var(--edu-heading);
                border-top: 2px solid var(--edu-border);
                border-bottom: 0;
            }

        .daysum-mode {
            display: inline-flex;
            align-items: center;
            gap: .4rem;
            font-weight: 700;
            color: var(--edu-heading);
        }

            .daysum-mode i {
                color: var(--edu-primary);
            }

        /* ───────────────────────── Duplicate receipt copies ──────── */
        .copy-tag {
            display: inline-block;
            background: var(--edu-primary-soft);
            color: var(--edu-primary);
            border: 1px solid rgba(255, 138, 0, .25);
            border-radius: 999px;
            padding: .15rem .65rem;
            font-size: .66rem;
            font-weight: 800;
            letter-spacing: .04em;
            margin-bottom: .6rem;
        }

        /* ───────────────────────── Responsive ────────────────────── */
        @@media(max-width: 1399px) {
            .main-grid {
                grid-template-columns: 300px minmax(0, 1fr);
            }

            .history-panel {
                grid-column: 1 / -1;
                min-height: auto;
            }

            .history-list {
                max-height: 380px;
            }
        }

        @@media(max-width: 991px) {
            .main-grid {
                grid-template-columns: 1fr;
            }

            .erp-panel {
                min-height: auto;
            }

            .student-list,
            .history-list {
                max-height: 360px;
            }

            .due-list {
                max-height: none;
            }

            .ledger-summary {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @@media(max-width: 575px) {
            .ledger-summary {
                grid-template-columns: 1fr;
            }

            .student-filter-row {
                grid-template-columns: 1fr;
            }

            .due-item {
                grid-template-columns: 26px minmax(0, 1fr);
            }

            .due-amount {
                grid-column: 2;
                text-align: left;
            }

            .selected-student {
                align-items: flex-start;
            }

            .mode-pill {
                min-width: 30%;
            }
        }
    </style>
}

<div class="container-fluid flex-grow-1 container-p-y">
<div class="ec-page-shell">
<div class="ec-page-content fee-page">

    <div class="ec-page-header fee-header-compact mb-3">
        <div class="ec-page-header-inner">
            <div class="d-flex align-items-center gap-2">
                <div class="ec-page-icon">
                    <i class="bx bx-wallet"></i>
                </div>
                <div>
                    <h4 class="ec-page-title mb-0">Fee Collection</h4>
                    <p class="ec-page-subtitle mb-0 d-none d-md-block">Operational fee counter — collect, concession, advance & receipts.</p>
                </div>
            </div>

            <div class="d-flex align-items-center gap-2 flex-wrap">
                <button type="button" class="btn btn-primary btn-premium btn-sm" id="dayEndBtn">
                    <i class="bx bx-bar-chart-alt-2 me-1"></i>
                    Day Summary
                </button>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-xl-3 col-md-6">
            <div class="kpi-card kpi-primary">
                <div class="kpi-top">
                    <div>
                        <div class="kpi-label">Collected Today</div>
                        <div class="kpi-value" id="collectedToday">₹0</div>
                        <div class="kpi-note"><span id="receiptsToday">0</span> receipts today</div>
                    </div>
                    <div class="kpi-icon"><i class="bx bx-rupee"></i></div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="kpi-card kpi-success">
                <div class="kpi-top">
                    <div>
                        <div class="kpi-label">Total Collected</div>
                        <div class="kpi-value" id="totalCollected">₹0</div>
                        <div class="kpi-note">All receipts, all students</div>
                    </div>
                    <div class="kpi-icon"><i class="bx bx-credit-card"></i></div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="kpi-card kpi-danger">
                <div class="kpi-top">
                    <div>
                        <div class="kpi-label">Total Pending Due</div>
                        <div class="kpi-value" id="totalPendingDue">₹0</div>
                        <div class="kpi-note"><span id="overdueStudents">0</span> students overdue</div>
                    </div>
                    <div class="kpi-icon"><i class="bx bx-calendar-exclamation"></i></div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="kpi-card kpi-info">
                <div class="kpi-top">
                    <div>
                        <div class="kpi-label">Advance Held</div>
                        <div class="kpi-value" id="totalAdvanceHeld">₹0</div>
                        <div class="kpi-note">Adjustable against future dues</div>
                    </div>
                    <div class="kpi-icon"><i class="bx bx-wallet-alt"></i></div>
                </div>
            </div>
        </div>
    </div>

    <div class="main-grid">

        <!-- ════════════ LEFT: STUDENTS ════════════ -->
        <div class="erp-panel">
            <div class="panel-header">
                <div>
                    <div class="panel-title">Students</div>
                    <div class="panel-subtitle">Search and select student ledger</div>
                </div>
                <span class="panel-count" id="studentCount">0</span>
            </div>

            <div class="panel-body">
                <div class="student-filter-row">
                    <select class="form-select" id="filterClass">
                        <option>All Classes</option>
                    </select>

                    <select class="form-select" id="filterSection">
                        <option>All Sections</option>
                    </select>
                </div>

                <div class="quick-filter-row" id="quickFilterRow">
                    <button type="button" class="quick-filter active" data-filter="All">All</button>
                    <button type="button" class="quick-filter" data-filter="Pending">Pending</button>
                    <button type="button" class="quick-filter" data-filter="Overdue">Overdue</button>
                    <button type="button" class="quick-filter" data-filter="Paid">Paid</button>
                </div>

                <div class="search-wrap">
                    <i class="bx bx-search"></i>
                    <input class="form-control" id="studentSearch" placeholder="Search name, admission no, parent...">
                    <span class="search-kbd">/</span>
                </div>

                <div class="student-list" id="studentList"></div>
            </div>
        </div>

        <!-- ════════════ CENTER: COLLECTION COUNTER ════════════ -->
        <div class="erp-panel">
            <div class="collection-hero">
                <div class="selected-student">
                    <div class="student-avatar" id="selectedAvatar">--</div>

                    <div class="flex-grow-1">
                        <div class="selected-name" id="selectedName">Select Student</div>
                        <div class="selected-info" id="selectedInfo">Student details will appear here</div>
                    </div>

                    <span class="pill pill-paid" id="selectedStatusPill">Active</span>
                </div>

                <div class="ledger-summary">
                    <div class="ledger-box">
                        <div class="ledger-label">Total Charges</div>
                        <div class="ledger-value" id="totalLedgerCharges">₹0</div>
                    </div>

                    <div class="ledger-box">
                        <div class="ledger-label">Paid So Far</div>
                        <div class="ledger-value success" id="paidSoFar">₹0</div>
                    </div>

                    <div class="ledger-box">
                        <div class="ledger-label">Pending Due</div>
                        <div class="ledger-value danger" id="pendingDue">₹0</div>
                    </div>

                    <div class="ledger-box">
                        <div class="ledger-label">Advance Balance</div>
                        <div class="ledger-value success" id="advanceBalance">₹0</div>
                    </div>
                </div>
            </div>

            <div class="collection-body">
                <div class="section-heading">
                    <span>Pending Ledger Dues</span>

                    <div class="due-toolbar">
                        <button type="button" class="chip-btn" id="selectAllDuesBtn"><i class="bx bx-check-double"></i> Select All</button>
                        <button type="button" class="chip-btn" id="clearDuesBtn"><i class="bx bx-x"></i> Clear</button>
                        <button type="button" class="chip-btn" id="openGlobalConcessionBtn"><i class="bx bx-purchase-tag-alt"></i> Concession</button>
                        <button type="button" class="chip-btn" data-bs-toggle="modal" data-bs-target="#extraChargeModal"><i class="bx bx-plus"></i> Extra Charge</button>
                    </div>
                </div>

                <div class="due-list" id="dueList"></div>

                <div class="payment-card">
                    <div class="section-heading mb-3">
                        <span>
                            <span id="paymentSectionTitle">Collect Payment</span>
                            <span class="collection-mode-pill ms-2" id="collectionModePill">
                                <i class="bx bx-list-check"></i>
                                Selected Dues
                            </span>
                        </span>

                        <span class="section-note">Payment date will use server timestamp</span>
                    </div>

                    <div class="soft-info-box no-due-info-box" id="noDueInfoBox">
                        <i class="bx bx-info-circle me-1"></i>
                        No dues selected. Payment will be treated as advance payment.
                    </div>

                    <div class="soft-info-box partial-info-box" id="partialInfoBox">
                        <i class="bx bx-info-circle me-1"></i>
                        Entered amount is less than selected dues. This will be recorded as a partial payment (oldest due adjusted first).
                    </div>

                    <div class="soft-info-box advance-info-box" id="advanceInfoBox">
                        <i class="bx bx-check-circle me-1"></i>
                        Extra amount will be stored as student advance balance and can be adjusted in future dues.
                    </div>

                    <div class="advance-toggle" id="advanceToggleBox">
                        <div>
                            <div class="advance-toggle-label"><i class="bx bx-wallet"></i> Use advance balance (<span id="advanceAvailableLabel">₹0</span>)</div>
                            <div class="advance-toggle-sub">Advance will be adjusted against selected dues before cash.</div>
                        </div>
                        <div class="form-check form-switch m-0">
                            <input class="form-check-input" type="checkbox" id="useAdvanceSwitch">
                        </div>
                    </div>

                    <div class="row g-3 mt-0">
                        <div class="col-12">
                            <label class="form-label required">Payment Mode</label>
                            <div class="mode-pills" id="modePills">
                                <button type="button" class="mode-pill active" data-mode="Cash"><i class="bx bx-money"></i>Cash</button>
                                <button type="button" class="mode-pill" data-mode="UPI"><i class="bx bx-qr-scan"></i>UPI</button>
                                <button type="button" class="mode-pill" data-mode="Card"><i class="bx bx-credit-card-front"></i>Card</button>
                                <button type="button" class="mode-pill" data-mode="Bank Transfer"><i class="bx bx-buildings"></i>Bank</button>
                                <button type="button" class="mode-pill" data-mode="Cheque"><i class="bx bx-notepad"></i>Cheque</button>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label required">Amount Collecting Now</label>
                            <div class="amount-input-group">
                                <span class="amount-prefix">₹</span>
                                <input type="number" class="form-control amount-input" id="paymentAmount" min="0">
                            </div>
                        </div>

                        <div class="col-md-6" id="referenceNoCol">
                            <label class="form-label" id="referenceNoLabel">Reference No</label>
                            <input class="form-control" id="paymentReferenceNo" placeholder="UPI / cheque / bank ref">
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Remarks</label>
                            <input class="form-control" id="paymentRemarks" placeholder="Optional note for receipt">
                        </div>
                    </div>

                    <div class="selected-dues-box">
                        <div class="d-flex justify-content-between gap-2">
                            <span class="section-note fw-bold">Collecting Against</span>
                            <span class="section-note" id="selectedDueCount">0 dues</span>
                        </div>
                        <ul id="selectedDuesSummary">
                            <li>No dues selected</li>
                        </ul>
                    </div>

                    <div class="balance-box">
                        <div class="balance-row primary">
                            <span>Selected Dues</span>
                            <strong id="selectedPayableAmount">₹0</strong>
                        </div>

                        <div class="balance-row">
                            <span>Concession Applied</span>
                            <strong id="concessionAppliedAmount">₹0</strong>
                        </div>

                        <div class="balance-row success" id="advanceUsedRow">
                            <span>Advance Adjusted</span>
                            <strong id="advanceUsedAmount">₹0</strong>
                        </div>

                        <div class="balance-row">
                            <span>Paying Now (Cash / Bank)</span>
                            <strong id="payingNowAmount">₹0</strong>
                        </div>

                        <div class="balance-divider"></div>

                        <div class="balance-row danger" id="remainingBalanceRow">
                            <span>Remaining Balance</span>
                            <strong id="remainingBalanceAmount">₹0</strong>
                        </div>

                        <div class="balance-row success" id="advanceAddedRow">
                            <span>Advance Added</span>
                            <strong id="advanceAddedAmount">₹0</strong>
