@{
    ViewData["Title"] = "Day Close";
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
}

@*
   Day Close / shift reconciliation — the logged-in cashier totals their day's
   collection mode-wise, sees expected cash (cash collected − cash refunded),
   enters the counted cash, and records the difference. core.sp_fee_day_*.
*@

@section PageStyles {
<link href="~/css/educore-theme.css" rel="stylesheet" />
<style>
.fee-day-page{ --suc:#28c76f;--suc-soft:#e8fadf;--dng:#ea5455;--dng-soft:#fdeceb;--amb:#ff9f43;--amb-soft:#fff1e0;--info:#00bad1;--info-soft:#dff7fa; color:var(--ec-text); }
.fee-day-page .kpis{ display:grid;grid-template-columns:repeat(4,1fr);gap:.85rem;margin-bottom:1.25rem; }
.fee-day-page .kpi{ border:1px solid var(--ec-border);border-radius:14px;padding:.9rem 1rem;background:#fff; }
.fee-day-page .kpi .l{ font-size:.66rem;font-weight:800;text-transform:uppercase;letter-spacing:.04em;color:var(--ec-text-muted);display:flex;align-items:center;gap:.35rem; }
.fee-day-page .kpi .v{ font-size:1.35rem;font-weight:950;color:var(--ec-text-dark);letter-spacing:-.02em;margin-top:.25rem;font-variant-numeric:tabular-nums; }
.fee-day-page .kpi.cash{ background:linear-gradient(135deg,var(--ec-primary-light),#fff);border-color:#ffc98a; } .fee-day-page .kpi.cash .v{ color:var(--ec-primary); }
.fee-day-page .kpi .ic{ width:24px;height:24px;border-radius:7px;display:inline-flex;align-items:center;justify-content:center;font-size:.85rem; }
.fee-day-page .mode-amt{ font-variant-numeric:tabular-nums;font-weight:800; }
.fee-day-page .recon-line{ display:flex;justify-content:space-between;align-items:center;padding:.5rem 0;font-weight:700; }
.fee-day-page .recon-line .v{ font-variant-numeric:tabular-nums; }
.fee-day-page .diff{ display:flex;justify-content:space-between;align-items:center;border-radius:12px;padding:.75rem 1rem;margin-top:.4rem;font-weight:900; }
.fee-day-page .diff.ok{ background:var(--suc-soft);color:#1f9254; } .fee-day-page .diff.short{ background:var(--dng-soft);color:#c4332f; } .fee-day-page .diff.over{ background:var(--amb-soft);color:#cc7a1f; }
.fee-day-page .closed-badge{ font-size:.7rem;font-weight:800;color:#1f9254;background:var(--suc-soft);padding:3px 10px;border-radius:999px; }
@@media (max-width:767.98px){ .fee-day-page .kpis{ grid-template-columns:repeat(2,1fr); } }
@@media print{ .no-print{ display:none!important; } .ec-page-shell{ box-shadow:none;border:0; } }
</style>
}

<div class="ec-page-shell fee-day-page">
  <div class="ec-page-content">

    <div class="ec-page-header">
      <div class="ec-page-header-inner">
        <div class="d-flex align-items-center gap-2">
          <div class="ec-page-icon"><i class="bx bx-lock-open-alt"></i></div>
          <div><h4 class="ec-page-title mb-1">Day Close</h4>
            <p class="ec-page-subtitle">Reconcile your day's collection and record the cash count</p></div>
        </div>
        <div class="d-flex gap-2 align-items-end no-print">
          <div><label class="form-label mb-1">Date</label><input type="date" id="dDate" class="form-control form-control-sm"></div>
          <a href="@Url.Action("ManageFee","Fee",new{area="ERP"})" class="btn btn-sm btn-outline-secondary"><i class="bx bx-wallet me-1"></i>Counter</a>
          <button id="btnPrint" class="btn btn-sm ec-btn-soft"><i class="bx bx-printer me-1"></i>Print</button>
        </div>
      </div>
    </div>

    <div id="closedNote" class="alert alert-success py-2 d-none"><i class="bx bx-check-circle me-1"></i><span id="closedText"></span></div>

    <!-- KPIs -->
    <div class="kpis">
      <div class="kpi"><div class="l"><span class="ic" style="background:var(--suc-soft);color:#1f9254"><i class="bx bx-rupee"></i></span>Collected</div><div class="v" id="kCollected">₹0</div></div>
      <div class="kpi"><div class="l"><span class="ic" style="background:#eef0f2;color:#6b7280"><i class="bx bx-receipt"></i></span>Receipts</div><div class="v" id="kReceipts">0</div></div>
      <div class="kpi"><div class="l"><span class="ic" style="background:var(--dng-soft);color:#c4332f"><i class="bx bx-money-withdraw"></i></span>Refunds out</div><div class="v" id="kRefunds">₹0</div></div>
      <div class="kpi cash"><div class="l"><span class="ic" style="background:#fff;color:var(--ec-primary)"><i class="bx bx-wallet"></i></span>Expected cash</div><div class="v" id="kExpected">₹0</div></div>
    </div>

    <div class="row g-4">
      <!-- mode-wise -->
      <div class="col-12 col-lg-6">
        <div class="ec-card"><div class="ec-card-header"><div class="ec-section-title-wrap">
          <div class="ec-section-icon"><i class="bx bx-credit-card"></i></div>
          <div><h6 class="ec-section-title">Collection by mode</h6><div class="ec-section-subtitle">Cancelled receipts excluded</div></div>
        </div></div>
          <div class="ec-card-body p-0">
            <div class="table-responsive"><table class="table ec-table mb-0">
              <thead><tr><th>Mode</th><th class="text-end">Receipts</th><th class="text-end">Amount</th></tr></thead>
              <tbody id="modeRows"></tbody>
            </table></div>
          </div>
        </div>
      </div>

      <!-- reconciliation -->
      <div class="col-12 col-lg-6">
        <div class="ec-card"><div class="ec-card-header"><div class="ec-section-title-wrap">
          <div class="ec-section-icon"><i class="bx bx-calculator"></i></div>
          <div class="d-flex align-items-center gap-2"><h6 class="ec-section-title mb-0">Cash reconciliation</h6><span id="closedBadge" class="closed-badge d-none">Closed</span></div>
        </div></div>
          <div class="ec-card-body">
            <div class="recon-line muted"><span>Cash collected</span><span class="v" id="rCashIn">₹0</span></div>
            <div class="recon-line muted"><span>Cash refunded</span><span class="v" id="rCashOut">−₹0</span></div>
            <div class="recon-line" style="border-top:1px dashed var(--ec-border)"><span>Expected in drawer</span><span class="v" id="rExpected">₹0</span></div>

            <div class="mt-3"><label class="form-label">Counted cash <span class="text-danger">*</span></label>
              <input type="number" min="0" id="counted" class="form-control" placeholder="Enter cash counted in drawer"></div>

            <div class="diff ok" id="diffBox"><span id="diffLabel">Difference</span><span id="diffVal">₹0</span></div>

            <div class="mt-3"><label class="form-label">Remarks</label><input type="text" id="remarks" class="form-control" placeholder="Optional note"></div>

            <button id="btnClose" class="btn btn-primary w-100 mt-3 no-print"><i class="bx bx-lock-alt me-1"></i>Close day</button>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

@Html.AntiForgeryToken()

@section PageScripts {
<script>
$(function () {
    'use strict';
    function money(n){ return '₹' + Math.round(Number(n||0)).toLocaleString('en-IN'); }
    function num(n){ n=Number(n); return isFinite(n)?n:0; }
    function esc(s){ return String(s==null?'':s).replace(/[&<>"]/g,function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c];}); }
    function notify(t,m){ if (typeof toastr!=='undefined') toastr[t](m); }

    var CSRF=$('input[name="__RequestVerificationToken"]').val();
    var URL={ get:'@Url.Action("GetDayCollection","Fee",new{area="ERP"})', close:'@Url.Action("CloseDay","Fee",new{area="ERP"})' };
    var expected=0;

    function todayStr(){ var d=new Date(); return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0'); }
    $('#dDate').val(todayStr());

    function load(){
        $.getJSON(URL.get,{date:$('#dDate').val()}).done(function(d){
            expected=num(d.expectedCash);
            $('#kCollected').text(money(d.totalCollected));
            $('#kReceipts').text(d.receiptCount + (d.cancelledCount>0?' (+'+d.cancelledCount+' cancelled)':''));
            $('#kRefunds').text(money(d.totalRefunded));
            $('#kExpected').text(money(d.expectedCash));
            $('#rCashIn').text(money(d.cashCollected));
            $('#rCashOut').text('−'+money(d.cashRefunded));
            $('#rExpected').text(money(d.expectedCash));

            var rows=(d.modes||[]);
            $('#modeRows').html(rows.length? rows.map(function(m){
                return '<tr><td class="fw-semibold">'+esc(m.mode)+'</td><td class="text-end text-muted">'+m.count+'</td><td class="text-end mode-amt">'+money(m.amount)+'</td></tr>';
            }).join('') : '<tr><td colspan="3" class="text-muted text-center py-4">No collection on this date.</td></tr>');

            // closed state
            if(d.isClosed){
                $('#counted').val(d.countedCash); $('#remarks').val(d.closeRemarks||'');
                $('#closedBadge').removeClass('d-none');
                $('#closedNote').removeClass('d-none'); $('#closedText').text('This day is already closed. Counted '+money(d.countedCash)+', difference '+money(d.difference)+'. Saving again updates it.');
                $('#btnClose').html('<i class="bx bx-refresh me-1"></i>Update close');
            } else {
                $('#counted').val(''); $('#closedBadge').addClass('d-none'); $('#closedNote').addClass('d-none');
                $('#btnClose').html('<i class="bx bx-lock-alt me-1"></i>Close day');
            }
            diff();
        }).fail(function(){ notify('error','Could not load the day collection.'); });
    }
    function diff(){
        var counted=num($('#counted').val()), d=counted-expected;
        $('#diffVal').text((d>0?'+':'')+money(d));
        var $b=$('#diffBox').removeClass('ok short over');
        $('#diffLabel').text(d===0?'Tallies' : (d<0?'Short by':'Excess'));
        $b.addClass(d===0?'ok':(d<0?'short':'over'));
    }
    $('#counted').on('input', diff);
    $('#dDate').on('change', load);
    $('#btnPrint').on('click', function(){ window.print(); });

    $('#btnClose').on('click', function(){
        var counted=$('#counted').val();
        if(counted===''||isNaN(Number(counted))){ notify('warning','Enter the counted cash.'); return; }
        var $btn=$(this), old=$btn.html(); $btn.prop('disabled',true).html('<i class="bx bx-loader-circle bx-spin"></i>');
        $.ajax({url:URL.close,type:'POST',contentType:'application/json',headers:{'RequestVerificationToken':CSRF},
                data:JSON.stringify({ date:$('#dDate').val(), countedCash:Number(counted), remarks:$('#remarks').val() })})
        .done(function(res){
            $btn.prop('disabled',false);
            if(!res||!res.success){ notify('error',(res&&res.message)||'Could not close.'); $btn.html(old); return; }
            notify('success',res.message||'Day closed.'); load();
        }).fail(function(){ $btn.prop('disabled',false).html(old); notify('error','Could not close the day.'); });
    });

    if (typeof toastr !== 'undefined') toastr.options = { closeButton:true, progressBar:true, positionClass:'toast-top-right', timeOut:3500 };
    load();
});
</script>
}
