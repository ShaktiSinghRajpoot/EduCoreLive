@using System.Linq
@using Microsoft.AspNetCore.Mvc.Rendering
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "New Admission";
    Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
}

@section PageStyles {
<link href="~/css/educore-theme.css" rel="stylesheet" />
<style>
.student-admission-page{
    --ec-primary:#ff8a00;--ec-primary-soft:#fff4e6;--ec-cream:#fff7ed;
    --ec-soft-bg:#f8f7f5;--ec-panel:#ffffff;--ec-border:#ececf5;
    --ec-heading:#2b1b12;--ec-text:#2b2c40;--ec-muted:#8b8175;--ec-label:#9a938b;
    color:var(--ec-text);
}
.student-admission-page .ec-card,.student-admission-page .ec-detail-box{transition:transform .2s ease,box-shadow .2s ease,border-color .2s ease;}
.student-admission-page .ec-card:hover,.student-admission-page .ec-detail-box:hover{transform:translateY(-2px);box-shadow:0 16px 34px rgba(43,27,18,.08);border-color:rgba(255,138,0,.22);}
.student-admission-page .ec-page-icon,.student-admission-page .ec-section-icon,.student-admission-page .ec-detail-icon{background:var(--ec-primary-soft);color:var(--ec-primary);}
.student-admission-page .btn-primary{background:linear-gradient(135deg,#ff8a00,#ff9f2f);border:0;color:#fff;border-radius:999px;font-weight:800;box-shadow:0 12px 24px rgba(255,138,0,.22);transition:transform .2s ease,box-shadow .2s ease;}
.student-admission-page .btn-primary:hover{color:#fff;transform:translateY(-1px);box-shadow:0 16px 30px rgba(255,138,0,.28);}
.student-admission-page .btn-outline-secondary{border-color:rgba(43,27,18,.14);color:var(--ec-text);background:#fff;border-radius:999px;font-weight:800;transition:all .2s ease;}
.student-admission-page .btn-outline-secondary:hover{background:var(--ec-primary-soft);border-color:rgba(255,138,0,.35);color:var(--ec-heading);}
.student-admission-page .form-label{color:var(--ec-label);font-size:.76rem;font-weight:800;letter-spacing:.01em;margin-bottom:.4rem;}
.student-admission-page .required::after{content:" *";color:#ea5455;}
.student-admission-page .form-control,.student-admission-page .form-select{border:1px solid var(--ec-border);border-radius:14px;min-height:46px;color:var(--ec-text);font-weight:650;font-size:.9rem;background-color:#fff;transition:border-color .2s ease,box-shadow .2s ease;}
.student-admission-page textarea.form-control{min-height:96px;}
.student-admission-page .form-control:focus,.student-admission-page .form-select:focus{border-color:rgba(255,138,0,.65);box-shadow:0 0 0 4px rgba(255,138,0,.13);}

.fee-preview-sidebar{position:sticky;top:1rem;background:linear-gradient(180deg,#ffffff,#fff7ed 100%);border:1px solid rgba(255,138,0,.18);border-radius:20px;box-shadow:0 18px 40px rgba(43,27,18,.08);}
.fee-total{font-size:clamp(1.8rem,4vw,2.45rem);line-height:1.1;font-weight:950;letter-spacing:-.04em;color:var(--ec-heading);}
.fee-empty{min-height:280px;display:flex;align-items:center;justify-content:center;flex-direction:column;text-align:center;color:var(--ec-muted);border:1px dashed rgba(255,138,0,.28);border-radius:20px;background:rgba(255,255,255,.72);padding:1.5rem;}
.fee-empty i{font-size:3rem;color:var(--ec-primary);margin-bottom:.75rem;}
.fee-empty h6{color:var(--ec-heading);font-weight:950;margin-bottom:.3rem;}
.fee-group-title{color:var(--ec-label);font-size:.72rem;text-transform:uppercase;letter-spacing:.08em;font-weight:950;margin:1rem 0 .55rem;}
.fee-row,.fee-check-row{border:1px solid var(--ec-border);border-radius:16px;background:rgba(255,255,255,.86);padding:.85rem;margin-bottom:.7rem;display:flex;justify-content:space-between;align-items:center;gap:.75rem;}
.fee-row small,.fee-check-row small{color:var(--ec-muted);font-weight:650;}
.fee-summary{background:#fff;border:1px solid rgba(255,138,0,.16);border-radius:18px;padding:1rem;margin-top:1rem;}
.summary-line{display:flex;justify-content:space-between;gap:1rem;font-size:.86rem;margin-bottom:.75rem;color:var(--ec-muted);}
.summary-line:last-child{margin-bottom:0;}
.summary-line strong{color:var(--ec-heading);font-weight:950;white-space:nowrap;}
.kit-meta{color:var(--ec-muted);font-size:.76rem;font-weight:650;}
.optional-chip{background:#e8f4fd;color:#0d6efd;border-radius:999px;font-size:.68rem;font-weight:800;padding:.2rem .6rem;}
.admission-footer-hint{color:var(--ec-muted);font-size:.8rem;font-weight:650;}
.adm-actions{padding:1rem 1.25rem;border-top:1px solid var(--ec-border);background:rgba(255,255,255,.92);}
@@media (max-width:991.98px){ .fee-preview-sidebar{position:static;} }
@@media (max-width:575.98px){
    .adm-actions{flex-direction:column;align-items:stretch !important;}
    .adm-actions .btn{width:100% !important;}
}
</style>
}

<div class="ec-page-shell student-admission-page">
  <div class="ec-page-content">

    <div class="ec-page-header">
      <div class="ec-page-header-inner">
        <div class="ec-page-title-wrap d-flex align-items-center gap-2">
          <div class="ec-page-icon rounded-4 d-flex align-items-center justify-content-center">
            <i class="bx bx-id-card fs-4"></i>
          </div>
          <div>
            <h4 class="ec-page-title mb-1">New Student Admission</h4>
            <div class="ec-page-subtitle">Select academic year and class to load the configured fee structure</div>
          </div>
        </div>
        <a asp-area="ERP" asp-controller="Student" asp-action="StudentList"
           class="btn btn-outline-secondary d-flex align-items-center gap-1">
          <i class="bx bx-arrow-back"></i><span>Back to Students</span>
        </a>
      </div>
    </div>

    <form id="admissionForm" novalidate>
        @Html.AntiForgeryToken()
        <input type="hidden" name="EnquiryId" id="adm_EnquiryId" value="@(ViewBag.PrefillEnquiryId ?? "")" />
        <div class="row g-4">

            <div class="col-12 col-lg-7">
                <div class="ec-detail-box mb-4">
                    <div class="d-flex gap-3 align-items-start">
                        <div class="ec-detail-icon rounded-4 d-flex align-items-center justify-content-center">
                            <i class="bx bx-info-circle fs-5"></i>
                        </div>
                        <div>
                            <div class="ec-detail-title">How admission &amp; fees work</div>
                            <div class="ec-detail-value text-muted">Admission creates the student record and sets up the full fee schedule. <strong>One-time charges are collected now</strong>; monthly &amp; yearly fees are billed later from the Fee module on their due dates — not paid upfront here.</div>
                        </div>
                    </div>
                </div>

                <div class="ec-card mb-4">
                    <div class="ec-card-header p-3 p-lg-4">
                        <div class="ec-section-title-wrap d-flex align-items-center gap-3">
                            <div class="ec-section-icon rounded-4 d-flex align-items-center justify-content-center"><i class="bx bx-user fs-5"></i></div>
                            <div><div class="ec-section-title">Student Details</div><div class="ec-section-subtitle">Identity and academic placement</div></div>
                        </div>
                    </div>
                    <div class="ec-card-body p-3 p-lg-4 pt-0">
                        <div class="row g-3">
                            <div class="col-12 col-md-6">
                                <label class="form-label">Admission No</label>
                                <input type="text" name="AdmissionNo" id="adm_AdmissionNo" class="form-control" placeholder="Leave blank to auto-generate (e.g. ADM-2026-0001)">
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label">Roll No</label>
                                <input type="text" name="RollNo" id="adm_RollNo" class="form-control" placeholder="Optional">
                            </div>
                            <div class="col-12">
                                <label class="form-label required">Student Full Name</label>
                                <input type="text" name="StudentName" id="adm_StudentName" class="form-control" placeholder="Enter full name" required>
                            </div>
                            <div class="col-12 col-md-4">
                                <label class="form-label required">Academic Year</label>
                                <select id="academicYearSelect" name="AcademicYear" class="form-select" required>
                                    <option value="">Select Year</option>
                                    @foreach (var s in (ViewBag.Sessions as IEnumerable<SelectListItem> ?? Enumerable.Empty<SelectListItem>()))
                                    {
                                        <option value="@s.Text" data-ayid="@s.Value" selected="@s.Selected">@s.Text</option>
                                    }
                                </select>
                            </div>
                            <div class="col-12 col-md-4">
                                <label class="form-label required">Class</label>
                                <select id="classSelect" name="ClassName" class="form-select" required>
                                    <option value="">Select Class</option>
                                    @foreach (var c in (ViewBag.Classes as IEnumerable<SelectListItem> ?? Enumerable.Empty<SelectListItem>()))
                                    {
                                        <option value="@c.Text">@c.Text</option>
                                    }
                                </select>
                            </div>
                            <div class="col-12 col-md-4">
                                <label class="form-label required">Section</label>
                                <select name="Section" id="adm_Section" class="form-select" required>
                                    <option value="">Select year &amp; class first</option>
                                </select>
                            </div>
                            <div class="col-12 col-md-4">
                                <label class="form-label required">Gender</label>
                                <select name="Gender" id="adm_Gender" class="form-select" required>
                                    <option value="">Select</option>
                                    <option>Male</option><option>Female</option><option>Other</option>
                                </select>
                            </div>
                            <div class="col-12 col-md-4">
                                <label class="form-label required">Date of Birth</label>
                                <input type="date" name="DateOfBirth" class="form-control" required>
                            </div>
                            <div class="col-12 col-md-4">
                                <label class="form-label required">Admission Date</label>
                                <input type="date" id="admissionDate" name="AdmissionDate" class="form-control" required>
                            </div>

                            <div class="col-12"><hr class="my-1 opacity-25"></div>
                            <div class="col-12 col-md-4">
                                <label class="form-label">Category</label>
                                <select name="Category" class="form-select">
                                    <option value="">Select</option>
                                    <option>General</option><option>OBC</option><option>SC</option><option>ST</option><option>EWS</option>
                                </select>
                            </div>
                            <div class="col-12 col-md-4">
                                <label class="form-label">Blood Group</label>
                                <select name="BloodGroup" class="form-select">
                                    <option value="">Select</option>
                                    <option>A+</option><option>A-</option><option>B+</option><option>B-</option>
                                    <option>O+</option><option>O-</option><option>AB+</option><option>AB-</option>
                                </select>
                            </div>
                            <div class="col-12 col-md-4">
                                <label class="form-label">Aadhaar / ID No</label>
                                <input type="text" name="IdProofNo" class="form-control" placeholder="Optional">
                            </div>
                            <div class="col-12 col-md-4">
                                <label class="form-label">Religion</label>
                                <input type="text" name="Religion" class="form-control" placeholder="Optional">
                            </div>
                            <div class="col-12 col-md-4">
                                <label class="form-label">Nationality</label>
                                <input type="text" name="Nationality" class="form-control" placeholder="e.g. Indian">
                            </div>
                            <div class="col-12 col-md-4">
                                <label class="form-label">Mother Tongue</label>
                                <input type="text" name="MotherTongue" class="form-control" placeholder="Optional">
                            </div>
                        </div>
                    </div>
                </div>

                <div class="ec-card mb-4">
                    <div class="ec-card-header p-3 p-lg-4">
                        <div class="ec-section-title-wrap d-flex align-items-center gap-3">
                            <div class="ec-section-icon rounded-4 d-flex align-items-center justify-content-center"><i class="bx bx-phone fs-5"></i></div>
                            <div><div class="ec-section-title">Parent &amp; Contact</div><div class="ec-section-subtitle">Guardian communication and address</div></div>
                        </div>
                    </div>
                    <div class="ec-card-body p-3 p-lg-4 pt-0">
                        <div class="row g-3">
                            <div class="col-12 col-md-6">
                                <label class="form-label required">Father / Guardian Name</label>
                                <input type="text" name="GuardianName" id="adm_GuardianName" class="form-control" placeholder="Enter parent name" required>
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label">Mother Name</label>
                                <input type="text" name="MotherName" class="form-control" placeholder="Optional">
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label required">Mobile Number</label>
                                <input type="tel" name="MobileNumber" id="adm_MobileNumber" maxlength="10" pattern="[0-9]{10}" class="form-control" placeholder="10 digit mobile" required>
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label">Alternate Mobile</label>
                                <input type="tel" name="AlternateMobile" maxlength="10" pattern="[0-9]{10}" class="form-control" placeholder="Optional">
                            </div>

                            <div class="col-12"><hr class="my-1 opacity-25"></div>
                            <div class="col-12 col-md-6">
                                <label class="form-label">Father Occupation</label>
                                <input type="text" name="FatherOccupation" class="form-control" placeholder="Optional">
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label">Father Qualification</label>
                                <input type="text" name="FatherQualification" class="form-control" placeholder="Optional">
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label">Mother Occupation</label>
                                <input type="text" name="MotherOccupation" class="form-control" placeholder="Optional">
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label">Mother Qualification</label>
                                <input type="text" name="MotherQualification" class="form-control" placeholder="Optional">
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label">Father Email</label>
                                <input type="email" name="FatherEmail" class="form-control" placeholder="Optional">
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label">Mother Email</label>
                                <input type="email" name="MotherEmail" class="form-control" placeholder="Optional">
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label">Annual Family Income (₹)</label>
                                <input type="number" min="0" step="1" name="AnnualIncome" class="form-control" placeholder="Used for concession / RTE">
                            </div>

                            <div class="col-12">
                                <label class="form-label required">Address</label>
                                <textarea name="Address" class="form-control" rows="3" placeholder="Complete address" required></textarea>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="ec-card mb-4">
                    <div class="ec-card-header p-3 p-lg-4">
                        <div class="ec-section-title-wrap d-flex align-items-center gap-3">
                            <div class="ec-section-icon rounded-4 d-flex align-items-center justify-content-center"><i class="bx bx-buildings fs-5"></i></div>
                            <div><div class="ec-section-title">Previous School</div><div class="ec-section-subtitle">Fill only for transfer / lateral admissions</div></div>
                        </div>
                    </div>
                    <div class="ec-card-body p-3 p-lg-4 pt-0">
                        <div class="row g-3">
                            <div class="col-12 col-md-6">
                                <label class="form-label">Previous School Name</label>
                                <input type="text" name="PrevSchoolName" class="form-control" placeholder="Optional">
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label">Board</label>
                                <input type="text" name="PrevBoard" class="form-control" placeholder="e.g. CBSE / ICSE / State">
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label">Last Class Attended</label>
                                <input type="text" name="PrevClass" class="form-control" placeholder="Optional">
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label">TC Number</label>
                                <input type="text" name="PrevTcNo" class="form-control" placeholder="Transfer Certificate no">
                            </div>
                        </div>
                    </div>
                </div>

                <div class="ec-card mb-4 mb-lg-0">
                    <div class="ec-card-header p-3 p-lg-4">
                        <div class="ec-section-title-wrap d-flex align-items-center gap-3">
                            <div class="ec-section-icon rounded-4 d-flex align-items-center justify-content-center"><i class="bx bx-folder-open fs-5"></i></div>
                            <div><div class="ec-section-title">Documents</div><div class="ec-section-subtitle">Tick what's collected at admission</div></div>
                        </div>
                    </div>
                    <div class="ec-card-body p-3 p-lg-4 pt-0">
                        <div class="kit-meta mb-2">File upload &amp; storage is a separate step — this records the collection checklist for now.</div>
                        <div class="row g-2" id="docChecklist">
                            <div class="col-12 col-md-6"><label class="fee-check-row" style="cursor:pointer;"><div class="d-flex gap-2 align-items-center"><input type="checkbox" class="form-check-input doc-chk" value="Birth Certificate"><div class="fw-bold" style="color:var(--ec-heading)">Birth Certificate</div></div></label></div>
                            <div class="col-12 col-md-6"><label class="fee-check-row" style="cursor:pointer;"><div class="d-flex gap-2 align-items-center"><input type="checkbox" class="form-check-input doc-chk" value="Aadhaar Card"><div class="fw-bold" style="color:var(--ec-heading)">Aadhaar Card</div></div></label></div>
                            <div class="col-12 col-md-6"><label class="fee-check-row" style="cursor:pointer;"><div class="d-flex gap-2 align-items-center"><input type="checkbox" class="form-check-input doc-chk" value="Transfer Certificate"><div class="fw-bold" style="color:var(--ec-heading)">Transfer Certificate</div></div></label></div>
                            <div class="col-12 col-md-6"><label class="fee-check-row" style="cursor:pointer;"><div class="d-flex gap-2 align-items-center"><input type="checkbox" class="form-check-input doc-chk" value="Previous Marksheet"><div class="fw-bold" style="color:var(--ec-heading)">Previous Marksheet</div></div></label></div>
                            <div class="col-12 col-md-6"><label class="fee-check-row" style="cursor:pointer;"><div class="d-flex gap-2 align-items-center"><input type="checkbox" class="form-check-input doc-chk" value="Passport Photos"><div class="fw-bold" style="color:var(--ec-heading)">Passport Photos</div></div></label></div>
                            <div class="col-12 col-md-6"><label class="fee-check-row" style="cursor:pointer;"><div class="d-flex gap-2 align-items-center"><input type="checkbox" class="form-check-input doc-chk" value="Address Proof"><div class="fw-bold" style="color:var(--ec-heading)">Address Proof</div></div></label></div>
                        </div>
                        <input type="hidden" name="DocumentsJson" id="documentsJson">
                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-5">
                <div class="ec-sidebar fee-preview-sidebar p-3 p-lg-4">
                    <div class="ec-profile-box mb-4">
                        <div class="d-flex align-items-center justify-content-between gap-3 flex-wrap">
                            <div>
                                <div class="ec-profile-subtitle">Collect at Admission</div>
                                <div class="fee-total" id="annualTotalText">₹0</div>
                                <div class="kit-meta mt-1" id="annualRefText">One-time charges due now</div>
                            </div>
                            <div class="ec-avatar rounded-4 d-flex align-items-center justify-content-center">
                                <i class="bx bx-wallet fs-4"></i>
                            </div>
                        </div>
                    </div>

                    <div id="feeContent">
                        <div class="fee-empty">
                            <i class="bx bx-wallet"></i>
                            <h6>Select Academic Year &amp; Class</h6>
                            <p class="mb-0">Configured fee structure will appear here.</p>
                        </div>
                    </div>

                    <div id="kitPanel" class="d-none">
                        <div class="fee-group-title d-flex align-items-center justify-content-between">
                            <span><i class="bx bx-package me-1"></i>Optional Store Add-ons</span>
                            <span class="optional-chip">Optional</span>
                        </div>
                        <div class="kit-meta mb-2" style="margin-top:-.25rem;">Inventory / store sale — added to today's collection, separate from school fees.</div>
                        <label class="fee-check-row" style="cursor:pointer;">
                            <div class="d-flex gap-2 align-items-start">
                                <input type="checkbox" class="form-check-input kit-checkbox mt-1" data-amount="650" name="SelectedKitItems" value="Uniform Set">
                                <div><div class="fw-bold" style="color:var(--ec-heading)">Uniform Set</div><small>Store item</small></div>
                            </div>
                            <strong>₹650</strong>
                        </label>
                        <label class="fee-check-row" style="cursor:pointer;">
                            <div class="d-flex gap-2 align-items-start">
                                <input type="checkbox" class="form-check-input kit-checkbox mt-1" data-amount="120" name="SelectedKitItems" value="Tie &amp; Belt">
                                <div><div class="fw-bold" style="color:var(--ec-heading)">Tie &amp; Belt</div><small>Uniform accessory</small></div>
                            </div>
                            <strong>₹120</strong>
                        </label>
                        <label class="fee-check-row" style="cursor:pointer;">
                            <div class="d-flex gap-2 align-items-start">
                                <input type="checkbox" class="form-check-input kit-checkbox mt-1" data-amount="80" name="SelectedKitItems" value="Diary">
                                <div><div class="fw-bold" style="color:var(--ec-heading)">School Diary</div><small>Store item</small></div>
                            </div>
                            <strong>₹80</strong>
                        </label>
                        <label class="fee-check-row" style="cursor:pointer;">
                            <div class="d-flex gap-2 align-items-start">
                                <input type="checkbox" class="form-check-input kit-checkbox mt-1" data-amount="60" name="SelectedKitItems" value="ID Card">
                                <div><div class="fw-bold" style="color:var(--ec-heading)">ID Card</div><small>Identity card charge</small></div>
                            </div>
                            <strong>₹60</strong>
                        </label>
                    </div>

                    <div id="concessionPanel" class="d-none">
                        <div class="fee-group-title">Concession / Discount</div>
                        <div class="fee-summary">
                            <div class="row g-2">
                                <div class="col-12 col-sm-6">
                                    <label class="form-label">Type</label>
                                    <select id="discountType" name="DiscountType" class="form-select">
                                        <option value="fixed">Fixed Amount</option>
                                        <option value="percentage">Percentage</option>
                                    </select>
                                </div>
                                <div class="col-12 col-sm-6">
                                    <label class="form-label">Value</label>
                                    <input type="number" id="discountValue" name="DiscountValue" class="form-control" value="0" min="0">
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Apply To</label>
                                    <select id="discountApplyTo" name="DiscountApplyTo" class="form-select">
                                        <option value="payToday">Pay Today Only</option>
                                        <option value="annual">Estimated Annual</option>
                                    </select>
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Reason</label>
                                    <input type="text" id="discountReason" name="DiscountReason" class="form-control" placeholder="Required if discount is applied">
                                </div>
                            </div>
                        </div>
                    </div>
                    @if (ViewBag.CollectFeeAtAdmission == true)
                    {
                    <div id="collectNowPanel" class="mt-2">
                        <div class="fee-group-title d-flex align-items-center justify-content-between">
                            <span><i class="bx bx-wallet me-1"></i>Collect Fee Now</span>
                            <div class="form-check form-switch m-0">
                                <input class="form-check-input" type="checkbox" id="collectFeeNow" name="CollectFeeNow" value="true" checked>
                            </div>
                        </div>
                        <div class="fee-summary" id="collectNowFields">
                            <div class="row g-2">
                                <div class="col-12 col-sm-6">
                                    <label class="form-label">Amount to Collect</label>
                                    <input type="number" min="0" step="1" id="paymentAmount" name="PaymentAmount" class="form-control" placeholder="0">
                                </div>
                                <div class="col-12 col-sm-6">
                                    <label class="form-label">Mode</label>
                                    <select id="paymentMode" name="PaymentMode" class="form-select">
                                        <option>Cash</option><option>UPI</option><option>Card</option>
                                        <option>Cheque</option><option>Bank Transfer</option>
                                    </select>
                                </div>
                                <div class="col-12" id="paymentRefRow">
                                    <label class="form-label">Reference No</label>
                                    <input type="text" id="paymentReference" name="PaymentReference" class="form-control" placeholder="Txn / cheque / UPI ref (optional)">
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Remarks</label>
                                    <input type="text" id="paymentRemarks" name="PaymentRemarks" class="form-control" placeholder="Optional">
                                </div>
                            </div>
                        </div>
                    </div>
                    }
                    <input type="hidden" id="ledgerJson" name="LedgerPreviewJson" />
                </div>
            </div>
        </div>

        <div class="ec-card mt-4">
            <div class="adm-actions d-flex flex-column flex-sm-row justify-content-between align-items-center gap-3">
                <div class="admission-footer-hint">
                    Saving creates the student record and initialises fee ledger rows.
                </div>
                <div class="d-flex flex-column flex-sm-row gap-2">
                    <a asp-area="ERP" asp-controller="Student" asp-action="StudentList"
                       class="btn btn-outline-secondary px-4">Cancel</a>
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bx bx-check me-1"></i>Save Admission
                    </button>
                </div>
            </div>
        </div>
    </form>

  </div>
</div>

@section PageScripts {
@{
    bool awEnableSec = ViewBag.EnableSecurityFee is bool sfb && sfb;
    decimal awSecAmt = awEnableSec && ViewBag.SecurityFeeAmount != null ? Convert.ToDecimal(ViewBag.SecurityFeeAmount) : 0m;
    var awSecAmtStr = awSecAmt.ToString(System.Globalization.CultureInfo.InvariantCulture);
}
<script>
/* =========================================================
   NEW ADMISSION (dedicated page)
   - loads fee structure + sections from master (AJAX)
   - posts the form via AJAX, then returns to the student list
========================================================= */
$(function () {
    'use strict';

    var $year       = $('#academicYearSelect');
    var $class      = $('#classSelect');
    var $section    = $('#adm_Section');
    var $admDate    = $('#admissionDate');
    var $feeBox     = $('#feeContent');
    var $annual     = $('#annualTotalText');
    var $annualRef  = $('#annualRefText');
    var $kit        = $('#kitPanel');
    var $concession = $('#concessionPanel');
    var $discType   = $('#discountType');
    var $discValue  = $('#discountValue');
    var $discApply  = $('#discountApplyTo');
    var $discReason = $('#discountReason');
    var $ledger     = $('#ledgerJson');
    var $form       = $('#admissionForm');

    var URL_FEES     = '@Url.Action("GetFeeStructure", "Admission", new { area = "ERP" })';
    var URL_SECTIONS = '@Url.Action("GetSections", "Admission", new { area = "ERP" })';
    var URL_SAVE     = '@Url.Action("SaveAdmission", "Admission", new { area = "ERP" })';
    var URL_LIST     = '@Url.Action("StudentList", "Student", new { area = "ERP" })';

    var fees = [];   // fee rows for the selected class + year
    var SECURITY_FEE = @awSecAmtStr;   // one-time security deposit from workflow settings (0 = disabled)

    function money(n) { return '₹' + Math.round(Number(n || 0)).toLocaleString('en-IN'); }

    // School-level one-time security deposit, injected as a synthetic due-now fee head.
    function injectSecurityFee() {
        if (SECURITY_FEE > 0) {
            fees.unshift({
                id: null, name: 'Security Deposit', group: 'One Time Payable Now',
                cycle: 'One Time', stage: 'Admission', amount: SECURITY_FEE,
                mandatory: true, selected: true, isSecurity: true
            });
        }
    }
    function notify(type, msg) { if (typeof toastr !== 'undefined') toastr[type](msg); }

    /* ── sections: configured per class + year in Academic Setup ── */
    function loadSections() {
        var ayid = $year.find('option:selected').data('ayid');
        var cls = $class.val();

        if (!ayid || !cls) {
            $section.html('<option value="">Select year &amp; class first</option>');
            return;
        }
        $section.html('<option value="">Loading…</option>');
        $.getJSON(URL_SECTIONS, { academicYearId: ayid, className: cls })
            .done(function (res) {
                var secs = (res && res.sections) || [];
                if (!secs.length) {
                    $section.html('<option value="">No sections configured</option>');
                    return;
                }
                var html = '<option value="">Select Section</option>';
                $.each(secs, function (_, s) { html += '<option value="' + s + '">' + s + '</option>'; });
                $section.html(html);
            })
            .fail(function () { $section.html('<option value="">Select Section</option>'); });
    }

    /* ── fee preview ─────────────────────────────────── */
    function showEmptyFees() {
        fees = [];
        $annual.text('₹0');
        $annualRef.text('One-time charges due now');
        $kit.addClass('d-none');
        $concession.addClass('d-none');
        $ledger.val('');
        $feeBox.html('<div class="fee-empty"><i class="bx bx-wallet"></i><h6>Select Year &amp; Class</h6><p class="mb-0">Fee structure will appear here.</p></div>');
    }

    function loadFees() {
        var yr = $year.val(), cls = $class.val();
        if (!yr || !cls) { showEmptyFees(); return; }

        $feeBox.html('<div class="fee-empty"><i class="bx bx-loader-circle bx-spin"></i><h6>Loading fee structure…</h6></div>');
        $.getJSON(URL_FEES, { className: cls, academicYear: yr })
            .done(function (res) {
                if (!res || !res.success || !res.fees || !res.fees.length) {
                    fees = [];
                    $annual.text('₹0');
                    $annualRef.text('One-time charges due now');
                    $kit.addClass('d-none');
                    $concession.addClass('d-none');
                    $ledger.val('');
                    $feeBox.html('<div class="fee-empty"><i class="bx bx-error-circle"></i><h6>No Fee Structure</h6><p class="mb-0">' + ((res && res.message) || 'Configure fee structure for this class first.') + '</p></div>');
                    return;
                }
                fees = $.map(res.fees, function (f) {
                    return {
                        id: f.feeHeadId, name: f.feeHeadName, group: f.group,
                        cycle: f.frequency, stage: f.stage,
                        amount: Number(f.amount || 0),
                        mandatory: f.mandatory !== false, selected: true
                    };
                });
                injectSecurityFee();
                $kit.removeClass('d-none');
                $concession.removeClass('d-none');
                renderFees();
            })
            .fail(function () {
                fees = [];
                $ledger.val('');
                $feeBox.html('<div class="fee-empty"><i class="bx bx-error-circle"></i><h6>Error</h6><p class="mb-0">Could not load fee structure. Please try again.</p></div>');
            });
    }

    /* ── discount + summary ──────────────────────────── */
    function discountOn(base) {
        var v = Number($discValue.val() || 0);
        if (v <= 0) return 0;
        if ($discType.val() === 'percentage') return Math.round((base * Math.min(v, 100)) / 100);
        return Math.min(v, base);
    }
    function kitTotal() {
        var t = 0;
        $('.kit-checkbox:checked').each(function () { t += Number($(this).data('amount') || 0); });
        return t;
    }

    function renderFees() {
        if (!fees.length) { showEmptyFees(); return; }

        // Render a single fee line. One-time rows are "due now"; recurring rows
        // are shown muted because they are scheduled, not collected at admission.
        function rowHtml(fee, idx, muted) {
            var per = fee.cycle === 'Monthly' ? '/mo' : (fee.stage === 'Yearly' ? '/yr' : '');
            var amt = '<strong>' + money(fee.amount) + per + '</strong>';
            var sub = fee.cycle + (muted ? ' · billed later' : ' · due now');
            if (!fee.mandatory) {
                return '<div class="fee-check-row"><div class="d-flex gap-2">' +
                    '<input class="form-check-input optional-fee-checkbox" type="checkbox" data-index="' + idx + '" ' + (fee.selected ? 'checked' : '') + '>' +
                    '<div><div class="fw-bold" style="color:var(--ec-heading)">' + fee.name + '</div><small>' + sub + '</small></div>' +
                    '</div>' + amt + '</div>';
            }
            if (!fee.selected) return '';
            return '<div class="fee-row"' + (muted ? ' style="opacity:.72;"' : '') + '><div><div class="fw-bold" style="color:var(--ec-heading)">' + fee.name + '</div><small>' + sub + '</small></div>' + amt + '</div>';
        }

        var oneTimeRows = '', recurringRows = '';
        $.each(fees, function (idx, fee) {
            if (fee.stage === 'Admission') oneTimeRows += rowHtml(fee, idx, false);
            else recurringRows += rowHtml(fee, idx, true);
        });

        var html = '';
        if (oneTimeRows) {
            html += '<div><div class="fee-group-title"><i class="bx bx-time-five me-1"></i>Due Now — One-Time</div>' +
                '<div class="kit-meta mb-2" style="margin-top:-.35rem;">Collected at admission.</div>' +
                oneTimeRows + '</div>';
        }
        if (recurringRows) {
            html += '<div><div class="fee-group-title"><i class="bx bx-calendar me-1"></i>Scheduled — Billed Later</div>' +
                '<div class="kit-meta mb-2" style="margin-top:-.35rem;">Set up as the fee schedule. Collected each cycle from the Fee module — not now.</div>' +
                recurringRows + '</div>';
        }

        var payNow = 0, monthly = 0, yearly = 0, annual = 0;
        $.each(fees, function (_, f) {
            if (!f.selected) return;
            annual += (f.cycle === 'Monthly' ? f.amount * 12 : f.amount);
            if (f.stage === 'Admission') payNow += f.amount;
            if (f.stage === 'Monthly') monthly += f.amount;
            if (f.stage === 'Yearly') yearly += f.amount;
        });

        var kit = kitTotal();
        var applyTo = $discApply.val();
        var disc = discountOn(applyTo === 'annual' ? annual : payNow);
        // Pay-today = one-time fees + optional store add-ons − concession (if applied here).
        var payToday = payNow + kit - (applyTo === 'payToday' ? disc : 0);
        // Estimated annual = school fees for the year (store kit is not a recurring fee).
        var estAnnual = annual - (applyTo === 'annual' ? disc : 0);

        var summary = '<div class="fee-summary">' +
            '<div class="fee-group-title" style="margin:0 0 .5rem;">Due at Admission</div>' +
            '<div class="summary-line"><span>One-Time Fees</span><strong>' + money(payNow) + '</strong></div>';
        if (kit > 0) summary += '<div class="summary-line"><span>Store Add-ons</span><strong>' + money(kit) + '</strong></div>';
        if (applyTo === 'payToday' && disc > 0) summary += '<div class="summary-line"><span>Concession</span><strong>- ' + money(disc) + '</strong></div>';
        summary += '<hr class="opacity-25"><div class="summary-line"><span style="color:var(--ec-heading);font-weight:950;">Collect at Admission</span><strong style="color:var(--ec-primary);">' + money(payToday) + '</strong></div>';
        summary += '<div class="fee-group-title" style="margin:1rem 0 .5rem;">Scheduled — Billed Later</div>' +
            '<div class="summary-line"><span>Monthly</span><strong>' + money(monthly) + '/mo</strong></div>' +
            '<div class="summary-line"><span>Yearly</span><strong>' + money(yearly) + '/yr</strong></div>';
        if (applyTo === 'annual' && disc > 0) summary += '<div class="summary-line"><span>Concession</span><strong>- ' + money(disc) + '</strong></div>';
        summary += '<div class="summary-line"><span>Estimated Annual Fee</span><strong>' + money(estAnnual) + '</strong></div>' +
            '</div>';
        html += summary;

        $annual.text(money(payToday));
        $annualRef.text('Est. annual fee ' + money(estAnnual) + ' · billed through the year');
        $feeBox.html(html);

        // Default "Amount to Collect" to Pay Today (until the user edits it).
        if ($('#paymentAmount').length && !window._payEdited) {
            $('#paymentAmount').val(Math.round(payToday));
        }

        $ledger.val(JSON.stringify({
            academicYear: $year.val(),
            className: $class.val(),
            admissionDate: $admDate.val(),
            selectedFees: $.map(fees, function (f) {
                return f.selected
                    ? { feeHeadId: f.id, feeHeadName: f.name, frequency: f.cycle, amount: f.amount, mandatory: f.mandatory }
                    : null;
            }),
            selectedKitItems: $('.kit-checkbox:checked').map(function () {
                return { name: $(this).val(), amount: Number($(this).data('amount') || 0) };
            }).get(),
            concession: {
                type: $discType.val(), value: Number($discValue.val() || 0),
                applyTo: applyTo, calculatedAmount: disc, reason: $discReason.val() || ''
            },
            summary: { payToday: payToday, monthlyRecurring: monthly, yearlyScheduled: yearly, estimatedAnnual: estAnnual }
        }));
    }

    /* ── events ──────────────────────────────────────── */
    $year.add($class).on('change', function () { loadFees(); loadSections(); });
    $admDate.add($discType).add($discApply).on('change', renderFees);
    $discValue.add($discReason).on('input', renderFees);
    $(document).on('change', '.kit-checkbox', renderFees);
    $feeBox.on('change', '.optional-fee-checkbox', function () {
        fees[Number($(this).data('index'))].selected = this.checked;
        renderFees();
    });

    /* ── Collect Now (only present when the school enables it) ── */
    $('#paymentAmount').on('input', function () { window._payEdited = true; });
    $('#collectFeeNow').on('change', function () {
        $('#collectNowFields').toggle(this.checked);
    });
    $('#paymentMode').on('change', function () {
        // Reference is only meaningful for non-cash modes.
        $('#paymentRefRow').toggle($(this).val() !== 'Cash');
    }).trigger('change');

    /* ── submit (AJAX) ───────────────────────────────── */
    $form.on('submit', function (e) {
        e.preventDefault();

        if (!this.checkValidity()) { $form.addClass('was-validated'); return; }
        if (Number($discValue.val() || 0) > 0 && !$.trim($discReason.val())) {
            $discReason.focus();
            notify('error', 'Please enter a concession reason.');
            return;
        }
        if (!$ledger.val()) {
            if (!$year.val() || !$class.val()) {
                notify('error', 'Please select Academic Year and Class.');
            } else {
                notify('error', 'No fee structure is configured for ' + $class.val() + ' (' + $year.val() + '). Set it up under School Settings → Fee Structure first.');
            }
            return;
        }

        // Documents checklist → [{name, status}] for every listed document.
        $('#documentsJson').val(JSON.stringify($('.doc-chk').map(function () {
            return { name: $(this).val(), status: this.checked ? 'Collected' : 'Pending' };
        }).get()));

        var $btn = $form.find('button[type="submit"]');
        var oldHtml = $btn.html();
        $btn.prop('disabled', true).html('<i class="bx bx-loader-circle bx-spin me-1"></i>Saving…');

        $.ajax({
            url: URL_SAVE,
            type: 'POST',
            data: new FormData(this),
            processData: false,
            contentType: false,
            headers: { 'RequestVerificationToken': $form.find('input[name="__RequestVerificationToken"]').val() }
        })
        .done(function (res) {
            if (res && res.success) {
                var msg = 'Admission ' + (res.admissionNo || '') + ' saved.';
                if (res.receiptNo) msg += ' Receipt ' + res.receiptNo + ' generated.';
                notify('success', msg);
                // Hand off to the student list (it will re-fetch the fresh record).
                setTimeout(function () { window.location.href = URL_LIST; }, 900);
            } else {
                notify('error', (res && res.message) || 'Unable to save admission.');
                $btn.prop('disabled', false).html(oldHtml);
            }
        })
        .fail(function () {
            notify('error', 'Something went wrong while saving.');
            $btn.prop('disabled', false).html(oldHtml);
        });
    });

    if (typeof toastr !== 'undefined') {
        toastr.options = { closeButton: true, progressBar: true, positionClass: 'toast-top-right', timeOut: 3000 };
    }

    showEmptyFees();

    /* ── prefill from a converted enquiry ────────────── */
@if (ViewBag.PrefillJson != null)
{
    <text>
    (function () {
        try {
            var p = @Html.Raw(ViewBag.PrefillJson);
            $('#adm_StudentName').val(p.studentName || '');
            $('#adm_GuardianName').val(p.guardianName || '');
            $('#adm_MobileNumber').val(p.mobile || '');
            if (p.gender) $('#adm_Gender').val(p.gender);
            if (p.className) $class.val(p.className);
            if (p.academicYear) $year.val(p.academicYear);
            if (p.enquiryId) $('#adm_EnquiryId').val(p.enquiryId);
            if ($class.val() && $year.val()) { loadFees(); loadSections(); }
        } catch (e) { }
    })();
    </text>
}
});
</script>
}
