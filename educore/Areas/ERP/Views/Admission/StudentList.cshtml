@section PageScripts {
<script>
/* =========================================================
   STUDENT LIST — search / filter / sort / paginate
   Data is fetched once from the server, then handled in the
   browser (client-side filtering & paging).
========================================================= */
$(function () {
    'use strict';

    var students = [];   // full set from server
    var filtered = [];   // after filters
    var page = 1, perPage = 10, sortCol = null, sortDir = 'asc';

    var COLORS = ['primary', 'info', 'success', 'warning', 'danger', 'secondary'];
    var MONTHS = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
    var URL_STUDENTS  = '@Url.Action("GetStudentsData", "Admission", new { area = "ERP" })';
    var URL_DASHBOARD = '@Url.Action("Dashboard", "Admission", new { area = "ERP" })';

    /* ── helpers ─────────────────────────────────────── */
    function fmtDate(d) {
        var x = new Date(d);
        if (isNaN(x.getTime())) return '—';
        return String(x.getDate()).padStart(2, '0') + ' ' + MONTHS[x.getMonth()] + ' ' + x.getFullYear();
    }
    function initials(name) {
        return (name || '').split(' ').slice(0, 2).map(function (w) { return w.charAt(0); }).join('').toUpperCase();
    }
    function feeBadge(v) {
        var map = { Paid: 'b-paid', Partial: 'b-partial', Pending: 'b-pending' };
        return '<span class="sl-bdg ' + (map[v] || 'b-pending') + '">' + v + '</span>';
    }
    function statusBadge(v) {
        var map = { Active: 'b-active', Inactive: 'b-inactive', Transfer: 'b-transfer' };
        return '<span class="sl-bdg ' + (map[v] || 'b-inactive') + '">' + v + '</span>';
    }
    function genderHtml(g) {
        var map = { Male: ['gm', 'bx-male'], Female: ['gf', 'bx-female'], Other: ['go', 'bx-user'] };
        var c = map[g] || map.Other;
        return '<span class="sl-gen ' + c[0] + '"><i class="bx ' + c[1] + '"></i>' + (g || '—') + '</span>';
    }
    function attendHtml(p) {
        var cls = p >= 75 ? 'att-hi' : (p >= 50 ? 'att-mi' : 'att-lo');
        return '<div class="sl-att ' + cls + '"><div class="sl-att-b"><div class="sl-att-f" style="width:' + p + '%"></div></div><span class="sl-att-p">' + p + '%</span></div>';
    }
    function toast(type, msg) { if (typeof toastr !== 'undefined') toastr[type](msg); }
    function dashUrl(id) { return URL_DASHBOARD + '/' + id; }

    /* ── load from server ────────────────────────────── */
    function loadStudents() {
        $.getJSON(URL_STUDENTS, { pageSize: 1000 })
            .done(function (res) {
                var rows = (res && res.success && res.rows) ? res.rows : [];
                students = $.map(rows, function (s) {
                    return {
                        id:       s.studentId,
                        name:     s.studentName,
                        roll:     s.rollNo || s.admissionNo,
                        cls:      s.className,
                        sec:      s.section || '',
                        gender:   s.gender || '',
                        admDate:  s.admissionDate || '',
                        guardian: s.guardianName || '—',
                        phone:    s.mobile || '—',
                        feeSt:    s.feeStatus || 'Pending',
                        status:   s.status || 'Active',
                        attend:   0,
                        admYear:  parseInt(String(s.academicYear || '0').slice(0, 4)) || 0,
                        color:    COLORS[(s.studentId || 0) % COLORS.length]
                    };
                });
                applyFilters();
            })
            .fail(function () { students = []; applyFilters(); });
    }

    /* ── filter ──────────────────────────────────────── */
    function applyFilters() {
        var q   = $.trim($('#slSearch').val()).toLowerCase();
        var cls = $('#fClass').val();
        var gen = $('#fGender').val();
        var fee = $('#fFee').val();
        var yr  = $('#fYear').val();

        filtered = $.grep(students, function (s) {
            var matchText = !q
                || s.name.toLowerCase().indexOf(q) > -1
                || s.roll.toLowerCase().indexOf(q) > -1
                || s.cls.toLowerCase().indexOf(q) > -1;
            return matchText
                && (!cls || s.cls === cls)
                && (!gen || s.gender === gen)
                && (!fee || s.feeSt === fee)
                && (!yr  || s.admYear === parseInt(yr));
        });

        $.each(['fClass', 'fGender', 'fFee', 'fYear'], function (_, id) {
            $('#' + id).toggleClass('active-filter', $('#' + id).val() !== '');
        });
        $('#clearBtn').toggleClass('d-none', !(q || cls || gen || fee || yr));

        updateCards();
        page = 1;
        render();
    }

    function updateCards() {
        var src = filtered.length ? filtered : students;
        $('#sumTotal').text(src.length);
        $('#sumMale').text($.grep(src, function (s) { return s.gender === 'Male'; }).length);
        $('#sumFemale').text($.grep(src, function (s) { return s.gender === 'Female'; }).length);
        $('#sumActive').text($.grep(src, function (s) { return s.status === 'Active'; }).length);
    }

    /* ── sort ────────────────────────────────────────── */
    function sortRows(list) {
        if (!sortCol) return list;
        return list.slice().sort(function (a, b) {
            var va = a[sortCol], vb = b[sortCol];
            if (sortCol === 'admDate') { va = new Date(va); vb = new Date(vb); }
            if (va < vb) return sortDir === 'asc' ? -1 : 1;
            if (va > vb) return sortDir === 'asc' ? 1 : -1;
            return 0;
        });
    }
    function updateSortIcons() {
        $.each(['name', 'admDate', 'attend'], function (_, col) {
            var $i = $('#si-' + col);
            if (!$i.length) return;
            $i.attr('class', col === sortCol
                ? 'bx ' + (sortDir === 'asc' ? 'bx-sort-up' : 'bx-sort-down') + ' sl-si sl-si-on'
                : 'bx bx-sort sl-si');
        });
    }

    /* ── render ──────────────────────────────────────── */
    function render() {
        var sorted = sortRows(filtered);
        var total = sorted.length;

        var perVal = $('#perPage').val();
        perPage = (perVal === 'all') ? (total || 1) : parseInt(perVal);

        var pages = Math.ceil(total / perPage) || 1;
        if (page > pages) page = pages;
        if (page < 1) page = 1;

        var start = (page - 1) * perPage;
        var end = Math.min(start + perPage, total);
        var slice = sorted.slice(start, end);

        renderDesktop(slice);
        renderMobile(slice);
        renderPagination(pages, total, start, end);

        $('#resultText').text(total
            ? 'Showing ' + (start + 1) + '–' + end + ' of ' + total + ' students'
            : 'No students found');
    }

    function renderDesktop(rows) {
        if (!rows.length) {
            $('#tblBody').empty();
            $('#emptyDesk').removeClass('d-none');
            $('#pgWrap').addClass('d-none');
            return;
        }
        $('#emptyDesk').addClass('d-none');
        $('#pgWrap').removeClass('d-none');

        var html = $.map(rows, function (s) {
            return '<tr>' +
                '<td onclick="event.stopPropagation()"><input type="checkbox" class="form-check-input" data-id="' + s.id + '"></td>' +
                '<td>' +
                    '<a href="' + dashUrl(s.id) + '" class="d-flex align-items-center gap-2 text-decoration-none">' +
                        '<span class="sl-av bg-label-' + s.color + ' text-' + s.color + '">' + initials(s.name) + '</span>' +
                        '<div><div class="sl-nm">' + s.name + '</div><div class="sl-rl">' + s.roll + '</div></div>' +
                    '</a>' +
                '</td>' +
                '<td><span class="fw-bold">' + s.cls + '</span> <span class="text-muted">– ' + s.sec + '</span></td>' +
                '<td>' + genderHtml(s.gender) + '</td>' +
                '<td>' + fmtDate(s.admDate) + '</td>' +
                '<td>' + s.guardian + '</td>' +
                '<td>' + s.phone + '</td>' +
                '<td>' + feeBadge(s.feeSt) + '</td>' +
                '<td>' + attendHtml(s.attend) + '</td>' +
                '<td>' + statusBadge(s.status) + '</td>' +
                '<td><a href="' + dashUrl(s.id) + '" class="sl-view-btn"><i class="bx bx-layout"></i>Dashboard</a></td>' +
            '</tr>';
        }).join('');
        $('#tblBody').html(html);
    }

    function renderMobile(rows) {
        if (!rows.length) {
            $('#mobList').empty();
            $('#emptyMob').removeClass('d-none');
            return;
        }
        $('#emptyMob').addClass('d-none');

        var html = $.map(rows, function (s) {
            return '<div class="sl-mob-card">' +
                '<div class="sl-mob-top">' +
                    '<span class="sl-mob-av bg-label-' + s.color + ' text-' + s.color + '">' + initials(s.name) + '</span>' +
                    '<div class="flex-grow-1"><div class="sl-nm">' + s.name + '</div><div class="sl-rl">' + s.roll + ' · ' + s.cls + ' ' + s.sec + '</div></div>' +
                    statusBadge(s.status) +
                '</div>' +
                '<div class="sl-mob-grid">' +
                    '<div class="sl-mob-field"><label>Guardian</label><span>' + s.guardian + '</span></div>' +
                    '<div class="sl-mob-field"><label>Contact</label><span>' + s.phone + '</span></div>' +
                    '<div class="sl-mob-field"><label>Admitted</label><span>' + fmtDate(s.admDate) + '</span></div>' +
                    '<div class="sl-mob-field"><label>Gender</label><span>' + (s.gender || '—') + '</span></div>' +
                    '<div class="sl-mob-field"><label>Fee Status</label>' + feeBadge(s.feeSt) + '</div>' +
                    '<div class="sl-mob-field"><label>Attendance</label>' + attendHtml(s.attend) + '</div>' +
                '</div>' +
                '<a href="' + dashUrl(s.id) + '" class="btn btn-sm btn-primary w-100"><i class="bx bx-layout me-1"></i>View Dashboard</a>' +
            '</div>';
        }).join('');
        $('#mobList').html(html);
    }

    function renderPagination(pages, total, start, end) {
        $('#pgInfo').text(total ? 'Showing ' + (start + 1) + '–' + end + ' of ' + total : '0 results');

        if (pages <= 1) { $('#pgBtns').empty(); return; }

        var html = pageItem(page - 1, '<i class="bx bx-chevron-left"></i>', page <= 1, false);
        $.each(pageRange(page, pages), function (_, p) {
            html += (p === '...') ? pageItem(0, '…', true, false) : pageItem(p, p, false, p === page);
        });
        html += pageItem(page + 1, '<i class="bx bx-chevron-right"></i>', page >= pages, false);
        $('#pgBtns').html(html);
    }
    function pageItem(p, label, disabled, active) {
        return '<li class="page-item' + (disabled ? ' disabled' : '') + (active ? ' active' : '') + '">' +
               '<a class="page-link" href="#" data-p="' + p + '">' + label + '</a></li>';
    }
    function pageRange(cur, total) {
        if (total <= 7) {
            var all = [];
            for (var i = 1; i <= total; i++) all.push(i);
            return all;
        }
        var r = [1];
        if (cur > 3) r.push('...');
        for (var j = Math.max(2, cur - 1); j <= Math.min(total - 1, cur + 1); j++) r.push(j);
        if (cur < total - 2) r.push('...');
        r.push(total);
        return r;
    }

    /* ── export to CSV ───────────────────────────────── */
    function exportCsv() {
        var headers = ['Roll', 'Name', 'Class', 'Sec', 'Gender', 'Adm Date', 'Guardian', 'Phone', 'Fee', 'Status'];
        var rows = $.map(filtered, function (s) {
            return [[s.roll, s.name, s.cls, s.sec, s.gender, fmtDate(s.admDate), s.guardian, s.phone, s.feeSt, s.status]];
        });
        var csv = '﻿' + [headers].concat(rows).map(function (r) {
            return r.map(function (c) { return '"' + String(c).replace(/"/g, '""') + '"'; }).join(',');
        }).join('\r\n');

        var $a = $('<a>').attr({
            href: 'data:text/csv;charset=utf-8,' + encodeURIComponent(csv),
            download: 'students_' + new Date().toISOString().slice(0, 10) + '.csv'
        }).appendTo('body');
        $a[0].click();
        $a.remove();
        toast('success', filtered.length + ' students exported.');
    }

    /* ── events ──────────────────────────────────────── */
    $('#slSearch').on('input', applyFilters);
    $('#fClass, #fGender, #fFee, #fYear, #perPage').on('change', applyFilters);

    $('#clearBtn').on('click', function () {
        $('#slSearch').val('');
        $('#fClass, #fGender, #fFee, #fYear').val('').removeClass('active-filter');
        applyFilters();
    });

    $('.sl-sortable').on('click', function () {
        var col = $(this).data('col');
        if (sortCol === col) sortDir = (sortDir === 'asc' ? 'desc' : 'asc');
        else { sortCol = col; sortDir = 'asc'; }
        updateSortIcons();
        render();
    });

    $('#pgBtns').on('click', '.page-link', function (e) {
        e.preventDefault();
        var p = parseInt($(this).data('p'));
        var pages = Math.ceil(filtered.length / perPage) || 1;
        if (!isNaN(p) && p >= 1 && p <= pages && p !== page) { page = p; render(); }
    });

    $('#btnExcel').on('click', exportCsv);
    $('#btnPdf').on('click', function () { window.print(); });

    if (typeof toastr !== 'undefined') {
        toastr.options = { closeButton: true, progressBar: true, positionClass: 'toast-top-right', timeOut: 3000 };
    }

    window._sl = { refresh: loadStudents };   // refresh hook for the modal
    loadStudents();
});


/* =========================================================
   NEW ADMISSION MODAL
   - loads fee structure + sections from master (AJAX)
   - posts the form via AJAX
========================================================= */
$(function () {
    'use strict';

    var $year       = $('#academicYearSelect');
    var $class      = $('#classSelect');
    var $section    = $('#adm_Section');
    var $admDate    = $('#admissionDate');
    var $feeBox     = $('#feeContent');
    var $annual     = $('#annualTotalText');
    var $concession = $('#concessionPanel');
    var $discType   = $('#discountType');
    var $discValue  = $('#discountValue');
    var $discApply  = $('#discountApplyTo');
    var $discReason = $('#discountReason');
    var $ledger     = $('#ledgerJson');
    var $form       = $('#admissionForm');
    var modalEl     = document.getElementById('studentAdmissionModal');

    var URL_FEES     = '@Url.Action("GetFeeStructure", "Admission", new { area = "ERP" })';
    var URL_SECTIONS = '@Url.Action("GetSections", "Admission", new { area = "ERP" })';
    var URL_SAVE     = '@Url.Action("SaveAdmission", "Admission", new { area = "ERP" })';

    var fees = [];   // fee rows for the selected class + year

    function money(n) { return '₹' + Math.round(Number(n || 0)).toLocaleString('en-IN'); }
    function notify(type, msg) { if (typeof toastr !== 'undefined') toastr[type](msg); }
    function hideModal() { bootstrap.Modal.getOrCreateInstance(modalEl).hide(); }

    /* ── sections: configured per class + year in Academic Setup ── */
    function loadSections() {
        var ayid = $year.find('option:selected').data('ayid');
        var cls = $class.val();

        if (!ayid || !cls) {
            $section.html('<option value="">Select year &amp; class first</option>');
            return;
        }
        $section.html('<option value="">Loading…</option>');
        $.getJSON(URL_SECTIONS, { academicYearId: ayid, className: cls })
            .done(function (res) {
                var secs = (res && res.sections) || [];
                if (!secs.length) {
                    $section.html('<option value="">No sections configured</option>');
                    return;
                }
                var html = '<option value="">Select Section</option>';
                $.each(secs, function (_, s) { html += '<option value="' + s + '">' + s + '</option>'; });
                $section.html(html);
            })
            .fail(function () { $section.html('<option value="">Select Section</option>'); });
    }

    /* ── fee preview ─────────────────────────────────── */
    function showEmptyFees() {
        fees = [];
        $annual.text('₹0');
        $concession.addClass('d-none');
        $ledger.val('');
        $feeBox.html('<div class="fee-empty"><i class="bx bx-wallet"></i><h6>Select Year &amp; Class</h6><p class="mb-0">Fee structure will appear here.</p></div>');
    }

    function loadFees() {
        var yr = $year.val(), cls = $class.val();
        if (!yr || !cls) { showEmptyFees(); return; }

        $feeBox.html('<div class="fee-empty"><i class="bx bx-loader-circle bx-spin"></i><h6>Loading fee structure…</h6></div>');
        $.getJSON(URL_FEES, { className: cls, academicYear: yr })
            .done(function (res) {
                if (!res || !res.success || !res.fees || !res.fees.length) {
                    fees = [];
                    $annual.text('₹0');
                    $concession.addClass('d-none');
                    $ledger.val('');
                    $feeBox.html('<div class="fee-empty"><i class="bx bx-error-circle"></i><h6>No Fee Structure</h6><p class="mb-0">' + ((res && res.message) || 'Configure fee structure for this class first.') + '</p></div>');
                    return;
                }
                fees = $.map(res.fees, function (f) {
                    return {
                        id: f.feeHeadId, name: f.feeHeadName, group: f.group,
                        cycle: f.frequency, stage: f.stage,
                        amount: Number(f.amount || 0),
                        mandatory: f.mandatory !== false, selected: true
                    };
                });
                $concession.removeClass('d-none');
                renderFees();
            })
            .fail(function () {
                fees = [];
                $ledger.val('');
                $feeBox.html('<div class="fee-empty"><i class="bx bx-error-circle"></i><h6>Error</h6><p class="mb-0">Could not load fee structure. Please try again.</p></div>');
            });
    }

    /* ── discount + summary ──────────────────────────── */
    function discountOn(base) {
        var v = Number($discValue.val() || 0);
        if (v <= 0) return 0;
        if ($discType.val() === 'percentage') return Math.round((base * Math.min(v, 100)) / 100);
        return Math.min(v, base);
    }
    function kitTotal() {
        var t = 0;
        $('.kit-checkbox:checked').each(function () { t += Number($(this).data('amount') || 0); });
        return t;
    }

    function renderFees() {
        if (!fees.length) { showEmptyFees(); return; }

        var groups = ['One Time Payable Now', 'Monthly Recurring', 'Yearly Charges', 'Optional Charges'];
        var html = '';
        $.each(groups, function (_, grp) {
            var groupRows = '';
            $.each(fees, function (idx, fee) {
                if (fee.group !== grp) return;
                var amt = '<strong>' + money(fee.amount) + (fee.cycle === 'Monthly' ? '/mo' : '') + '</strong>';
                if (!fee.mandatory) {
                    groupRows += '<div class="fee-check-row"><div class="d-flex gap-2">' +
                        '<input class="form-check-input optional-fee-checkbox" type="checkbox" data-index="' + idx + '" ' + (fee.selected ? 'checked' : '') + '>' +
                        '<div><div class="fw-bold" style="color:var(--ec-heading)">' + fee.name + '</div><small>' + fee.cycle + ' · ' + fee.stage + '</small></div>' +
                        '</div>' + amt + '</div>';
                } else if (fee.selected) {
                    groupRows += '<div class="fee-row"><div><div class="fw-bold" style="color:var(--ec-heading)">' + fee.name + '</div><small>' + fee.cycle + ' · ' + fee.stage + '</small></div>' + amt + '</div>';
                }
            });
            if (groupRows) html += '<div><div class="fee-group-title">' + grp + '</div>' + groupRows + '</div>';
        });

        var payNow = 0, monthly = 0, yearly = 0, annual = 0;
        $.each(fees, function (_, f) {
            if (!f.selected) return;
            annual += (f.cycle === 'Monthly' ? f.amount * 12 : f.amount);
            if (f.stage === 'Admission') payNow += f.amount;
            if (f.stage === 'Monthly') monthly += f.amount;
            if (f.stage === 'Yearly') yearly += f.amount;
        });

        var kit = kitTotal();
        var applyTo = $discApply.val();
        var disc = discountOn(applyTo === 'annual' ? annual : payNow);
        var payToday = payNow + kit - (applyTo === 'payToday' ? disc : 0);
        var estAnnual = annual + kit - (applyTo === 'annual' ? disc : 0);

        html += '<div class="fee-summary">' +
            '<div class="summary-line"><span>Pay Today</span><strong>' + money(payToday) + '</strong></div>' +
            '<div class="summary-line"><span>Monthly</span><strong>' + money(monthly) + '/mo</strong></div>' +
            '<div class="summary-line"><span>Yearly</span><strong>' + money(yearly) + '/yr</strong></div>' +
            '<div class="summary-line"><span>Kit</span><strong>' + money(kit) + '</strong></div>' +
            '<div class="summary-line"><span>Concession</span><strong>- ' + money(disc) + '</strong></div>' +
            '<hr class="opacity-25"><div class="summary-line"><span>Estimated Annual</span><strong>' + money(estAnnual) + '</strong></div>' +
            '</div>';

        $annual.text(money(estAnnual));
        $feeBox.html(html);

        $ledger.val(JSON.stringify({
            academicYear: $year.val(),
            className: $class.val(),
            admissionDate: $admDate.val(),
            selectedFees: $.map(fees, function (f) {
                return f.selected
                    ? { feeHeadId: f.id, feeHeadName: f.name, frequency: f.cycle, amount: f.amount, mandatory: f.mandatory }
                    : null;
            }),
            selectedKitItems: $('.kit-checkbox:checked').map(function () {
                return { name: $(this).val(), amount: Number($(this).data('amount') || 0) };
            }).get(),
            concession: {
                type: $discType.val(), value: Number($discValue.val() || 0),
                applyTo: applyTo, calculatedAmount: disc, reason: $discReason.val() || ''
            },
            summary: { payToday: payToday, monthlyRecurring: monthly, yearlyScheduled: yearly, estimatedAnnual: estAnnual }
        }));
    }

    /* ── events ──────────────────────────────────────── */
    $year.add($class).on('change', function () { loadFees(); loadSections(); });
    $admDate.add($discType).add($discApply).on('change', renderFees);
    $discValue.add($discReason).on('input', renderFees);
    $(document).on('change', '.kit-checkbox', renderFees);
    $feeBox.on('change', '.optional-fee-checkbox', function () {
        fees[Number($(this).data('index'))].selected = this.checked;
        renderFees();
    });

    $(modalEl).on('hidden.bs.modal', function () {
        $form[0].reset();
        $form.removeClass('was-validated');
        showEmptyFees();
    });

    /* ── submit (AJAX) ───────────────────────────────── */
    $form.on('submit', function (e) {
        e.preventDefault();

        if (!this.checkValidity()) { $form.addClass('was-validated'); return; }
        if (Number($discValue.val() || 0) > 0 && !$.trim($discReason.val())) {
            $discReason.focus();
            notify('error', 'Please enter a concession reason.');
            return;
        }
        if (!$ledger.val()) {
            notify('error', 'Please select Academic Year and Class.');
            return;
        }

        var $btn = $form.find('button[type="submit"]');
        var oldHtml = $btn.html();
        $btn.prop('disabled', true).html('<i class="bx bx-loader-circle bx-spin me-1"></i>Saving…');

        $.ajax({
            url: URL_SAVE,
            type: 'POST',
            data: new FormData(this),
            processData: false,
            contentType: false,
            headers: { 'RequestVerificationToken': $form.find('input[name="__RequestVerificationToken"]').val() }
        })
        .done(function (res) {
            if (res && res.success) {
                hideModal();
                notify('success', 'Admission ' + (res.admissionNo || '') + ' saved. Fee ledger created.');
                if (window._sl) window._sl.refresh();
            } else {
                notify('error', (res && res.message) || 'Unable to save admission.');
            }
        })
        .fail(function () { notify('error', 'Something went wrong while saving.'); })
        .always(function () { $btn.prop('disabled', false).html(oldHtml); });
    });

    /* ── prefill from a converted enquiry ────────────── */
@if (ViewBag.PrefillJson != null)
{
    <text>
    (function () {
        try {
            var p = @Html.Raw(ViewBag.PrefillJson);
            $('#adm_StudentName').val(p.studentName || '');
            $('#adm_GuardianName').val(p.guardianName || '');
            $('#adm_MobileNumber').val(p.mobile || '');
            if (p.gender) $('#adm_Gender').val(p.gender);
            if (p.className) $class.val(p.className);
            if (p.academicYear) $year.val(p.academicYear);
            if (p.enquiryId) $('#adm_EnquiryId').val(p.enquiryId);
            if ($class.val() && $year.val()) { loadFees(); loadSections(); }
            bootstrap.Modal.getOrCreateInstance(modalEl).show();
        } catch (e) { }
    })();
    </text>
}

    showEmptyFees();
});
</script>
}
