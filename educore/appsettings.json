{
  // SECURITY: no DB credentials live in this file (it is committed to git).
  //  - Local dev: set DefaultConnection in appsettings.Development.json (git-ignored).
  //  - Production: set the environment variable  ConnectionStrings__DefaultConnection
  //    (double underscore maps to ConnectionStrings:DefaultConnection).
  "Security": {
    // Flip to true ONLY when the site is served over HTTPS (valid TLS cert / reverse proxy).
    // When true: auth + session cookies become Secure-only, HTTPS redirection + HSTS turn on.
    // Leave false for plain-HTTP hosting, otherwise users cannot log in (Secure cookies are dropped over HTTP).
    "RequireHttps": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  // SMTP for transactional email (new-school-admin welcome credentials).
  // SECRET-FREE here. Set Username/Password (and override Host/From) in
  // appsettings.Development.json (git-ignored) or Email__* env vars in production.
  // Leave Enabled=false until SMTP creds are configured — sends are then logged and skipped.
  "Email": {
    "Enabled": true,
    "Host": "",
    "Port": 587,
    "UseSsl": true,
    "Username": "",
    "Password": "",
    "FromAddress": "",
    "FromName": "EduCore"
  },
  // Multi-channel notifications. Email is configured above. SMS/WhatsApp stay disabled
  // until a provider is wired — while disabled the message (e.g. an OTP) is written to the
  // app log so the flow is testable for free. Put provider ApiKey/SenderId in
  // appsettings.Development.json or Notifications__* env vars (never commit secrets here).
  "Notifications": {
    "Sms": {
      "Enabled": false,
      "Provider": "",
      "ApiKey": "",
      "SenderId": ""
    },
    "WhatsApp": {
      "Enabled": false,
      "Provider": "",
      "ApiKey": "",
      "FromNumber": ""
    }
  },
  "AllowedHosts": "*"
}